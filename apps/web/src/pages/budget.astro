---
import Layout from "@layouts/Layout.astro";
import { budgetItems } from "@lib/data";
import { formatMoneyBGN } from "@lib/format";

const years = Array.from(new Set(budgetItems.map((item) => item.year))).sort((a, b) => b - a);
const initialTotal = budgetItems.reduce((sum, item) => sum + item.amount_bgn, 0);
---

<Layout title="Бюджет · Отворен Пловдив">
  <section class="page-head">
    <div class="container">
      <p class="eyebrow">Къде отиват местните данъци?</p>
      <h1>Бюджетен преглед</h1>
      <p class="lead">
        Примерни бюджетни категории с ясно показани суми, източници и свързани проектни записи.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="filters">
        <div class="field">
          <label for="year-select">Година</label>
          <select id="year-select">
            {years.map((year) => <option value={year}>{year}</option>)}
          </select>
        </div>
        <div class="field">
          <label for="budget-total">Общо</label>
          <input id="budget-total" type="text" readonly value={formatMoneyBGN(initialTotal)} />
        </div>
      </div>

      <div class="notice">
        Това са примерни бюджетни редове за тестване на интерфейса. Реална версия трябва да сочи
        към конкретен бюджетен документ за всеки ред.
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid grid-2">
      <article>
        <h2>Категории</h2>
        <div id="category-cards" class="grid grid-2" aria-live="polite">
          <p class="loading">Зареждане</p>
        </div>
      </article>
      <article>
        <h2>Разпределение</h2>
        <div id="budget-chart" class="chart" aria-live="polite">
          <p class="loading">Зареждане</p>
        </div>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Източници и свързани проекти</h2>
      <div id="budget-sources" class="list" aria-live="polite">
        <p class="loading">Зареждане</p>
      </div>
    </div>
  </section>

  <script>
    const categoryLabels = {
      roads: "Улици",
      pavement: "Тротоари",
      street_lighting: "Осветление",
      parks: "Паркове",
      waste: "Чистота",
      public_transport: "Транспорт",
      accessibility: "Достъпност",
      drainage: "Отводняване",
      culture: "Култура",
      education: "Образование",
      other: "Друго"
    };

    const yearSelect = document.querySelector("#year-select");
    const totalField = document.querySelector("#budget-total");
    const categoryCards = document.querySelector("#category-cards");
    const budgetChart = document.querySelector("#budget-chart");
    const budgetSources = document.querySelector("#budget-sources");

    let budgetItems = [];
    let projects = [];

    function escapeHtml(value) {
      return String(value)
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
    }

    function formatMoney(amount) {
      return new Intl.NumberFormat("bg-BG", {
        style: "currency",
        currency: "BGN",
        maximumFractionDigits: 0
      }).format(amount);
    }

    function selectedItems() {
      return budgetItems.filter((item) => String(item.year) === yearSelect.value);
    }

    function relatedProjects(item) {
      return projects
        .filter((project) => project.related_budget_item_id === item.id)
        .slice(0, 4);
    }

    function renderBudget() {
      const items = selectedItems();
      const total = items.reduce((sum, item) => sum + item.amount_bgn, 0);
      totalField.value = formatMoney(total);

      categoryCards.innerHTML = items
        .map(
          (item) => `
            <article class="card">
              <p class="eyebrow">${escapeHtml(categoryLabels[item.category] ?? item.category)}</p>
              <h3>${escapeHtml(item.title_bg)}</h3>
              <p class="money">${formatMoney(item.amount_bgn)}</p>
              <p>${escapeHtml(item.plain_language_bg ?? "")}</p>
              <span class="badge sample">Примерни данни</span>
            </article>
          `
        )
        .join("");

      budgetChart.innerHTML = items
        .slice()
        .sort((a, b) => b.amount_bgn - a.amount_bgn)
        .map((item) => {
          const percent = total > 0 ? Math.max(2, (item.amount_bgn / total) * 100) : 0;
          return `
            <div class="bar-row">
              <strong>${escapeHtml(categoryLabels[item.category] ?? item.category)}</strong>
              <div class="bar-track" aria-hidden="true"><div class="bar-fill" style="width: ${percent}%"></div></div>
              <span class="money">${formatMoney(item.amount_bgn)}</span>
            </div>
          `;
        })
        .join("");

      budgetSources.innerHTML = items
        .map((item) => {
          const linked = relatedProjects(item);
          return `
            <article class="card">
              <header>
                <h3>${escapeHtml(item.title_bg)}</h3>
                <p class="money">${formatMoney(item.amount_bgn)}</p>
              </header>
              <p>
                <a href="${escapeHtml(item.source_document.url)}" target="_blank" rel="noreferrer">${escapeHtml(item.source_document.title)}</a>
                <span class="meta"> · достъп ${escapeHtml(item.source_document.accessed_at)}</span>
              </p>
              <h4>Свързани проекти</h4>
              ${
                linked.length
                  ? `<ul class="source-list">${linked
                      .map((project) => `<li><a href="/projects/${escapeHtml(project.id)}">${escapeHtml(project.title_bg)}</a></li>`)
                      .join("")}</ul>`
                  : `<p class="meta">Няма свързани проекти.</p>`
              }
            </article>
          `;
        })
        .join("");
    }

    yearSelect.addEventListener("change", renderBudget);

    try {
      [budgetItems, projects] = await Promise.all([
        fetch("/data/budget-items.json").then((response) => {
          if (!response.ok) throw new Error("budget failed");
          return response.json();
        }),
        fetch("/data/projects.json").then((response) => {
          if (!response.ok) throw new Error("projects failed");
          return response.json();
        })
      ]);
      renderBudget();
    } catch {
      totalField.value = "Грешка";
      categoryCards.innerHTML = '<p class="error">Бюджетните данни не се заредиха.</p>';
      budgetChart.innerHTML = '<p class="error">Графиката не може да бъде показана.</p>';
      budgetSources.innerHTML = '<p class="error">Източниците не могат да бъдат показани.</p>';
    }
  </script>
</Layout>
