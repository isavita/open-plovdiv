---
// Sticky in-page section navigation with scroll-spy (active-section highlight).
// Targets must carry the matching id AND `data-subnav-target` (for scroll offset).
type Item = { id: string; label: string };
interface Props {
  items: Item[];
  label?: string;
}
const { items, label } = Astro.props;
---

<nav class="page-subnav" aria-label={label ?? "Sections"} data-subnav-fade>
  <div class="container page-subnav-inner" data-subnav-scroller>
    {items.map((s) => (
      <a href={`#${s.id}`} data-subnav-link={s.id}>{s.label}</a>
    ))}
  </div>
</nav>

<script>
  (() => {
    const links = [...document.querySelectorAll<HTMLAnchorElement>("[data-subnav-link]")];
    const ids = links
      .map((a) => a.getAttribute("data-subnav-link"))
      .filter((id): id is string => Boolean(id));
    if (!ids.length) return;
    let activeId = "";
    const setActive = (id: string) => {
      if (id === activeId) return;
      activeId = id;
      for (const link of links) {
        link.setAttribute(
          "aria-current",
          link.getAttribute("data-subnav-link") === id ? "true" : "false"
        );
      }
    };
    // Active = the last target whose top has scrolled above the sticky-bar line.
    let ticking = false;
    const update = () => {
      ticking = false;
      const line = 140;
      let current = ids[0];
      for (const id of ids) {
        const el = document.getElementById(id);
        if (el && el.getBoundingClientRect().top <= line) current = id;
      }
      setActive(current);
    };
    window.addEventListener(
      "scroll",
      () => {
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(update);
        }
      },
      { passive: true }
    );
    update();

    // Edge fades on the tab row itself: only show "there's more" on whichever
    // side actually has hidden content, so the cue disappears once you've
    // scrolled a side fully into view instead of sitting there as noise.
    const fadeNav = document.querySelector<HTMLElement>("[data-subnav-fade]");
    const scroller = document.querySelector<HTMLElement>("[data-subnav-scroller]");
    if (fadeNav && scroller) {
      const updateFade = () => {
        const overflows = scroller.scrollWidth > scroller.clientWidth + 1;
        const atStart = scroller.scrollLeft <= 1;
        const atEnd = scroller.scrollLeft + scroller.clientWidth >= scroller.scrollWidth - 1;
        fadeNav.classList.toggle("has-start-fade", overflows && !atStart);
        fadeNav.classList.toggle("has-end-fade", overflows && !atEnd);
      };
      scroller.addEventListener("scroll", updateFade, { passive: true });
      window.addEventListener("resize", updateFade);
      updateFade();
    }
  })();
</script>
