---
type Source = {
  title: string;
  url: string;
  accessed_at: string;
};

type Props = {
  sources: Source[];
};

const { sources } = Astro.props;
---

{
  sources.length > 0 ? (
    <ul class="source-list">
      {sources.map((source) => (
        <li>
          <a href={source.url} target="_blank" rel="noreferrer">{source.title}</a>
          <span class="meta"> · достъп {source.accessed_at}</span>
        </li>
      ))}
    </ul>
  ) : (
    <p class="meta">Няма публичен източник за този примерен сигнал.</p>
  )
}
