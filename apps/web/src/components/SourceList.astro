---
import { ui, type Lang } from "@i18n/utils";
import { sourceTitle } from "@lib/format";

type Source = {
  title: string;
  url: string;
  accessed_at: string;
};

type Props = {
  sources: Source[];
  lang: Lang;
};

const { sources, lang } = Astro.props;
const t = ui[lang];
---

{
  sources.length > 0 ? (
    <ul class="source-list">
      {sources.map((source) => (
        <li>
          <a href={source.url} target="_blank" rel="noreferrer">{sourceTitle(source.title, lang)}</a>
          <span class="meta"> · {`${t.common.accessed} ${source.accessed_at}`}</span>
        </li>
      ))}
    </ul>
  ) : (
    <p class="meta">{t.common.noSource}</p>
  )
}
