---
// A symmetric heritage flourish used as a section divider — a central
// rosette flanked by curling scrolls, set between two gilded rules. Inspired
// by the carved wood sunburst panels on Plovdiv's National Revival houses.
// Purely decorative; `currentColor` (gold via .ornament) controls the tone.
type Props = { class?: string };
const { class: className = "" } = Astro.props;
---

<div class={`ornament ${className}`.trim()} aria-hidden="true">
  <span class="ornament-rule"></span>
  <svg
    class="ornament-mark"
    viewBox="0 0 120 40"
    xmlns="http://www.w3.org/2000/svg"
    fill="none"
    stroke="currentColor"
    stroke-width="1.6"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <!-- left scroll -->
    <path d="M6 20 C 18 20, 26 12, 34 20 C 30 24, 26 22, 28 18" />
    <path d="M14 20 C 20 20, 24 16, 30 20" opacity="0.7" />
    <!-- left leaf -->
    <path d="M34 20 C 38 14, 44 12, 48 16 C 46 20, 42 21, 40 20" />
    <!-- central rosette -->
    <path d="M60 8 L66 20 L60 32 L54 20 Z" />
    <circle cx="60" cy="20" r="3.2" fill="currentColor" stroke="none" />
    <path d="M52 20 L48 20 M68 20 L72 20" />
    <path d="M60 12 L60 9 M60 28 L60 31" opacity="0.7" />
    <!-- right leaf (mirrored) -->
    <path d="M86 20 C 82 14, 76 12, 72 16 C 74 20, 78 21, 80 20" />
    <!-- right scroll (mirrored) -->
    <path d="M114 20 C 102 20, 94 12, 86 20 C 90 24, 94 22, 92 18" />
    <path d="M106 20 C 100 20, 96 16, 90 20" opacity="0.7" />
  </svg>
  <span class="ornament-rule"></span>
</div>
