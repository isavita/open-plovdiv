<Layout lang={lang} path="/people" title={labels.title} description={labels.lead}>
  <section class="section hero hero-compact people-hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">{labels.eyebrow}</p>
        <h1>{labels.title}</h1>
        <p class="lead">{labels.lead}</p>
      </div>
      <dl class="stats-grid people-stats" aria-label={labels.title}>
        <div class="stat-card">
          <dt>{labels.people}</dt>
          <dd>{historyKnowledgeIndex.counts.people}</dd>
        </div>
        <div class="stat-card">
          <dt>{labels.roles}</dt>
          <dd>{uniqueRoles.size}</dd>
        </div>
        <div class="stat-card">
          <dt>{labels.links}</dt>
          <dd>{relationCount}</dd>
        </div>
        <div class="stat-card">
          <dt>{labels.events}</dt>
          <dd>{peopleEventCount}</dd>
        </div>
      </dl>
    </div>
  </section>

    <SectionNav
    items={lang === "bg"
      ? [{ id: "people-connections", label: "Връзки" }, { id: "people-catalog", label: "Каталог" }]
      : lang === "de"
        ? [{ id: "people-connections", label: "Verbindungen" }, { id: "people-catalog", label: "Katalog" }]
        : lang === "fr"
        ? [{ id: "people-connections", label: "Liens" }, { id: "people-catalog", label: "Catalogue" }]
        : lang === "it"
        ? [{ id: "people-connections", label: "Legami" }, { id: "people-catalog", label: "Catalogo" }]
        : [{ id: "people-connections", label: "Connections" }, { id: "people-catalog", label: "Catalog" }]}
    label={lang === "bg" ? "Раздели на страницата" : lang === "de" ? "Seitenabschnitte" : lang === "fr" ? "Sections de la page" : lang === "it" ? "Sezioni della pagina" : "Page sections"}
  />

  <section class="section people-connections" id="people-connections" data-subnav-target>
    <div class="container">
      <div class="section-head">
        <div>
          <h2>{labels.connectionsTitle}</h2>
          <p class="meta" style="margin-top:8px;max-width:78ch">{labels.connectionsLead}</p>
        </div>
      </div>

      <div class="toolbar people-toolbar">
        <div class="filters">
          <div class="field">
            <label for="people-search">{labels.search}</label>
            <input id="people-search" type="search" placeholder={labels.searchPlaceholder} />
          </div>
          <div class="field">
            <label for="people-group">{labels.group}</label>
            <select id="people-group">
              <option value="all">{labels.allGroups}</option>
              {groupOrder.map((group) => <option value={group}>{groupLabels[group]}</option>)}
            </select>
          </div>
          <div class="field">
            <label for="people-century">{labels.century}</label>
            <select id="people-century">
              <option value="all">{labels.allCenturies}</option>
              {centuries.map((century) => <option value={century}>{century}</option>)}
            </select>
          </div>
          <div class="field">
            <label for="people-relationship">{labels.relationship}</label>
            <select id="people-relationship">
              <option value="all">{labels.allRelationships}</option>
              <option value="with">{labels.withRelationships}</option>
              <option value="without">{labels.withoutRelationships}</option>
            </select>
          </div>
        </div>
      </div>

      <div class="results-bar">
        <p id="people-count" class="meta">{personIndex.length} {labels.people}</p>
        <button type="button" id="people-reset" class="link-button" hidden>{labels.reset}</button>
      </div>

      <section class="relationship-ledger" aria-labelledby="relationship-ledger-title">
        <div class="relationship-ledger-head">
          <div>
            <h3 id="relationship-ledger-title">{labels.ledgerTitle}</h3>
            <p class="meta">{labels.ledgerLead}</p>
          </div>
          <p id="people-relationship-count" class="meta">
            {relationshipRows.length} {labels.ledgerRows}
          </p>
        </div>
        <div class="relationship-list" id="people-relationship-list" aria-live="polite"></div>
      </section>
    </div>
  </section>

  <section class="section section-tint" id="people-catalog" data-subnav-target>
    <div class="container">
      <div class="section-head">
        <div>
          <h2>{labels.catalogTitle}</h2>
        </div>
      </div>

      <div class="person-grid" id="people-list" aria-live="polite"></div>
      <p id="people-empty" class="empty" hidden>{labels.noResults}</p>
    </div>
  </section>

  <script type="application/json" id="people-config" set:html={JSON.stringify(nodeConfig)}></script>
  <script>
    const config = JSON.parse(document.getElementById("people-config")?.textContent ?? "{}");
    const search = document.querySelector<HTMLInputElement>("#people-search")!;
    const group = document.querySelector<HTMLSelectElement>("#people-group")!;
    const century = document.querySelector<HTMLSelectElement>("#people-century")!;
    const relationship = document.querySelector<HTMLSelectElement>("#people-relationship")!;
    const count = document.querySelector<HTMLElement>("#people-count")!;
    const reset = document.querySelector<HTMLButtonElement>("#people-reset")!;
    const empty = document.querySelector<HTMLElement>("#people-empty")!;
    const list = document.querySelector<HTMLElement>("#people-list")!;
    const relationshipList = document.querySelector<HTMLElement>("#people-relationship-list")!;
    const relationshipCount = document.querySelector<HTMLElement>("#people-relationship-count");
    let cards: any[] = [];
    let relationshipRows = [...document.querySelectorAll<HTMLElement>("[data-relationship-row]")];

    function escapePeopleHtml(value: unknown): string {
      return String(value)
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
    }

    async function fetchPeopleJson(url: string) {
      const response = await fetch(url);
      if (!response.ok) throw new Error(`Unable to load ${url}`);
      return await response.json();
    }

    function collectionFromPayload(payload: any, preferredKey: string) {
      if (Array.isArray(payload)) return payload;
      if (payload && Array.isArray(payload[preferredKey])) return payload[preferredKey];
      return [];
    }

    function localizedPerson(record: Record<string, any> | undefined, base: string) {
      if (!record) return "";
      return String(
        record[`${base}_${config.lang}`] ?? record[`${base}_en`] ?? record[`${base}_bg`] ?? ""
      );
    }

    function roleLabel(role: string) {
      return config.roleLabels?.[role] ?? role.replaceAll("_", " ");
    }

    function relationshipLabel(type: string) {
      return config.relationshipLabels?.[type] ?? type.replaceAll("_", " ");
    }

    function primaryGroup(person: any) {
      return config.roleGroups?.[person.roles?.[0]] ?? "civic";
    }

    function personReferenceYear(person: any) {
      if (person.birth_year) return person.birth_year;
      return 1900;
    }

    function centuryFor(year: number) {
      return Math.floor((year - 1) / 100) + 1;
    }

    function lifeLabel(person: any) {
      if (person.birth_year && person.death_year) return `${person.birth_year}-${person.death_year}`;
      if (person.birth_year) return `${config.labels.born ?? ""} ${person.birth_year}`.trim();
      return "n/a";
    }

    function eventDateLabel(event: any) {
      return localizedPerson(event?.date, "display");
    }

    async function loadPeopleCards() {
      if (cards.length > 0) return cards;
      const api = config.api ?? {};
      const [peoplePayload, sourcePayload, eventPayload] = await Promise.all([
        fetchPeopleJson(api.people),
        fetchPeopleJson(api.sources),
        fetchPeopleJson(api.events)
      ]);
      const people = collectionFromPayload(peoplePayload, "people");
      const personById = new Map(people.map((person: any) => [person.id, person]));
      const sourceById = new Map(collectionFromPayload(sourcePayload, "sources").map((source: any) => [source.id, source]));
      const eventCountByPerson = new Map<string, number>();
      for (const event of collectionFromPayload(eventPayload, "events")) {
        for (const personId of event.person_ids ?? []) {
          eventCountByPerson.set(personId, (eventCountByPerson.get(personId) ?? 0) + 1);
        }
      }
      cards = people
        .sort((a: any, b: any) =>
          localizedPerson(a, "name").localeCompare(localizedPerson(b, "name"), config.locale)
        )
        .map((person: any) => {
          const group = primaryGroup(person);
          const primarySource = sourceById.get(person.source_ids?.[0]) as any;
          const relationshipPreview = (person.relationships ?? [])
            .map((relationship: any) => ({
              relationship,
              target: personById.get(relationship.person_id) as any,
              source: sourceById.get(relationship.source_id) as any
            }))
            .filter((item: any) => item.target && item.source)
            .slice(0, 4)
            .map(({ relationship, target, source }: any) => ({
              label: relationshipLabel(relationship.type),
              targetName: localizedPerson(target, "name"),
              sourceUrl: source.url
            }));
          return {
            id: person.id,
            search: [
              localizedPerson(person, "name"),
              localizedPerson(person, "summary"),
              lifeLabel(person),
              ...(person.roles ?? []).map(roleLabel),
              config.groupLabels?.[group] ?? group
            ].join(" ").toLocaleLowerCase(config.locale),
            group,
            groupLabel: config.groupLabels?.[group] ?? group,
            century: centuryFor(personReferenceYear(person)),
            relationshipsMode: (person.relationships ?? []).length > 0 ? "with" : "without",
            name: localizedPerson(person, "name"),
            life: lifeLabel(person),
            summary: localizedPerson(person, "summary"),
            avatar: person.image,
            initials: localizedPerson(person, "name").slice(0, 2),
            roles: (person.roles ?? []).slice(0, 4).map(roleLabel),
            eventCount: eventCountByPerson.get(person.id) ?? 0,
            relationshipCount: (person.relationships ?? []).length,
            relationshipPreview,
            primarySource: primarySource
              ? {
                  url: primarySource.url,
                  title: localizedPerson(primarySource, "title")
                }
              : null
          };
        });
      return cards;
    }

    function renderRelationshipRow(row: any) {
      const linkedEvent = row.event
        ? `<p>${escapePeopleHtml(config.labels.linkedEvent)}: ${escapePeopleHtml(row.event.title)} (${escapePeopleHtml(row.event.date)})</p>`
        : "";
      const evidence = row.evidenceProperty ? `<p>${escapePeopleHtml(row.evidenceProperty)}</p>` : "";
      const sources = row.sources.length
        ? `<p>${escapePeopleHtml(config.labels.sources)}: ${row.sources
            .map(
              (source: any, index: number) =>
                `${index > 0 ? ", " : ""}<a href="${escapePeopleHtml(source.url)}" target="_blank" rel="noreferrer">${escapePeopleHtml(source.title)} ↗</a>`
            )
            .join("")}</p>`
        : "";
      return `
        <article
          class="relationship-row relationship-row-${escapePeopleHtml(row.category)}"
          data-relationship-row="${escapePeopleHtml(row.id)}"
          data-edge-from="${escapePeopleHtml(row.fromId)}"
          data-edge-to="${escapePeopleHtml(row.toId)}"
          data-search="${escapePeopleHtml(row.search)}"
        >
          <div>
            <span class="relationship-label">${escapePeopleHtml(config.labels.from)}</span>
            <strong>${escapePeopleHtml(row.fromName)}</strong>
          </div>
          <div>
            <span class="relationship-label">${escapePeopleHtml(config.labels.type)}</span>
            <span>${escapePeopleHtml(row.typeLabel)}</span>
          </div>
          <div>
            <span class="relationship-label">${escapePeopleHtml(config.labels.to)}</span>
            <strong>${escapePeopleHtml(row.toName)}</strong>
          </div>
          <div class="relationship-evidence">
            <span class="relationship-label">${escapePeopleHtml(config.labels.evidence)}</span>
            ${linkedEvent}
            ${evidence}
            ${sources}
          </div>
        </article>`;
    }

    async function loadRelationshipRows() {
      if (relationshipRows.length > 0) return relationshipRows;
      const api = config.api ?? {};
      const [relationshipPayload, peoplePayload, sourcePayload, eventPayload] = await Promise.all([
        fetchPeopleJson(api.personRelationships),
        fetchPeopleJson(api.people),
        fetchPeopleJson(api.sources),
        fetchPeopleJson(api.events)
      ]);
      const peopleById = new Map(collectionFromPayload(peoplePayload, "people").map((person: any) => [person.id, person]));
      const sourcesById = new Map(collectionFromPayload(sourcePayload, "sources").map((source: any) => [source.id, source]));
      const eventsById = new Map(collectionFromPayload(eventPayload, "events").map((event: any) => [event.id, event]));
      const rows = collectionFromPayload(relationshipPayload, "person_relationships").map((relationship: any) => {
        const from = peopleById.get(relationship.from_person_id) as any;
        const to = peopleById.get(relationship.to_person_id) as any;
        const event = relationship.event_id ? (eventsById.get(relationship.event_id) as any) : null;
        const sources = (relationship.source_ids ?? [])
          .map((id: string) => sourcesById.get(id) as any)
          .filter(Boolean)
          .map((source: any) => ({
            title: localizedPerson(source, "title"),
            url: source.url
          }));
        const typeLabel = relationshipLabel(relationship.relationship_type);
        const eventView = event
          ? {
              title: localizedPerson(event, "title"),
              date: eventDateLabel(event)
            }
          : null;
        return {
          id: relationship.id,
          fromId: relationship.from_person_id,
          toId: relationship.to_person_id,
          fromName: localizedPerson(from, "name"),
          toName: localizedPerson(to, "name"),
          typeLabel,
          category: relationship.relationship_type === "succeeded_by" ? "succession" : "family",
          evidenceProperty: relationship.evidence_property,
          event: eventView,
          sources,
          search: [
            localizedPerson(from, "name"),
            localizedPerson(to, "name"),
            typeLabel,
            localizedPerson(event, "title"),
            ...sources.map((source: any) => source.title),
            relationship.evidence_property
          ].join(" ").toLocaleLowerCase(config.locale)
        };
      });
      relationshipList.innerHTML = rows.map(renderRelationshipRow).join("");
      relationshipRows = [...document.querySelectorAll<HTMLElement>("[data-relationship-row]")];
      if (relationshipCount) {
        relationshipCount.textContent = `${relationshipRows.length} ${config.labels.ledgerRows}`;
      }
      return relationshipRows;
    }

    function renderPersonCard(card: any) {
      const prefix = config.lang === "bg" ? "" : `/${config.lang}`;
      const profileHref = `${prefix}/people/${encodeURIComponent(card.id)}/`;
      const avatar = card.avatar
        ? `<img class="person-avatar" src="${escapePeopleHtml(card.avatar)}" alt="${escapePeopleHtml(card.name)}" loading="lazy" decoding="async" />`
        : `<span class="person-avatar person-avatar-fallback" aria-hidden="true">${escapePeopleHtml(card.initials)}</span>`;
      const roles = Array.isArray(card.roles)
        ? `<div class="tag-row">${card.roles.map((role: string) => `<span>${escapePeopleHtml(role)}</span>`).join("")}</div>`
        : "";
      const relationshipPreview = Array.isArray(card.relationshipPreview) && card.relationshipPreview.length
        ? `<div class="person-relations"><p>${escapePeopleHtml(config.labels.relationshipSources)}</p><ul>${card.relationshipPreview
            .map(
              (item: any) =>
                `<li><a href="${escapePeopleHtml(item.sourceUrl)}" target="_blank" rel="noreferrer">${escapePeopleHtml(item.label)}: ${escapePeopleHtml(item.targetName)} ↗</a></li>`
            )
            .join("")}</ul></div>`
        : "";
      const source = card.primarySource
        ? `<a class="src-link" href="${escapePeopleHtml(card.primarySource.url)}" target="_blank" rel="noreferrer">${escapePeopleHtml(config.labels.source)}: ${escapePeopleHtml(card.primarySource.title)} ↗</a>`
        : "";

      return `
        <article
          class="person-card people-group-${escapePeopleHtml(card.group)}"
          data-person-card="${escapePeopleHtml(card.id)}"
          data-group="${escapePeopleHtml(card.group)}"
          data-century="${escapePeopleHtml(card.century)}"
          data-relationships="${escapePeopleHtml(card.relationshipsMode)}"
        >
          <header>
            ${avatar}
            <div>
              <p class="eyebrow">${escapePeopleHtml(card.groupLabel)}</p>
              <h3><a href="${escapePeopleHtml(profileHref)}">${escapePeopleHtml(card.name)}</a></h3>
              <p class="meta">${escapePeopleHtml(card.life)}</p>
            </div>
          </header>
          <p>${escapePeopleHtml(card.summary)}</p>
          ${roles}
          ${relationshipPreview}
          <dl class="person-metrics">
            <div>
              <dt>${escapePeopleHtml(config.labels.linkedEvents)}</dt>
              <dd>${escapePeopleHtml(card.eventCount)}</dd>
            </div>
            <div>
              <dt>${escapePeopleHtml(config.labels.relationshipCount)}</dt>
              <dd>${escapePeopleHtml(card.relationshipCount)}</dd>
            </div>
          </dl>
          <a class="text-link" href="${escapePeopleHtml(profileHref)}">${escapePeopleHtml(config.labels.profile)}</a>
          ${source}
        </article>`;
    }

    function matches(card: any) {
      const q = search.value.trim().toLocaleLowerCase();
      return (
        (!q || (card.search ?? "").includes(q)) &&
        (group.value === "all" || card.group === group.value) &&
        (century.value === "all" || String(card.century) === century.value) &&
        (relationship.value === "all" || card.relationshipsMode === relationship.value)
      );
    }

    function applyPeopleFilters() {
      const visibleCards = cards.filter(matches);
      const visibleIds = new Set<string>(visibleCards.map((card: any) => card.id));
      list.innerHTML = visibleCards.map(renderPersonCard).join("");

      let visibleRelationshipRows = 0;
      for (const row of relationshipRows) {
        const show =
          visibleIds.has(row.dataset.edgeFrom ?? "") ||
          visibleIds.has(row.dataset.edgeTo ?? "");
        row.hidden = !show;
        if (show) visibleRelationshipRows += 1;
      }

      count.textContent =
        visibleCards.length === cards.length
          ? `${cards.length} ${config.labels.people}`
          : `${config.labels.visible}: ${visibleCards.length} ${config.labels.of} ${cards.length}`;
      if (relationshipCount) {
        relationshipCount.textContent =
          visibleRelationshipRows === relationshipRows.length
            ? `${relationshipRows.length} ${config.labels.ledgerRows}`
            : `${config.labels.visible}: ${visibleRelationshipRows} ${config.labels.of} ${relationshipRows.length} ${config.labels.ledgerRows}`;
      }
      empty.hidden = visibleCards.length !== 0;
      reset.hidden = !(
        search.value ||
        group.value !== "all" ||
        century.value !== "all" ||
        relationship.value !== "all"
      );
    }

    function refreshPeopleCatalogue() {
      loadPeopleCards()
        .then(() => applyPeopleFilters())
        .catch(() => {
          empty.hidden = false;
          empty.textContent = config.labels.noResults;
        });
    }

    search.addEventListener("input", refreshPeopleCatalogue);
    group.addEventListener("change", refreshPeopleCatalogue);
    century.addEventListener("change", refreshPeopleCatalogue);
    relationship.addEventListener("change", refreshPeopleCatalogue);
    reset.addEventListener("click", () => {
      search.value = "";
      group.value = "all";
      century.value = "all";
      relationship.value = "all";
      refreshPeopleCatalogue();
      search.focus();
    });
    const catalogSection = document.getElementById("people-catalog");
    if (catalogSection && "IntersectionObserver" in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          if (entries.some((entry) => entry.isIntersecting)) {
            observer.disconnect();
            refreshPeopleCatalogue();
          }
        },
        { rootMargin: "220px 0px" }
      );
      observer.observe(catalogSection);
    } else {
      window.setTimeout(refreshPeopleCatalogue, 900);
    }

    const ledgerSection = document.querySelector<HTMLElement>(".relationship-ledger");
    if (ledgerSection && "IntersectionObserver" in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          if (entries.some((entry) => entry.isIntersecting)) {
            observer.disconnect();
            loadRelationshipRows()
              .then(() => {
                if (cards.length > 0) applyPeopleFilters();
              })
              .catch(() => {});
          }
        },
        { rootMargin: "220px 0px" }
      );
      observer.observe(ledgerSection);
    } else {
      window.setTimeout(() => {
        loadRelationshipRows().catch(() => {});
      }, 900);
    }
  </script>
</Layout>
