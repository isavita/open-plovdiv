const groupOrder = ["governance", "culture", "science", "faith", "sport", "civic"] as const;
const sourceById = new Map(historyKnowledgeSources.map((source) => [source.id, source]));

function localized(record: Record<string, any>, base: string): string {
  return String(
    record[`${base}_${lang}`] ?? record[`${base}_en`] ?? record[`${base}_bg`] ?? ""
  );
}

function roleLabel(role: string): string {
  return roleLabels[role]?.[lang] ?? roleLabels[role]?.en ?? role.replaceAll("_", " ");
}

function relationshipLabel(type: string): string {
  return relationshipTypeLabels[type]?.[lang] ?? relationshipTypeLabels[type]?.en ?? type.replaceAll("_", " ");
}

function relationshipCategory(type: string): "succession" | "family" {
  return type === "succeeds" || type === "succeeded_by" ? "succession" : "family";
}

function personReferenceYear(person: KnowledgePerson): number {
  if (person.birth_year) return person.birth_year;
  const termYears = person.term_events
    .map((id) => historyKnowledgeEvents.find((event) => event.id === id)?.date.year)
    .filter((year): year is number => typeof year === "number");
  return termYears[0] ?? 1900;
}

function centuryFor(year: number): number {
  return Math.floor((year - 1) / 100) + 1;
}

function lifeLabel(person: KnowledgePerson): string {
  if (person.birth_year && person.death_year) return `${person.birth_year}-${person.death_year}`;
  if (person.birth_year) return `${labels.born} ${person.birth_year}`;
  return "n/a";
}

const people = [...historyKnowledgePeople].sort((a, b) =>
  localized(a, "name").localeCompare(localized(b, "name"), locale)
);
const personById = new Map(people.map((person) => [person.id, person]));
const uniqueRoles = new Set(people.flatMap((person) => person.roles));
const relationCount = people.reduce((sum, person) => sum + person.relationships.length, 0);
const peopleEventCount = historyKnowledgeEvents.filter((event) => event.person_ids.length > 0).length;

const personIndex = people.map((person) => ({
  id: person.id,
  year: personReferenceYear(person),
  century: centuryFor(personReferenceYear(person))
}));
const edgeByKey = new Map<
  string,
  {
    from: string;
    to: string;
    category: "succession" | "family";
    labels: string[];
    entries: Array<{
      from: string;
      to: string;
      type: string;
      eventId: string | null;
      sourceId: string;
      evidenceProperty?: string;
      label: string;
    }>;
  }
>();
for (const person of people) {
  for (const relationship of person.relationships) {
    if (!personById.has(relationship.person_id)) continue;
    if (relationship.type === "succeeds") continue;

    const category = relationshipCategory(relationship.type);
    const key =
      category === "succession"
        ? `${person.id}|${relationship.person_id}|${relationship.event_id ?? relationship.type}`
        : `${[person.id, relationship.person_id].sort().join("|")}|family`;
    const target = personById.get(relationship.person_id);
    const label = `${localized(person, "name")} — ${relationshipLabel(relationship.type)} — ${
      target ? localized(target, "name") : relationship.person_id
    }`;
    const entry = {
      from: person.id,
      to: relationship.person_id,
      type: relationship.type,
      eventId: relationship.event_id,
      sourceId: relationship.source_id,
      evidenceProperty: relationship.evidence_property,
      label
    };
    const existing = edgeByKey.get(key);
    if (existing) {
      if (!existing.labels.includes(label)) existing.labels.push(label);
      existing.entries.push(entry);
    } else {
      edgeByKey.set(key, {
        from: person.id,
        to: relationship.person_id,
        category,
        labels: [label],
        entries: [entry]
      });
    }
  }
}
const relationEdges = [...edgeByKey.values()];
const relationshipRows = relationEdges
  .map((edge, index) => {
    const from = personById.get(edge.from);
    const to = personById.get(edge.to);
    const sourceIds = [...new Set(edge.entries.map((entry) => entry.sourceId))];
    const eventIds = [...new Set(edge.entries.map((entry) => entry.eventId).filter(Boolean))] as string[];
    const typeLabels = [...new Set(edge.entries.map((entry) => relationshipLabel(entry.type)))];
    const evidenceProperties = [...new Set(edge.entries.map((entry) => entry.evidenceProperty).filter(Boolean))] as string[];
    const eventYears = eventIds
      .map((id) => historyKnowledgeEvents.find((event) => event.id === id)?.date.year)
      .filter((year): year is number => typeof year === "number");

    return {
      id: `relationship-${index}`,
      edge,
      from,
      to,
      typeLabels,
      sourceIds,
      eventIds,
      evidenceProperties,
      year: eventYears[0] ?? Math.min(personReferenceYear(from!), personReferenceYear(to!)),
      search: [
        from ? localized(from, "name") : edge.from,
        to ? localized(to, "name") : edge.to,
        ...typeLabels,
        ...sourceIds.map((id) => localized(sourceById.get(id) ?? {}, "title")),
        ...eventIds.map((id) => localized(historyKnowledgeEvents.find((event) => event.id === id) ?? {}, "title")),
        ...evidenceProperties
      ].join(" ").toLocaleLowerCase(locale)
    };
  })
  .filter((row) => row.from && row.to)
  .sort((a, b) => a.year - b.year || localized(a.from!, "name").localeCompare(localized(b.from!, "name"), locale));

const centuries = [...new Set(personIndex.map((person) => person.century))].sort((a, b) => a - b);
const clientRoleLabels = Object.fromEntries([...uniqueRoles].map((role) => [role, roleLabel(role)]));
const clientRelationshipLabels = Object.fromEntries(
  Object.keys(relationshipTypeLabels).map((type) => [type, relationshipLabel(type)])
);
const nodeConfig = {
  lang,
  locale,
  api: {
    events: historyKnowledgeIndex.endpoints.events,
    people: historyKnowledgeIndex.endpoints.people,
    personRelationships: historyKnowledgeIndex.endpoints.person_relationships,
    sources: historyKnowledgeIndex.endpoints.sources
  },
  groupLabels,
  relationshipLabels: clientRelationshipLabels,
  roleGroups,
  roleLabels: clientRoleLabels,
  labels: {
    visible: labels.visible,
    of: labels.of,
    people: labels.people,
    noResults: labels.noResults,
    born: labels.born,
    ledgerRows: labels.ledgerRows,
    source: labels.source,
    profile: labels.profile,
    relationshipSources: labels.relationshipSources,
    linkedEvents: labels.linkedEvents,
    relationshipCount: labels.relationshipCount,
    from: labels.from,
    to: labels.to,
    type: labels.type,
    evidence: labels.evidence,
    linkedEvent: labels.linkedEvent,
    sources: labels.sources
  },
  total: personIndex.length
};
