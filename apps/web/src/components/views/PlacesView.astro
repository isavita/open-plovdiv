const categoryLabels: Record<string, Record<Lang, string>> = {
  civic: { bg: "Градска среда", en: "Civic", de: "Stadtraum", fr: "Espace urbain", it: "Spazio urbano", tr: "Kentsel alan", es: "Espacio urbano", el: "Αστικός χώρος", ja: "都市空間" },
  hill: { bg: "Хълм", en: "Hill", de: "Hügel", fr: "Colline", it: "Colle", tr: "Tepe", es: "Colina", el: "Λόφος", ja: "丘" },
  medieval: { bg: "Средновековие", en: "Medieval", de: "Mittelalterlich", fr: "Médiéval", it: "Medievale", tr: "Orta Çağ", es: "Medieval", el: "Μεσαιωνικό", ja: "中世" },
  monument: { bg: "Паметник", en: "Monument", de: "Denkmal", fr: "Monument", it: "Monumento", tr: "Anıt", es: "Monumento", el: "Μνημείο", ja: "記念碑" },
  ottoman: { bg: "Османски пласт", en: "Ottoman", de: "Osmanisch", fr: "Ottoman", it: "Ottomano", tr: "Osmanlı", es: "Otomano", el: "Οθωμανικό", ja: "オスマン層" },
  religious: { bg: "Религиозен обект", en: "Religious", de: "Religiöser Ort", fr: "Site religieux", it: "Sito religioso", tr: "Dinî yapı", es: "Sitio religioso", el: "Θρησκευτικός χώρος", ja: "宗教施設" },
  revival: { bg: "Възраждане", en: "Revival", de: "Wiedergeburtszeit", fr: "Renaissance nationale", it: "Rinascita nazionale", tr: "Ulusal Uyanış", es: "Renacimiento Nacional", el: "Εθνική Αναγέννηση", ja: "民族復興期" },
  roman: { bg: "Римски пласт", en: "Roman", de: "Römisch", fr: "Romain", it: "Romano", tr: "Roma", es: "Romano", el: "Ρωμαϊκό", ja: "ローマ層" },
  thracian: { bg: "Тракийски пласт", en: "Thracian", de: "Thrakisch", fr: "Thrace", it: "Tracio", tr: "Trak", es: "Tracio", el: "Θρακικό", ja: "トラキア層" }
};

function localized(record: Record<string, any>, base: string): string {
  return String(record[`${base}_${lang}`] ?? record[`${base}_en`] ?? record[`${base}_bg`] ?? "");
}

function categoryLabel(category: string): string {
  return categoryLabels[category]?.[lang] ?? category.replaceAll("_", " ");
}

function placeFacts(place: KnowledgePlace, options: { includeCreatorFallback?: boolean } = {}) {
  const includeCreatorFallback = options.includeCreatorFallback ?? true;
  const hasNamedCreator = Boolean(localized(place, "architect") || localized(place, "builder"));
  return [
    localized(place.date_context, "display") ? { label: labels.built, value: localized(place.date_context, "display") } : null,
    localized(place, "architect") ? { label: labels.architect, value: localized(place, "architect") } : null,
    localized(place, "builder") ? { label: labels.builder, value: localized(place, "builder") } : null,
    includeCreatorFallback && !hasNamedCreator && localized(place.creator_context, "display")
      ? { label: labels.creator, value: localized(place.creator_context, "display") }
      : null
  ].filter(Boolean) as Array<{ label: string; value: string }>;
}

const places = [...historyKnowledgePlaces].sort((a, b) =>
  localized(a, "name").localeCompare(localized(b, "name"), locale)
);
const sourceById = new Map(historyKnowledgeSources.map((source) => [source.id, source]));
const archiveCountByPlace = new Map<string, number>();
const pairCountByPlace = new Map<string, number>();
const eventCountByPlace = new Map<string, number>();
for (const item of historicalArchiveItems) archiveCountByPlace.set(item.place_id, (archiveCountByPlace.get(item.place_id) ?? 0) + 1);
for (const pair of thenNowPairs) pairCountByPlace.set(pair.place_id, (pairCountByPlace.get(pair.place_id) ?? 0) + 1);
for (const event of historyKnowledgeEvents) {
  for (const placeId of event.place_ids) eventCountByPlace.set(placeId, (eventCountByPlace.get(placeId) ?? 0) + 1);
}

const eras = [...new Set(places.map((place) => place.era))].sort();
const categories = [...new Set(places.map((place) => place.category))].sort((a, b) =>
  categoryLabel(a).localeCompare(categoryLabel(b), locale)
);
const placeholderImage = "data:image/gif;base64,R0lGODlhAQABAAAAACw=";
const initialPlaceCount = 24;
const placeCards = places.map((place) => {
  const source = sourceById.get(place.source_ids[0]);
  const facts = placeFacts(place, { includeCreatorFallback: false });
  const archiveCount = archiveCountByPlace.get(place.id) ?? 0;
  const pairCount = pairCountByPlace.get(place.id) ?? 0;
  const eventCount = eventCountByPlace.get(place.id) ?? 0;
  const search = [
    localized(place, "name"),
    localized(place, "summary"),
    localized(place, "current_status"),
    localized(place, "era"),
    categoryLabel(place.category),
    ...facts.map((fact) => fact.value)
  ].join(" ").toLocaleLowerCase(locale);

  return {
    id: place.id,
    href: localizePath(`/places/${place.id}`, lang),
    className: `place-card landmark-${place.category}`,
    category: place.category,
    era: place.era,
    eraLabel: localized(place, "era"),
    categoryLabel: categoryLabel(place.category),
    name: localized(place, "name"),
    summary: localized(place, "summary"),
    search,
    facts,
    eventCount,
    archiveCount,
    pairCount,
    media: place.media?.[0]
      ? {
          src: commonsImageUrl(place.media[0].url, 500),
          credit: `${place.media[0].credit} · ${place.media[0].license}`,
          licenseUrl: place.media[0].license_url
        }
      : null,
    source: source
      ? {
          url: source.url,
          title: sourceTitle(localized(source, "title"), lang)
        }
      : null
  };
});
const initialPlaceCards = placeCards.slice(0, initialPlaceCount);
const config = {
  labels: {
    visible: labels.visible,
    of: labels.of,
    noResults: labels.noResults,
    places: labels.places,
    events: labels.events,
    archive: labels.archive,
    thenNow: labels.thenNow,
    source: labels.source,
    open: labels.open
  },
  total: placeCards.length,
  batchSize: initialPlaceCount,
  placeholderImage,
  lang,
  cardsEndpoint: "/api/history/place-cards.json"
};

// --- all-places map (pins every place with coordinates, synced to filters) ---
const mapL =
  lang === "bg"
    ? {
        title: "Карта на местата",
        lead: "Всички документирани места с координати, оцветени по категория. Филтрите по-долу важат и за картата."
      }
    : lang === "de"
      ? {
        title: "Karte der Orte",
        lead: "Alle dokumentierten Orte mit Koordinaten, nach Kategorie eingefärbt. Die Filter unten steuern auch die Karte."
      }
      : lang === "fr"
      ? {
        title: "Carte des lieux",
        lead: "Tous les lieux documentés avec coordonnées, colorés par catégorie. Les filtres ci-dessous s'appliquent aussi à la carte."
      }
      : lang === "it"
      ? {
        title: "Mappa dei luoghi",
        lead: "Tutti i luoghi documentati con coordinate, colorati per categoria. Anche i filtri qui sotto si applicano alla mappa."
      }
      : lang === "tr"
      ? {
        title: "Yerlerin haritası",
        lead: "Koordinatlarıyla belgelenmiş tüm yerler, kategoriye göre renklendirilmiştir. Aşağıdaki filtreler haritaya da uygulanır."
      }
      : lang === "es"
      ? {
        title: "Mapa de los lugares",
        lead: "Todos los lugares documentados con coordenadas, coloreados por categoría. Los filtros de abajo también afectan al mapa."
      }
      : lang === "el"
      ? {
        title: "Χάρτης των τοποθεσιών",
        lead: "Όλες οι τεκμηριωμένες τοποθεσίες με συντεταγμένες, χρωματισμένες ανά κατηγορία. Τα φίλτρα παρακάτω ισχύουν και για τον χάρτη."
      }
      : lang === "ja"
      ? {
        title: "場所の地図",
        lead: "座標付きで記録されたすべての場所をカテゴリ別に色分けしています。下のフィルターは地図にも反映されます。"
      }
      : {
        title: "Map of the places",
        lead: "All documented places with coordinates, coloured by category. The filters below also drive the map."
      };
const placesMapConfig = {
  openLabel: labels.open,
  lang,
  mapEndpoint: "/api/history/place-map.json"
};
---

<Layout lang={lang} path="/places" title={labels.title} description={labels.lead}>
  <section class="section hero hero-compact places-hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">{labels.eyebrow}</p>
        <h1>{labels.title}</h1>
        <p class="lead">{labels.lead}</p>
      </div>
      <dl class="stats-grid places-stats" data-cat="places" aria-label={labels.title}>
        <div class="stat-card">
          <dt>{labels.places}</dt>
          <dd>{historyKnowledgeIndex.counts.places}</dd>
        </div>
        <div class="stat-card">
          <dt>{labels.coordinates}</dt>
          <dd>{places.filter((place) => place.coordinates).length}</dd>
        </div>
        <div class="stat-card">
          <dt>{labels.images}</dt>
          <dd>{places.filter((place) => place.media.length).length}</dd>
        </div>
        <div class="stat-card">
          <dt>{labels.thenNow}</dt>
          <dd>{thenNowPairs.length}</dd>
        </div>
      </dl>
    </div>
  </section>

  <section class="section" id="places-catalog">
    <div class="container">
      <div class="places-map-head">
        <h2>{mapL.title}</h2>
        <p class="meta" style="max-width:74ch;margin-top:6px">{mapL.lead}</p>
      </div>
      <div class="card map-card" style="padding:0;overflow:hidden;margin-bottom:24px">
        <div id="places-map" class="places-map"></div>
      </div>

      <div class="toolbar places-toolbar">
        <div class="filters">
          <div class="field">
            <label for="places-search">{labels.search}</label>
            <input id="places-search" type="search" placeholder={labels.searchPlaceholder} />
          </div>
          <div class="field">
            <label for="places-era">{labels.era}</label>
            <select id="places-era">
              <option value="all">{labels.allEras}</option>
              {eras.map((era) => <option value={era}>{t.history.eraLabels[era]}</option>)}
            </select>
          </div>
          <div class="field">
            <label for="places-category">{labels.category}</label>
            <select id="places-category">
              <option value="all">{labels.allCategories}</option>
              {categories.map((category) => <option value={category}>{categoryLabel(category)}</option>)}
            </select>
          </div>
          <div class="field">
            <label for="places-evidence">{labels.evidence}</label>
            <select id="places-evidence">
              <option value="all">{labels.allEvidence}</option>
              <option value="then-now">{labels.withThenNow}</option>
              <option value="archive">{labels.withArchive}</option>
            </select>
          </div>
        </div>
      </div>

      <div class="results-bar">
        <p id="places-count" class="meta">{labels.visible}: {initialPlaceCards.length} {labels.of} {placeCards.length} {labels.places}</p>
        <button type="button" id="places-reset" class="link-button" hidden>{labels.reset}</button>
      </div>

      <div class="place-grid" id="places-list">
        {initialPlaceCards.map((card) => {
          return (
            <article
              class={card.className}
              data-place-card
              data-search={card.search}
              data-era={card.era}
              data-category={card.category}
              data-archive={card.archiveCount}
              data-then-now={card.pairCount}
            >
              {card.media && (
                <figure class="place-card-media">
                  <img
                    src={placeholderImage}
                    data-src={card.media.src}
                    data-place-image
                    alt={card.name}
                    width="500"
                    height="313"
                    loading="lazy"
                    decoding="async"
                    crossorigin="anonymous"
                    referrerpolicy="no-referrer"
                  />
                  <figcaption class="place-card-credit">
                    <a href={card.media.licenseUrl} target="_blank" rel="noreferrer">
                      {card.media.credit}
                    </a>
                  </figcaption>
                </figure>
              )}
              <div class="place-card-body">
                <p class="eyebrow">{card.eraLabel} · {card.categoryLabel}</p>
                <h2><a href={card.href}>{card.name}</a></h2>
                <p>{card.summary}</p>
                {card.facts.length > 0 && (
                  <dl class="place-facts">
                    {card.facts.map((fact) => (
                      <>
                        <dt>{fact.label}</dt>
                        <dd>{fact.value}</dd>
                      </>
                    ))}
                  </dl>
                )}
                {card.eventCount + card.archiveCount + card.pairCount > 0 && (
                  <dl class="place-evidence-counts">
                    <div><dt>{labels.events}</dt><dd>{card.eventCount}</dd></div>
                    <div><dt>{labels.archive}</dt><dd>{card.archiveCount}</dd></div>
                    <div><dt>{labels.thenNow}</dt><dd>{card.pairCount}</dd></div>
                  </dl>
                )}
                {card.source && (
                  <a class="src-link" href={card.source.url} target="_blank" rel="noreferrer">
                    {labels.source}: {card.source.title} ↗
                  </a>
                )}
                <a class="text-link" href={card.href}>{labels.open}</a>
              </div>
            </article>
          );
        })}
      </div>
      <p id="places-empty" class="empty" hidden>{labels.noResults}</p>
      <button type="button" id="places-load-more" class="button secondary places-load-more">
        {labels.loadMore}
      </button>
    </div>
  </section>

  <script type="application/json" id="places-config" set:html={JSON.stringify(config)}></script>
  <script>
    const config = JSON.parse(document.getElementById("places-config")?.textContent ?? "{}");
    const placeholderImage = config.placeholderImage ?? "data:image/gif;base64,R0lGODlhAQABAAAAACw=";
    const totalCards = Number(config.total) || 0;
    const search = document.querySelector<HTMLInputElement>("#places-search")!;
    const era = document.querySelector<HTMLSelectElement>("#places-era")!;
    const category = document.querySelector<HTMLSelectElement>("#places-category")!;
    const evidence = document.querySelector<HTMLSelectElement>("#places-evidence")!;
    const count = document.querySelector<HTMLElement>("#places-count")!;
    const reset = document.querySelector<HTMLButtonElement>("#places-reset")!;
    const empty = document.querySelector<HTMLElement>("#places-empty")!;
    const list = document.querySelector<HTMLElement>("#places-list")!;
    const loadMore = document.querySelector<HTMLButtonElement>("#places-load-more")!;
    let renderedCount = document.querySelectorAll<HTMLElement>("[data-place-card]").length;
    let cards = [...document.querySelectorAll<HTMLElement>("[data-place-card]")];
    let allPlaceCards: any[] | null = null;
    let placeCardsPromise: Promise<any[]> | null = null;
    let imageObserver: IntersectionObserver | null = null;

    function escapePlacesHtml(value: unknown): string {
      return String(value)
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
    }

    function renderPlaceCard(card: any): string {
      const media = card.media
        ? `<figure class="place-card-media">
            <img
              src="${placeholderImage}"
              data-src="${escapePlacesHtml(card.media.src)}"
              data-place-image
              alt="${escapePlacesHtml(card.name)}"
              width="500"
              height="313"
              loading="lazy"
              decoding="async"
              crossorigin="anonymous"
              referrerpolicy="no-referrer"
            />
            <figcaption class="place-card-credit">
              <a href="${escapePlacesHtml(card.media.licenseUrl)}" target="_blank" rel="noreferrer">${escapePlacesHtml(card.media.credit)}</a>
            </figcaption>
          </figure>`
        : "";
      const facts = Array.isArray(card.facts) && card.facts.length
        ? `<dl class="place-facts">${card.facts
            .map(
              (fact: any) =>
                `<dt>${escapePlacesHtml(fact.label)}</dt><dd>${escapePlacesHtml(fact.value)}</dd>`
            )
            .join("")}</dl>`
        : "";
      const hasEvidence = Number(card.eventCount) + Number(card.archiveCount) + Number(card.pairCount) > 0;
      const evidenceCounts = hasEvidence
        ? `<dl class="place-evidence-counts">
            <div><dt>${escapePlacesHtml(config.labels.events)}</dt><dd>${escapePlacesHtml(card.eventCount)}</dd></div>
            <div><dt>${escapePlacesHtml(config.labels.archive)}</dt><dd>${escapePlacesHtml(card.archiveCount)}</dd></div>
            <div><dt>${escapePlacesHtml(config.labels.thenNow)}</dt><dd>${escapePlacesHtml(card.pairCount)}</dd></div>
          </dl>`
        : "";
      const source = card.source
        ? `<a class="src-link" href="${escapePlacesHtml(card.source.url)}" target="_blank" rel="noreferrer">${escapePlacesHtml(config.labels.source)}: ${escapePlacesHtml(card.source.title)} ↗</a>`
        : "";

      return `<article
          class="${escapePlacesHtml(card.className)}"
          data-place-card
          data-search="${escapePlacesHtml(card.search)}"
          data-era="${escapePlacesHtml(card.era)}"
          data-category="${escapePlacesHtml(card.category)}"
          data-archive="${escapePlacesHtml(card.archiveCount)}"
          data-then-now="${escapePlacesHtml(card.pairCount)}"
        >
          ${media}
          <div class="place-card-body">
            <p class="eyebrow">${escapePlacesHtml(card.eraLabel)} · ${escapePlacesHtml(card.categoryLabel)}</p>
            <h2><a href="${escapePlacesHtml(card.href)}">${escapePlacesHtml(card.name)}</a></h2>
            <p>${escapePlacesHtml(card.summary)}</p>
            ${facts}
            ${evidenceCounts}
            ${source}
            <a class="text-link" href="${escapePlacesHtml(card.href)}">${escapePlacesHtml(config.labels.open)}</a>
          </div>
        </article>`;
    }

    function refreshPlaceCards() {
      cards = [...document.querySelectorAll<HTMLElement>("[data-place-card]")];
      loadMore.hidden = renderedCount >= totalCards || hasActiveFilters();
    }

    function applyPlacesFilters() {
      const q = search.value.trim().toLocaleLowerCase();
      let visible = 0;
      for (const card of cards) {
        const evidenceMode = evidence.value;
        const show =
          (!q || (card.dataset.search ?? "").includes(q)) &&
          (era.value === "all" || card.dataset.era === era.value) &&
          (category.value === "all" || card.dataset.category === category.value) &&
          (evidenceMode === "all" ||
            (evidenceMode === "archive" && Number(card.dataset.archive) > 0) ||
            (evidenceMode === "then-now" && Number(card.dataset.thenNow) > 0));
        card.hidden = !show;
        if (show) visible += 1;
      }
      const total = hasActiveFilters() ? cards.length : totalCards;
      count.textContent = `${config.labels.visible}: ${visible} ${config.labels.of} ${total} ${config.labels.places}`;
      empty.hidden = visible !== 0;
      reset.hidden = !(
        search.value ||
        era.value !== "all" ||
        category.value !== "all" ||
        evidence.value !== "all"
      );
      loadMore.hidden = renderedCount >= totalCards || hasActiveFilters();
    }

    function hasActiveFilters() {
      return Boolean(
        search.value.trim() ||
        era.value !== "all" ||
        category.value !== "all" ||
        evidence.value !== "all"
      );
    }

    function loadPlaceImage(image: HTMLImageElement) {
      const source = image.dataset.src;
      if (!source) return;
      image.addEventListener("load", () => image.removeAttribute("data-src"), { once: true });
      image.src = source;
    }

    function observePlaceImages(scope: ParentNode = document) {
      const images = [...scope.querySelectorAll<HTMLImageElement>("[data-place-image][data-src]")];
      if (!imageObserver) {
        images.forEach(loadPlaceImage);
        return;
      }
      images.forEach((image) => imageObserver?.observe(image));
    }

    async function loadAllPlaceCards() {
      if (allPlaceCards) return allPlaceCards;
      if (!placeCardsPromise) {
        placeCardsPromise = fetch(config.cardsEndpoint)
          .then((response) => {
            if (!response.ok) throw new Error("Unable to load places");
            return response.json();
          })
          .then((payload) => {
            const localizedCards = payload?.cards?.[config.lang];
            return Array.isArray(localizedCards) ? localizedCards : [];
          });
      }
      allPlaceCards = await placeCardsPromise;
      return allPlaceCards;
    }

    async function renderNextPlaces(batchSize = Number(config.batchSize) || 36) {
      if (renderedCount >= totalCards) return;
      const allCards = await loadAllPlaceCards();
      const nextCards = allCards.slice(renderedCount, renderedCount + batchSize);
      list.insertAdjacentHTML("beforeend", nextCards.map(renderPlaceCard).join(""));
      renderedCount += nextCards.length;
      refreshPlaceCards();
      observePlaceImages(list);
      applyPlacesFilters();
    }

    async function renderAllPlaces() {
      if (renderedCount >= totalCards) return;
      const allCards = await loadAllPlaceCards();
      const nextCards = allCards.slice(renderedCount);
      list.insertAdjacentHTML("beforeend", nextCards.map(renderPlaceCard).join(""));
      renderedCount = allCards.length;
      refreshPlaceCards();
      observePlaceImages(list);
    }

    async function applyFiltersFromControls() {
      if (hasActiveFilters()) await renderAllPlaces();
      applyPlacesFilters();
    }

    search.addEventListener("input", () => void applyFiltersFromControls());
    era.addEventListener("change", () => void applyFiltersFromControls());
    category.addEventListener("change", () => void applyFiltersFromControls());
    evidence.addEventListener("change", () => void applyFiltersFromControls());
    loadMore.addEventListener("click", () => void renderNextPlaces());
    reset.addEventListener("click", () => {
      search.value = "";
      era.value = "all";
      category.value = "all";
      evidence.value = "all";
      applyPlacesFilters();
      search.focus();
    });

    function hydratePlaceImages() {
      if (!("IntersectionObserver" in window)) {
        observePlaceImages();
        return;
      }
      imageObserver = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (!entry.isIntersecting) continue;
            const image = entry.target as HTMLImageElement;
            imageObserver?.unobserve(image);
            loadPlaceImage(image);
          }
        },
        { rootMargin: "120px 0px" }
      );
      observePlaceImages();
    }

    refreshPlaceCards();
    applyPlacesFilters();
    window.setTimeout(hydratePlaceImages, 1200);
  </script>

  <script type="application/json" id="places-map-config" set:html={JSON.stringify(placesMapConfig)}></script>
  <script>
    const mapCfg = JSON.parse(document.getElementById("places-map-config")?.textContent ?? "{}");
    const mapEl = document.getElementById("places-map");
    type PlaceMapItem = {
      lat: number;
      lng: number;
      name: string;
      category: string;
      era: string;
      catLabel: string;
      href: string;
      color: string;
      archive: boolean;
      thenNow: boolean;
      search: string;
    };
    const mEsc = (v: unknown) =>
      String(v).replaceAll("&", "&amp;").replaceAll("<", "&lt;").replaceAll(">", "&gt;").replaceAll('"', "&quot;");

    async function loadPlaceMapItems(): Promise<PlaceMapItem[]> {
      const response = await fetch(mapCfg.mapEndpoint);
      if (!response.ok) throw new Error("Unable to load place map data");
      const payload = await response.json();
      const localizedPlaces = payload?.places?.[mapCfg.lang];
      return Array.isArray(localizedPlaces) ? localizedPlaces : [];
    }

    async function initPlacesMap() {
      if (!mapEl) return;
      const placeItems = await loadPlaceMapItems();
      if (!placeItems.length) return;
      const leaflet = await import("leaflet");
      const L = leaflet.default;
      const map = L.map(mapEl, { scrollWheelZoom: false }).setView([42.145, 24.75], 13);
      L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
        maxZoom: 19,
        attribution: "&copy; OpenStreetMap contributors"
      }).addTo(map);
      const layer = L.layerGroup().addTo(map);
      const markers = placeItems.map((it) => {
        const marker = L.circleMarker([it.lat, it.lng], {
          radius: 6,
          color: it.color,
          weight: 1.5,
          fillColor: it.color,
          fillOpacity: 0.62
        });
        marker.bindPopup(
          `<strong>${mEsc(it.name)}</strong><br><span class="meta">${mEsc(it.catLabel)}</span><br><a href="${mEsc(it.href)}">${mEsc(mapCfg.openLabel)} →</a>`
        );
        return { marker, it };
      });

      const fSearch = document.querySelector<HTMLInputElement>("#places-search");
      const fEra = document.querySelector<HTMLSelectElement>("#places-era");
      const fCat = document.querySelector<HTMLSelectElement>("#places-category");
      const fEvi = document.querySelector<HTMLSelectElement>("#places-evidence");

      function applyMap(refit: boolean) {
        const q = (fSearch?.value ?? "").trim().toLowerCase();
        const era = fEra?.value ?? "all";
        const cat = fCat?.value ?? "all";
        const evi = fEvi?.value ?? "all";
        layer.clearLayers();
        const visible: [number, number][] = [];
        for (const { marker, it } of markers) {
          const ok =
            (!q || it.search.includes(q)) &&
            (era === "all" || it.era === era) &&
            (cat === "all" || it.category === cat) &&
            (evi === "all" || (evi === "archive" ? it.archive : evi === "then-now" ? it.thenNow : true));
          if (ok) {
            marker.addTo(layer);
            visible.push([it.lat, it.lng]);
          }
        }
        if (refit && visible.length) map.fitBounds(visible, { padding: [30, 30], maxZoom: 15 });
      }

      applyMap(true);
      fSearch?.addEventListener("input", () => applyMap(false));
      [fEra, fCat, fEvi].forEach((el) => el?.addEventListener("change", () => applyMap(true)));
      document.querySelector("#places-reset")?.addEventListener("click", () => window.setTimeout(() => applyMap(true), 0));
    }

    function schedulePlacesMap() {
      if (!mapEl) return;
      let started = false;
      const start = () => {
        if (started) return;
        started = true;
        void initPlacesMap();
      };
      if ("IntersectionObserver" in window) {
        const observer = new IntersectionObserver(
          (entries) => {
            if (entries.some((entry) => entry.isIntersecting)) {
              observer.disconnect();
              start();
            }
          },
          { rootMargin: "60px 0px" }
        );
        observer.observe(mapEl);
        return;
      }
      window.setTimeout(start, 1600);
    }

    schedulePlacesMap();
  </script>
</Layout>
