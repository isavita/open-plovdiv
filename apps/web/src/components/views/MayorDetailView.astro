---
import Layout from "@layouts/Layout.astro";
import { ui, type Lang } from "@i18n/ui";
import { field, localeForLang, localizePath } from "@i18n/utils";
import { cityArchive, mayorWikidataEnrichment, type CityArchiveRecord } from "@lib/data";
import { sourceTitle } from "@lib/format";

type Props = { lang: Lang; mayor: CityArchiveRecord };
const { lang, mayor } = Astro.props;
const t = ui[lang];
const locale = localeForLang(lang);
const currentYear = new Date().getFullYear();

const terms = cityArchive
  .filter((r) => r.kind === "mayor_term")
  .sort(
    (a, b) => a.year_start - b.year_start || (a.year_end ?? currentYear) - (b.year_end ?? currentYear)
  );
const index = terms.findIndex((r) => r.id === mayor.id);
const prev = index > 0 ? terms[index - 1] : null;
const next = index < terms.length - 1 ? terms[index + 1] : null;

const name = field(mayor, "actor", lang);
const period = field(mayor, "period", lang);
const isCurrent = mayor.year_end == null;
const isActing =
  field(mayor, "period", "bg").toLocaleLowerCase("bg-BG").includes("и.д.") ||
  field(mayor, "period", "en").toLocaleLowerCase("en-GB").includes("acting") ||
  period.toLocaleLowerCase(locale).includes("amtierend");
const yearLabel = `${mayor.year_start}${mayor.year_end ? `-${mayor.year_end}` : `-${currentYear}`}`;
const century = Math.floor((mayor.year_start - 1) / 100) + 1;
const duration = Math.max(1, (mayor.year_end ?? currentYear) - mayor.year_start + 1);

const otherTerms = terms.filter((r) => r.id !== mayor.id && field(r, "actor", lang) === name);
const wikiSearch = `https://${lang}.wikipedia.org/w/index.php?search=${encodeURIComponent(name)}`;
const bio = mayor.bio_bg ? field(mayor, "bio", lang) : null;
const isWikipediaMoreUrl = mayor.more_url
  ? (() => {
      try {
        return new URL(mayor.more_url).hostname.endsWith("wikipedia.org");
      } catch {
        return false;
      }
    })()
  : false;
const officialProfile = mayor.official_profile;
const officialProfileUrl = officialProfile
  ? lang !== "bg" && officialProfile.url_en
    ? officialProfile.url_en
    : officialProfile.url
  : null;
const officialProfileTitle = officialProfile
  ? lang !== "bg" && officialProfile.title_en
    ? officialProfile.title_en
    : officialProfile.title
  : null;
const referenceLinks =
  mayor.reference_links?.map((link) => ({
    title: lang !== "bg" && link.title_en ? link.title_en : link.title,
    url: lang !== "bg" && link.url_en ? link.url_en : link.url,
    accessed_at: link.accessed_at
  })) ?? [];
const mono = name
  .replace(/^(д-р|Д-р|инж\.|Mayor:)\s*/u, "")
  .trim()
  .split(/\s+/)
  .slice(0, 2)
  .map((w) => w[0] ?? "")
  .join("")
  .toLocaleUpperCase(locale);

// Sourced Wikidata enrichment (education, birthplace links, other roles, the
// person's own Wikipedia article). Keyed by the Bulgarian name.
const enrich = mayorWikidataEnrichment[field(mayor, "actor", "bg")] ?? null;
const pick = (bg: string | null, en: string | null) => (lang === "bg" ? bg || en : en || bg) ?? null;
const enrichLink = (item: { name_bg: string | null; name_en: string | null; wikipedia_bg: string | null; wikipedia_en: string | null }) => ({
  name: pick(item.name_bg, item.name_en),
  url: pick(item.wikipedia_bg, item.wikipedia_en)
});
const education = (enrich?.education ?? []).map(enrichLink).filter((x) => x.name);
const roles = (enrich?.positions ?? []).map(enrichLink).filter((x) => x.name);
const birthplaceName = enrich ? pick(enrich.birthplace_name_bg, enrich.birthplace_name_en) : field(mayor, "birthplace", lang) || null;
const birthplaceUrl = enrich ? pick(enrich.birthplace_wikipedia_bg, enrich.birthplace_wikipedia_en) : null;
const personWiki = enrich ? pick(enrich.person_wikipedia_bg, enrich.person_wikipedia_en) : null;
// Avoid showing the same Wikipedia article twice (it may already be a reference link).
const existingUrls = new Set(
  [mayor.source_document?.url, officialProfileUrl, mayor.more_url, ...referenceLinks.map((l) => l.url)].filter(
    Boolean
  )
);
const showPersonWiki = Boolean(personWiki && !existingUrls.has(personWiki));

const mayorStoryLabels =
  lang === "bg"
    ? {
        eyebrow: "Разказ за кмета",
        title: "Къде стои този мандат в историята на Пловдив",
        sourceTrail: "Източникова следа",
        termSentence: (person: string, term: string, years: string, yearsCount: string) =>
          `${person} управлява Пловдив през ${years}. Мандатът е описан като ${term}, с приблизителна продължителност ${yearsCount}.`,
        birthplaceSentence: (placeName: string) => `Биографичният профил свързва кмета с родно място: ${placeName}.`,
        educationSentence: (items: string) => `Проследените образователни връзки включват ${items}.`,
        rolesSentence: (items: string) => `Другите публични длъжности и роли, намерени в източниците, включват ${items}.`,
        repeatSentence: (count: number) => `Тази личност има още ${count} отделни кметски мандата в хронологията.`
      }
    : lang === "de"
      ? {
          eyebrow: "Geschichte des Bürgermeisters",
          title: "Wo diese Amtszeit in der Geschichte Plovdivs steht",
          sourceTrail: "Quellenspur",
          termSentence: (person: string, term: string, years: string, yearsCount: string) =>
            `${person} leitete Plovdiv in den Jahren ${years}. Die Amtszeit ist als ${term} beschrieben und dauerte ungefähr ${yearsCount}.`,
          birthplaceSentence: (placeName: string) => `Das biografische Profil verbindet den Bürgermeister mit dem Geburtsort ${placeName}.`,
          educationSentence: (items: string) => `Die nachgewiesenen Bildungsbezüge umfassen ${items}.`,
          rolesSentence: (items: string) => `Weitere in den Quellen gefundene öffentliche Ämter und Rollen umfassen ${items}.`,
          repeatSentence: (count: number) => `Diese Person hat ${count} weitere eigene Bürgermeistermandate in der Chronologie.`
        }
      : lang === "fr"
        ? {
            eyebrow: "Récit du maire",
            title: "Où ce mandat se situe dans l'histoire de Plovdiv",
            sourceTrail: "Trace documentaire",
            termSentence: (person: string, term: string, years: string, yearsCount: string) =>
              `${person} dirige Plovdiv pendant ${years}. Le mandat est décrit comme ${term}, avec une durée approximative de ${yearsCount}.`,
            birthplaceSentence: (placeName: string) => `Le profil biographique relie le maire à son lieu de naissance : ${placeName}.`,
            educationSentence: (items: string) => `Les liens de formation relevés comprennent ${items}.`,
            rolesSentence: (items: string) => `Les autres fonctions et rôles publics trouvés dans les sources comprennent ${items}.`,
            repeatSentence: (count: number) => `Cette personne possède ${count} autres mandats distincts dans la chronologie.`
          }
        : lang === "it"
          ? {
              eyebrow: "Storia del sindaco",
              title: "Dove si colloca questo mandato nella storia di Plovdiv",
              sourceTrail: "Traccia delle fonti",
              termSentence: (person: string, term: string, years: string, yearsCount: string) =>
                `${person} guidò Plovdiv nel periodo ${years}. Il mandato è descritto come ${term}, con una durata approssimativa di ${yearsCount}.`,
              birthplaceSentence: (placeName: string) => `Il profilo biografico collega il sindaco al luogo di nascita: ${placeName}.`,
              educationSentence: (items: string) => `I collegamenti formativi tracciati includono ${items}.`,
              rolesSentence: (items: string) => `Gli altri incarichi e ruoli pubblici trovati nelle fonti includono ${items}.`,
              repeatSentence: (count: number) => `Questa persona ha altri ${count} mandati distinti nella cronologia.`
            }
          : lang === "tr"
            ? {
                eyebrow: "Belediye başkanının hikayesi",
                title: "Bu dönem Plovdiv tarihinin neresinde duruyor",
                sourceTrail: "Kaynak izi",
                termSentence: (person: string, term: string, years: string, yearsCount: string) =>
                  `${person}, ${years} döneminde Plovdiv'i yönetti. Dönem ${term} olarak tanımlanır ve yaklaşık süresi ${yearsCount}.`,
                birthplaceSentence: (placeName: string) => `Biyografik profil belediye başkanını doğum yeri olan ${placeName} ile ilişkilendirir.`,
                educationSentence: (items: string) => `İzlenen eğitim bağlantıları ${items} içerir.`,
                rolesSentence: (items: string) => `Kaynaklarda bulunan diğer kamusal görev ve roller ${items} içerir.`,
                repeatSentence: (count: number) => `Bu kişinin kronolojide ${count} ayrı belediye başkanlığı dönemi daha vardır.`
              }
            : lang === "es"
              ? {
                  eyebrow: "Historia del alcalde",
                  title: "Dónde encaja este mandato en la historia de Plovdiv",
                  sourceTrail: "Rastro de fuentes",
                  termSentence: (person: string, term: string, years: string, yearsCount: string) =>
                    `${person} gobernó Plovdiv durante ${years}. El mandato se describe como ${term}, con una duración aproximada de ${yearsCount}.`,
                  birthplaceSentence: (placeName: string) => `El perfil biográfico vincula al alcalde con su lugar de nacimiento: ${placeName}.`,
                  educationSentence: (items: string) => `Los vínculos educativos documentados incluyen ${items}.`,
                  rolesSentence: (items: string) => `Otros cargos y roles públicos encontrados en las fuentes incluyen ${items}.`,
                  repeatSentence: (count: number) => `Esta persona tiene otros ${count} mandatos separados en la cronología.`
                }
              : lang === "el"
                ? {
                    eyebrow: "Ιστορία του δημάρχου",
                    title: "Πού βρίσκεται αυτή η θητεία στην ιστορία της Φιλιππούπολης",
                    sourceTrail: "Ίχνος πηγών",
                    termSentence: (person: string, term: string, years: string, yearsCount: string) =>
                      `${person} διοίκησε τη Φιλιππούπολη την περίοδο ${years}. Η θητεία περιγράφεται ως ${term}, με κατά προσέγγιση διάρκεια ${yearsCount}.`,
                    birthplaceSentence: (placeName: string) => `Το βιογραφικό προφίλ συνδέει τον δήμαρχο με τόπο γέννησης: ${placeName}.`,
                    educationSentence: (items: string) => `Οι τεκμηριωμένοι εκπαιδευτικοί δεσμοί περιλαμβάνουν ${items}.`,
                    rolesSentence: (items: string) => `Άλλες δημόσιες θέσεις και ρόλοι που βρέθηκαν στις πηγές περιλαμβάνουν ${items}.`,
                    repeatSentence: (count: number) => `Αυτό το πρόσωπο έχει ακόμη ${count} χωριστές δημαρχιακές θητείες στη χρονολογία.`
                  }
                : lang === "ja"
                  ? {
                      eyebrow: "市長の物語",
                      title: "この任期がプロヴディフ史のどこに位置するか",
                      sourceTrail: "出典の流れ",
                      termSentence: (person: string, term: string, years: string, yearsCount: string) =>
                        `${person}は${years}にプロヴディフを率いました。この任期は${term}として記録され、おおよその期間は${yearsCount}です。`,
                      birthplaceSentence: (placeName: string) => `伝記情報では、この市長は出生地${placeName}と結び付けられています。`,
                      educationSentence: (items: string) => `確認された教育上のつながりには${items}があります。`,
                      rolesSentence: (items: string) => `出典で確認できるその他の公職・役割には${items}があります。`,
                      repeatSentence: (count: number) => `この人物には、年表上で別に${count}件の市長任期があります。`
                    }
                  : {
                      eyebrow: "Mayor story",
                      title: "Where this term sits in Plovdiv's history",
                      sourceTrail: "Source trail",
                      termSentence: (person: string, term: string, years: string, yearsCount: string) =>
                        `${person} governed Plovdiv during ${years}. The term is described as ${term}, with an approximate duration of ${yearsCount}.`,
                      birthplaceSentence: (placeName: string) => `The biographical profile links the mayor to a birthplace: ${placeName}.`,
                      educationSentence: (items: string) => `The traced education links include ${items}.`,
                      rolesSentence: (items: string) => `Other public offices and roles found in the sources include ${items}.`,
                      repeatSentence: (count: number) => `This person has ${count} other separate mayoral terms in the chronology.`
                    };

const storyListFormatter = new Intl.ListFormat(locale, { style: "long", type: "conjunction" });
const storyList = (items: string[]) => storyListFormatter.format([...new Set(items.filter(Boolean))].slice(0, 5));
const mayorStoryParagraphs = [
  bio,
  field(mayor, "summary", lang),
  mayorStoryLabels.termSentence(name, period, yearLabel, t.mayors.yearsApprox(duration)),
  birthplaceName ? mayorStoryLabels.birthplaceSentence(birthplaceName) : "",
  education.length > 0 ? mayorStoryLabels.educationSentence(storyList(education.map((item) => item.name))) : "",
  roles.length > 0 ? mayorStoryLabels.rolesSentence(storyList(roles.map((item) => item.name))) : "",
  otherTerms.length > 0 ? mayorStoryLabels.repeatSentence(otherTerms.length) : ""
].filter(Boolean);
---

<Layout lang={lang} path={`/mayors/${mayor.id}`} title={name} description={field(mayor, "summary", lang)}>
  <section class="page-head">
    <div class="container">
      <nav class="breadcrumb" aria-label="breadcrumb">
        <a href={localizePath("/", lang)}>{t.nav.home}</a>
        <span class="sep" aria-hidden="true">/</span>
        <a href={localizePath("/mayors", lang)}>{t.nav.mayors}</a>
        <span class="sep" aria-hidden="true">/</span>
        <span aria-current="page">{name}</span>
      </nav>
      <div class="mayor-detail-head">
        <figure class="mayor-portrait-wrap">
          {mayor.image ? (
            <img
              class="mayor-portrait-lg"
              src={mayor.image}
              alt={t.mayors.portraitAlt(name)}
              width="128"
              height="128"
              loading="lazy"
            />
          ) : (
            <span class="mayor-portrait-lg mayor-portrait-fallback" aria-hidden="true">{mono}</span>
          )}
          {mayor.image && mayor.image_credit && (
            <figcaption>{t.mayors.imageCredit}: {mayor.image_credit}</figcaption>
          )}
        </figure>
        <div class="mayor-detail-headtext">
          <p class="eyebrow">{t.mayors.termNumber} {index + 1} · {t.mayors.centuryLabel(century)}</p>
          <h1>{name}</h1>
          <div class="pill-row" style="margin-top:14px">
            <span class="badge no-dot">{yearLabel}</span>
            {isCurrent && <span class="badge status-active">{t.mayors.currentBadge}</span>}
            {isActing && <span class="badge no-dot">{t.mayors.actingBadge}</span>}
            {mayor.fate && <span class="badge badge-killed">{t.mayors.fateLabels[mayor.fate]}</span>}
          </div>
          <p class="lead" style="font-size:1.06rem;margin-top:14px"><strong>{period}</strong></p>
        </div>
      </div>
    </div>
  </section>

  {mayor.fate && (
    <section class="section" style="padding-top:0">
      <div class="container">
        <div class="card fate-callout">
          <span class="fate-icon" aria-hidden="true">✝</span>
          <div>
            <h2>{t.mayors.fateHeading}: {t.mayors.fateLabels[mayor.fate]}</h2>
            <p style="margin-top:6px">{field(mayor, "fate_note", lang)}</p>
          </div>
        </div>
      </div>
    </section>
  )}

  <section class="section" style="padding-top:0">
    <div class="container">
      <article class="card mayor-story-panel" data-mayor-story={mayor.id}>
        <p class="eyebrow">{mayorStoryLabels.eyebrow}</p>
        <h2>{mayorStoryLabels.title}</h2>
        <div class="mayor-story-prose">
          {mayorStoryParagraphs.map((paragraph) => <p>{paragraph}</p>)}
        </div>
        <div class="mayor-story-sources" aria-label={mayorStoryLabels.sourceTrail}>
          <a href={mayor.source_document.url} target="_blank" rel="noreferrer">
            {sourceTitle(mayor.source_document.title, lang)}
          </a>
          {referenceLinks.slice(0, 3).map((link) => (
            <a href={link.url} target="_blank" rel="noreferrer">{link.title}</a>
          ))}
          {officialProfileUrl && officialProfileTitle && (
            <a href={officialProfileUrl} target="_blank" rel="noreferrer">{officialProfileTitle}</a>
          )}
        </div>
      </article>
    </div>
  </section>

  <section class="section" style="padding-top:0">
    <div class="container grid grid-2">
      <article class="card">
        <h2>{t.mayors.detailsTitle}</h2>
        <div class="mayor-facts">
          <div><span>{t.mayors.years}</span><strong>{yearLabel}</strong></div>
          <div><span>{t.mayors.duration}</span><strong>{t.mayors.yearsApprox(duration)}</strong></div>
          <div><span>{t.mayors.century}</span><strong>{t.mayors.centuryLabel(century)}</strong></div>
        </div>
        {(birthplaceName || education.length > 0 || roles.length > 0) && (
          <dl class="mayor-profile-facts">
            {birthplaceName && (
              <div>
                <dt>{t.mayors.birthplaceLabel}</dt>
                <dd>
                  {birthplaceUrl ? (
                    <a href={birthplaceUrl} target="_blank" rel="noreferrer">{birthplaceName}</a>
                  ) : (
                    birthplaceName
                  )}
                </dd>
              </div>
            )}
            {education.length > 0 && (
              <div>
                <dt>{t.mayors.educationLabel}</dt>
                <dd>
                  {education.map((ed, i) => (
                    <>
                      {i > 0 ? ", " : ""}
                      {ed.url ? <a href={ed.url} target="_blank" rel="noreferrer">{ed.name}</a> : ed.name}
                    </>
                  ))}
                </dd>
              </div>
            )}
            {roles.length > 0 && (
              <div>
                <dt>{t.mayors.rolesLabel}</dt>
                <dd>
                  {roles.map((r, i) => (
                    <>
                      {i > 0 ? ", " : ""}
                      {r.url ? <a href={r.url} target="_blank" rel="noreferrer">{r.name}</a> : r.name}
                    </>
                  ))}
                </dd>
              </div>
            )}
          </dl>
        )}
        <p class="meta" style="margin-top:14px">{field(mayor, "summary", lang)}</p>
      </article>

      <article class="card">
        <h2>{t.mayors.moreInfo}</h2>
        <ul class="source-list">
          <li>
            <a href={mayor.source_document.url} target="_blank" rel="noreferrer">
              {sourceTitle(mayor.source_document.title, lang)}
            </a>
            <span class="meta"> · {mayor.source_document.accessed_at}</span>
          </li>
          {officialProfile && officialProfileUrl && officialProfileTitle && (
            <li>
              <a href={officialProfileUrl} target="_blank" rel="noreferrer">
                {t.mayors.officialProfile}: {officialProfileTitle}
              </a>
              <span class="meta"> · {officialProfile.accessed_at}</span>
            </li>
          )}
          {referenceLinks.map((link) => (
            <li>
              <a href={link.url} target="_blank" rel="noreferrer">
                {t.mayors.referenceSource}: {link.title}
              </a>
              <span class="meta"> · {link.accessed_at}</span>
            </li>
          ))}
          {showPersonWiki && (
            <li>
              <a href={personWiki} target="_blank" rel="noreferrer">{t.mayors.wikipediaArticle}: {name}</a>
            </li>
          )}
          {!personWiki &&
            (mayor.more_url ? (
              <li>
                <a href={mayor.more_url} target="_blank" rel="noreferrer">
                  {isWikipediaMoreUrl ? t.mayors.wikipediaArticle : t.mayors.moreInfoLink}: {name}
                </a>
              </li>
            ) : (
              <li>
                <a href={wikiSearch} target="_blank" rel="noreferrer">{t.mayors.wikipediaSearch}: {name}</a>
              </li>
            ))}
          {enrich?.official_website && (
            <li>
              <a href={enrich.official_website} target="_blank" rel="noreferrer">{t.mayors.officialProfile}</a>
            </li>
          )}
        </ul>
        <p class="meta" style="margin-top:14px">{t.mayors.sourceNote}</p>
      </article>
    </div>
  </section>

  {otherTerms.length > 0 && (
    <section class="section section-tint">
      <div class="container">
        <div class="section-head"><h2>{t.mayors.otherTerms}</h2></div>
        <div class="grid grid-3">
          {otherTerms.map((term) => (
            <a class="card card-link" href={localizePath(`/mayors/${term.id}`, lang)}>
              <p class="eyebrow">{term.year_start}{term.year_end ? `-${term.year_end}` : `-${currentYear}`}</p>
              <h3>{field(term, "actor", lang)}</h3>
              <p class="meta">{field(term, "period", lang)}</p>
              <span class="arrow" aria-hidden="true">→</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section">
    <div class="container">
      <div class="results-bar">
        {prev ? (
          <a class="button secondary" href={localizePath(`/mayors/${prev.id}`, lang)}>
            <span class="arrow" aria-hidden="true">←</span> {t.mayors.prevTerm}: {field(prev, "actor", lang)}
          </a>
        ) : <span></span>}
        <a class="link-button" href={localizePath("/mayors", lang)}>{t.mayors.backToAll}</a>
        {next ? (
          <a class="button secondary" href={localizePath(`/mayors/${next.id}`, lang)}>
            {t.mayors.nextTerm}: {field(next, "actor", lang)} <span class="arrow" aria-hidden="true">→</span>
          </a>
        ) : <span></span>}
      </div>
    </div>
  </section>
</Layout>
