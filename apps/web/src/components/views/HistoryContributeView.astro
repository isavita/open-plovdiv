        submit: "レビューに送信",
        submitting: "送信中...",
        successTitle: "受け付けました",
        successText: "投稿はモデレーション待ち行列に入りました。参照番号:",
        submitAnother: "別の投稿を送信",
        backToHistory: "歴史ページへ戻る",
        selected: "選択した地点",
        errors: {
          rate_limited: "短時間に送信が多すぎます。後でもう一度お試しください。",
          invalid_category: "有効な投稿の種類を選択してください。",
          invalid_title: "タイトルは3文字以上120文字以内にしてください。",
          invalid_description: "説明は10文字以上1000文字以内にしてください。",
          invalid_source: "出典は有効なhttp/httpsリンクまたは短いメモにしてください。",
          contains_personal_data: "テキストに個人情報と思われる内容が含まれています。",
          invalid_location: "Plovdiv市内の地点を選択してください。",
          missing_confirmation: "2つの確認項目にチェックしてください。",
