---
import Layout from "@layouts/Layout.astro";
import { categoryColors, ui, type Lang } from "@i18n/ui";
import { field, localizePath } from "@i18n/utils";
import { budgetItems, cityArchive } from "@lib/data";
import { categoryLabel, formatMoney } from "@lib/format";

type Props = { lang: Lang };
const { lang } = Astro.props;
const t = ui[lang];
const EUR_RATE = 1.95583;

const budget2025Total = budgetItems.find(
  (item) => item.year === 2025 && item.kind === "summary" && item.summary_key === "total_budget"
);
const budget2025Capital = budgetItems.find(
  (item) => item.year === 2025 && item.kind === "summary" && item.summary_key === "capital_programme"
);
const sectors = budgetItems
  .filter((item) => item.year === 2025 && item.kind === "sector" && item.amount_bgn != null)
  .sort((a, b) => (b.amount_bgn ?? 0) - (a.amount_bgn ?? 0));
const maxShare = Math.max(...sectors.map((s) => s.share_percent ?? 0), 1);
const budget2025Source =
  budget2025Capital?.source_document.url ?? budget2025Total?.source_document.url ?? sectors[0]?.source_document.url;

const fundingColors: Record<string, string> = {
  eu_funds: "#2f7fb0",
  own_remainder: "#3f8a5b",
  programme_cofinancing: "#9a5b8f",
  state_subsidy: "#b07d1a",
  other_sources: "#6b7280"
};
const funding2026 = budgetItems
  .filter((item) => item.year === 2026 && item.kind === "funding_source" && item.amount_eur != null)
  .sort((a, b) => (a.display_order ?? 0) - (b.display_order ?? 0));
const capital2026 = funding2026.reduce((sum, f) => sum + (f.amount_eur ?? 0), 0);
const maxFund = Math.max(...funding2026.map((f) => f.amount_eur ?? 0), 1);
const budget2026Source = funding2026[0]?.source_document.url;
const capital2026Lev = Math.round(capital2026 * EUR_RATE);

const totalsByYear = budgetItems
  .filter(
    (item) =>
      item.kind === "summary" &&
      (item.summary_key === "total_budget" || item.summary_key === "budget_execution") &&
      item.amount_bgn != null
  )
  .sort((a, b) => a.year - b.year);
const totalHistoryMax = Math.max(...totalsByYear.map((item) => item.amount_bgn ?? 0), 1);

const capitalByYear = [
  ...budgetItems
    .filter((item) => item.kind === "summary" && item.summary_key === "capital_programme" && item.amount_bgn != null)
    .map((item) => ({
      year: item.year,
      lev: item.amount_bgn ?? 0,
      provisional: item.basis === "provisional",
      executed: item.basis === "executed",
      src: item.source_document.url
    })),
  { year: 2026, lev: capital2026Lev, provisional: true, executed: false, src: budget2026Source }
].sort((a, b) => a.year - b.year);
const capitalHistoryMax = Math.max(...capitalByYear.map((item) => item.lev), 1);

const mayorTerms = cityArchive
  .filter((record) => record.kind === "mayor_term")
  .sort((a, b) => b.year_start - a.year_start);
const currentMayor = mayorTerms.find((record) => record.year_end == null) ?? mayorTerms[0];
const recentMayors = mayorTerms.filter((record) => record.id !== currentMayor?.id).slice(0, 7);
const earlyMayors = [...mayorTerms].sort((a, b) => a.year_start - b.year_start).slice(0, 6);
const archiveEvents = cityArchive
  .filter((record) => record.kind !== "mayor_term" && record.kind !== "historical_finance")
  .sort((a, b) => a.year_start - b.year_start);
const mayorSource = currentMayor?.source_document.url ?? mayorTerms[0]?.source_document.url;

function compactBgn(amount: number): string {
  const millions = Math.round(amount / 1e6);
  if (lang === "bg") return `${millions} млн лв`;
  if (lang === "de") return `${millions} Mio. BGN`;
  return `BGN ${millions}M`;
}
---

<Layout lang={lang} path="/budget" title={t.budget.title} description={t.budget.lead}>
  <section class="page-head">
    <div class="container">
      <p class="eyebrow">{t.budget.eyebrow}</p>
      <h1>{t.budget.title}</h1>
      <p class="lead">{t.budget.lead}</p>
    </div>
  </section>

  <!-- 2025 -->
  <section class="section" style="padding-top:0">
    <div class="container">
      <div class="stat-row budget-summary-stats">
        <div class="stat">
          <strong>{formatMoney(budget2025Total?.amount_bgn ?? 0, lang, "BGN")}</strong>
          <span>{t.budget.totalLabel}</span>
        </div>
        <div class="stat">
          <strong>{formatMoney(budget2025Capital?.amount_bgn ?? 0, lang, "BGN")}</strong>
          <span>{t.budget.capitalLabel}</span>
        </div>
      </div>

      <div class="section-head" style="margin-top:28px"><h2>{t.budget.sectorTitle}</h2></div>
      <div class="chart card">
        {sectors.map((item) => (
          <div class="bar-row">
            <span class="bar-label">
              <span class="cat-dot" style={`--dot:${categoryColors[item.category] ?? "var(--muted)"}`}></span>
              {categoryLabel(item.category, lang)}
            </span>
            <div class="bar-track" aria-hidden="true">
              <div class="bar-fill" style={`width:${Math.max(3, ((item.share_percent ?? 0) / maxShare) * 100)}%`}></div>
            </div>
            <span class="money">{item.share_percent}% · ≈{formatMoney(item.amount_bgn ?? 0, lang, "BGN")}</span>
          </div>
        ))}
      </div>
      <p class="meta" style="margin-top:12px">
        {t.budget.approxNote}{" "}
        {budget2025Source && <a href={budget2025Source} target="_blank" rel="noreferrer">{t.budget.sourceLabel}</a>}
      </p>
    </div>
  </section>

  <!-- 2026 -->
  <section class="section section-tint">
    <div class="container">
      <div class="section-head"><h2>{t.budget.provTitle}</h2></div>
      <div class="notice" style="margin-bottom:22px">
        <span class="notice-icon" aria-hidden="true">ⓘ</span>
        <span>{t.budget.provText}</span>
      </div>

      <div class="stat-row" style="grid-template-columns:repeat(1,minmax(0,1fr));max-width:360px">
        <div class="stat">
          <strong>{formatMoney(capital2026, lang, "EUR")}</strong>
          <span>{t.budget.provTitle}</span>
        </div>
      </div>

      <div class="section-head" style="margin-top:28px"><h2 style="font-size:1.3rem">{t.budget.fundingTitle}</h2></div>
      <div class="chart card">
        {funding2026.map((f) => (
          <div class="bar-row">
            <span class="bar-label">
              <span class="cat-dot" style={`--dot:${fundingColors[f.funding_key ?? ""] ?? "var(--muted)"}`}></span>
              {field(f, "title", lang)}
            </span>
            <div class="bar-track" aria-hidden="true">
              <div class="bar-fill" style={`width:${Math.max(3, ((f.amount_eur ?? 0) / maxFund) * 100)}%`}></div>
            </div>
            <span class="money">{formatMoney(f.amount_eur ?? 0, lang, "EUR")}</span>
          </div>
        ))}
      </div>
      <p class="meta" style="margin-top:12px">
        {budget2026Source && <a href={budget2026Source} target="_blank" rel="noreferrer">{t.budget.sourceLabel}</a>}
      </p>
    </div>
  </section>

  <!-- Historical budget archive -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <div>
          <h2>{t.budget.historyTitle}</h2>
          <p class="meta" style="margin-top:8px;max-width:70ch">{t.budget.historyLead}</p>
        </div>
      </div>

      <div class="chart-grid">
        <div class="chart-card">
          <h3>{t.budget.totalHistoryTitle}</h3>
          <div class="compare-cols" data-dense>
            {totalsByYear.map((item) => (
              <div class="compare-col">
                <div
                  class={`compare-bar${item.basis === "provisional" ? " provisional" : item.basis === "executed" ? " archive" : ""}`}
                  style={`height:${((item.amount_bgn ?? 0) / totalHistoryMax) * 100}%`}
                ></div>
                <div class="compare-meta">
                  <strong>{compactBgn(item.amount_bgn ?? 0)}</strong>
                  <span>
                    {item.basis === "provisional"
                      ? `${item.year} · ${t.budget.provisionalShort}`
                      : item.basis === "executed"
                        ? `${item.year} · ${t.budget.executedShort}`
                        : item.year}
                  </span>
                </div>
              </div>
            ))}
          </div>
          <div class="pill-row" style="margin-top:14px">
            {totalsByYear.map((item) => (
              <a class="meta" href={item.source_document.url} target="_blank" rel="noreferrer">{item.year}</a>
            ))}
          </div>
        </div>

        <div class="chart-card">
          <h3>{t.budget.capitalHistoryTitle}</h3>
          <div class="compare-cols" data-dense>
            {capitalByYear.map((item) => (
              <div class="compare-col">
                <div
                  class={`compare-bar${item.provisional ? " provisional" : item.executed ? " archive" : ""}`}
                  style={`height:${(item.lev / capitalHistoryMax) * 100}%`}
                ></div>
                <div class="compare-meta">
                  <strong>{compactBgn(item.lev)}</strong>
                  <span>
                    {item.provisional
                      ? `${item.year} · ${t.budget.provisionalShort}`
                      : item.executed
                        ? `${item.year} · ${t.budget.executedShort}`
                        : item.year}
                  </span>
                </div>
              </div>
            ))}
          </div>
          <div class="pill-row" style="margin-top:14px">
            {capitalByYear.map((item) => (
              item.src && <a class="meta" href={item.src} target="_blank" rel="noreferrer">{item.year}</a>
            ))}
          </div>
        </div>
      </div>

      <p class="meta" style="margin-top:14px;max-width:76ch">{t.budget.historyNote}</p>
    </div>
  </section>

  <!-- Mayoral archive -->
  <section class="section section-tint">
    <div class="container">
      <div class="section-head">
        <div>
          <h2>{t.budget.mayorsTitle}</h2>
          <p class="meta" style="margin-top:8px;max-width:70ch">{t.budget.mayorsLead}</p>
        </div>
      </div>

      <div class="stat-row" style="grid-template-columns:repeat(2,minmax(0,1fr));max-width:680px">
        <div class="stat">
          <strong>{mayorTerms.length}</strong>
          <span>{t.budget.mayorTermCount}</span>
        </div>
        {currentMayor && (
          <div class="stat">
            <strong>{field(currentMayor, "actor", lang)}</strong>
            <span>{t.budget.currentMayorLabel}</span>
          </div>
        )}
      </div>

      {currentMayor && (
        <div class="notice" style="margin-top:22px">
          <span class="notice-icon" aria-hidden="true">ⓘ</span>
          <span>
            <strong>{field(currentMayor, "title", lang)}</strong>{" "}
            {field(currentMayor, "period", lang)}
            {" · "}
            <a href={currentMayor.source_document.url} target="_blank" rel="noreferrer">{t.budget.sourceLabel}</a>
          </span>
        </div>
      )}

      <div class="grid grid-2" style="margin-top:22px">
        <article class="chart-card">
          <h3>{t.budget.recentMayorsTitle}</h3>
          <ul class="archive-list">
            {recentMayors.map((record) => (
              <li>
                <div>
                  <strong>{field(record, "actor", lang)}</strong>
                  <span>{field(record, "period", lang)}</span>
                </div>
                <a class="meta" href={record.source_document.url} target="_blank" rel="noreferrer">{record.year_start}</a>
              </li>
            ))}
          </ul>
        </article>

        <article class="chart-card">
          <h3>{t.budget.earlyMayorsTitle}</h3>
          <ul class="archive-list">
            {earlyMayors.map((record) => (
              <li>
                <div>
                  <strong>{field(record, "actor", lang)}</strong>
                  <span>{field(record, "period", lang)}</span>
                </div>
                <a class="meta" href={record.source_document.url} target="_blank" rel="noreferrer">{record.year_start}</a>
              </li>
            ))}
          </ul>
        </article>
      </div>

      {mayorSource && (
        <div class="actions">
          <a class="button secondary" href={localizePath("/archive", lang)}>{t.nav.archive}</a>
          <a class="button secondary" href={mayorSource} target="_blank" rel="noreferrer">{t.budget.fullMayorArchive}</a>
        </div>
      )}
    </div>
  </section>

  <!-- Events and programmes -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <div>
          <h2>{t.budget.eventsTitle}</h2>
          <p class="meta" style="margin-top:8px;max-width:70ch">{t.budget.eventsLead}</p>
        </div>
      </div>

      <div class="grid grid-2">
        {archiveEvents.map((record) => (
          <article class="card project-card">
            <header>
              <div>
                <p class="eyebrow">{field(record, "period", lang)}</p>
                <h3>{field(record, "title", lang)}</h3>
              </div>
              {record.amount_bgn && <span class="badge no-dot">{formatMoney(record.amount_bgn, lang, "BGN")}</span>}
            </header>
            <p>{field(record, "summary", lang)}</p>
            <div class="pill-row">
              <a class="meta" href={record.source_document.url} target="_blank" rel="noreferrer">{t.budget.sourceLabel}</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="notice">
        <span class="notice-icon" aria-hidden="true">ⓘ</span>
        <span>
          {t.home.notice}{" "}
          <a href={localizePath("/data-sources", lang)}>{t.home.noticeSources}</a> ·
          <a href={localizePath("/projects", lang)}> {t.nav.projects}</a>.
        </span>
      </div>
    </div>
  </section>
</Layout>
