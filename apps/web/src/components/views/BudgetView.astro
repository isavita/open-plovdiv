---
import Layout from "@layouts/Layout.astro";
import { categoryColors, categoryLabels, sourceTitleLabels, ui, type Lang } from "@i18n/ui";
import { localizePath } from "@i18n/utils";
import { budgetItems } from "@lib/data";
import { formatMoney } from "@lib/format";

type Props = { lang: Lang };
const { lang } = Astro.props;
const t = ui[lang];

const years = Array.from(new Set(budgetItems.map((item) => item.year))).sort((a, b) => b - a);
const initialTotal = budgetItems
  .filter((item) => item.year === years[0])
  .reduce((sum, item) => sum + item.amount_bgn, 0);

const config = {
  lang,
  locale: lang === "bg" ? "bg-BG" : "en-GB",
  projectBase: localizePath("/projects", lang),
  categoryLabels: categoryLabels[lang],
  categoryColors,
  sourceTitles: sourceTitleLabels[lang],
  labels: {
    related: t.budget.relatedProjects,
    noRelated: t.budget.noRelated,
    accessed: t.common.accessed,
    share: t.budget.shareOfTotal,
    errorTotal: lang === "bg" ? "Грешка" : "Error",
    errorLoad: t.budget.loadError,
    errorChart: t.budget.chartError,
    errorSources: t.budget.sourcesError
  }
};
---

<Layout lang={lang} path="/budget" title={t.budget.title} description={t.budget.lead}>
  <section class="page-head">
    <div class="container">
      <p class="eyebrow">{t.budget.eyebrow}</p>
      <h1>{t.budget.title}</h1>
      <p class="lead">{t.budget.lead}</p>
    </div>
  </section>

  <section class="section" style="padding-top:0">
    <div class="container">
      <div class="toolbar">
        <div class="filters" style="grid-template-columns: repeat(2, minmax(0,1fr))">
          <div class="field">
            <label for="year-select">{t.budget.year}</label>
            <select id="year-select">
              {years.map((year) => <option value={year}>{year}</option>)}
            </select>
          </div>
          <div class="field">
            <label for="budget-total">{t.budget.total}</label>
            <input id="budget-total" type="text" readonly value={formatMoney(initialTotal, lang)} />
          </div>
        </div>
      </div>

      <div class="notice">
        <span class="notice-icon" aria-hidden="true">ⓘ</span>
        <span>{t.budget.notice}</span>
      </div>
    </div>
  </section>

  <section class="section" style="padding-top:0">
    <div class="container grid grid-2">
      <article>
        <div class="section-head"><h2>{t.budget.categories}</h2></div>
        <div id="category-cards" class="grid" aria-live="polite">
          <p class="loading">{t.common.loading}</p>
        </div>
      </article>
      <article>
        <div class="section-head"><h2>{t.budget.distribution}</h2></div>
        <div id="budget-chart" class="chart card" aria-live="polite">
          <p class="loading">{t.common.loading}</p>
        </div>
      </article>
    </div>
  </section>

  <section class="section section-tint">
    <div class="container">
      <div class="section-head"><h2>{t.budget.sourcesTitle}</h2></div>
      <div id="budget-sources" class="grid grid-2" aria-live="polite">
        <p class="loading">{t.common.loading}</p>
      </div>
    </div>
  </section>

  <script type="application/json" id="budget-config" set:html={JSON.stringify(config)}></script>

  <script>
    type BudgetConfig = {
      lang: string;
      locale: string;
      projectBase: string;
      categoryLabels: Record<string, string>;
      categoryColors: Record<string, string>;
      sourceTitles: Record<string, string>;
      labels: Record<string, string>;
    };

    const config: BudgetConfig = JSON.parse(
      document.getElementById("budget-config")?.textContent ?? "{}"
    );
    const L = config.labels;

    const yearSelect = document.querySelector<HTMLSelectElement>("#year-select")!;
    const totalField = document.querySelector<HTMLInputElement>("#budget-total")!;
    const categoryCards = document.querySelector<HTMLElement>("#category-cards")!;
    const budgetChart = document.querySelector<HTMLElement>("#budget-chart")!;
    const budgetSources = document.querySelector<HTMLElement>("#budget-sources")!;

    let budgetItems: any[] = [];
    let projects: any[] = [];

    function escapeHtml(value: unknown): string {
      return String(value)
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
    }

    function loc(record: any, base: string): string {
      return record[`${base}_${config.lang}`] ?? record[`${base}_bg`] ?? "";
    }

    function catLabel(category: string): string {
      return config.categoryLabels[category] ?? category;
    }

    function catColor(category: string): string {
      return config.categoryColors[category] ?? "var(--muted)";
    }

    function formatMoney(amount: number): string {
      return new Intl.NumberFormat(config.locale, {
        style: "currency",
        currency: "BGN",
        maximumFractionDigits: 0
      }).format(amount);
    }

    function selectedItems() {
      return budgetItems.filter((item) => String(item.year) === yearSelect.value);
    }

    function relatedProjects(item: any) {
      return projects
        .filter((project) => project.related_budget_item_id === item.id)
        .slice(0, 4);
    }

    function renderBudget() {
      const items = selectedItems();
      const total = items.reduce((sum, item) => sum + item.amount_bgn, 0);
      totalField.value = formatMoney(total);

      categoryCards.innerHTML = items
        .map(
          (item) => `
            <article class="card">
              <p class="eyebrow" style="color:${catColor(item.category)}">${escapeHtml(catLabel(item.category))}</p>
              <h3>${escapeHtml(loc(item, "title"))}</h3>
              <p class="money">${formatMoney(item.amount_bgn)}</p>
              <p class="meta">${escapeHtml(loc(item, "plain_language"))}</p>
            </article>
          `
        )
        .join("");

      budgetChart.innerHTML = items
        .slice()
        .sort((a, b) => b.amount_bgn - a.amount_bgn)
        .map((item) => {
          const percent = total > 0 ? Math.max(2, (item.amount_bgn / total) * 100) : 0;
          return `
            <div class="bar-row">
              <span class="bar-label"><span class="cat-dot" style="--dot:${catColor(item.category)}"></span>${escapeHtml(catLabel(item.category))}</span>
              <div class="bar-track" aria-hidden="true"><div class="bar-fill" style="width:${percent}%"></div></div>
              <span class="money">${formatMoney(item.amount_bgn)}</span>
            </div>
          `;
        })
        .join("");

      budgetSources.innerHTML = items
        .map((item) => {
          const linked = relatedProjects(item);
          return `
            <article class="card">
              <header style="display:flex;justify-content:space-between;gap:12px;align-items:baseline">
                <h3>${escapeHtml(loc(item, "title"))}</h3>
                <span class="money">${formatMoney(item.amount_bgn)}</span>
              </header>
              <p class="stack-sm">
                <a href="${escapeHtml(item.source_document.url)}" target="_blank" rel="noreferrer">${escapeHtml(config.sourceTitles[item.source_document.title] ?? item.source_document.title)}</a>
                <span class="meta"> · ${escapeHtml(L.accessed)} ${escapeHtml(item.source_document.accessed_at)}</span>
              </p>
              <h4>${escapeHtml(L.related)}</h4>
              ${
                linked.length
                  ? `<ul class="source-list">${linked
                      .map(
                        (project) =>
                          `<li><a href="${config.projectBase}/${escapeHtml(project.id)}">${escapeHtml(loc(project, "title"))}</a></li>`
                      )
                      .join("")}</ul>`
                  : `<p class="meta">${escapeHtml(L.noRelated)}</p>`
              }
            </article>
          `;
        })
        .join("");
    }

    yearSelect.addEventListener("change", renderBudget);

    try {
      [budgetItems, projects] = await Promise.all([
        fetch("/data/budget-items.json").then((r) => {
          if (!r.ok) throw new Error("budget failed");
          return r.json();
        }),
        fetch("/data/projects.json").then((r) => {
          if (!r.ok) throw new Error("projects failed");
          return r.json();
        })
      ]);
      renderBudget();
    } catch {
      totalField.value = L.errorTotal;
      categoryCards.innerHTML = `<p class="error">${L.errorLoad}</p>`;
      budgetChart.innerHTML = `<p class="error">${L.errorChart}</p>`;
      budgetSources.innerHTML = `<p class="error">${L.errorSources}</p>`;
    }
  </script>
</Layout>
