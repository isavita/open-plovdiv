---
import Layout from "@layouts/Layout.astro";
import { categoryColors, ui, type Lang } from "@i18n/ui";
import { localizePath } from "@i18n/utils";
import { budgetItems } from "@lib/data";
import { categoryLabel, formatMoney } from "@lib/format";

type Props = { lang: Lang };
const { lang } = Astro.props;
const t = ui[lang];

// 2025 — adopted budget (BGN). Figures from the municipality's 2025 budget.
const TOTAL_2025 = 715154301;
const CAPITAL_2025 = 139597929;
const budget2025Source = "https://www.plovdiv.bg/en/proekt-budget-2025/";

const sectors = budgetItems
  .filter((item) => item.year === 2025)
  .sort((a, b) => b.amount_bgn - a.amount_bgn);
const maxShare = Math.max(...sectors.map((s) => s.share_percent ?? 0), 1);

// 2026 — provisional capital programme (EUR). Figures reported June 2026.
const funding2026 = [
  { label: t.budget.fundEu, amount: 51100000, color: "#2f7fb0" },
  { label: t.budget.fundOwn, amount: 20900000, color: "#3f8a5b" },
  { label: t.budget.fundOpco, amount: 7130000, color: "#9a5b8f" },
  { label: t.budget.fundState, amount: 2960000, color: "#b07d1a" },
  { label: t.budget.fundOther, amount: 5080000, color: "#6b7280" }
];
const capital2026 = funding2026.reduce((sum, f) => sum + f.amount, 0);
const maxFund = Math.max(...funding2026.map((f) => f.amount), 1);
const budget2026Source =
  "https://podtepeto.com/aktualno/obsthina-plovdiv-planira-blizo-87-mln-evro-za-kapitalovi-razhodi-prez-2026-g/";
---

<Layout lang={lang} path="/budget" title={t.budget.title} description={t.budget.lead}>
  <section class="page-head">
    <div class="container">
      <p class="eyebrow">{t.budget.eyebrow}</p>
      <h1>{t.budget.title}</h1>
      <p class="lead">{t.budget.lead}</p>
    </div>
  </section>

  <!-- 2025 -->
  <section class="section" style="padding-top:0">
    <div class="container">
      <div class="stat-row" style="grid-template-columns:repeat(2,minmax(0,1fr))">
        <div class="stat">
          <strong>{formatMoney(TOTAL_2025, lang, "BGN")}</strong>
          <span>{t.budget.totalLabel}</span>
        </div>
        <div class="stat">
          <strong>{formatMoney(CAPITAL_2025, lang, "BGN")}</strong>
          <span>{t.budget.capitalLabel}</span>
        </div>
      </div>

      <div class="section-head" style="margin-top:28px"><h2>{t.budget.sectorTitle}</h2></div>
      <div class="chart card">
        {sectors.map((item) => (
          <div class="bar-row">
            <span class="bar-label">
              <span class="cat-dot" style={`--dot:${categoryColors[item.category] ?? "var(--muted)"}`}></span>
              {categoryLabel(item.category, lang)}
            </span>
            <div class="bar-track" aria-hidden="true">
              <div class="bar-fill" style={`width:${Math.max(3, ((item.share_percent ?? 0) / maxShare) * 100)}%`}></div>
            </div>
            <span class="money">{item.share_percent}% · ≈{formatMoney(item.amount_bgn, lang, "BGN")}</span>
          </div>
        ))}
      </div>
      <p class="meta" style="margin-top:12px">
        {t.budget.approxNote}{" "}
        <a href={budget2025Source} target="_blank" rel="noreferrer">{t.budget.sourceLabel}</a>
      </p>
    </div>
  </section>

  <!-- 2026 -->
  <section class="section section-tint">
    <div class="container">
      <div class="section-head"><h2>{t.budget.provTitle}</h2></div>
      <div class="notice" style="margin-bottom:22px">
        <span class="notice-icon" aria-hidden="true">ⓘ</span>
        <span>{t.budget.provText}</span>
      </div>

      <div class="stat-row" style="grid-template-columns:repeat(1,minmax(0,1fr));max-width:360px">
        <div class="stat">
          <strong>{formatMoney(capital2026, lang, "EUR")}</strong>
          <span>{t.budget.provTitle}</span>
        </div>
      </div>

      <div class="section-head" style="margin-top:28px"><h2 style="font-size:1.3rem">{t.budget.fundingTitle}</h2></div>
      <div class="chart card">
        {funding2026.map((f) => (
          <div class="bar-row">
            <span class="bar-label">
              <span class="cat-dot" style={`--dot:${f.color}`}></span>
              {f.label}
            </span>
            <div class="bar-track" aria-hidden="true">
              <div class="bar-fill" style={`width:${Math.max(3, (f.amount / maxFund) * 100)}%`}></div>
            </div>
            <span class="money">{formatMoney(f.amount, lang, "EUR")}</span>
          </div>
        ))}
      </div>
      <p class="meta" style="margin-top:12px">
        <a href={budget2026Source} target="_blank" rel="noreferrer">{t.budget.sourceLabel}</a>
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="notice">
        <span class="notice-icon" aria-hidden="true">ⓘ</span>
        <span>
          {t.home.notice}{" "}
          <a href={localizePath("/data-sources", lang)}>{t.home.noticeSources}</a> ·
          <a href={localizePath("/projects", lang)}> {t.nav.projects}</a>.
        </span>
      </div>
    </div>
  </section>
</Layout>
