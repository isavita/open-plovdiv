---
import Layout from "@layouts/Layout.astro";
import { ui, type Lang } from "@i18n/utils";

type Props = { lang: Lang };
const { lang } = Astro.props;
const t = ui[lang];

const steps = [
  { title: t.methodology.collectTitle, text: t.methodology.collectText },
  { title: t.methodology.verifyTitle, text: t.methodology.verifyText },
  { title: t.methodology.aiTitle, text: t.methodology.aiText },
  { title: t.methodology.correctTitle, text: t.methodology.correctText }
];
---

<Layout lang={lang} path="/methodology" title={t.methodology.title} description={t.methodology.lead}>
  <section class="page-head">
    <div class="container">
      <p class="eyebrow">{t.methodology.eyebrow}</p>
      <h1>{t.methodology.title}</h1>
      <p class="lead">{t.methodology.lead}</p>
    </div>
  </section>

  <section class="section" style="padding-top:0">
    <div class="container grid grid-2">
      {steps.map((step, index) => (
        <article class="card">
          <p class="eyebrow">{String(index + 1).padStart(2, "0")}</p>
          <h2 style="font-size:1.3rem">{step.title}</h2>
          <p class="meta">{step.text}</p>
        </article>
      ))}
    </div>
  </section>
</Layout>
