---
import Layout from "@layouts/Layout.astro";
import { ui, type Lang } from "@i18n/ui";
import { field, localizePath } from "@i18n/utils";
import { cityArchive } from "@lib/data";
import { sourceTitle } from "@lib/format";

type Props = { lang: Lang };
const { lang } = Astro.props;
const t = ui[lang];

const currentYear = new Date().getFullYear();

const mayorTerms = cityArchive
  .filter((record) => record.kind === "mayor_term")
  .sort((a, b) => a.year_start - b.year_start || (a.year_end ?? currentYear) - (b.year_end ?? currentYear));

function centuryFor(year: number): number {
  return Math.floor((year - 1) / 100) + 1;
}

function normalizeName(name: string): string {
  return name
    .replace(/^(д-р|Д-р|инж\.)\s+/u, "")
    .replace(/^Mayor:\s+/u, "")
    .trim()
    .toLocaleLowerCase(lang === "bg" ? "bg-BG" : "en-GB");
}

function durationYears(start: number, end?: number): number {
  return Math.max(1, (end ?? currentYear) - start + 1);
}

const uniqueMayors = new Set(mayorTerms.map((term) => normalizeName(field(term, "actor", lang))));
const currentMayor = mayorTerms.find((term) => term.year_end == null);
const firstYear = mayorTerms[0]?.year_start ?? 1878;
const lastYear = currentMayor?.year_start ?? mayorTerms[mayorTerms.length - 1]?.year_end ?? currentYear;
const coveredYears = currentYear - firstYear + 1;

const centuries = [...new Set(mayorTerms.map((term) => centuryFor(term.year_start)))].sort((a, b) => a - b);
const centuryCounts = new Map(
  centuries.map((century) => [
    century,
    mayorTerms.filter((term) => centuryFor(term.year_start) === century).length
  ])
);

const sourceUrls = [...new Map(mayorTerms.map((term) => [term.source_document.url, term.source_document])).values()];

const config = {
  countAll: t.mayors.count(mayorTerms.length),
  countFiltered: "{visible} " + (lang === "bg" ? "от" : "of") + ` ${mayorTerms.length} ` + (lang === "bg" ? "мандата" : "terms"),
  empty: t.mayors.empty
};

function initials(name: string): string {
  return name
    .replace(/^(д-р|Д-р|инж\.|Mayor:)\s*/u, "")
    .trim()
    .split(/\s+/)
    .slice(0, 2)
    .map((w) => w[0] ?? "")
    .join("")
    .toLocaleUpperCase(lang === "bg" ? "bg-BG" : "en-GB");
}

// --- relationship graph: connections between mayors ---
const groups = new Map<string, typeof mayorTerms>();
for (const term of mayorTerms) {
  const key = normalizeName(field(term, "actor", lang));
  if (!groups.has(key)) groups.set(key, []);
  groups.get(key)!.push(term);
}
const multiTerm = [...groups.values()]
  .filter((g) => g.length > 1)
  .sort((a, b) => a[0].year_start - b[0].year_start);
const repeatTermIds = new Set(multiTerm.flat().map((tm) => tm.id));

// sourced family ties between mayors
const familyPairs = [
  { a: "Христо Г. Данов", b: "Милош Данов", label_bg: "баща и син", label_en: "father & son" }
];

const W = 1000;
const AX = 168;
const PAD = 28;
const span = Math.max(1, currentYear - firstYear);
const xFor = (year: number) => PAD + ((year - firstYear) / span) * (W - 2 * PAD);
const arcPath = (x1: number, x2: number, lift: number) =>
  `M ${x1.toFixed(1)} ${AX} C ${x1.toFixed(1)} ${(AX - lift).toFixed(1)}, ${x2.toFixed(1)} ${(AX - lift).toFixed(1)}, ${x2.toFixed(1)} ${AX}`;

const repeatArcs = multiTerm.flatMap((g) =>
  g.slice(1).map((term, i) => {
    const x1 = xFor(g[i].year_start);
    const x2 = xFor(term.year_start);
    return arcPath(x1, x2, Math.min(118, 24 + Math.abs(x2 - x1) * 0.42));
  })
);

const familyArcs = familyPairs
  .map((pair) => {
    const ta = mayorTerms.find((m) => m.actor_bg === pair.a);
    const tb = mayorTerms.find((m) => m.actor_bg === pair.b);
    if (!ta || !tb) return null;
    const x1 = xFor(ta.year_start);
    const x2 = xFor(tb.year_start);
    return { d: arcPath(x1, x2, Math.min(150, 54 + Math.abs(x2 - x1) * 0.5)), pair };
  })
  .filter((x): x is NonNullable<typeof x> => x !== null);

const axisTicks: number[] = [];
for (let y = Math.ceil(firstYear / 20) * 20; y <= currentYear; y += 20) axisTicks.push(y);

// --- birthplaces of mayors (from Wikidata: place of birth + coordinates) ---
const birthPersons = new Map<string, (typeof mayorTerms)[number]>();
for (const term of mayorTerms) {
  if (term.birth_lat == null || term.birth_lng == null || !term.more_url) continue;
  if (!birthPersons.has(term.more_url)) birthPersons.set(term.more_url, term);
}
const birthTownsMap = new Map<
  string,
  { lat: number; lng: number; name: string; country: string; people: string[] }
>();
for (const p of birthPersons.values()) {
  const key = p.birth_wikidata ?? `${p.birth_lat},${p.birth_lng}`;
  if (!birthTownsMap.has(key)) {
    birthTownsMap.set(key, {
      lat: p.birth_lat!,
      lng: p.birth_lng!,
      name: field(p, "birthplace", lang),
      country: field(p, "birth_country", lang),
      people: []
    });
  }
  birthTownsMap.get(key)!.people.push(field(p, "actor", lang));
}
const birthTowns = [...birthTownsMap.values()].sort((a, b) => b.people.length - a.people.length);
const maxBirthCount = Math.max(1, ...birthTowns.map((tw) => tw.people.length));
const birthCountries = new Set(birthTowns.map((tw) => tw.country).filter(Boolean));
const birthConfig = { markers: birthTowns, mayorsLabel: t.mayors.birthPopupMayors };
---

<Layout lang={lang} path="/mayors" title={t.mayors.title} description={t.mayors.lead}>
  <section class="page-head">
    <div class="container">
      <p class="eyebrow">{t.mayors.eyebrow}</p>
      <h1>{t.mayors.title}</h1>
      <p class="lead">{t.mayors.lead}</p>
      <p class="meta" style="margin-top:10px">{t.mayors.sourceNote}</p>
    </div>
  </section>

  <section class="section" style="padding-top:0">
    <div class="container">
      <div class="stat-row">
        <div class="stat"><strong>{mayorTerms.length}</strong><span>{t.mayors.statTerms}</span></div>
        <div class="stat"><strong>{uniqueMayors.size}</strong><span>{t.mayors.statPeople}</span></div>
        <div class="stat"><strong>{coveredYears}</strong><span>{t.mayors.statYears}</span></div>
        {currentMayor && <div class="stat"><strong>{field(currentMayor, "actor", lang)}</strong><span>{t.mayors.statCurrent}</span></div>}
      </div>
    </div>
  </section>

  <section class="section" style="padding-top:0">
    <div class="container">
      <div class="section-head">
        <div>
          <h2>{t.mayors.connectionsTitle}</h2>
          <p class="meta" style="margin-top:8px;max-width:74ch">{t.mayors.connectionsLead}</p>
        </div>
      </div>

      <div class="card arc-card">
        <svg
          class="mayor-arc"
          viewBox="0 0 1000 200"
          role="img"
          aria-label={t.mayors.connectionsTitle}
          preserveAspectRatio="xMidYMid meet"
        >
          {repeatArcs.map((d) => <path class="arc-repeat" d={d} fill="none" />)}
          {familyArcs.map((fa) => <path class="arc-family" d={fa.d} fill="none" />)}
          <line class="arc-axis" x1={PAD} y1={AX} x2={W - PAD} y2={AX} />
          {axisTicks.map((y) => (
            <text class="arc-tick-label" x={xFor(y)} y={AX + 20} text-anchor="middle">{y}</text>
          ))}
          {mayorTerms.map((term) => {
            const cx = xFor(term.year_start);
            const cls =
              term.fate === "killed"
                ? "dot dot-killed"
                : term.year_end == null
                  ? "dot dot-current"
                  : repeatTermIds.has(term.id)
                    ? "dot dot-repeat"
                    : "dot";
            const big = term.fate === "killed" || term.year_end == null;
            return (
              <circle class={cls} cx={cx} cy={AX} r={big ? 6 : 4}>
                <title>
                  {`${field(term, "actor", lang)} · ${term.year_start}${term.year_end ? `–${term.year_end}` : `–${currentYear}`}`}
                </title>
              </circle>
            );
          })}
        </svg>
        <div class="arc-legend">
          <span class="lg lg-repeat">{t.mayors.legendSame}</span>
          <span class="lg lg-family">{t.mayors.legendFamily}</span>
          <span class="lg lg-killed">{t.mayors.legendKilled}</span>
          <span class="lg lg-current">{t.mayors.legendCurrent}</span>
        </div>
      </div>

      <div class="grid grid-2" style="margin-top:18px">
        <div class="card">
          <h3>{t.mayors.multiTermTitle}</h3>
          <ul class="connect-list">
            {multiTerm.map((g) => (
              <li>
                <a href={localizePath(`/mayors/${g[0].id}`, lang)}>{field(g[0], "actor", lang)}</a>
                <span class="connect-years">
                  {g
                    .map((tm) => `${tm.year_start}${tm.year_end ? `–${tm.year_end}` : `–${currentYear}`}`)
                    .join(" · ")}
                </span>
              </li>
            ))}
          </ul>
        </div>
        {familyArcs.length > 0 && (
          <div class="card">
            <h3>{t.mayors.familyTitle}</h3>
            <ul class="connect-list">
              {familyArcs.map((fa) => (
                <li>
                  <span>{`${fa.pair.a} — ${fa.pair.b}`}</span>
                  <span class="connect-years">{lang === "bg" ? fa.pair.label_bg : fa.pair.label_en}</span>
                </li>
              ))}
            </ul>
            <p class="meta" style="margin-top:14px">{t.mayors.portraitNote}</p>
          </div>
        )}
      </div>
    </div>
  </section>

  {birthTowns.length > 0 && (
    <section class="section" style="padding-top:0">
      <div class="container">
        <div class="section-head">
          <div>
            <h2>{t.mayors.birthTitle}</h2>
            <p class="meta" style="margin-top:8px;max-width:74ch">{t.mayors.birthLead}</p>
          </div>
          <div class="pill-row">
            <span class="badge no-dot">{`${birthTowns.length} ${t.mayors.birthStatTowns}`}</span>
            <span class="badge no-dot">{`${birthCountries.size} ${t.mayors.birthStatCountries}`}</span>
          </div>
        </div>

        <div class="grid grid-2 birth-layout">
          <div class="card map-card" style="padding:0;overflow:hidden">
            <div id="mayor-birth-map" class="birth-map"></div>
          </div>
          <div class="card">
            <h3>{t.mayors.birthByTown}</h3>
            <ul class="birth-bars">
              {birthTowns.map((town) => (
                <li>
                  <span class="birth-town" title={town.name}>{town.name}</span>
                  <span class="birth-bar">
                    <span
                      class="birth-bar-fill"
                      style={`width:${Math.round((town.people.length / maxBirthCount) * 100)}%`}
                    ></span>
                  </span>
                  <span class="birth-count">{town.people.length}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>
  )}

  <section class="section section-tint">
    <div class="container">
      <div class="section-head">
        <div>
          <h2>{t.mayors.timelineTitle}</h2>
          <p class="meta" style="margin-top:8px;max-width:74ch">{t.mayors.timelineLead}</p>
        </div>
      </div>

      <div class="mayor-timeline" aria-label={t.mayors.timelineTitle}>
        {mayorTerms.map((term, index) => {
          const isCurrent = term.year_end == null;
          const isActing = field(term, "period", lang).toLocaleLowerCase(lang === "bg" ? "bg-BG" : "en-GB").includes("и.д.");
          const search = [
            field(term, "actor", lang),
            field(term, "period", lang),
            term.year_start,
            term.year_end ?? currentYear,
            field(term, "summary", lang)
          ].join(" ").toLocaleLowerCase(lang === "bg" ? "bg-BG" : "en-GB");
          return (
            <a
              class="mayor-chip"
              href={`#${term.id}`}
              data-mayor-chip
              data-search={search}
              data-century={centuryFor(term.year_start)}
              data-status={isCurrent ? "current" : isActing ? "acting" : "regular"}
            >
              <span>{index + 1}</span>
              <strong>{field(term, "actor", lang)}</strong>
              <small>{term.year_start}{term.year_end ? `-${term.year_end}` : `-${currentYear}`}</small>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="toolbar">
        <div class="filters" style="grid-template-columns: minmax(0, 1.5fr) repeat(2, minmax(0, 1fr));">
          <div class="field">
            <label for="mayor-search">{t.mayors.search}</label>
            <input id="mayor-search" type="search" placeholder={t.mayors.searchPlaceholder} />
          </div>
          <div class="field">
            <label for="mayor-century">{t.mayors.century}</label>
            <select id="mayor-century">
              <option value="all">{t.mayors.allCenturies}</option>
              {centuries.map((century) => (
                <option value={century}>
                  {t.mayors.centuryLabel(century)} ({centuryCounts.get(century)})
                </option>
              ))}
            </select>
          </div>
          <div class="field">
            <label for="mayor-status">{t.mayors.status}</label>
            <select id="mayor-status">
              <option value="all">{t.mayors.allStatuses}</option>
              <option value="current">{t.mayors.currentOnly}</option>
              <option value="acting">{t.mayors.actingOnly}</option>
            </select>
          </div>
        </div>
      </div>

      <div class="results-bar">
        <p id="mayor-count" class="meta">{t.mayors.count(mayorTerms.length)}</p>
        <button type="button" id="mayor-reset" class="link-button" hidden>{t.mayors.reset}</button>
      </div>

      <div class="mayor-layout">
        <aside class="mayor-index" aria-label={t.mayors.century}>
          <h2>{t.mayors.detailsTitle}</h2>
          <ol>
            {centuries.map((century) => (
              <li>
                <a href={`#century-${century}`}>{t.mayors.centuryLabel(century)}</a>
                <span>{centuryCounts.get(century)}</span>
              </li>
            ))}
          </ol>
          <div class="muted-card">
            <h3>{t.mayors.sourcesTitle}</h3>
            <p class="meta">{t.mayors.sourcesText}</p>
            <ul class="source-list" style="margin-top:12px">
              {sourceUrls.map((source) => (
                <li>
                  <a href={source.url} target="_blank" rel="noreferrer">{sourceTitle(source.title, lang)}</a>
                  <span class="meta"> · {source.accessed_at}</span>
                </li>
              ))}
            </ul>
          </div>
        </aside>

        <div class="mayor-list">
          {centuries.map((century) => (
            <section class="mayor-century" id={`century-${century}`}>
              <div class="section-head">
                <h2>{t.mayors.centuryLabel(century)}</h2>
                <p class="meta">{centuryCounts.get(century)} {t.mayors.statTerms}</p>
              </div>
              <div class="list">
                {mayorTerms
                  .filter((term) => centuryFor(term.year_start) === century)
                  .map((term) => {
                    const index = mayorTerms.findIndex((item) => item.id === term.id) + 1;
                    const isCurrent = term.year_end == null;
                    const period = field(term, "period", lang);
                    const isActing = period.toLocaleLowerCase(lang === "bg" ? "bg-BG" : "en-GB").includes("и.д.");
                    const search = [
                      field(term, "actor", lang),
                      period,
                      term.year_start,
                      term.year_end ?? currentYear,
                      field(term, "summary", lang)
                    ].join(" ").toLocaleLowerCase(lang === "bg" ? "bg-BG" : "en-GB");
                    return (
                      <article
                        class="card mayor-card"
                        id={term.id}
                        data-mayor-card
                        data-search={search}
                        data-century={century}
                        data-status={isCurrent ? "current" : isActing ? "acting" : "regular"}
                      >
                        <header class="mayor-card-head">
                          {term.image ? (
                            <img
                              class="mayor-portrait"
                              src={term.image}
                              alt={t.mayors.portraitAlt(field(term, "actor", lang))}
                              width="52"
                              height="52"
                              loading="lazy"
                            />
                          ) : (
                            <span class="mayor-portrait mayor-portrait-fallback" aria-hidden="true">
                              {initials(field(term, "actor", lang))}
                            </span>
                          )}
                          <div class="mayor-card-headtext">
                            <p class="eyebrow">{t.mayors.termNumber} {index}</p>
                            <h3>{field(term, "actor", lang)}</h3>
                          </div>
                          <div class="pill-row">
                            {isCurrent && <span class="badge status-active">{t.mayors.currentBadge}</span>}
                            {isActing && <span class="badge no-dot">{t.mayors.actingBadge}</span>}
                            {term.fate === "killed" && <span class="badge badge-killed">{t.mayors.fateLabels.killed}</span>}
                            {term.bio_bg && <span class="badge no-dot">{t.mayors.biography}</span>}
                          </div>
                        </header>
                        <div class="mayor-facts">
                          <div>
                            <span>{t.mayors.years}</span>
                            <strong>{term.year_start}{term.year_end ? `-${term.year_end}` : `-${currentYear}`}</strong>
                          </div>
                          <div>
                            <span>{t.mayors.duration}</span>
                            <strong>{t.mayors.yearsApprox(durationYears(term.year_start, term.year_end))}</strong>
                          </div>
                          <div>
                            <span>{t.mayors.century}</span>
                            <strong>{t.mayors.centuryLabel(centuryFor(term.year_start))}</strong>
                          </div>
                        </div>
                        <p><strong>{period}</strong></p>
                        <p>{field(term, "summary", lang)}</p>
                        <div class="pill-row">
                          <a class="button secondary" href={localizePath(`/mayors/${term.id}`, lang)}>
                            {t.mayors.profile}<span class="arrow" aria-hidden="true">→</span>
                          </a>
                          <a href={term.source_document.url} target="_blank" rel="noreferrer">
                            {t.mayors.openSource}: {sourceTitle(term.source_document.title, lang)}
                          </a>
                        </div>
                      </article>
                    );
                  })}
              </div>
            </section>
          ))}
          <p id="mayor-empty" class="empty" hidden>{t.mayors.empty}</p>
        </div>
      </div>
    </div>
  </section>

  <script type="application/json" id="mayor-config" set:html={JSON.stringify(config)}></script>
  <script>
    const config = JSON.parse(document.getElementById("mayor-config")?.textContent ?? "{}");
    const search = document.querySelector<HTMLInputElement>("#mayor-search")!;
    const century = document.querySelector<HTMLSelectElement>("#mayor-century")!;
    const status = document.querySelector<HTMLSelectElement>("#mayor-status")!;
    const reset = document.querySelector<HTMLButtonElement>("#mayor-reset")!;
    const count = document.querySelector<HTMLElement>("#mayor-count")!;
    const empty = document.querySelector<HTMLElement>("#mayor-empty")!;

    function applyFilters() {
      const query = search.value.trim().toLocaleLowerCase();
      const cards = Array.from(document.querySelectorAll<HTMLElement>("[data-mayor-card]"));
      const chips = Array.from(document.querySelectorAll<HTMLElement>("[data-mayor-chip]"));
      let visible = 0;

      const matches = (item: HTMLElement) =>
        (!query || (item.dataset.search ?? "").includes(query)) &&
        (century.value === "all" || item.dataset.century === century.value) &&
        (status.value === "all" || item.dataset.status === status.value);

      cards.forEach((card) => {
        const show = matches(card);
        card.hidden = !show;
        if (show) visible += 1;
      });
      chips.forEach((chip) => {
        chip.hidden = !matches(chip);
      });
      document.querySelectorAll<HTMLElement>(".mayor-century").forEach((section) => {
        const visibleCards = section.querySelectorAll<HTMLElement>("[data-mayor-card]:not([hidden])").length;
        section.hidden = visibleCards === 0;
      });

      const filtering = Boolean(query) || century.value !== "all" || status.value !== "all";
      count.textContent = filtering
        ? config.countFiltered.replace("{visible}", String(visible))
        : config.countAll;
      reset.hidden = !filtering;
      empty.hidden = visible > 0;
    }

    function resetFilters() {
      search.value = "";
      century.value = "all";
      status.value = "all";
      applyFilters();
      search.focus();
    }

    search.addEventListener("input", applyFilters);
    century.addEventListener("change", applyFilters);
    status.addEventListener("change", applyFilters);
    reset.addEventListener("click", resetFilters);
  </script>

  <script type="application/json" id="mayor-birth-config" set:html={JSON.stringify(birthConfig)}></script>
  <script>
    import L from "leaflet";
    import "leaflet/dist/leaflet.css";

    const cfg = JSON.parse(document.getElementById("mayor-birth-config")?.textContent ?? "{}");
    const el = document.getElementById("mayor-birth-map");
    const markers = (cfg.markers ?? []) as Array<{
      lat: number;
      lng: number;
      name: string;
      country: string;
      people: string[];
    }>;

    function esc(value: string): string {
      return String(value)
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;");
    }

    if (el && markers.length) {
      const map = L.map(el, { scrollWheelZoom: false }).setView([42.4, 24.4], 7);
      L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
        maxZoom: 19,
        attribution: "&copy; OpenStreetMap contributors"
      }).addTo(map);

      const maxCount = Math.max(1, ...markers.map((m) => m.people.length));
      const points: [number, number][] = [];
      for (const m of markers) {
        const radius = 7 + (m.people.length / maxCount) * 15;
        const names = m.people.map((n) => `<li>${esc(n)}</li>`).join("");
        L.circleMarker([m.lat, m.lng], {
          radius,
          color: "#b4632a",
          weight: 2,
          fillColor: "#b4632a",
          fillOpacity: 0.45
        })
          .addTo(map)
          .bindPopup(
            `<strong>${esc(m.name)}</strong>${m.country ? ` · ${esc(m.country)}` : ""}` +
              `<br><span class="meta">${esc(cfg.mayorsLabel)} (${m.people.length})</span>` +
              `<ul style="margin:6px 0 0;padding-left:18px">${names}</ul>`
          );
        points.push([m.lat, m.lng]);
      }
      if (points.length > 1) map.fitBounds(points, { padding: [32, 32] });
    }
  </script>
</Layout>
