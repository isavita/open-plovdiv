const l = copy[lang];
const sectionNav = [
  { id: "who-governed", label: l.navWho },
  { id: "archive-changes", label: l.navArchive },
  { id: "money-projects", label: l.navMoney },
  { id: "go-deeper", label: l.navRoutes }
];

const mayorTerms = cityArchive
  .filter((record) => record.kind === "mayor_term")
  .sort((a, b) => a.year_start - b.year_start || (a.year_end ?? currentYear) - (b.year_end ?? currentYear));
const currentMayor = mayorTerms.find((record) => record.year_end == null) ?? mayorTerms[mayorTerms.length - 1];
const earlyMayors = mayorTerms.slice(0, 5);
const recentMayors = [...mayorTerms]
  .filter((record) => record.id !== currentMayor?.id)
  .sort((a, b) => b.year_start - a.year_start || (b.year_end ?? currentYear) - (a.year_end ?? currentYear))
  .slice(0, 6);

function normalizeMayorName(record: CityArchiveRecord): string {
  return field(record, "actor", lang)
    .replace(/^(д-р|Д-р|инж\.|Mayor:)\s*/u, "")
    .trim()
    .toLocaleLowerCase(locale);
}

const uniqueMayorCount = new Set(mayorTerms.map((record) => normalizeMayorName(record))).size;
const nonMayorArchive = cityArchive
  .filter((record) => record.kind !== "mayor_term")
  .sort((a, b) => a.year_start - b.year_start || (a.year_end ?? a.year_start) - (b.year_end ?? b.year_start));
const governanceChanges = nonMayorArchive.filter((record) => record.kind === "governance_change");
const programmeAndFinance = nonMayorArchive.filter((record) => record.kind !== "governance_change");

function pickEvenly<T>(items: T[], max: number): T[] {
  if (items.length <= max) return items;
  const selected: T[] = [];
  const used = new Set<number>();
  for (let i = 0; i < max; i += 1) {
    const index = Math.round((i * (items.length - 1)) / Math.max(1, max - 1));
    if (!used.has(index)) {
      selected.push(items[index]);
      used.add(index);
    }
  }
  return selected;
}

const archiveHighlights = [...governanceChanges, ...pickEvenly(programmeAndFinance, 8)].sort(
  (a, b) => a.year_start - b.year_start || (a.year_end ?? a.year_start) - (b.year_end ?? b.year_start)
);

const latestTotalBudget = [...budgetItems]
  .filter(
    (item) =>
      item.kind === "summary" &&
      item.summary_key === "total_budget" &&
      item.amount_bgn != null
  )
  .sort((a, b) => b.year - a.year)[0];
const latestCapitalBudget = [...budgetItems]
  .filter(
    (item) =>
      item.kind === "summary" &&
      item.summary_key === "capital_programme" &&
      item.amount_bgn != null
  )
  .sort((a, b) => b.year - a.year)[0];
const latestFundingYear = Math.max(
  ...budgetItems
    .filter((item) => item.kind === "funding_source" && item.amount_eur != null)
    .map((item) => item.year),
  0
);
const latestFundingLines = budgetItems.filter(
  (item) => item.year === latestFundingYear && item.kind === "funding_source" && item.amount_eur != null
);
const latestFundingTotal = latestFundingLines.reduce((sum, item) => sum + (item.amount_eur ?? 0), 0);

const budgetPanels = [
  latestTotalBudget && {
    label: l.latestTotal,
    value: formatMoney(latestTotalBudget.amount_bgn ?? 0, lang, "BGN"),
    meta: `${latestTotalBudget.year} · ${field(latestTotalBudget, "title", lang)}`,
    source: latestTotalBudget.source_document
  },
  latestCapitalBudget && {
    label: l.latestCapital,
    value: formatMoney(latestCapitalBudget.amount_bgn ?? 0, lang, "BGN"),
    meta: `${latestCapitalBudget.year} · ${field(latestCapitalBudget, "title", lang)}`,
    source: latestCapitalBudget.source_document
  },
  latestFundingLines.length > 0 && {
    label: l.fundingLines,
    value: formatMoney(latestFundingTotal, lang, "EUR"),
    meta: `${latestFundingYear} · ${latestFundingLines.map((item) => field(item, "title", lang)).join(" · ")}`,
    source: latestFundingLines[0].source_document
  }
].filter(Boolean) as Array<{
  label: string;
  value: string;
  meta: string;
  source: BudgetItem["source_document"];
}>;

const statusRank: Record<string, number> = {
  in_progress: 0,
  contracted: 1,
  funded: 2,
  planned: 3,
  postponed: 4
};
const currentProjects = [...projects]
  .filter((project) => ["in_progress", "contracted", "funded"].includes(project.status))
  .sort(
    (a, b) =>
      b.budget.year - a.budget.year ||
      (statusRank[a.status] ?? 99) - (statusRank[b.status] ?? 99) ||
      field(a, "title", lang).localeCompare(field(b, "title", lang), locale)
  )
  .slice(0, 6);

function termEnd(term: CityArchiveRecord): number {
  return term.year_end ?? currentYear;
}

function overlapsTerm(record: CityArchiveRecord, term: CityArchiveRecord): boolean {
  const recordEnd = record.year_end ?? record.year_start;
  return record.year_start <= termEnd(term) && recordEnd >= term.year_start;
}

function linkedArchiveForTerm(term: CityArchiveRecord): CityArchiveRecord[] {
  return archiveHighlights.filter((record) => overlapsTerm(record, term)).slice(0, 3);
}

function mayorOverlapLabel(record: CityArchiveRecord): string {
  const recordEnd = record.year_end ?? record.year_start;
  const overlaps = mayorTerms.filter(
    (term) => term.year_start <= recordEnd && termEnd(term) >= record.year_start
  );
  if (!overlaps.length) return "";
  const names = overlaps.slice(0, 2).map((term) => field(term, "actor", lang));
  return `${names.join(" · ")}${overlaps.length > 2 ? ` +${overlaps.length - 2}` : ""}`;
}

function amountForArchive(record: CityArchiveRecord): string | null {
  if (record.amount_bgn != null) return formatMoney(record.amount_bgn, lang, "BGN");
  if (record.amount_eur != null) return formatMoney(record.amount_eur, lang, "EUR");
  return null;
}

function amountForProject(project: Project): string {
  if (project.budget.amount_eur != null) return formatMoney(project.budget.amount_eur, lang, "EUR");
  if (project.budget.amount_bgn != null) return formatMoney(project.budget.amount_bgn, lang, "BGN");
  return l.noAmount;
}

function sourceLabel(source: { title: string } | null | undefined): string {
  return source ? sourceTitle(source.title, lang) : l.source;
}

const mayorGroups = [
  { title: l.currentGroup, terms: currentMayor ? [currentMayor] : [] },
  { title: l.earlyGroup, terms: earlyMayors },
  { title: l.recentGroup, terms: recentMayors }
];

const ctas = [
  { href: "/mayors", title: l.ctaMayors, text: l.ctaMayorsText },
  { href: "/budget", title: l.ctaBudget, text: l.ctaBudgetText },
  { href: "/projects", title: l.ctaProjects, text: l.ctaProjectsText },
  { href: "/archive", title: l.ctaArchive, text: l.ctaArchiveText }
];
---

<Layout lang={lang} path="/governance" title={l.title} description={l.description}>
  <section class="page-head governance-hero">
    <div class="container governance-hero-grid">
      <div class="governance-intro">
        <p class="eyebrow">{l.eyebrow}</p>
        <h1>{l.title}</h1>
        <p class="lead">{l.lead}</p>
        <div class="hero-actions">
          <a class="button" href={localizePath("/mayors", lang)}>{l.ctaMayors}<span class="arrow">→</span></a>
          <a class="button secondary" href={localizePath("/archive", lang)}>{l.ctaArchive}<span class="arrow">→</span></a>
        </div>
      </div>
      {currentMayor && (
        <aside class="current-panel" aria-label={l.currentTitle}>
          {currentMayor.image && (
            <img src={currentMayor.image} alt={field(currentMayor, "actor", lang)} loading="eager" />
          )}
          <div>
            <p class="eyebrow">{l.currentTitle}</p>
            <h2>{field(currentMayor, "actor", lang)}</h2>
            <p class="meta">{field(currentMayor, "period", lang)}</p>
            <p>{field(currentMayor, "summary", lang)}</p>
            <a href={localizePath(`/mayors/${currentMayor.id}`, lang)}>{l.detail} →</a>
          </div>
        </aside>
      )}
    </div>
  </section>

  <SectionNav items={sectionNav} label={l.sectionNavLabel} />

  <section class="section" style="padding-top:0">
    <div class="container">
      <div class="stat-row governance-stats">
        <div class="stat" data-cat="people" style="--cat:var(--data-people)">
          <strong>{formatPlainNumber(mayorTerms.length, lang)}</strong>
          <span>{l.statTerms}</span>
        </div>
        <div class="stat" data-cat="people" style="--cat:var(--data-people)">
          <strong>{formatPlainNumber(uniqueMayorCount, lang)}</strong>
          <span>{l.statMayors}</span>
        </div>
        <div class="stat" data-cat="events" style="--cat:var(--data-events)">
          <strong>{formatPlainNumber(nonMayorArchive.length, lang)}</strong>
          <span>{l.statArchive}</span>
        </div>
        <div class="stat" data-cat="sources" style="--cat:var(--data-sources)">
          <strong>{formatPlainNumber(sourceRegistry.length, lang)}</strong>
          <span>{l.statSources}</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="who-governed" data-subnav-target>
    <div class="container">
      <div class="section-head">
        <div>
          <h2>{l.whoTitle}</h2>
          <p class="meta">{l.whoLead}</p>
        </div>
      </div>

      <div class="mayor-board">
        {mayorGroups.map((group) => (
          <section class="mayor-column" aria-label={group.title}>
            <h3>{group.title}</h3>
            <div class="term-list">
              {group.terms.map((term) => {
                const linked = linkedArchiveForTerm(term);
                return (
                  <article class="term-card">
                    <header>
                      <p class="eyebrow">{l.officeTerm}</p>
                      <h4><a href={localizePath(`/mayors/${term.id}`, lang)}>{field(term, "actor", lang)}</a></h4>
                      <p class="meta">{field(term, "period", lang)}</p>
                    </header>
                    <p>{field(term, "summary", lang)}</p>
                    <div class="term-evidence">
                      <p class="eyebrow">{l.linkedArchive}</p>
                      {linked.length > 0 ? (
                        <ul>
                          {linked.map((record) => (
                            <li>
                              <span>{record.year_start}</span>
                              <strong>{field(record, "title", lang)}</strong>
                            </li>
                          ))}
                        </ul>
                      ) : (
                        <p class="meta">{l.noLinkedArchive}</p>
                      )}
                    </div>
                    <div class="pill-row">
                      <a class="meta" href={term.source_document.url} target="_blank" rel="noreferrer">
                        {sourceLabel(term.source_document)}
                      </a>
                      <a class="meta" href={localizePath(`/mayors/${term.id}`, lang)}>{l.detail}</a>
                    </div>
                  </article>
                );
              })}
            </div>
          </section>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-tint" id="archive-changes" data-subnav-target>
    <div class="container">
      <div class="section-head">
        <div>
          <h2>{l.archiveTitle}</h2>
          <p class="meta">{l.archiveLead}</p>
        </div>
        <a href={localizePath("/archive", lang)}>{l.ctaArchive} →</a>
      </div>

      <div class="archive-spine">
        {archiveHighlights.map((record) => {
          const amount = amountForArchive(record);
          const overlap = mayorOverlapLabel(record);
          return (
            <article class="archive-node">
              <div class="node-year">
                <strong>{record.year_start}</strong>
                {record.year_end && record.year_end !== record.year_start && <span>{record.year_end}</span>}
              </div>
              <div class="node-body">
                <p class="eyebrow">{kindLabels[lang][record.kind]}</p>
                <h3>{field(record, "title", lang)}</h3>
                <p>{field(record, "summary", lang)}</p>
                <div class="pill-row">
                  {overlap && <span class="badge no-dot">{l.mayorOverlap}: {overlap}</span>}
                  {amount && <span class="badge no-dot">{l.amountLabel}: {amount}</span>}
                  <a class="meta" href={record.source_document.url} target="_blank" rel="noreferrer">
                    {sourceLabel(record.source_document)}
                  </a>
                </div>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <section class="section" id="money-projects" data-subnav-target>
    <div class="container">
      <div class="section-head">
        <div>
          <h2>{l.budgetTitle}</h2>
          <p class="meta">{l.budgetLead}</p>
        </div>
        <a href={localizePath("/budget", lang)}>{l.ctaBudget} →</a>
      </div>

      <div class="budget-panels">
        {budgetPanels.map((panel) => (
          <article class="budget-panel">
            <p class="eyebrow">{panel.label}</p>
            <strong>{panel.value}</strong>
            <p>{panel.meta}</p>
            <a class="meta" href={panel.source.url} target="_blank" rel="noreferrer">
              {sourceLabel(panel.source)}
            </a>
          </article>
        ))}
      </div>

      <div class="section-head compact" style="margin-top:34px">
        <div>
          <h2>{l.projectsTitle}</h2>
          <p class="meta">{l.projectLead}</p>
        </div>
        <a href={localizePath("/projects", lang)}>{l.ctaProjects} →</a>
      </div>

      <div class="grid grid-3 governance-projects">
        {currentProjects.map((project) => (
          <article class="card project-card">
            <header>
              <div>
                <p class="eyebrow">{l.projectYear} {project.budget.year}</p>
                <h3><a href={localizePath(`/projects/${project.id}`, lang)}>{field(project, "title", lang)}</a></h3>
                <p class="meta">{categoryLabel(project.category, lang)}</p>
              </div>
              <span class="badge no-dot">{projectStatusLabel(project.status, lang)}</span>
            </header>
            <p>{field(project, "summary", lang)}</p>
            <div class="pill-row">
              <span class="money">{amountForProject(project)}</span>
              <a class="meta" href={localizePath(`/projects/${project.id}`, lang)}>{l.detail}</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-tint" id="go-deeper" data-subnav-target>
    <div class="container">
      <div class="section-head">
        <div>
          <h2>{l.deepTitle}</h2>
          <p class="meta">{l.deepLead}</p>
        </div>
      </div>
      <div class="cta-grid">
        {ctas.map((cta) => (
          <a class="governance-cta" href={localizePath(cta.href, lang)}>
            <span>{cta.title}</span>
            <strong>{cta.text}</strong>
            <em>{l.open} →</em>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

