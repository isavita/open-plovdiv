---
import Layout from "@layouts/Layout.astro";
import {
  categoryActionTrack,
  categoryColors,
  categoryHelpGroups,
  categoryLabels,
  fixStatusDescriptions,
  fixStatusLabels,
  ui,
  type Lang
} from "@i18n/ui";
import { field, localeForLang, localizePath } from "@i18n/utils";
import { communityInitiatives } from "@lib/data";
import { FIX_CATEGORIES } from "@lib/server/moderation";
import { categoryLabel, fixStatusLabel } from "@lib/format";

type Props = { lang: Lang };
const { lang } = Astro.props;
const t = ui[lang];

const fixCategories = [...FIX_CATEGORIES];
const fixStatuses = Object.keys(fixStatusLabels[lang]);

// Civic-action model: which categories need official action vs civic help.
const officialCats = fixCategories.filter((c) => categoryActionTrack[c] !== "civic");
const civicCats = fixCategories.filter((c) => categoryActionTrack[c] !== "municipal");
const helpGroups = communityInitiatives.map((g) => ({
  title: field(g, "title", lang),
  category: g.category,
  url:
    g.organizer?.website_url ??
    g.organizer?.facebook_url ??
    g.contact_links?.[0]?.url ??
    localizePath("/community", lang)
}));

const config = {
  lang,
  locale: localeForLang(lang),
  projectBase: localizePath("/projects", lang),
  publicUrl: "/api/reports/public",
  streamUrl: "/api/reports/stream",
  fallbackUrl: "/data/community-fix-reports.json",
  categoryLabels: categoryLabels[lang],
  categoryColors,
  statusLabels: fixStatusLabels[lang],
  statusDescriptions: fixStatusDescriptions[lang],
  track: categoryActionTrack,
  helpGroupsMap: categoryHelpGroups,
  groups: helpGroups,
  officialUrl: "https://www.plovdiv.bg/",
  reportHref: localizePath("/fix-map/report", lang),
  communityHref: localizePath("/community", lang),
  civic: {
    whatYouCanDo: t.civic.whatYouCanDo,
    reportOfficial: t.civic.actReportOfficial,
    joinGroup: t.civic.actJoinGroup,
    addReport: t.civic.actAddReport,
    document: t.civic.actDocument,
    follow: t.civic.actFollow,
    groupsTitle: t.civic.groupsTitle,
    noGroups: t.civic.noGroups,
    trackOfficial: t.civic.trackOfficial,
    trackCivic: t.civic.trackCivic,
    trackBoth: t.civic.trackBoth
  },
  labels: {
    statusLabel: t.fixMap.statusLabel,
    nearby: t.fixMap.nearbyProjects,
    noNearby: t.fixMap.noNearbyRadius,
    community: t.fixMap.communityBadge,
    emptyTitle: t.fixMap.emptyTitle,
    emptyText: t.fixMap.emptyText,
    noFilterResults: t.fixMap.noFilterResults,
    updated: t.fixMap.lastUpdated,
    justNow: t.fixMap.justNow,
    of: lang === "bg" ? "от" : lang === "de" ? "von" : lang === "fr" ? "sur" : lang === "it" ? "di" : lang === "tr" ? "/" : lang === "es" ? "de" : "of",
    km: lang === "bg" ? "км" : "km",
    errorTitle: t.fixMap.loadErrorTitle,
    errorText: t.fixMap.loadErrorText,
    newReports: t.fixMap.newReports,
    selectTitle: t.fixMap.selectTitle,
    selectHint: t.fixMap.selectHint
  }
};
---

<Layout lang={lang} path="/fix-map" title={t.fixMap.title} description={t.fixMap.lead}>
  <section class="page-head">
    <div class="container">
      <p class="eyebrow">{t.fixMap.eyebrow}</p>
      <h1>{t.fixMap.title}</h1>
      <p class="lead">{t.fixMap.lead}</p>
      <div class="actions">
        <a class="button" href={localizePath("/fix-map/report", lang)}>
          {t.fixMap.reportCta}<span class="arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <section class="section" style="padding-top:0">
    <div class="container">
      <div class="notice">
        <span class="notice-icon" aria-hidden="true">ⓘ</span>
        <span>{t.fixMap.notice}</span>
      </div>

      <div class="toolbar">
        <div class="filters">
          <div class="field">
            <label for="category-filter">{t.fixMap.category}</label>
            <select id="category-filter">
              <option value="all">{t.fixMap.allCategories}</option>
              {fixCategories.map((c) => <option value={c}>{categoryLabel(c, lang)}</option>)}
            </select>
          </div>
          <div class="field">
            <label for="status-filter">{t.fixMap.status}</label>
            <select id="status-filter">
              <option value="all">{t.fixMap.allStatuses}</option>
              {fixStatuses.map((s) => <option value={s}>{fixStatusLabel(s, lang)}</option>)}
            </select>
          </div>
          <div class="field">
            <label for="radius-filter">{t.fixMap.radius}</label>
            <select id="radius-filter">
              <option value="0.5">{t.fixMap.radius500}</option>
              <option value="1" selected>{t.fixMap.radius1}</option>
              <option value="2">{t.fixMap.radius2}</option>
            </select>
          </div>
          <div class="field">
            <label for="visible-count">{t.fixMap.visible}</label>
            <input id="visible-count" type="text" readonly value={t.common.loading} />
          </div>
        </div>
      </div>

      <div class="results-bar">
        <span class="meta">{t.fixMap.liveNote}</span>
        <span class="meta" id="map-live-indicator" aria-live="polite"></span>
        <a class="meta" href="/data/community-fix-reports.json" download>{t.fixMap.downloadCommunityData}</a>
        <span class="meta" id="map-updated"></span>
      </div>

      <div class="map-layout">
        <div id="fix-map-canvas" class="map-canvas" aria-label={t.fixMap.title}></div>
        <aside id="report-detail" class="detail-panel" aria-live="polite">
          <h2>{t.fixMap.selectTitle}</h2>
          <p class="meta">{t.fixMap.selectHint}</p>
        </aside>
      </div>

      <h3 style="margin-top:22px">{t.fixMap.legend}</h3>
      <div class="legend">
        {fixCategories.map((c) => (
          <span class="legend-item">
            <span class="cat-dot" style={`--dot:${categoryColors[c]}`}></span>
            {categoryLabel(c, lang)}
          </span>
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="how-to-help" style="scroll-margin-top:84px">
    <div class="container">
      <div class="section-head"><h2>{t.civic.title}</h2></div>
      <p class="lead" style="font-size:1.02rem;max-width:72ch">{t.civic.lead}</p>
      <div class="grid grid-2" style="margin-top:20px">
        <article class="card">
          <span class="badge no-dot" style="background:var(--badge-info-bg);color:var(--badge-info-fg)">{t.civic.trackOfficial}</span>
          <p class="meta" style="margin-top:10px">{t.civic.trackOfficialText}</p>
          <div class="legend" style="margin-top:12px">
            {officialCats.map((c) => (
              <span class="legend-item"><span class="cat-dot" style={`--dot:${categoryColors[c]}`}></span>{categoryLabel(c, lang)}</span>
            ))}
          </div>
          <h4 style="margin-top:16px">{t.civic.whatYouCanDo}</h4>
          <ul class="source-list">
            <li><a href="https://www.plovdiv.bg/" target="_blank" rel="noreferrer">{t.civic.actReportOfficial}</a></li>
            <li><a href={localizePath("/fix-map/report", lang)}>{t.civic.actAddReport}</a></li>
            <li>{t.civic.actDocument}</li>
            <li>{t.civic.actFollow}</li>
          </ul>
        </article>
        <article class="card">
          <span class="badge no-dot" style="background:var(--badge-ok-bg);color:var(--badge-ok-fg)">{t.civic.trackCivic}</span>
          <p class="meta" style="margin-top:10px">{t.civic.trackCivicText}</p>
          <div class="legend" style="margin-top:12px">
            {civicCats.map((c) => (
              <span class="legend-item"><span class="cat-dot" style={`--dot:${categoryColors[c]}`}></span>{categoryLabel(c, lang)}</span>
            ))}
          </div>
          <h4 style="margin-top:16px">{t.civic.whatYouCanDo}</h4>
          <ul class="source-list">
            <li><a href={localizePath("/community", lang)}>{t.civic.actJoinGroup}</a></li>
            <li><a href={localizePath("/fix-map/report", lang)}>{t.civic.actAddReport}</a></li>
            <li>{t.civic.actDocument}</li>
            <li>{t.civic.actFollow}</li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-tint">
    <div class="container grid grid-2">
      <article>
        <div class="section-head"><h2>{t.fixMap.statusesTitle}</h2></div>
        <div class="list">
          {Object.entries(fixStatusDescriptions[lang]).map(([status, description]) => (
            <div class="card">
              <span class={`badge status-${status}`}>{fixStatusLabel(status, lang)}</span>
              <p class="meta" style="margin-top:8px">{description}</p>
            </div>
          ))}
        </div>
      </article>
      <article>
        <div class="section-head"><h2>{t.fixMap.officialTitle}</h2></div>
        <div class="card">
          <p>{t.fixMap.officialText}</p>
          <a class="button secondary" style="margin-top:8px" href="https://www.plovdiv.bg/" target="_blank" rel="noreferrer">
            {t.fixMap.officialLink}<span class="arrow" aria-hidden="true">↗</span>
          </a>
        </div>
      </article>
    </div>
  </section>

  <script type="application/json" id="fixmap-config" set:html={JSON.stringify(config)}></script>

  <script>
    import L from "leaflet";
    import "leaflet/dist/leaflet.css";

    const config = JSON.parse(
      document.getElementById("fixmap-config")?.textContent ?? "{}"
    );
    const LB = config.labels;

    function escapeHtml(value: unknown): string {
      return String(value)
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
    }

    function loc(record: any, base: string): string {
      return record[`${base}_${config.lang}`] ?? record[`${base}_en`] ?? record[`${base}_bg`] ?? record[base] ?? "";
    }

    const catLabel = (c: string) => config.categoryLabels[c] ?? c;
    const catColor = (c: string) => config.categoryColors[c] ?? "#6b7280";
    const statusLabel = (s: string) => config.statusLabels[s] ?? s;
    const statusDesc = (s: string) => config.statusDescriptions[s] ?? "";

    // Civic-action block: classifies the problem (official / civic / shared),
    // lists concrete next actions, and links volunteer groups that can help.
    function actionBlock(report: any): string {
      const C = config.civic ?? {};
      const track = config.track?.[report.category] ?? "civic";
      const trackLabel =
        track === "municipal" ? C.trackOfficial : track === "civic" ? C.trackCivic : C.trackBoth;
      const trackBg =
        track === "civic" ? "var(--badge-ok-bg)" : track === "municipal" ? "var(--badge-info-bg)" : "var(--badge-sample-bg)";
      const trackFg =
        track === "civic" ? "var(--badge-ok-fg)" : track === "municipal" ? "var(--badge-info-fg)" : "var(--badge-sample-fg)";

      const items: string[] = [];
      if (track !== "civic") {
        items.push(`<li><a href="${escapeHtml(config.officialUrl)}" target="_blank" rel="noreferrer">${escapeHtml(C.reportOfficial)}</a></li>`);
      }
      if (track !== "municipal") {
        items.push(`<li><a href="${escapeHtml(config.communityHref)}">${escapeHtml(C.joinGroup)}</a></li>`);
      }
      items.push(`<li><a href="${escapeHtml(config.reportHref)}">${escapeHtml(C.addReport)}</a></li>`);
      items.push(`<li>${escapeHtml(C.document)}</li>`);
      items.push(`<li>${escapeHtml(C.follow)}</li>`);

      const cats = config.helpGroupsMap?.[report.category] ?? ["civic"];
      const groups = (config.groups ?? []).filter((g: any) => cats.includes(g.category)).slice(0, 3);
      const groupsHtml = groups.length
        ? `<h3>${escapeHtml(C.groupsTitle)}</h3><ul class="source-list">${groups
            .map(
              (g: any) =>
                `<li><a href="${escapeHtml(g.url)}" target="_blank" rel="noreferrer">${escapeHtml(g.title)}</a></li>`
            )
            .join("")}</ul>`
        : track !== "municipal"
          ? `<p class="meta">${escapeHtml(C.noGroups)}</p>`
          : "";

      return `
        <p style="margin-top:14px"><span class="badge no-dot" style="background:${trackBg};color:${trackFg}">${escapeHtml(trackLabel)}</span></p>
        <h3>${escapeHtml(C.whatYouCanDo)}</h3>
        <ul class="source-list">${items.join("")}</ul>
        ${groupsHtml}
      `;
    }

    const categoryFilter = document.querySelector<HTMLSelectElement>("#category-filter")!;
    const statusFilter = document.querySelector<HTMLSelectElement>("#status-filter")!;
    const radiusFilter = document.querySelector<HTMLSelectElement>("#radius-filter")!;
    const countField = document.querySelector<HTMLInputElement>("#visible-count")!;
    const detail = document.querySelector<HTMLElement>("#report-detail")!;

    const map = L.map("fix-map-canvas", { scrollWheelZoom: false }).setView([42.141, 24.75], 13);
    L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
      maxZoom: 19,
      attribution: "&copy; OpenStreetMap contributors"
    }).addTo(map);

    const markerLayer = L.layerGroup().addTo(map);
    const updatedEl = document.querySelector<HTMLElement>("#map-updated");
    const liveIndicator = document.querySelector<HTMLElement>("#map-live-indicator");
    let selectedReport: any = null;
    let communityReports: any[] = [];
    let projects: any[] = [];
    const allReports = () => communityReports;

    function distanceKm(a: any, b: any): number {
      const radiusKm = 6371;
      const toRad = (d: number) => (d * Math.PI) / 180;
      const dLat = toRad(b.lat - a.lat);
      const dLng = toRad(b.lng - a.lng);
      const h =
        Math.sin(dLat / 2) ** 2 +
        Math.sin(dLng / 2) ** 2 * Math.cos(toRad(a.lat)) * Math.cos(toRad(b.lat));
      return 2 * radiusKm * Math.atan2(Math.sqrt(h), Math.sqrt(1 - h));
    }

    function markerIcon(report: any) {
      return L.divIcon({
        className: "",
        html: `<span class="marker-pin${report.source === "citizen_submission" ? " community" : ""}" style="--pin:${catColor(report.category)}"></span>`,
        iconSize: [28, 28],
        iconAnchor: [14, 28]
      });
    }

    function visibleReports() {
      const category = categoryFilter.value;
      const status = statusFilter.value;
      return allReports().filter(
        (r) =>
          (category === "all" || r.category === category) &&
          (status === "all" || r.status === status)
      );
    }

    function nearbyProjects(report: any) {
      const radius = Number(radiusFilter.value);
      return projects
        .map((p) => ({ ...p, distance: distanceKm(report.location, p.location) }))
        .filter((p) => p.distance <= radius)
        .sort((a, b) => a.distance - b.distance)
        .slice(0, 5);
    }

    function renderDetail(report: any) {
      selectedReport = report;
      const nearby = nearbyProjects(report);
      const photos = Array.isArray(report.photo_thumbnail_urls)
        ? report.photo_thumbnail_urls
        : [];
      detail.innerHTML = `
        <span class="badge status-${escapeHtml(report.status)}">${escapeHtml(statusLabel(report.status))}</span>
        <h2 style="margin-top:10px">${escapeHtml(loc(report, "title"))}</h2>
        <p>${escapeHtml(loc(report, "description"))}</p>
        <p class="meta"><span class="cat-dot" style="--dot:${catColor(report.category)}"></span> ${escapeHtml(catLabel(report.category))} · ${escapeHtml(loc(report.location, "address"))}</p>
        <p><strong>${escapeHtml(LB.statusLabel)}:</strong> ${escapeHtml(statusDesc(report.status))}</p>
        <p><span class="badge" style="background:var(--accent-soft);color:var(--accent)">${escapeHtml(LB.community)}</span></p>
        ${
          photos.length
            ? `<div class="photo-grid">${photos
                .map(
                  (url: string) =>
                    `<a class="photo-preview" href="${escapeHtml(url)}" target="_blank" rel="noreferrer"><img src="${escapeHtml(url)}" alt="" loading="lazy" /></a>`
                )
                .join("")}</div>`
            : ""
        }
        ${actionBlock(report)}
        <h3>${escapeHtml(LB.nearby)}</h3>
        ${
          nearby.length
            ? `<ul class="source-list">${nearby
                .map(
                  (p) =>
                    `<li><a href="${config.projectBase}/${escapeHtml(p.id)}">${escapeHtml(loc(p, "title"))}</a><span class="meta"> · ${p.distance.toFixed(1)} ${escapeHtml(LB.km)}</span></li>`
                )
                .join("")}</ul>`
            : `<p class="meta">${escapeHtml(LB.noNearby)}</p>`
        }
      `;
    }

    function renderSelectionPrompt() {
      detail.innerHTML = `<h2>${escapeHtml(LB.selectTitle)}</h2><p class="meta">${escapeHtml(LB.selectHint)}</p>`;
    }

    function renderMarkers() {
      markerLayer.clearLayers();
      const visible = visibleReports();
      countField.value = `${visible.length} ${LB.of} ${allReports().length}`;
      if (selectedReport && !visible.some((report) => report.id === selectedReport.id)) {
        selectedReport = null;
      }

      visible.forEach((report) => {
        L.marker([report.location.lat, report.location.lng], {
          icon: markerIcon(report),
          title: loc(report, "title")
        })
          .on("click", () => renderDetail(report))
          .addTo(markerLayer);
      });

      if (selectedReport) renderDetail(selectedReport);
      else if (allReports().length === 0) {
        detail.innerHTML = `<h2>${escapeHtml(LB.emptyTitle)}</h2><p class="meta">${escapeHtml(LB.emptyText)}</p>`;
      } else if (visible.length === 0) {
        detail.innerHTML = `<h2>${escapeHtml(LB.noFilterResults)}</h2><p class="meta">${escapeHtml(LB.emptyText)}</p>`;
      } else {
        renderSelectionPrompt();
      }
    }

    categoryFilter.addEventListener("change", renderMarkers);
    statusFilter.addEventListener("change", renderMarkers);
    radiusFilter.addEventListener("change", () => {
      if (selectedReport) renderDetail(selectedReport);
    });

    function setUpdated(iso?: string) {
      if (!updatedEl) return;
      const when = iso ? new Date(iso) : new Date();
      const time = Number.isNaN(when.getTime())
        ? LB.justNow
        : when.toLocaleTimeString(config.locale, { hour: "2-digit", minute: "2-digit" });
      updatedEl.textContent = `${LB.updated}: ${time}`;
    }

    function setLiveIndicator(previous: number, next: number) {
      if (!liveIndicator) return;
      if (next > previous) {
        liveIndicator.textContent = LB.newReports.replace("{count}", String(next - previous));
      } else {
        liveIndicator.textContent = "";
      }
    }

    // Approved citizen reports come from the live API; if it is unavailable
    // (e.g. on a purely static deploy) fall back to the exported JSON snapshot.
    async function loadCommunity() {
      const previousCount = communityReports.length;
      try {
        const res = await fetch(config.publicUrl, { headers: { Accept: "application/json" } });
        if (!res.ok) throw new Error("api");
        const data = await res.json();
        communityReports = Array.isArray(data.reports) ? data.reports : [];
        setLiveIndicator(previousCount, communityReports.length);
        setUpdated(data.updated_at || undefined);
        return;
      } catch {
        try {
          const res = await fetch(config.fallbackUrl);
          if (res.ok) {
            const data = await res.json();
            communityReports = Array.isArray(data) ? data : data.reports ?? [];
            setLiveIndicator(previousCount, communityReports.length);
          }
        } catch {
          /* no community reports available */
        }
        setUpdated();
      }
    }

    try {
      projects = await fetch("/data/projects.json").then((r) => {
        if (!r.ok) throw new Error("projects failed");
        return r.json();
      });
      await loadCommunity();
      renderMarkers();
      if ("EventSource" in window) {
        try {
          const events = new EventSource(config.streamUrl);
          events.addEventListener("reports", (event: MessageEvent) => {
            const previousCount = communityReports.length;
            const data = JSON.parse(event.data);
            communityReports = Array.isArray(data.reports) ? data.reports : [];
            setLiveIndicator(previousCount, communityReports.length);
            setUpdated(data.updated_at || undefined);
            renderMarkers();
          });
        } catch {
          /* polling remains the reliable fallback */
        }
      }
      // Near-real-time: refresh approved citizen reports every 30 seconds.
      setInterval(async () => {
        await loadCommunity();
        renderMarkers();
      }, 30000);
    } catch {
      countField.value = config.lang === "bg" ? "Грешка" : config.lang === "de" ? "Fehler" : config.lang === "fr" ? "Erreur" : config.lang === "it" ? "Errore" : config.lang === "tr" ? "Hata" : config.lang === "es" ? "Error" : "Error";
      detail.innerHTML = `<h2>${escapeHtml(LB.errorTitle)}</h2><p class="error">${escapeHtml(LB.errorText)}</p>`;
    }
  </script>
</Layout>
