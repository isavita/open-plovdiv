function matchQualityLabel(value: string): string {
  return matchQualityLabels[value] ?? value.replaceAll("_", " ");
}

function placeFacts(item: KnowledgePlace) {
  const hasNamedCreator = Boolean(localized(item, "architect") || localized(item, "builder"));
  return [
    localized(item.date_context, "display") ? { label: labels.built, value: localized(item.date_context, "display") } : null,
    localized(item, "architect") ? { label: labels.architect, value: localized(item, "architect") } : null,
    localized(item, "builder") ? { label: labels.builder, value: localized(item, "builder") } : null,
    !hasNamedCreator && localized(item.creator_context, "display")
      ? { label: labels.creator, value: localized(item.creator_context, "display") }
      : null
  ].filter(Boolean) as Array<{ label: string; value: string }>;
}

const listFormatter = new Intl.ListFormat(locale, { style: "long", type: "conjunction" });
function formatList(items: string[], max = 4): string {
  const clean = [...new Set(items.filter(Boolean))];
  if (clean.length <= max) return listFormatter.format(clean);
  return `${listFormatter.format(clean.slice(0, max))} +${clean.length - max}`;
}

function localizedText(values: Partial<Record<Lang, string>> | undefined): string {
  if (!values) return "";
  return values[lang] ?? values.en ?? values.bg ?? Object.values(values).find(Boolean) ?? "";
}

function wikidataValueLabel(value: PlaceWikidataClaimValue): string {
  if (value.type === "item") return localizedText(value.labels);
  if (value.type === "text") return value.text;
  if (value.type === "time") {
    if (value.year == null) return value.time;
    return new Intl.NumberFormat(locale, { useGrouping: false }).format(value.year);
  }
  return "";
}

function wikidataClaimLabel(key: keyof typeof wikidataLabels): string {
  return wikidataLabels[key] ?? key.replaceAll("_", " ");
}

function claimRow(key: keyof typeof wikidataLabels, values: PlaceWikidataClaimValue[] | undefined) {
  const text = formatList((values ?? []).map(wikidataValueLabel).filter(Boolean), 5);
  return text ? { label: wikidataClaimLabel(key), value: text } : null;
}

const sourceById = new Map(historyKnowledgeSources.map((source) => [source.id, source]));
const eventById = new Map(historyKnowledgeEvents.map((event) => [event.id, event]));
const peopleById = new Map(historyKnowledgePeople.map((person) => [person.id, person]));
const organizationById = new Map(historyKnowledgeOrganizations.map((organization) => [organization.id, organization]));
const placeById = new Map(historyKnowledgePlaces.map((item) => [item.id, item]));
const archiveItems = historicalArchiveItems
  .filter((item) => item.place_id === place.id)
  .sort((a, b) => a.date_year - b.date_year || a.id.localeCompare(b.id));
const pairs = publicThenNowPairs(thenNowPairs.filter((pair) => pair.place_id === place.id))
  .sort((a, b) => localized(a, "title").localeCompare(localized(b, "title"), locale));
const directEvents = place.event_ids.map((eventId) => eventById.get(eventId)).filter(Boolean);
const reverseLinkedEvents = historyKnowledgeEvents.filter((event) => event.place_ids.includes(place.id));
const relatedEvents = [...new Map([...directEvents, ...reverseLinkedEvents].map((event) => [event!.id, event!])).values()].sort(
  (a, b) => a.date.year - b.date.year || a.id.localeCompare(b.id)
);
const relatedStories = storyLongreads.filter((story) => story.linked_place_ids.includes(place.id));
const facts = placeFacts(place);
const image = place.media[0];
const sourceRecords = place.source_ids.map((sourceId) => sourceById.get(sourceId)).filter(Boolean);
const wikidataRecord = placeWikidataEnrichment[place.id] ?? null;
const wikidataDescription = localizedText(wikidataRecord?.descriptions);
const wikidataArticle = wikidataRecord?.sitelinks[lang] ?? wikidataRecord?.sitelinks.en ?? wikidataRecord?.sitelinks.bg ?? null;
const linkedPeople = place.person_ids.map((personId) => peopleById.get(personId)).filter(Boolean);
const linkedOrganizations = place.organization_ids.map((organizationId) => organizationById.get(organizationId)).filter(Boolean);
const relatedPlaceIds = [
  ...new Set(
    relatedEvents
      .flatMap((event) => event.place_ids)
      .filter((placeId) => placeId !== place.id)
  )
];
const relatedPlaces = relatedPlaceIds.map((placeId) => placeById.get(placeId)).filter(Boolean).slice(0, 8);
const evidenceSourceIds = new Set([
  ...place.source_ids,
  ...relatedEvents.flatMap((event) => event.source_ids),
  ...archiveItems.flatMap((item) => item.source_ids ?? []),
  ...pairs.flatMap((pair) => pair.source_ids ?? [])
]);
const dateSource = place.date_context?.source_id ? sourceById.get(place.date_context.source_id) : null;
const creatorSource = place.creator_context?.source_id ? sourceById.get(place.creator_context.source_id) : null;
const creatorFact = facts.find((fact) => fact.label === labels.architect || fact.label === labels.builder);
const creatorDetail = creatorFact?.value ?? localized(place.creator_context, "display");
// Curated, sourced narrative (authored bg+en; other languages resolved at runtime
// by field() via the translation cache). Replaces the old templated boilerplate.
const placeHistory = place.history ?? null;
const historyLede = placeHistory ? field(placeHistory, "lede", lang) : "";
const historySections = placeHistory?.sections ?? [];
const historyHighlights = placeHistory?.highlights ?? [];
// Honest fallback for places that do not yet have a curated history — the real
// summary plus any distinct public-record description and a couple of linked
// events, with none of the old "not just a point on the map" filler sentences.
const fallbackParagraphs = [
  localized(place, "summary"),
  wikidataDescription && !localized(place, "summary").toLocaleLowerCase(locale).includes(wikidataDescription.toLocaleLowerCase(locale))
    ? wikidataDescription
    : "",
  ...relatedEvents.slice(0, 3).map((event) => `${localized(event.date, "display")}: ${localized(event, "summary")}`),
  ...relatedStories.slice(0, 2).map((story) => `${localized(story, "title")}: ${localized(story, "dek")}`)
].filter(Boolean);
const stewardshipText = linkedOrganizations.length
  ? storyLabels.stewardshipWithOrgs(formatList(linkedOrganizations.map((organization) => localized(organization!, "name"))))
  : storyLabels.noOwnership;
const peopleText = linkedPeople.length
  ? storyLabels.peopleSentence(formatList(linkedPeople.map((person) => localized(person!, "name"))))
  : storyLabels.noPeople;
const relatedPlacesText = relatedPlaces.length
  ? storyLabels.relatedPlacesSentence(formatList(relatedPlaces.map((item) => localized(item!, "name"))))
  : storyLabels.noRelatedPlaces;
const wikidataFactRows = wikidataRecord
  ? [
      claimRow("instance_of", wikidataRecord.claims.instance_of),
      claimRow("heritage_designation", wikidataRecord.claims.heritage_designation),
      claimRow("inception", wikidataRecord.claims.inception),
      claimRow("start_time", wikidataRecord.claims.start_time),
      claimRow("architect", wikidataRecord.claims.architect),
      claimRow("creator", wikidataRecord.claims.creator),
      claimRow("owned_by", wikidataRecord.claims.owned_by),
      claimRow("operator", wikidataRecord.claims.operator),
      claimRow("location", wikidataRecord.claims.location),
      claimRow("street_address", wikidataRecord.claims.street_address)
    ].filter(Boolean)
  : [];
const publicRecordCount = wikidataRecord ? wikidataFactRows.length + (wikidataDescription ? 1 : 0) + (wikidataArticle ? 1 : 0) : 0;
const contextNodes = [
  { key: "events", label: historyAtlasLabels.eventsNode, value: relatedEvents.length, accent: "brand" },
  { key: "stories", label: historyAtlasLabels.storiesNode, value: relatedStories.length, accent: "gold" },
  { key: "people", label: historyAtlasLabels.peopleNode, value: linkedPeople.length, accent: "accent" },
  { key: "organizations", label: historyAtlasLabels.organizationsNode, value: linkedOrganizations.length, accent: "data" },
  { key: "archive", label: historyAtlasLabels.archiveNode, value: archiveItems.length, accent: "archive" },
  { key: "then-now", label: historyAtlasLabels.thenNowNode, value: pairs.length, accent: "then-now" },
  { key: "public-record", label: historyAtlasLabels.publicRecordNode, value: publicRecordCount, accent: "record" },
  { key: "sources", label: historyAtlasLabels.sourcesNode, value: evidenceSourceIds.size, accent: "sources" }
].filter((node) => node.value > 0);
const eventGroups = Object.values(
  relatedEvents.reduce<Record<string, { key: string; label: string; events: typeof relatedEvents }>>((groups, event) => {
    const key = event.category || "historical_event";
    groups[key] ??= { key, label: knownHistoryLabel(key, lang), events: [] };
    groups[key].events.push(event);
    return groups;
  }, {})
).sort((a, b) => b.events.length - a.events.length || a.label.localeCompare(b.label, locale));
const mapHref = place.coordinates
  ? `https://www.openstreetmap.org/?mlat=${place.coordinates.lat}&mlon=${place.coordinates.lng}#map=17/${place.coordinates.lat}/${place.coordinates.lng}`
  : "";
---

<Layout lang={lang} path={`/places/${place.id}`} title={localized(place, "name")} description={localized(place, "summary")}>
  <article class="place-detail">
    <header class="section place-detail-hero">
      <div class="container place-detail-grid">
        <div>
          <a class="text-link" href={localizePath("/places", lang)}>{labels.back}</a>
          <p class="eyebrow">{localized(place, "era")}</p>
          <h1>{localized(place, "name")}</h1>
          <p class="lead">{localized(place, "summary")}</p>
        </div>
        {image && (
          <figure class="place-detail-media">
            <img src={image.url} alt={localized(place, "name")} />
            <figcaption>
              {image.credit} · {image.license}
              <a href={image.page_url} target="_blank" rel="noreferrer">{labels.mediaLicense}</a>
            </figcaption>
          </figure>
        )}
      </div>
    </header>

    <section class="section">
      <div class="container place-detail-layout">
        <div class="place-detail-main">
          <section class="place-panel place-story-panel" data-place-story={place.id}>
            <p class="eyebrow">{storyLabels.storyEyebrow}</p>
            <h2>{storyLabels.storyTitle}</h2>
            {placeHistory ? (
              <div class="place-history">
                {historyLede && <p class="place-history-lede" data-reveal>{historyLede}</p>}
                {historyHighlights.length > 0 && (
                  <dl class="place-history-highlights" data-reveal-stagger>
                    {historyHighlights.map((highlight) => (
                      <div>
                        <dt>{field(highlight, "label", lang)}</dt>
                        <dd>{field(highlight, "value", lang)}</dd>
                      </div>
                    ))}
                  </dl>
                )}
                <div class="place-history-article">
                  {historySections.map((section) => (
                    <section class={`place-history-section is-${section.id}`} data-reveal>
                      <h3>{field(section, "heading", lang)}</h3>
                      {field(section, "body", lang)
                        .split(/\n\n+/)
                        .map((para) => <p>{para}</p>)}
                      {section.source && (
                        <a class="src-link" href={section.source.url} target="_blank" rel="noreferrer">
                          {storyLabels.sourceLabel}: {sourceTitle(section.source.title, lang)} ↗
                        </a>
                      )}
                    </section>
                  ))}
                </div>
              </div>
            ) : (
              <div class="place-story-prose">
                {fallbackParagraphs.map((paragraph) => <p>{paragraph}</p>)}
              </div>
            )}
          </section>

          <section class="place-story-grid" aria-label={storyLabels.storyTitle}>
            <article class="place-story-card">
              <span>{storyLabels.originTitle}</span>
              <h3>{storyLabels.dateLabel}</h3>
              <p>{localized(place.date_context, "display")}</p>
              {dateSource && (
                <a class="src-link" href={dateSource.url} target="_blank" rel="noreferrer">
                  {storyLabels.sourceLabel}: {sourceTitle(localized(dateSource, "title"), lang)} ↗
                </a>
              )}
            </article>
            <article class="place-story-card">
              <span>{storyLabels.creatorLabel}</span>
              <h3>{creatorFact?.label ?? labels.creator}</h3>
              <p>{creatorDetail}</p>
              {creatorSource && (
                <a class="src-link" href={creatorSource.url} target="_blank" rel="noreferrer">
                  {storyLabels.sourceLabel}: {sourceTitle(localized(creatorSource, "title"), lang)} ↗
                </a>
              )}
            </article>
            <article class="place-story-card">
              <span>{storyLabels.useTitle}</span>
              <h3>{storyLabels.statusLabel}</h3>
              <p>{localized(place, "current_status")}</p>
              {mapHref && <a class="src-link" href={mapHref} target="_blank" rel="noreferrer">{labels.openMap} ↗</a>}
            </article>
          </section>

          <section class="place-history-atlas" data-place-history-atlas={place.id}>
            <div class="place-atlas-head">
              <p class="eyebrow">{historyAtlasLabels.eyebrow}</p>
              <h2>{historyAtlasLabels.title}</h2>
              <p>{historyAtlasLabels.lead(relatedEvents.length, relatedStories.length, evidenceSourceIds.size)}</p>
            </div>
            <div class="place-atlas-layout">
              <div class="place-atlas-thread" aria-label={storyLabels.evidenceTitle}>
                <div>
                  <span>{storyLabels.dateLabel}</span>
                  <strong>{localized(place.date_context, "display") || localized(place, "era")}</strong>
                </div>
                <div>
                  <span>{storyLabels.creatorLabel}</span>
                  <strong>{creatorDetail}</strong>
                </div>
                <div>
                  <span>{storyLabels.statusLabel}</span>
                  <strong>{localized(place, "current_status")}</strong>
                </div>
              </div>
              <div class="place-context-web" aria-label={historyAtlasLabels.contextTitle}>
                <div class="place-context-root">
                  <span>{historyAtlasLabels.rootNode}</span>
                  <strong>{localized(place, "name")}</strong>
                </div>
                <div class="place-context-branches">
                  {contextNodes.map((node) => (
                    <div class={`place-context-node is-${node.accent}`}>
                      <span>{node.label}</span>
                      <strong>{node.value}</strong>
                    </div>
                  ))}
                </div>
              </div>
            </div>
            <p class="place-atlas-note">{historyAtlasLabels.contextLead}</p>
          </section>

          {wikidataRecord && (wikidataDescription || wikidataFactRows.length > 0 || wikidataArticle) && (
            <section class="place-panel place-public-record-panel" data-place-wikidata={place.id}>
              <h2>{wikidataLabels.title}</h2>
              {wikidataDescription && <p>{wikidataDescription}</p>}
              {wikidataFactRows.length > 0 && (
                <dl class="place-public-record-list">
                  {wikidataFactRows.map((fact) => (
                    <div>
                      <dt>{fact!.label}</dt>
                      <dd>{fact!.value}</dd>
                    </div>
                  ))}
                </dl>
              )}
              <div class="place-record-links">
                <a class="src-link" href={wikidataRecord.wikidata_url} target="_blank" rel="noreferrer">
                  {wikidataLabels.wikidata} ↗
                </a>
                {wikidataArticle && (
                  <a class="src-link" href={wikidataArticle.url} target="_blank" rel="noreferrer">
                    {wikidataLabels.wikipedia}: {wikidataArticle.title} ↗
                  </a>
                )}
              </div>
            </section>
          )}

          <section class="place-panel place-evidence-panel">
            <h2>{storyLabels.evidenceTitle}</h2>
            <ul class="place-evidence-list">
              {place.provenance.map((item) => (
                <li>
                  <p>{localized(item, "claim")}</p>
                  <a class="src-link" href={sourceById.get(item.source_id)?.url ?? item.url} target="_blank" rel="noreferrer">
                    {storyLabels.sourceLabel}: {sourceTitle(localized(sourceById.get(item.source_id), "title"), lang) || sourceTitle(item.source_id, lang)} ↗
                  </a>
                </li>
              ))}
            </ul>
          </section>

          <section class="place-panel">
            <h2>{labels.currentStatus}</h2>
            <p>{localized(place, "current_status")}</p>
          </section>

          <section class="place-panel place-connections-panel">
            <h2>{storyLabels.stewardshipTitle}</h2>
            <p>{stewardshipText}</p>
            {linkedOrganizations.length > 0 && (
              <ul class="place-chip-list">
                {linkedOrganizations.map((organization) => (
                  <li>{localized(organization!, "name")}</li>
                ))}
              </ul>
            )}
          </section>

          <section class="place-panel place-connections-panel">
            <h2>{storyLabels.peopleTitle}</h2>
            <p>{peopleText}</p>
            {linkedPeople.length > 0 && (
              <ul class="place-chip-list">
                {linkedPeople.slice(0, 10).map((person) => (
                  <li><a href={localizePath(`/people/${person!.id}`, lang)}>{localized(person!, "name")}</a></li>
                ))}
              </ul>
            )}
          </section>

          <section class="place-panel">
            <h2>{labels.visit}</h2>
            <dl class="place-facts">
              {place.coordinates && (
                <>
                  <dt>{labels.coordinates}</dt>
                  <dd>{place.coordinates.lat.toFixed(5)}, {place.coordinates.lng.toFixed(5)} · {knownHistoryLabel(place.coordinates.accuracy, lang)}</dd>
                </>
              )}
              {facts.map((fact) => (
                <>
                  <dt>{fact.label}</dt>
                  <dd>{fact.value}</dd>
                </>
              ))}
            </dl>
            {mapHref && <a class="button secondary" href={mapHref} target="_blank" rel="noreferrer">{labels.openMap}</a>}
          </section>

          <section class="place-panel place-timeline-panel place-event-browser" data-place-event-browser={place.id}>
            <h2>{historyAtlasLabels.eventBrowserTitle}</h2>
            <p>{historyAtlasLabels.eventBrowserLead(relatedEvents.length)}</p>
            {relatedEvents.length > 0 ? (
              <div class="place-event-groups">
                {eventGroups.map((group) => (
                  <details class="place-event-group" open={relatedEvents.length <= 24}>
                    <summary>
                      <span>{group.label}</span>
                      <strong>{historyAtlasLabels.eventCount(group.events.length)}</strong>
                    </summary>
                    <ol class="place-story-timeline">
                      {group.events.map((event) => (
                        <li>
                          <time>{localized(event.date, "display")}</time>
                          <div>
                            <h3>{localized(event, "title")}</h3>
                            <p>{localized(event, "summary")}</p>
                          </div>
                        </li>
                      ))}
                    </ol>
                  </details>
                ))}
              </div>
            ) : (
              <p>{historyAtlasLabels.noEvents}</p>
            )}
          </section>

          <section class="place-panel place-connections-panel">
            <h2>{storyLabels.aroundTitle}</h2>
            <p>{relatedPlacesText}</p>
            {relatedPlaces.length > 0 && (
              <ul class="place-chip-list">
                {relatedPlaces.map((item) => (
                  <li><a href={localizePath(`/places/${item!.id}`, lang)}>{localized(item!, "name")}</a></li>
                ))}
              </ul>
            )}
          </section>

          {pairs.length > 0 && (
            <section class="place-panel">
              <h2>{labels.thenNowTitle}</h2>
              <div class="then-now-grid">
                {pairs.map((pair) => (
                  <article class="then-now-card" data-place-then-now>
                    <div class="compare-frame" style="--split:50%">
                      <img
                        class="compare-now"
                        src={pair.now_media.url}
                        alt={`${labels.nowLabel}: ${localized(pair, "title")}`}
                        loading="lazy"
                        decoding="async"
                      />
                      <div class="compare-then" aria-hidden="true">
                        <img src={pair.then_media.url} alt="" loading="lazy" decoding="async" />
                      </div>
                      <span class="compare-label compare-label-then">{labels.thenLabel}</span>
                      <span class="compare-label compare-label-now">{labels.nowLabel}</span>
                      <input
                        class="compare-range"
                        data-compare-range
                        type="range"
                        min="0"
                        max="100"
                        value="50"
                        aria-label={localized(pair, "title")}
                      />
                    </div>
                    <h3>{localized(pair, "title")}</h3>
                    <p>{localized(pair, "caption")}</p>
                    <dl class="then-now-evidence">
                      <div>
                        <dt>{labels.matchQuality}</dt>
                        <dd>{matchQualityLabel(pair.match_quality)}</dd>
                      </div>
                      <div>
                        <dt>{labels.thenLabel}</dt>
                        <dd>
                          <span>{labels.mediaCredit}: {pair.then_media.credit}</span>
                          <a href={pair.then_media.page_url} target="_blank" rel="noreferrer">{labels.mediaFile}</a>
                          <a href={pair.then_media.license_url} target="_blank" rel="noreferrer">{pair.then_media.license}</a>
                          <span>{t.common.accessed} {pair.then_media.accessed_at}</span>
                        </dd>
                      </div>
                      <div>
                        <dt>{labels.nowLabel}</dt>
                        <dd>
                          <span>{labels.mediaCredit}: {pair.now_media.credit}</span>
                          <a href={pair.now_media.page_url} target="_blank" rel="noreferrer">{labels.mediaFile}</a>
                          <a href={pair.now_media.license_url} target="_blank" rel="noreferrer">{pair.now_media.license}</a>
                          <span>{t.common.accessed} {pair.now_media.accessed_at}</span>
                        </dd>
                      </div>
                    </dl>
                  </article>
                ))}
              </div>
            </section>
          )}

          {archiveItems.length > 0 ? (
            <section class="place-panel">
              <h2>{labels.archiveTitle}</h2>
              <div class="archive-grid place-archive-grid">
                {archiveItems.map((item) => (
                  <article class="archive-card" data-place-archive>
                    <figure class="archive-media">
                      <img src={item.media.url} alt={localized(item, "title")} loading="lazy" decoding="async" />
                      <figcaption>{`${item.media.credit} · ${item.media.license}`}</figcaption>
                    </figure>
                    <p class="eyebrow">{localized(item, "date_display")}</p>
                    <h3>{localized(item, "title")}</h3>
                    <p>{localized(item, "description")}</p>
                    <a class="src-link" href={item.source.url} target="_blank" rel="noreferrer">
                      {labels.source}: {sourceTitle(item.source.title, lang)} ↗
                    </a>
                  </article>
                ))}
              </div>
            </section>
          ) : (
            <p class="notice"><span class="notice-icon" aria-hidden="true">i</span><span>{labels.noArchive}</span></p>
          )}
        </div>

        <aside class="place-detail-side">
          <section>
            <h2>{labels.sources}</h2>
            <ul class="source-list">
              {sourceRecords.map((source) => (
                <li>
                  <a href={source!.url} target="_blank" rel="noreferrer">{sourceTitle(localized(source!, "title"), lang)}</a>
                  <span class="meta"> · {`${t.common.accessed} ${source!.accessed_at}`}</span>
                </li>
              ))}
            </ul>
          </section>

          {relatedEvents.length > 0 && (
            <section>
              <h2>{labels.eventsTitle}</h2>
              <ol class="place-related-list">
                {relatedEvents.slice(0, 12).map((event) => (
                  <li>
                    <span>{localized(event.date, "display")}</span>
                    <strong>{localized(event, "title")}</strong>
                  </li>
                ))}
              </ol>
            </section>
          )}

          {relatedStories.length > 0 && (
            <section>
              <h2>{labels.storiesTitle}</h2>
              <ul class="source-list">
                {relatedStories.map((story) => (
                  <li><a href={localizePath(`/stories/${story.id}`, lang)}>{localized(story, "title")}</a></li>
                ))}
              </ul>
            </section>
          )}

          {place.coordinates && (
            <section>
              <h2>{labels.coordinates}</h2>
              <p class="meta">{place.coordinates.lat.toFixed(5)}, {place.coordinates.lng.toFixed(5)}</p>
              <p class="meta">{knownHistoryLabel(place.coordinates.accuracy, lang)}</p>
              {sourceById.get(place.coordinates.source_id) && (
                <a class="src-link" href={sourceById.get(place.coordinates.source_id)!.url} target="_blank" rel="noreferrer">
                  {labels.source}: {sourceTitle(localized(sourceById.get(place.coordinates.source_id)!, "title"), lang)} ↗
                </a>
              )}
            </section>
          )}
        </aside>
      </div>
    </section>
  </article>

  <script>
    document.querySelectorAll<HTMLInputElement>("[data-compare-range]").forEach((range) => {
      const frame = range.closest<HTMLElement>(".compare-frame");
      const update = () => frame?.style.setProperty("--split", `${range.value}%`);
      const setValue = (value: number) => {
        range.value = String(Math.min(100, Math.max(0, Math.round(value))));
        update();
      };
      const setFromPointer = (event: PointerEvent | MouseEvent) => {
        const rect = range.getBoundingClientRect();
        if (!rect.width) return;
        setValue(((event.clientX - rect.left) / rect.width) * 100);
        range.focus();
      };
      range.addEventListener("input", update);
      range.addEventListener("change", update);
      range.addEventListener("pointerdown", setFromPointer);
      range.addEventListener("click", setFromPointer);
      range.addEventListener("keydown", (event) => {
        const current = Number(range.value);
        const step = event.shiftKey ? 10 : 1;
        if (event.key === "ArrowLeft" || event.key === "ArrowDown") {
          event.preventDefault();
          setValue(current - step);
        } else if (event.key === "ArrowRight" || event.key === "ArrowUp") {
          event.preventDefault();
          setValue(current + step);
        } else if (event.key === "Home") {
          event.preventDefault();
          setValue(0);
        } else if (event.key === "End") {
          event.preventDefault();
          setValue(100);
        }
      });
      update();
    });
  </script>
</Layout>
