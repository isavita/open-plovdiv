---
import Layout from "@layouts/Layout.astro";
import { localeForLang, localizePath, ui, type Lang } from "@i18n/utils";
import { knownHistoryLabel, sourceTitle } from "@lib/format";
import { publicThenNowPairs } from "@lib/thenNow";
import {
  historicalArchiveItems,
  historyKnowledgeEvents,
  historyKnowledgeSources,
  storyLongreads,
  thenNowPairs,
  type KnowledgePlace
} from "@lib/data";

type Props = {
  lang: Lang;
  place: KnowledgePlace;
};

const { lang, place } = Astro.props;
const t = ui[lang];
const locale = localeForLang(lang);

const labels =
