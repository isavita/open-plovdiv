        currentStatus: "Aktueller Status",
        visit: "Besuch und Orientierung",
        coordinates: "Koordinaten",
        openMap: "Karte öffnen",
        built: "Bauzeit/Datum",
        architect: "Architekt",
        builder: "Bauherr",
        creator: "Architekt/Bauherr",
        source: "Quelle",
        sources: "Quellen",
        mediaLicense: "Bildlizenz",
        mediaFile: "Mediendatei",
        mediaCredit: "Bildnachweis",
        matchQuality: "Übereinstimmung",
        archiveTitle: "Archiv zu diesem Ort",
        thenNowTitle: "Damals/heute",
        thenLabel: "Damals",
        nowLabel: "Heute",
        eventsTitle: "Verknüpfte Ereignisse",
        storiesTitle: "Verknüpfte Geschichten",
        noArchive:
          "Für diesen Ort gibt es noch keinen eigenen Archiv- oder Damals/heute-Datensatz. Das Hauptbild, die Koordinaten und die Quellen bleiben veröffentlicht."
      }
      : lang === "fr"
      ? {
