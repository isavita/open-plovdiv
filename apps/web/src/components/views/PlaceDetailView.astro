---
import Layout from "@layouts/Layout.astro";
import { localizePath, ui, type Lang } from "@i18n/utils";
import { sourceTitle } from "@lib/format";
import {
  historicalArchiveItems,
  historyKnowledgeEvents,
  historyKnowledgeSources,
  storyLongreads,
  thenNowPairs,
  type KnowledgePlace
} from "@lib/data";

type Props = {
  lang: Lang;
  place: KnowledgePlace;
};

const { lang, place } = Astro.props;
const t = ui[lang];

const labels =
  lang === "bg"
    ? {
        back: "Всички места",
        facts: "Данни",
        currentStatus: "Текущ статус",
        visit: "Посещение и ориентация",
        coordinates: "Координати",
        openMap: "Отвори карта",
        built: "Дата/строеж",
        architect: "Архитект",
        builder: "Строител",
        creator: "Архитект/строител",
        source: "Източник",
        sources: "Източници и произход",
        mediaLicense: "Лиценз на изображение",
        mediaFile: "Медиен файл",
        mediaCredit: "Кредит",
        matchQuality: "Съвпадение",
        archiveTitle: "Архив за мястото",
        thenNowTitle: "Тогава/сега",
        thenLabel: "Тогава",
        nowLabel: "Сега",
        eventsTitle: "Свързани събития",
        storiesTitle: "Свързани разкази",
        noArchive:
          "Все още няма отделен архивен или тогава/сега запис за това място. Основното изображение, координатите и източниците остават публикувани.",
        editorial: "Записът е валидиран и източниково проследим, но очаква независим редакторски преглед.",
        panorama:
          "Панорамно или 360° съдържание не е маркирано в отворените данни за това място; няма добавено непроверено медийно твърдение."
      }
    : {
        back: "All places",
        facts: "Facts",
        currentStatus: "Current status",
        visit: "Visit and orientation",
        coordinates: "Coordinates",
        openMap: "Open map",
        built: "Built/date",
        architect: "Architect",
        builder: "Builder",
        creator: "Architect/builder",
        source: "Source",
        sources: "Sources and provenance",
        mediaLicense: "Image license",
        mediaFile: "Media file",
        mediaCredit: "Credit",
        matchQuality: "Match",
        archiveTitle: "Archive for this place",
        thenNowTitle: "Then/now",
        thenLabel: "Then",
        nowLabel: "Now",
        eventsTitle: "Linked events",
        storiesTitle: "Linked stories",
        noArchive:
          "No separate archive or then/now record is available for this place yet. The main image, coordinates and sources remain published.",
        editorial: "The record is validated and source-traceable, but still awaits independent editorial review.",
        panorama:
          "Panorama or 360-degree content is not marked in the open data for this place; no unverified media claim has been added."
      };

function localized(record: Record<string, any>, base: string): string {
  return String(record[`${base}_${lang}`] ?? record[`${base}_bg`] ?? "");
}

const matchQualityLabels: Record<string, string> =
  lang === "bg"
    ? {
        same_place_approximate_viewpoint: "същото място, приблизителна гледна точка",
        same_place_close_viewpoint: "същото място, близка гледна точка",
        city_context: "градски контекст"
      }
    : {
        same_place_approximate_viewpoint: "same place, approximate viewpoint",
        same_place_close_viewpoint: "same place, close viewpoint",
        city_context: "city context"
      };

function matchQualityLabel(value: string): string {
  return matchQualityLabels[value] ?? value.replaceAll("_", " ");
}

function placeFacts(item: KnowledgePlace) {
  const hasNamedCreator = Boolean(localized(item, "architect") || localized(item, "builder"));
  return [
    localized(item.date_context, "display") ? { label: labels.built, value: localized(item.date_context, "display") } : null,
    localized(item, "architect") ? { label: labels.architect, value: localized(item, "architect") } : null,
    localized(item, "builder") ? { label: labels.builder, value: localized(item, "builder") } : null,
    !hasNamedCreator && localized(item.creator_context, "display")
      ? { label: labels.creator, value: localized(item.creator_context, "display") }
      : null
  ].filter(Boolean) as Array<{ label: string; value: string }>;
}

const sourceById = new Map(historyKnowledgeSources.map((source) => [source.id, source]));
const archiveItems = historicalArchiveItems
  .filter((item) => item.place_id === place.id)
  .sort((a, b) => a.date_year - b.date_year || a.id.localeCompare(b.id));
const pairs = thenNowPairs
  .filter((pair) => pair.place_id === place.id)
  .sort((a, b) => localized(a, "title").localeCompare(localized(b, "title"), lang === "bg" ? "bg-BG" : "en-GB"));
const relatedEvents = historyKnowledgeEvents
  .filter((event) => event.place_ids.includes(place.id))
  .sort((a, b) => a.date.year - b.date.year || a.id.localeCompare(b.id));
const relatedStories = storyLongreads.filter((story) => story.linked_place_ids.includes(place.id));
const facts = placeFacts(place);
const image = place.media[0];
const sourceRecords = place.source_ids.map((sourceId) => sourceById.get(sourceId)).filter(Boolean);
const mapHref = place.coordinates
  ? `https://www.openstreetmap.org/?mlat=${place.coordinates.lat}&mlon=${place.coordinates.lng}#map=17/${place.coordinates.lat}/${place.coordinates.lng}`
  : "";
---

<Layout lang={lang} path={`/places/${place.id}`} title={localized(place, "name")} description={localized(place, "summary")}>
  <article class="place-detail">
    <header class="section place-detail-hero">
      <div class="container place-detail-grid">
        <div>
          <a class="text-link" href={localizePath("/places", lang)}>{labels.back}</a>
          <p class="eyebrow">{localized(place, "era")}</p>
          <h1>{localized(place, "name")}</h1>
          <p class="lead">{localized(place, "summary")}</p>
          <p class="meta" style="margin-top:12px">{labels.editorial}</p>
        </div>
        {image && (
          <figure class="place-detail-media">
            <img src={image.url} alt={localized(place, "name")} />
            <figcaption>
              {image.credit} · {image.license}
              <a href={image.page_url} target="_blank" rel="noreferrer">{labels.mediaLicense}</a>
            </figcaption>
          </figure>
        )}
      </div>
    </header>

    <section class="section">
      <div class="container place-detail-layout">
        <div class="place-detail-main">
          <section class="place-panel">
            <h2>{labels.currentStatus}</h2>
            <p>{localized(place, "current_status")}</p>
          </section>

          <section class="place-panel">
            <h2>{labels.visit}</h2>
            <dl class="place-facts">
              {place.coordinates && (
                <>
                  <dt>{labels.coordinates}</dt>
                  <dd>{place.coordinates.lat.toFixed(5)}, {place.coordinates.lng.toFixed(5)} · {place.coordinates.accuracy}</dd>
                </>
              )}
              {facts.map((fact) => (
                <>
                  <dt>{fact.label}</dt>
                  <dd>{fact.value}</dd>
                </>
              ))}
            </dl>
            {mapHref && <a class="button secondary" href={mapHref} target="_blank" rel="noreferrer">{labels.openMap}</a>}
            <p class="meta" style="margin-top:14px">{labels.panorama}</p>
          </section>

          {pairs.length > 0 && (
            <section class="place-panel">
              <h2>{labels.thenNowTitle}</h2>
              <div class="then-now-grid">
                {pairs.map((pair) => (
                  <article class="then-now-card" data-place-then-now>
                    <div class="compare-frame" style="--split:50%">
                      <img
                        class="compare-now"
                        src={pair.now_media.url}
                        alt={`${labels.nowLabel}: ${localized(pair, "title")}`}
                        loading="lazy"
                        decoding="async"
                      />
                      <div class="compare-then" aria-hidden="true">
                        <img src={pair.then_media.url} alt="" loading="lazy" decoding="async" />
                      </div>
                      <span class="compare-label compare-label-then">{labels.thenLabel}</span>
                      <span class="compare-label compare-label-now">{labels.nowLabel}</span>
                      <input
                        class="compare-range"
                        data-compare-range
                        type="range"
                        min="0"
                        max="100"
                        value="50"
                        aria-label={localized(pair, "title")}
                      />
                    </div>
                    <h3>{localized(pair, "title")}</h3>
                    <p>{localized(pair, "caption")}</p>
                    <dl class="then-now-evidence">
                      <div>
                        <dt>{labels.matchQuality}</dt>
                        <dd>{matchQualityLabel(pair.match_quality)}</dd>
                      </div>
                      <div>
                        <dt>{labels.thenLabel}</dt>
                        <dd>
                          <span>{labels.mediaCredit}: {pair.then_media.credit}</span>
                          <a href={pair.then_media.page_url} target="_blank" rel="noreferrer">{labels.mediaFile}</a>
                          <a href={pair.then_media.license_url} target="_blank" rel="noreferrer">{pair.then_media.license}</a>
                          <span>{t.common.accessed} {pair.then_media.accessed_at}</span>
                        </dd>
                      </div>
                      <div>
                        <dt>{labels.nowLabel}</dt>
                        <dd>
                          <span>{labels.mediaCredit}: {pair.now_media.credit}</span>
                          <a href={pair.now_media.page_url} target="_blank" rel="noreferrer">{labels.mediaFile}</a>
                          <a href={pair.now_media.license_url} target="_blank" rel="noreferrer">{pair.now_media.license}</a>
                          <span>{t.common.accessed} {pair.now_media.accessed_at}</span>
                        </dd>
                      </div>
                    </dl>
                  </article>
                ))}
              </div>
            </section>
          )}

          {archiveItems.length > 0 ? (
            <section class="place-panel">
              <h2>{labels.archiveTitle}</h2>
              <div class="archive-grid place-archive-grid">
                {archiveItems.map((item) => (
                  <article class="archive-card" data-place-archive>
                    <figure class="archive-media">
                      <img src={item.media.url} alt={localized(item, "title")} loading="lazy" decoding="async" />
                      <figcaption>{`${item.media.credit} · ${item.media.license}`}</figcaption>
                    </figure>
                    <p class="eyebrow">{localized(item, "date_display")}</p>
                    <h3>{localized(item, "title")}</h3>
                    <p>{localized(item, "description")}</p>
                    <a class="src-link" href={item.source.url} target="_blank" rel="noreferrer">
                      {labels.source}: {item.source.title} ↗
                    </a>
                  </article>
                ))}
              </div>
            </section>
          ) : (
            <p class="notice"><span class="notice-icon" aria-hidden="true">i</span><span>{labels.noArchive}</span></p>
          )}
        </div>

        <aside class="place-detail-side">
          <section>
            <h2>{labels.sources}</h2>
            <ul class="source-list">
              {sourceRecords.map((source) => (
                <li>
                  <a href={source!.url} target="_blank" rel="noreferrer">{sourceTitle(localized(source!, "title"), lang)}</a>
                  <span class="meta"> · {`${t.common.accessed} ${source!.accessed_at}`}</span>
                </li>
              ))}
            </ul>
          </section>

          {relatedEvents.length > 0 && (
            <section>
              <h2>{labels.eventsTitle}</h2>
              <ol class="place-related-list">
                {relatedEvents.slice(0, 12).map((event) => (
                  <li>
                    <span>{localized(event.date, "display")}</span>
                    <strong>{localized(event, "title")}</strong>
                  </li>
                ))}
              </ol>
            </section>
          )}

          {relatedStories.length > 0 && (
            <section>
              <h2>{labels.storiesTitle}</h2>
              <ul class="source-list">
                {relatedStories.map((story) => (
                  <li><a href={localizePath(`/stories/${story.id}`, lang)}>{localized(story, "title")}</a></li>
                ))}
              </ul>
            </section>
          )}

          {place.coordinates && (
            <section>
              <h2>{labels.coordinates}</h2>
              <p class="meta">{place.coordinates.lat.toFixed(5)}, {place.coordinates.lng.toFixed(5)}</p>
              <p class="meta">{place.coordinates.accuracy}</p>
              {sourceById.get(place.coordinates.source_id) && (
                <a class="src-link" href={sourceById.get(place.coordinates.source_id)!.url} target="_blank" rel="noreferrer">
                  {labels.source}: {sourceTitle(localized(sourceById.get(place.coordinates.source_id)!, "title"), lang)} ↗
                </a>
              )}
            </section>
          )}
        </aside>
      </div>
    </section>
  </article>

  <script>
    document.querySelectorAll<HTMLInputElement>("[data-compare-range]").forEach((range) => {
      const frame = range.closest<HTMLElement>(".compare-frame");
      const update = () => frame?.style.setProperty("--split", `${range.value}%`);
      const setValue = (value: number) => {
        range.value = String(Math.min(100, Math.max(0, Math.round(value))));
        update();
      };
      const setFromPointer = (event: PointerEvent | MouseEvent) => {
        const rect = range.getBoundingClientRect();
        if (!rect.width) return;
        setValue(((event.clientX - rect.left) / rect.width) * 100);
        range.focus();
      };
      range.addEventListener("input", update);
      range.addEventListener("change", update);
      range.addEventListener("pointerdown", setFromPointer);
      range.addEventListener("click", setFromPointer);
      range.addEventListener("keydown", (event) => {
        const current = Number(range.value);
        const step = event.shiftKey ? 10 : 1;
        if (event.key === "ArrowLeft" || event.key === "ArrowDown") {
          event.preventDefault();
          setValue(current - step);
        } else if (event.key === "ArrowRight" || event.key === "ArrowUp") {
          event.preventDefault();
          setValue(current + step);
        } else if (event.key === "Home") {
          event.preventDefault();
          setValue(0);
        } else if (event.key === "End") {
          event.preventDefault();
          setValue(100);
        }
      });
      update();
    });
  </script>
</Layout>
