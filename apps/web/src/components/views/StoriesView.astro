---
import Layout from "@layouts/Layout.astro";
import { localizePath, ui, type Lang } from "@i18n/utils";
import { sourceTitle } from "@lib/format";
import {
  historicalArchiveItems,
  historyKnowledgeSources,
  historyKnowledgePlaces,
  storyLongreads,
  thenNowPairs,
  type StoryLongread
} from "@lib/data";

type Props = {
  lang: Lang;
};

const { lang } = Astro.props;
const t = ui[lang];

const labels = ({
  bg: {
    title: "Исторически разкази",
    eyebrow: "Илюстрирани дълги четива",
    lead:
      "Двуезични разкази за Пловдив, изградени върху събитията, местата, архивните изображения и публичните източници в Open Plovdiv.",
    stories: "разказа",
    sources: "източника",
    archive: "архивни образа",
    minutes: "мин четене",
    read: "Чети",
    evidence: "Свързани записи",
    editorialNote:
      "Всеки разказ събира проверени места, събития, изображения и източници в четим маршрут през историята на града."
  },
  en: {
    title: "Historical Stories",
    eyebrow: "Illustrated longreads",
    lead:
      "Bilingual stories on Plovdiv, built from the events, places, archive images and public sources in Open Plovdiv.",
    stories: "stories",
    sources: "sources",
    archive: "archive visuals",
    minutes: "min read",
    read: "Read",
    evidence: "Linked records",
    editorialNote:
      "Each story connects verified places, events, images and sources into a readable route through the city’s history."
  },
  de: {
    title: "Historische Geschichten",
    eyebrow: "Illustrierte Langtexte",
    lead:
      "Zweisprachige Geschichten über Plovdiv, aufgebaut aus den Ereignissen, Orten, Archivbildern und öffentlichen Quellen in Open Plovdiv.",
    stories: "Geschichten",
    sources: "Quellen",
    archive: "Archivbilder",
    minutes: "Min. Lesezeit",
    read: "Lesen",
    evidence: "Verknüpfte Datensätze",
    editorialNote:
      "Jede Geschichte verbindet geprüfte Orte, Ereignisse, Bilder und Quellen zu einem lesbaren Weg durch die Geschichte der Stadt."
  },
  fr: {
    title: "Récits historiques",
    eyebrow: "Longs formats illustrés",
    lead:
      "Des récits sur Plovdiv, construits à partir des événements, lieux, images d'archives et sources publiques d'Open Plovdiv.",
    stories: "récits",
    sources: "sources",
    archive: "visuels d'archives",
    minutes: "min de lecture",
    read: "Lire",
    evidence: "Fiches liées",
    editorialNote:
      "Chaque récit relie des lieux, événements, images et sources vérifiés en un parcours lisible à travers l'histoire de la ville."
  },
  it: {
    title: "Racconti storici",
    eyebrow: "Approfondimenti illustrati",
    lead:
      "Racconti su Plovdiv, costruiti a partire da eventi, luoghi, immagini d'archivio e fonti pubbliche di Open Plovdiv.",
    stories: "racconti",
    sources: "fonti",
    archive: "immagini d'archivio",
    minutes: "min di lettura",
    read: "Leggi",
    evidence: "Schede collegate",
    editorialNote:
      "Ogni racconto collega luoghi, eventi, immagini e fonti verificate in un percorso leggibile attraverso la storia della città."
  }
} satisfies Record<Lang, Record<string, string>>)[lang];

const archiveById = new Map(historicalArchiveItems.map((item) => [item.id, item]));
const pairById = new Map(thenNowPairs.map((pair) => [pair.id, pair]));
const placeById = new Map(historyKnowledgePlaces.map((place) => [place.id, place]));
const sourceById = new Map(historyKnowledgeSources.map((source) => [source.id, source]));

function localized(record: Record<string, unknown>, field: string): string {
  return String(
    record[`${field}_${lang}`] ?? record[`${field}_en`] ?? record[`${field}_bg`] ?? ""
  );
}

function sourceLabel(source: Record<string, unknown>): string {
  return sourceTitle(localized(source, "title"), lang);
}

function heroMedia(story: StoryLongread) {
  if (story.hero.kind === "archive_item") return archiveById.get(story.hero.ref_id)?.media;
  if (story.hero.kind === "then_now_pair") return pairById.get(story.hero.ref_id)?.then_media;
  return placeById.get(story.hero.ref_id)?.media[0];
}

function linkCount(story: StoryLongread): number {
  return (
    story.linked_event_ids.length +
    story.linked_place_ids.length +
    story.linked_archive_item_ids.length +
    story.linked_then_now_pair_ids.length
  );
}

const sourceCount = new Set(storyLongreads.flatMap((story) => story.source_ids)).size;
const archiveLinkCount = storyLongreads.reduce(
  (sum, story) => sum + story.linked_archive_item_ids.length + story.linked_then_now_pair_ids.length,
  0
);
---

<Layout lang={lang} path="/stories" title={labels.title} description={labels.lead}>
  <section class="section hero hero-compact stories-hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">{labels.eyebrow}</p>
        <h1>{labels.title}</h1>
        <p class="lead">{labels.lead}</p>
      </div>
      <dl class="stats-grid stories-stats" aria-label={labels.title}>
        <div class="stat-card">
          <dt>{labels.stories}</dt>
          <dd>{storyLongreads.length}</dd>
        </div>
        <div class="stat-card">
          <dt>{labels.sources}</dt>
          <dd>{sourceCount}</dd>
        </div>
        <div class="stat-card">
          <dt>{labels.archive}</dt>
          <dd>{archiveLinkCount}</dd>
        </div>
      </dl>
    </div>
  </section>

  <section class="section" id="stories">
    <div class="container">
      <div class="stories-toolbar">
        <p class="meta">{labels.editorialNote}</p>
      </div>

      <div class="story-grid">
        {storyLongreads.map((story) => {
          const media = heroMedia(story);
          const sourceRecords = story.source_ids
            .map((sourceId) => sourceById.get(sourceId))
            .filter(Boolean)
            .slice(0, 3);
          return (
            <article class="story-card" data-story-card>
              {media && (
                <a class="story-card-media" href={localizePath(`/stories/${story.id}`, lang)} aria-label={localized(story, "title")}>
                  <img
                    src={media.url}
                    alt={localized(story.hero, "caption")}
                    loading="lazy"
                    decoding="async"
                    crossorigin="anonymous"
                    referrerpolicy="no-referrer"
                  />
                </a>
              )}
              <div class="story-card-body">
                <p class="eyebrow">{`${story.reading_minutes} ${labels.minutes}`}</p>
                <h2><a href={localizePath(`/stories/${story.id}`, lang)}>{localized(story, "title")}</a></h2>
                <p>{localized(story, "dek")}</p>
                <div class="tag-row">
                  {story.era_tags.map((tag) => <span>{t.history.eraLabels[tag]}</span>)}
                  {story.theme_tags.slice(0, 3).map((tag) => <span>{tag.replaceAll("_", " ")}</span>)}
                </div>
                <dl class="story-evidence-counts">
                  <dt>{labels.evidence}</dt>
                  <dd>{linkCount(story)}</dd>
                </dl>
                <ul class="source-list compact">
                  {sourceRecords.map((source) => (
                    <li>
                      <a href={source!.url} target="_blank" rel="noreferrer">{sourceLabel(source!)}</a>
                    </li>
                  ))}
                </ul>
                <a class="text-link" href={localizePath(`/stories/${story.id}`, lang)}>{labels.read}</a>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>
</Layout>
