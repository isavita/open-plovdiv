const hiddenThemeTags = new Set(["people", "birth"]);

function labelCategory(category: string) {
  const known = categoryLabels[category];
  if (known) return known[lang] ?? known.en;
  return category.replaceAll("_", " ");
}

function labelTheme(theme: string) {
  if (theme in t.history.eraLabels) return t.history.eraLabels[theme as HistoryEra];
  if (theme in themeLabels) return themeLabels[theme][lang] ?? themeLabels[theme].en;
  return labelCategory(theme).replaceAll("_", " ");
}

function shouldShowThemeTag(theme: string) {
  return !hiddenThemeTags.has(theme);
}

function localized(record: Record<string, any>, base: string): string {
  return knownHistoryLabel(String(record[`${base}_${lang}`] ?? record[`${base}_en`] ?? record[`${base}_bg`] ?? ""), lang);
}

function dateLabel(event: KnowledgeEvent) {
  return localized(event.date, "display");
}

function placeFacts(place: Record<string, any>) {
  const hasNamedCreator = Boolean(localized(place, "architect") || localized(place, "builder"));
  return [
    localized(place.date_context, "display") ? { label: labels.built, value: localized(place.date_context, "display") } : null,
    localized(place, "architect") ? { label: labels.architect, value: localized(place, "architect") } : null,
    localized(place, "builder") ? { label: labels.builder, value: localized(place, "builder") } : null,
    !hasNamedCreator && localized(place.creator_context, "display")
      ? { label: labels.creator, value: localized(place.creator_context, "display") }
      : null
  ].filter(Boolean) as Array<{ label: string; value: string }>;
}

