const numberFmt = new Intl.NumberFormat(locale);

const pop = [...plovdivPopulation].sort((a, b) => a.year - b.year);
const latestPopulationPoint = pop[pop.length - 1];
const populationSources = [...new Map(pop.map((point) => [point.source.url, point.source])).values()];
const PW = 1000, PH = 340, popL = 56, popR = 16, popT = 30, popB = 46;
const minYear = pop[0].year;
const maxYear = pop[pop.length - 1].year;
const maxPop = Math.max(...pop.map((p) => p.population));
const niceMax = Math.ceil(maxPop / 100000) * 100000;
const popX = (year: number) => popL + ((year - minYear) / (maxYear - minYear)) * (PW - popL - popR);
const popY = (value: number) => PH - popB - (value / niceMax) * (PH - popT - popB);
const popPts = pop.map((p) => `${popX(p.year).toFixed(1)},${popY(p.population).toFixed(1)}`);
const popLine = `M ${popPts.join(" L ")}`;
const popArea = `M ${popX(minYear).toFixed(1)} ${(PH - popB).toFixed(1)} L ${popPts.join(" L ")} L ${popX(maxYear).toFixed(1)} ${(PH - popB).toFixed(1)} Z`;
const popYTicks = [0, 100000, 200000, 300000].concat(niceMax > 300000 ? [niceMax] : []);
const popXTicks = [...new Set([1880, 1900, 1920, 1946, 1965, 1985, 2001, latestPopulationPoint.year])].filter(
  (y) => y >= minYear && y <= maxYear
);
const peakPoint = pop.reduce((a, b) => (b.population > a.population ? b : a));

const cleanRate = (rate: number) => (Math.abs(rate) < 0.05 ? 0 : rate);
const formatRate = (rate: number) => {
  const value = cleanRate(rate);
  return `${value > 0 ? "+" : ""}${value.toFixed(1)}`;
};

// growth rate between consecutive reporting points (annualised percent)
const growthRates = pop.slice(1).map((p, i) => {
  const prev = pop[i];
  const years = p.year - prev.year;
  const rate = (Math.pow(p.population / prev.population, 1 / years) - 1) * 100;
  return { from: prev.year, to: p.year, rate: cleanRate(rate), label: formatRate(rate) };
});
const maxAbsRate = Math.max(...growthRates.map((g) => Math.abs(g.rate)), 1);
const RW = 1000, RH = 250, rL = 28, rR = 14, rT = 24, rB = 40;
const rPlotH = RH - rT - rB;
const rZero = rT + rPlotH / 2;
const rStep = (RW - rL - rR) / growthRates.length;
const rBarW = rStep * 0.62;
const rateBarH = (rate: number) => (Math.abs(rate) / maxAbsRate) * (rPlotH / 2);

// density (against the present city area)
