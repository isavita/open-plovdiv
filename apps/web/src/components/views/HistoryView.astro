type Props = { lang: Lang };
const { lang } = Astro.props;
const t = ui[lang];
const locale = localeForLang(lang);

const eraOrder: HistoryEra[] = [
  "prehistory",
  "thracian",
  "roman",
  "medieval",
  "ottoman",
  "revival",
  "liberation",
  "modern"
];

const entries = [...historyKnowledgeEvents].sort(
  (a, b) =>
    a.date.year - b.date.year ||
    (a.date.year_end ?? a.date.year) - (b.date.year_end ?? b.date.year) ||
    a.id.localeCompare(b.id)
);
const historyDataVersion = createHash("sha1")
  .update(
    JSON.stringify({
      events: historyKnowledgeEvents,
      organizations: historyKnowledgeOrganizations,
      people: historyKnowledgePeople,
      places: historyKnowledgePlaces,
      sources: historyKnowledgeSources
    })
  )
  .digest("hex")
  .slice(0, 12);
const erasPresent = eraOrder.filter((era) => entries.some((e) => e.era === era));
const mayorEvents = entries.filter((event) => event.category === "mayor_term");

const tr = (bg: string, en: string, de: string, fr: string, it: string, trk: string, esp: string, ell: string, ja: string): string =>
  ({ bg, en, de, fr, it, tr: trk, es: esp, el: ell, ja } satisfies Record<Lang, string>)[lang];

const stats = [
  { value: t.home.statYearsValue, label: t.history.statYears },
  { value: String(historyKnowledgeEvents.length), label: tr("събития", "events", "Ereignisse", "événements", "eventi", "etkinlik", "eventos", "γεγονότα", "出来事") },
  { value: String(historyKnowledgePeople.length), label: tr("хора", "people", "Personen", "personnalités", "personalità", "kişi", "personas", "πρόσωπα", "人物") },
  { value: String(historyKnowledgeSources.length), label: tr("източника", "sources", "Quellen", "sources", "fonti", "kaynak", "fuentes", "πηγές", "出典") }
];

