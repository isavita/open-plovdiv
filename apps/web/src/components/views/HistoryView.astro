const dataResourceLabels: Record<string, string> =
  lang === "bg"
    ? {
        index: "Индекс",
        events: "Събития",
        people: "Хора",
        person_relationships: "Връзки между личности",
        places: "Места",
        organizations: "Организации",
        sources: "Източници",
        archive_items: "Архивни обекти",
        then_now_pairs: "Двойки тогава/сега",
        primary_documents: "Първични документи",
        story_longreads: "Дълги разкази",
        education_resources: "Образователни ресурси",
        editorial_signoffs: "Редакторски подписи",
        editorial_review: "Редакторски преглед"
      }
    : {
        index: "Index",
        events: "Events",
        people: "People",
        person_relationships: "Person relationships",
        places: "Places",
        organizations: "Organizations",
        sources: "Sources",
        archive_items: "Archive items",
        then_now_pairs: "Then/now pairs",
        primary_documents: "Primary documents",
        story_longreads: "Story longreads",
        education_resources: "Education resources",
        editorial_signoffs: "Editorial sign-offs",
        editorial_review: "Editorial review"
      };

function dataResourceLabel(key: string) {
  return dataResourceLabels[key] ?? key.replaceAll("_", " ");
}

function fileNameFromHref(href: string) {
  return href.split("/").filter(Boolean).at(-1) ?? href;
}

const endpointRows = Object.entries(historyKnowledgeIndex.endpoints).map(([key, href]) => ({
  key,
  href,
  label: dataResourceLabel(key)
}));
const downloadRows = Object.entries(historyKnowledgeIndex.downloads)
  .filter(([key]) => key.endsWith("_json") || key.endsWith("_csv"))
  .map(([key, href]) => {
    const format = key.endsWith("_csv") ? "CSV" : "JSON";
    const resourceKey = key.replace(/_(json|csv)$/u, "");
    return {
      key,
      href,
      format,
      label: dataResourceLabel(resourceKey),
      fileName: fileNameFromHref(href)
    };
  });

const categoryLabels: Record<string, { bg: string; en: string }> = {
  historical_timeline: { bg: "Хронология", en: "Timeline" },
  mayor_term: { bg: "Кметски мандат", en: "Mayoral term" },
  historical_event: { bg: "Историческо събитие", en: "Historical event" },
  cultural_programme: { bg: "Културна програма", en: "Cultural programme" },
  historical_finance: { bg: "Исторически финанси", en: "Historical finance" },
  municipal_programme: { bg: "Общинска програма", en: "Municipal programme" },
  governance_change: { bg: "Управленска промяна", en: "Governance change" },
  archive_source: { bg: "Архивен източник", en: "Archive source" }
};

function labelCategory(category: string) {
  const known = categoryLabels[category];
  if (known) return known[lang];
  return category.replaceAll("_", " ");
}

function labelTheme(theme: string) {
  if (theme in t.history.eraLabels) return t.history.eraLabels[theme as HistoryEra];
  return labelCategory(theme).replaceAll("_", " ");
}

function localized(record: Record<string, any>, base: string): string {
  return String(record[`${base}_${lang}`] ?? record[`${base}_bg`] ?? "");
}

function dateLabel(event: KnowledgeEvent) {
  return localized(event.date, "display");
}

function placeFacts(place: Record<string, any>) {
  const hasNamedCreator = Boolean(localized(place, "architect") || localized(place, "builder"));
  return [
    localized(place.date_context, "display") ? { label: labels.built, value: localized(place.date_context, "display") } : null,
    localized(place, "architect") ? { label: labels.architect, value: localized(place, "architect") } : null,
    localized(place, "builder") ? { label: labels.builder, value: localized(place, "builder") } : null,
    !hasNamedCreator && localized(place.creator_context, "display")
      ? { label: labels.creator, value: localized(place.creator_context, "display") }
      : null
  ].filter(Boolean) as Array<{ label: string; value: string }>;
}

const categories = [...new Set(entries.map((event) => event.category))].sort((a, b) =>
  labelCategory(a).localeCompare(labelCategory(b), lang === "bg" ? "bg-BG" : "en-GB")
);
const themeTags = [...new Set(entries.flatMap((event) => event.theme_tags))].sort((a, b) =>
  labelTheme(a).localeCompare(labelTheme(b), lang === "bg" ? "bg-BG" : "en-GB")
);
const sourceById = new Map(historyKnowledgeSources.map((source) => [source.id, source]));
const peopleById = new Map(historyKnowledgePeople.map((person) => [person.id, person]));
const placesById = new Map(historyKnowledgePlaces.map((place) => [place.id, place]));
const orgsById = new Map(historyKnowledgeOrganizations.map((org) => [org.id, org]));
const mapPlaces = historyKnowledgePlaces.filter((place) => place.coordinates);
const mapPlaceIds = new Set(mapPlaces.map((place) => place.id));
const mapErasPresent = eraOrder.filter((era) => mapPlaces.some((place) => place.era === era));
const mapArchiveItems = historicalArchiveItems
  .filter((item) => item.coordinates)
  .sort((a, b) => a.date_year - b.date_year || a.id.localeCompare(b.id));
const mapRoutes = [
  {
    id: "ancient-philippopolis",
    title: labels.routeAncientTitle,
    summary: labels.routeAncientLead,
    color: "#a23b2d",
    stop_ids: [
      "place-nebet-tepe",
      "place-ancient-theatre",
      "place-ancient-stadium",
      "place-eastern-gate-of-philippopolis-q20500154",
      "place-odeon-of-philippopolis-q26046109",
      "place-bishop-s-basilica-of-philippopolis-q20500169"
    ].filter((id) => mapPlaceIds.has(id))
  },
  {
    id: "revival-old-town",
    title: labels.routeRevivalTitle,
    summary: labels.routeRevivalLead,
    color: "#b4632a",
    stop_ids: [
      "place-old-town",
      "place-holy-mother-of-god",
      "place-stoyan-chomakov-house",
      "place-lamartine-house",
      "place-house-of-hristo-g-danov-q29961385",
      "place-hindliyan-house-q19810343"
    ].filter((id) => mapPlaceIds.has(id))
  },
  {
    id: "seven-hills",
    title: labels.routeHillsTitle,
    summary: labels.routeHillsLead,
    color: "#7d8471",
    stop_ids: [
      "place-nebet-tepe",
      "place-dzhambaz-hill-in-plovdiv-q12277962",
      "place-taksim-hill-in-plovdiv-q12295975",
      "place-sahat-hill-in-plovdiv-q12293012",
      "place-bunardzhik-q12274023",
      "place-dzhendem-tepe-q5319673",
      "place-markovo-tepe-q6771348"
    ].filter((id) => mapPlaceIds.has(id))
  }
].filter((route) => route.stop_ids.length >= 2);
const timelinePeople = [...new Set(entries.flatMap((event) => event.person_ids))]
  .map((id) => peopleById.get(id))
  .filter(Boolean)
  .sort((a, b) =>
    localized(a as Record<string, any>, "name").localeCompare(
      localized(b as Record<string, any>, "name"),
      lang === "bg" ? "bg-BG" : "en-GB"
    )
  )
  .map((person) => ({
    id: person!.id,
    name: localized(person as Record<string, any>, "name")
  }));
const timelinePlaces = [...new Set(entries.flatMap((event) => event.place_ids))]
  .map((id) => placesById.get(id))
  .filter(Boolean)
  .sort((a, b) =>
    localized(a as Record<string, any>, "name").localeCompare(
      localized(b as Record<string, any>, "name"),
      lang === "bg" ? "bg-BG" : "en-GB"
    )
  )
  .map((place) => ({
    id: place!.id,
    name: localized(place as Record<string, any>, "name")
  }));

const clientCategoryLabels = Object.fromEntries(categories.map((category) => [category, labelCategory(category)]));
const clientThemeLabels = Object.fromEntries(themeTags.map((theme) => [theme, labelTheme(theme)]));

const coverageRows = [
  { label: labels.events, count: historyKnowledgeIndex.counts.events, target: historyKnowledgeIndex.targets.events },
  {
    label: labels.exactDateCount,
    count: historyKnowledgeIndex.counts.exact_date_events ?? 0,
    target: historyKnowledgeIndex.targets.exact_date_events ?? 60
  },
  { label: labels.people, count: historyKnowledgeIndex.counts.people, target: historyKnowledgeIndex.targets.people },
  { label: labels.places, count: historyKnowledgeIndex.counts.places, target: historyKnowledgeIndex.targets.places },
  {
    label: labels.placeImages,
    count: historyKnowledgeIndex.counts.places_with_media ?? 0,
    target: historyKnowledgeIndex.targets.places_with_media ?? historyKnowledgeIndex.targets.places
  },
  {
    label: labels.georeferencedItems,
    count: historyKnowledgeIndex.counts.georeferenced_archive_items ?? historicalArchiveItems.length,
    target: historyKnowledgeIndex.targets.georeferenced_archive_items
  },
  {
    label: labels.thenNowPairs,
    count: historyKnowledgeIndex.counts.then_now_pairs ?? thenNowPairs.length,
    target: historyKnowledgeIndex.targets.then_now_pairs
  },
  { label: labels.sources, count: historyKnowledgeIndex.counts.sources, target: historyKnowledgeIndex.counts.sources },
  { label: labels.editorial, count: signedOffCount, target: totalEditorialRecords }
].map((row) => ({
  ...row,
  pct: row.target ? Math.min(100, Math.round((row.count / row.target) * 100)) : 100,
  pctLabel: `${row.target ? Math.min(100, Math.round((row.count / row.target) * 100)) : 100}%`,
  barStyle: `width:${row.target ? Math.min(100, Math.round((row.count / row.target) * 100)) : 100}%`,
  meta: `${row.count} ${labels.of} ${row.target} ${labels.records}`
}));

const repeatedPeople = historyKnowledgePeople.filter((person) => person.term_events.length > 1);
const successionCount = historyKnowledgePeople.reduce(
  (sum, person) => sum + person.relationships.filter((relationship) => relationship.type === "succeeded_by").length,
  0
);
const firstYear = mayorEvents[0]?.date.year ?? 1878;
const lastYear = mayorEvents.at(-1)?.date.year_end ?? new Date().getFullYear();
const graphWidth = 1000;
const graphAxis = 146;
const graphPad = 28;
const graphSpan = Math.max(1, lastYear - firstYear);
const graphX = (year: number) => graphPad + ((year - firstYear) / graphSpan) * (graphWidth - graphPad * 2);
const repeatArcs = repeatedPeople.flatMap((person) => {
  const termEvents = person.term_events
    .map((id) => entries.find((event) => event.id === id))
    .filter(Boolean) as KnowledgeEvent[];
  termEvents
    .sort((a, b) => a.date.year - b.date.year);
  return termEvents.slice(1).map((event, index) => {
    const previous = termEvents[index];
    const x1 = graphX(previous.date.year);
    const x2 = graphX(event.date.year);
    const lift = Math.min(110, 24 + Math.abs(x2 - x1) * 0.42);
    return `M ${x1.toFixed(1)} ${graphAxis} C ${x1.toFixed(1)} ${(graphAxis - lift).toFixed(1)}, ${x2.toFixed(1)} ${(graphAxis - lift).toFixed(1)}, ${x2.toFixed(1)} ${graphAxis}`;
  });
});

