  lang,
  api: {
    archiveItems: historyKnowledgeIndex.endpoints.archive_items,
    places: historyKnowledgeIndex.endpoints.places,
    sources: historyKnowledgeIndex.endpoints.sources
  },
  labels: {
    selectPlace: labels.selectPlace,
    source: labels.source,
    coordinates: labels.coordinates,
    built: labels.built,
    architect: labels.architect,
    builder: labels.builder,
    creator: labels.creator,
    archivePlace: labels.archivePlace,
    georeference: labels.georeference,
    license: labels.license,
    visiblePlaces: labels.visiblePlaces,
    visibleArchiveItems: labels.visibleArchiveItems,
    routeStops: labels.routeStops,
    archiveOverlayNote: labels.archiveOverlayNote
  },
  routes: mapRoutes
};

const timelineItems = entries.map((event) => {
  const linkedNames = [
    ...event.person_ids
      .map((id) => peopleById.get(id))
      .filter(Boolean)
      .map((person) => localized(person as Record<string, any>, "name")),
    ...event.place_ids
      .map((id) => placesById.get(id))
      .filter(Boolean)
      .map((place) => localized(place as Record<string, any>, "name")),
    ...event.organization_ids
      .map((id) => orgsById.get(id))
      .filter(Boolean)
      .map((org) => localized(org as Record<string, any>, "name"))
  ];
  const source = sourceById.get(event.source_ids[0]);
  return {
    event,
    linkedNames,
    date: dateLabel(event),
    title: localized(event, "title"),
    summary: localized(event, "summary"),
    conflictNote: localized(event, "conflict_notes"),
    category: labelCategory(event.category),
    themes: event.theme_tags.map(labelTheme),
    sourceUrl: source?.url ?? "",
    sourceTitle: source ? localized(source, "title") : "",
    search: [
      localized(event, "title"),
      localized(event, "summary"),
      dateLabel(event),
      labelCategory(event.category),
      t.history.eraLabels[event.era],
      ...linkedNames
    ].join(" ").toLocaleLowerCase(lang === "bg" ? "bg-BG" : "en-GB")
  };
});

const exactDateItems = timelineItems
  .filter((item) => item.event.date.month && item.event.date.day)
  .map((item) => ({
    id: item.event.id,
    year: item.event.date.year,
    month: item.event.date.month,
    day: item.event.date.day,
    date: item.date,
    title: item.title,
    summary: item.summary,
    conflictNote: item.conflictNote,
    sourceUrl: item.sourceUrl,
    sourceTitle: item.sourceTitle
  }));

const timelineConfig = {
  lang,
  api: {
    events: historyKnowledgeIndex.endpoints.events,
    organizations: historyKnowledgeIndex.endpoints.organizations,
    people: historyKnowledgeIndex.endpoints.people,
    places: historyKnowledgeIndex.endpoints.places,
    sources: historyKnowledgeIndex.endpoints.sources
  },
  categoryLabels: clientCategoryLabels,
  themeLabels: clientThemeLabels,
  labels: {
    visible: labels.visible,
    of: labels.of,
    noResults: labels.noResults,
    today: labels.today,
    noOnThisDay: labels.noOnThisDay,
    exactDateCount: labels.exactDateCount,
    source: labels.source,
    sourcePlural: labels.sourcePlural,
    conflictNote: labels.conflictNote,
    needsReview: labels.needsReview
  },
  total: entries.length,
  exactDateItems
};

const archiveItemsForView = [...historicalArchiveItems].sort(
  (a, b) => a.date_year - b.date_year || a.id.localeCompare(b.id)
);
const thenNowPairsForView = [...thenNowPairs].sort((a, b) =>
  localized(a, "title").localeCompare(localized(b, "title"), lang === "bg" ? "bg-BG" : "en-GB")
);

// --- City growth: population chart + neighbourhood timeline ---
const growth =
  lang === "bg"
    ? {
        title: "Как растеше градът",
        popTitle: "Население на Пловдив през годините",
        popLead:
          "Преброявания от Освобождението до днес. След бурния ръст през XX век населението достига връх през 1985 г., а след това намалява.",
        nbTitle: "Кога са се появили кварталите",
        nbLead:
          "Подбрани квартали и райони на Пловдив, подредени по времето на възникване — всеки с публичен източник.",
        source: "Източник"
      }
    : {
        title: "How the city grew",
        popTitle: "Population of Plovdiv over time",
        popLead:
          "Censuses from the Liberation to today. After rapid 20th-century growth the population peaked in 1985, then declined.",
        nbTitle: "When the neighbourhoods appeared",
        nbLead:
          "Selected Plovdiv neighbourhoods and districts, ordered by when they emerged — each with a public source.",
        source: "Source"
      };
const nbEraLabels: Record<NeighbourhoodEra, string> =
  lang === "bg"
    ? { ottoman: "Османски период", revival: "Възраждане", modern: "Ново време (XX в.)", socialist: "Социалистически период" }
    : { ottoman: "Ottoman period", revival: "National Revival", modern: "Modern era (20th c.)", socialist: "Socialist period" };

const numberFmt = new Intl.NumberFormat(lang === "bg" ? "bg-BG" : "en-GB");

const pop = [...plovdivPopulation].sort((a, b) => a.year - b.year);
const PW = 1000, PH = 340, popL = 56, popR = 16, popT = 30, popB = 46;
const minYear = pop[0].year;
const maxYear = pop[pop.length - 1].year;
const maxPop = Math.max(...pop.map((p) => p.population));
const niceMax = Math.ceil(maxPop / 100000) * 100000;
const popX = (year: number) => popL + ((year - minYear) / (maxYear - minYear)) * (PW - popL - popR);
const popY = (value: number) => PH - popB - (value / niceMax) * (PH - popT - popB);
const popPts = pop.map((p) => `${popX(p.year).toFixed(1)},${popY(p.population).toFixed(1)}`);
const popLine = `M ${popPts.join(" L ")}`;
const popArea = `M ${popX(minYear).toFixed(1)} ${(PH - popB).toFixed(1)} L ${popPts.join(" L ")} L ${popX(maxYear).toFixed(1)} ${(PH - popB).toFixed(1)} Z`;
const popYTicks = [0, 100000, 200000, 300000].concat(niceMax > 300000 ? [niceMax] : []);
const popXTicks = [1880, 1900, 1920, 1946, 1965, 1985, 2001, 2021].filter((y) => y >= minYear && y <= maxYear);
const peakPoint = pop.reduce((a, b) => (b.population > a.population ? b : a));

const nbOrder: NeighbourhoodEra[] = ["ottoman", "revival", "modern", "socialist"];
const nbByEra = nbOrder
  .map((era) => ({
    era,
    items: plovdivNeighbourhoods.filter((n) => n.era_key === era).sort((a, b) => a.year - b.year)
  }))
  .filter((g) => g.items.length > 0);
