      </div>

      <div class="grid grid-2">
        <article class="card arc-card">
          <svg
            class="mayor-arc"
            viewBox="0 0 1000 190"
            role="img"
            aria-label={labels.peopleTitle}
            preserveAspectRatio="xMidYMid meet"
          >
            {repeatArcs.map((d) => <path class="arc-repeat" d={d} fill="none" />)}
            <line class="arc-axis" x1={graphPad} y1={graphAxis} x2={graphWidth - graphPad} y2={graphAxis} />
            {mayorEvents.map((event) => {
              const cx = graphX(event.date.year);
              return (
                <circle class="dot" cx={cx} cy={graphAxis} r={event.date.year_end ? 4 : 6}>
                  <title>{`${localized(event, "title")} · ${dateLabel(event)}`}</title>
                </circle>
              );
            })}
          </svg>
          <div class="arc-legend">
            <span class="lg lg-repeat">{labels.repeatTerms}</span>
            <span class="lg lg-current">{t.mayors.legendCurrent}</span>
          </div>
        </article>
        <article class="card">
          <div class="stat-row budget-summary-stats" style="margin-top:0">
            <div class="stat"><strong>{historyKnowledgePeople.length}</strong><span>{labels.people}</span></div>
            <div class="stat"><strong>{mayorEvents.length}</strong><span>{t.mayors.statTerms}</span></div>
            <div class="stat"><strong>{repeatedPeople.length}</strong><span>{labels.repeatTerms}</span></div>
            <div class="stat"><strong>{successionCount}</strong><span>{labels.successionLinks}</span></div>
          </div>
          <ul class="connect-list" style="margin-top:18px">
            {repeatedPeople.slice(0, 8).map((person) => (
              <li>
                <span>{localized(person, "name")}</span>
                <span class="connect-years">{person.term_events.length} {t.mayors.statTerms}</span>
              </li>
            ))}
          </ul>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <div>
          <h2>{labels.dataTitle}</h2>
          <p class="meta" style="margin-top:8px;max-width:74ch">{labels.dataLead}</p>
          <div class="button-row" style="margin-top:14px">
            <a class="button secondary" href={localizePath("/history/editorial-review", lang)}>
              {labels.reviewDashboard}
            </a>
          </div>
        </div>
      </div>

      <div class="grid grid-2">
        <article class="card">
          <h3>{labels.endpoint}</h3>
          <ul class="source-list">
            {endpointRows.map((row) => (
              <li><a href={row.href}>{row.label}: {row.href}</a></li>
            ))}
          </ul>
        </article>
        <article class="card">
          <h3>{labels.download}</h3>
          <ul class="source-list">
            {downloadRows.map((row) => (
              <li>
                <a href={row.href} download>
                  {row.format}: {row.label} <span class="meta">({row.fileName})</span>
                </a>
              </li>
            ))}
          </ul>
        </article>
      </div>
      <p class="meta" style="margin-top:18px;max-width:80ch">{t.history.sourceNote}</p>
    </div>
