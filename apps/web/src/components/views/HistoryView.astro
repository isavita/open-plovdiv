  <script type="application/json" id="history-timeline-config" set:html={JSON.stringify(timelineConfig)}></script>
  <script type="application/json" id="history-map-config" set:html={JSON.stringify(historyMapConfig)}></script>

  <script>
    const timelineConfig = JSON.parse(
      document.getElementById("history-timeline-config")?.textContent ?? "{}"
    );
    const search = document.querySelector<HTMLInputElement>("#history-search")!;
    const era = document.querySelector<HTMLSelectElement>("#history-era")!;
    const category = document.querySelector<HTMLSelectElement>("#history-category")!;
    const theme = document.querySelector<HTMLSelectElement>("#history-theme")!;
    const person = document.querySelector<HTMLSelectElement>("#history-person")!;
    const place = document.querySelector<HTMLSelectElement>("#history-place")!;
    const linked = document.querySelector<HTMLSelectElement>("#history-linked")!;
    const count = document.querySelector<HTMLElement>("#history-count")!;
    const reset = document.querySelector<HTMLButtonElement>("#history-reset")!;
    const empty = document.querySelector<HTMLElement>("#history-empty")!;
    const list = document.querySelector<HTMLElement>("#history-event-list")!;
    let items: any[] = [];
    let timelineItemsPromise: Promise<any[]> | null = null;
    let exactDateItems: any[] = [];
    const eraButtons = [...document.querySelectorAll<HTMLButtonElement>("[data-era-button]")];
    const onThisDayDate = document.querySelector<HTMLInputElement>("#history-on-this-day-date")!;
    const onThisDayToday = document.querySelector<HTMLButtonElement>("#history-on-this-day-today")!;
    const onThisDayList = document.querySelector<HTMLElement>("#history-on-this-day-list")!;
    const onThisDayEmpty = document.querySelector<HTMLElement>("#history-on-this-day-empty")!;

    function escapeTimelineHtml(value: unknown): string {
      return String(value)
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
    }

    function splitDataset(value: string | undefined) {
      return (value ?? "").split(" ").filter(Boolean);
    }

    function versionedHistoryUrl(url: string) {
      if (!timelineConfig.dataVersion || /^(https?:)?\/\//.test(url)) return url;
      const separator = url.includes("?") ? "&" : "?";
      return `${url}${separator}v=${encodeURIComponent(timelineConfig.dataVersion)}`;
    }

    async function fetchHistoryJson(url: string) {
      const response = await fetch(versionedHistoryUrl(url));
      if (!response.ok) throw new Error(`Unable to load ${url}`);
      return await response.json();
    }

    function collectionFromPayload(payload: any, preferredKey: string) {
      if (Array.isArray(payload)) return payload;
      if (payload && Array.isArray(payload[preferredKey])) return payload[preferredKey];
      return [];
    }

    function localizedApi(record: Record<string, any> | undefined, base: string) {
      if (!record) return "";
      return String(record[`${base}_${timelineConfig.lang}`] ?? record[`${base}_en`] ?? record[`${base}_bg`] ?? "");
    }

    function dateApiLabel(event: any) {
      return localizedApi(event.date, "display");
    }

    function labelApiCategory(category: string) {
      return timelineConfig.categoryLabels?.[category] ?? category.replaceAll("_", " ");
    }

    function labelApiTheme(theme: string) {
      return timelineConfig.themeLabels?.[theme] ?? labelApiCategory(theme);
    }

    function shouldShowApiTheme(theme: string) {
      return !(timelineConfig.hiddenThemeTags ?? []).includes(theme);
    }

    async function loadTimelineItems() {
      if (items.length > 0) return items;
      if (timelineItemsPromise) return timelineItemsPromise;
      timelineItemsPromise = (async () => {
        const api = timelineConfig.api ?? {};
        const [eventPayload, sourcePayload, peoplePayload, placePayload, organizationPayload] = await Promise.all([
          fetchHistoryJson(api.events),
          fetchHistoryJson(api.sources),
          fetchHistoryJson(api.people),
          fetchHistoryJson(api.places),
          fetchHistoryJson(api.organizations)
        ]);
        const events = collectionFromPayload(eventPayload, "events").sort(
          (a: any, b: any) =>
            a.date.year - b.date.year ||
            (a.date.year_end ?? a.date.year) - (b.date.year_end ?? b.date.year) ||
            a.id.localeCompare(b.id)
        );
        const sourcesById = new Map(collectionFromPayload(sourcePayload, "sources").map((source: any) => [source.id, source]));
        const peopleById = new Map(collectionFromPayload(peoplePayload, "people").map((person: any) => [person.id, person]));
        const placesById = new Map(collectionFromPayload(placePayload, "places").map((place: any) => [place.id, place]));
        const organizationsById = new Map(
          collectionFromPayload(organizationPayload, "organizations").map((organization: any) => [organization.id, organization])
        );
        items = events.map((event: any) => {
          const linkedNames = [
            ...event.person_ids.map((id: string) => localizedApi(peopleById.get(id) as any, "name")),
            ...event.place_ids.map((id: string) => localizedApi(placesById.get(id) as any, "name")),
            ...event.organization_ids.map((id: string) => localizedApi(organizationsById.get(id) as any, "name"))
          ].filter(Boolean);
          const eventSources = event.source_ids
            .map((id: string) => sourcesById.get(id) as any)
            .filter(Boolean)
            .map((source: any) => ({
              url: source.url ?? "",
              title: localizedApi(source, "title")
            }));
          return {
            id: event.id,
            era: event.era,
            category: event.category,
            categoryLabel: labelApiCategory(event.category),
            themeTags: event.theme_tags,
            personIds: event.person_ids,
            placeIds: event.place_ids,
            organizationIds: event.organization_ids,
            peopleCount: event.person_ids.length,
            placesCount: event.place_ids.length,
            organizationCount: event.organization_ids.length,
            search: [
              localizedApi(event, "title"),
              localizedApi(event, "summary"),
              localizedApi(event, "conflict_notes"),
              dateApiLabel(event),
              labelApiCategory(event.category),
              ...(event.theme_tags ?? []).map(labelApiTheme),
              ...linkedNames
            ].join(" ").toLocaleLowerCase(timelineConfig.locale),
            date: dateApiLabel(event),
            title: localizedApi(event, "title"),
            summary: localizedApi(event, "summary"),
            conflictNote: localizedApi(event, "conflict_notes"),
            themes: (event.theme_tags ?? []).filter(shouldShowApiTheme).map(labelApiTheme).slice(0, 4),
            linkedNames: linkedNames.slice(0, 5),
            sources: eventSources,
            year: event.date.year,
            month: event.date.month,
            day: event.date.day,
            sourceUrl: eventSources[0]?.url ?? ""
          };
        });
        return items;
      })();
      try {
        return await timelineItemsPromise;
      } finally {
        timelineItemsPromise = null;
      }
    }

    async function loadExactDateItems() {
      if (exactDateItems.length > 0) return exactDateItems;
      const timelineItems = await loadTimelineItems();
      exactDateItems = timelineItems.filter((item) => item.month && item.day);
      return exactDateItems;
    }

    function renderPills(values: unknown[]) {
      return values.length
        ? `<div class="pill-row">${values
            .map((value) => `<span class="badge no-dot">${escapeTimelineHtml(value)}</span>`)
            .join(" ")}</div>`
        : "";
    }

    function renderTimelineItem(item: any) {
      const categoryLabel = item.categoryLabel ?? labelApiCategory(item.category ?? "");
      const sources = Array.isArray(item.sources) ? item.sources : [];
      const sourceLinks = sources.length
        ? `<div class="history-source-links"><span>${escapeTimelineHtml(timelineConfig.labels.sourcePlural ?? timelineConfig.labels.source)}</span>${sources
            .map(
              (source: any) =>
                `<a class="src-link" href="${escapeTimelineHtml(source.url)}" target="_blank" rel="noreferrer">${escapeTimelineHtml(source.title)} ↗</a>`
            )
            .join("")}</div>`
        : "";
      const conflictNote = item.conflictNote
        ? `<p class="history-conflict-note"><strong>${escapeTimelineHtml(timelineConfig.labels.conflictNote)}:</strong> ${escapeTimelineHtml(item.conflictNote)}</p>`
        : "";
      return `
        <li
          id="${escapeTimelineHtml(item.id)}"
          class="timeline-item history-event-item"
          data-history-event
          data-history-event-id="${escapeTimelineHtml(item.id)}"
          data-era="${escapeTimelineHtml(item.era)}"
          data-category="${escapeTimelineHtml(item.category)}"
        >
          <div class="timeline-marker" aria-hidden="true"></div>
          <article class="timeline-card history-event-card era-${escapeTimelineHtml(item.era)}">
            <header>
              <div>
                <p class="timeline-period">${escapeTimelineHtml(item.date)}</p>
                <h3>${escapeTimelineHtml(item.title)}</h3>
              </div>
              <span class="badge no-dot">${escapeTimelineHtml(categoryLabel)}</span>
            </header>
            <p>${escapeTimelineHtml(item.summary)}</p>
            ${conflictNote}
            ${renderPills(Array.isArray(item.themes) ? item.themes : [])}
            ${renderPills(Array.isArray(item.linkedNames) ? item.linkedNames : [])}
            <div class="history-source-row">
              ${sourceLinks}
            </div>
          </article>
        </li>`;
    }

    function matchesHistoryItem(item: any) {
      const q = search.value.trim().toLocaleLowerCase(timelineConfig.locale);
      const linkMode = linked.value;
      const themeTags = Array.isArray(item.themeTags) ? item.themeTags : splitDataset(item.themeTags);
      const personIds = Array.isArray(item.personIds) ? item.personIds : splitDataset(item.personIds);
      const placeIds = Array.isArray(item.placeIds) ? item.placeIds : splitDataset(item.placeIds);
      return (
        (!q || (item.search ?? "").includes(q)) &&
        (era.value === "all" || item.era === era.value) &&
        (category.value === "all" || item.category === category.value) &&
        (theme.value === "all" || themeTags.includes(theme.value)) &&
        (person.value === "all" || personIds.includes(person.value)) &&
        (place.value === "all" || placeIds.includes(place.value)) &&
        (linkMode === "all" ||
          (linkMode === "people" && Number(item.peopleCount) > 0) ||
          (linkMode === "places" && Number(item.placesCount) > 0) ||
          (linkMode === "organizations" && Number(item.organizationCount) > 0))
      );
    }

    function syncEraButtons() {
      eraButtons.forEach((button) => {
        button.setAttribute("aria-pressed", button.dataset.eraButton === era.value ? "true" : "false");
      });
    }

    function applyHistoryFilters() {
      const visibleItems = items.filter(matchesHistoryItem);
      list.innerHTML = visibleItems.map(renderTimelineItem).join("");
      count.textContent = `${timelineConfig.labels.visible}: ${visibleItems.length} ${timelineConfig.labels.of} ${items.length}`;
      empty.hidden = visibleItems.length !== 0;
      reset.hidden = !(
        search.value ||
        era.value !== "all" ||
        category.value !== "all" ||
        theme.value !== "all" ||
        person.value !== "all" ||
        place.value !== "all" ||
        linked.value !== "all"
      );
      syncEraButtons();
    }

    function refreshHistoryTimeline() {
      loadTimelineItems()
        .then(() => {
          applyHistoryFilters();
          void renderOnThisDay();
        })
        .catch(() => {
          empty.hidden = false;
          empty.textContent = timelineConfig.labels.noResults;
        });
    }

    const stableTimelineJumpTargets = new Set(["city-growth", "landmarks", "archive-layer", "people", "data"]);
    let pendingStableJumpTarget: string | null = null;

    function alignHistoryElement(target: HTMLElement) {
      const root = document.documentElement;
      const previousScrollBehavior = root.style.scrollBehavior;
      const offset = Number.parseFloat(window.getComputedStyle(target).scrollMarginTop) || 124;
      root.style.scrollBehavior = "auto";
      window.scrollTo({ top: Math.max(0, target.getBoundingClientRect().top + window.scrollY - offset), behavior: "auto" });
      root.style.scrollBehavior = previousScrollBehavior;
    }

    function alignHistorySection(id: string) {
      const target = document.getElementById(id);
      if (!target) return;
      alignHistoryElement(target);
    }

    async function waitForStableHistoryLayout(id: string) {
      const target = document.getElementById(id);
      if (!target) return;
      const startedAt = performance.now();
      let stableSamples = 0;
      let previousHeight = -1;
      let previousTargetTop = -1;
      for (let sample = 0; sample < 10; sample += 1) {
        await new Promise<void>((resolve) => {
          window.setTimeout(() => requestAnimationFrame(() => resolve()), 80);
        });
        if (pendingStableJumpTarget !== id && window.location.hash.slice(1) !== id) return;
        const height = document.documentElement.scrollHeight;
        const targetTop = Math.round(target.getBoundingClientRect().top + window.scrollY);
        if (Math.abs(height - previousHeight) <= 2 && Math.abs(targetTop - previousTargetTop) <= 2) {
          stableSamples += 1;
          if (stableSamples >= 2 && performance.now() - startedAt >= 480) return;
        } else {
          stableSamples = 0;
        }
        previousHeight = height;
        previousTargetTop = targetTop;
      }
    }

    function scrollToHistorySection(id: string) {
      const alignIfCurrent = () => {
        if (pendingStableJumpTarget !== id && window.location.hash.slice(1) !== id) return;
        alignHistorySection(id);
      };
      requestAnimationFrame(() => requestAnimationFrame(alignIfCurrent));
      [240, 600].forEach((delay) => {
        window.setTimeout(() => requestAnimationFrame(alignIfCurrent), delay);
      });
    }

    async function prepareAndJumpToHistorySection(id: string, updateHash = true) {
      pendingStableJumpTarget = id;
      if (updateHash) history.pushState(null, "", `#${id}`);
      try {
        await loadTimelineItems();
        applyHistoryFilters();
        await renderOnThisDay();
        await waitForStableHistoryLayout(id);
        if (pendingStableJumpTarget === id) scrollToHistorySection(id);
      } catch {
        scrollToHistorySection(id);
      }
    }

    async function selectTimelineEra(eraKey: string, updateHash = true) {
      const knownEra = eraButtons.some((button) => button.dataset.eraButton === eraKey);
      if (!knownEra) return;
      era.value = eraKey;
      if (updateHash) history.pushState(null, "", `#era-${eraKey}`);
      try {
        await loadTimelineItems();
        applyHistoryFilters();
        await renderOnThisDay();
        await new Promise<void>((resolve) => {
          requestAnimationFrame(() => requestAnimationFrame(() => resolve()));
        });
        const firstEraItem =
          [...list.querySelectorAll<HTMLElement>("[data-history-event]")].find((item) => item.dataset.era === eraKey) ?? list;
        alignHistoryElement(firstEraItem);
      } catch {
        refreshHistoryTimeline();
        alignHistorySection("timeline");
      }
    }

    function scheduleInitialTimelineRender() {
      const timelineSection = document.getElementById("timeline");
      if (timelineSection && "IntersectionObserver" in window) {
        const observer = new IntersectionObserver(
          (entries) => {
            if (entries.some((entry) => entry.isIntersecting)) {
              observer.disconnect();
              refreshHistoryTimeline();
            }
          },
          { rootMargin: "180px 0px" }
        );
        observer.observe(timelineSection);
      } else {
        window.setTimeout(refreshHistoryTimeline, 900);
      }
    }

    search.addEventListener("input", refreshHistoryTimeline);
    era.addEventListener("change", refreshHistoryTimeline);
    category.addEventListener("change", refreshHistoryTimeline);
    theme.addEventListener("change", refreshHistoryTimeline);
    person.addEventListener("change", refreshHistoryTimeline);
    place.addEventListener("change", refreshHistoryTimeline);
    linked.addEventListener("change", refreshHistoryTimeline);
    reset.addEventListener("click", () => {
      search.value = "";
      era.value = "all";
      category.value = "all";
      theme.value = "all";
      person.value = "all";
      place.value = "all";
      linked.value = "all";
      refreshHistoryTimeline();
    });
    eraButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const eraKey = button.dataset.eraButton ?? "";
        void selectTimelineEra(eraKey);
      });
    });

    document.querySelectorAll<HTMLAnchorElement>("[data-subnav-link]").forEach((link) => {
      const id = link.getAttribute("data-subnav-link") ?? "";
      if (!stableTimelineJumpTargets.has(id)) return;
      link.addEventListener("click", (event) => {
        event.preventDefault();
        void prepareAndJumpToHistorySection(id);
      });
    });

    function dateInputValue(date: Date) {
      const year = date.getFullYear();
      const month = String(date.getMonth() + 1).padStart(2, "0");
      const day = String(date.getDate()).padStart(2, "0");
      return `${year}-${month}-${day}`;
    }

    async function renderOnThisDay() {
      const parts = onThisDayDate.value.split("-").map((part) => Number(part));
      const month = parts[1];
      const day = parts[2];
      const datedItems = await loadExactDateItems();
      const matches = datedItems.filter((item: any) => item.month === month && item.day === day);
      onThisDayList.innerHTML = matches
        .map((item: any) => {
          const source = item.sourceUrl
            ? `<a href="${escapeTimelineHtml(item.sourceUrl)}" target="_blank" rel="noreferrer">${escapeTimelineHtml(timelineConfig.labels.source)} ↗</a>`
            : "";
          const conflictNote = item.conflictNote
            ? `<p class="history-conflict-note"><strong>${escapeTimelineHtml(timelineConfig.labels.conflictNote)}:</strong> ${escapeTimelineHtml(item.conflictNote)}</p>`
            : "";
          return `<li><strong>${escapeTimelineHtml(item.date)}</strong><span>${escapeTimelineHtml(item.title)}</span><p>${escapeTimelineHtml(item.summary)}</p>${conflictNote}${source}</li>`;
        })
        .join("");
      onThisDayEmpty.textContent = matches.length ? "" : timelineConfig.labels.noOnThisDay;
    }

    onThisDayDate.value = dateInputValue(new Date());
    onThisDayDate.addEventListener("change", () => void renderOnThisDay());
    onThisDayToday.addEventListener("click", () => {
      onThisDayDate.value = dateInputValue(new Date());
      void renderOnThisDay();
    });
    void renderOnThisDay();
    syncEraButtons();
    scheduleInitialTimelineRender();

    function syncHistoryHashTarget() {
      const target = window.location.hash.slice(1);
      if (target.startsWith("era-")) {
        void selectTimelineEra(target.replace(/^era-/, ""), false);
      } else if (stableTimelineJumpTargets.has(target)) {
        void prepareAndJumpToHistorySection(target, false);
      }
    }

    syncHistoryHashTarget();
    window.addEventListener("hashchange", syncHistoryHashTarget);
  </script>

  <script>
    document.querySelectorAll<HTMLInputElement>("[data-compare-range]").forEach((range) => {
      const frame = range.closest<HTMLElement>(".compare-frame");
      const update = () => frame?.style.setProperty("--split", `${range.value}%`);
      const setValue = (value: number) => {
        range.value = String(Math.min(100, Math.max(0, Math.round(value))));
        update();
      };
      const setFromPointer = (event: PointerEvent | MouseEvent) => {
        const rect = range.getBoundingClientRect();
        if (!rect.width) return;
        setValue(((event.clientX - rect.left) / rect.width) * 100);
        range.focus();
      };
      range.addEventListener("input", update);
      range.addEventListener("change", update);
      range.addEventListener("pointerdown", setFromPointer);
      range.addEventListener("click", setFromPointer);
      range.addEventListener("keydown", (event) => {
        const current = Number(range.value);
        const step = event.shiftKey ? 10 : 1;
        if (event.key === "ArrowLeft" || event.key === "ArrowDown") {
          event.preventDefault();
          setValue(current - step);
        } else if (event.key === "ArrowRight" || event.key === "ArrowUp") {
          event.preventDefault();
          setValue(current + step);
        } else if (event.key === "PageDown") {
          event.preventDefault();
          setValue(current - 10);
        } else if (event.key === "PageUp") {
          event.preventDefault();
          setValue(current + 10);
        } else if (event.key === "Home") {
          event.preventDefault();
          setValue(0);
        } else if (event.key === "End") {
          event.preventDefault();
          setValue(100);
        }
      });
      update();
    });
  </script>

  <script>
    const config = JSON.parse(document.getElementById("history-map-config")?.textContent ?? "{}");
    const routes = Array.isArray(config.routes) ? config.routes : [];
    const detail = document.querySelector<HTMLElement>("#history-place-detail")!;
    const mapEra = document.querySelector<HTMLSelectElement>("#history-map-era");
    const archiveSelect = document.querySelector<HTMLSelectElement>("#history-map-archive");
    const mapCount = document.querySelector<HTMLElement>("#history-map-count");
    const archiveCount = document.querySelector<HTMLElement>("#history-archive-map-count");
    const routeButtons = [...document.querySelectorAll<HTMLButtonElement>("[data-history-route]")];

    function escapeHtml(value: unknown): string {
      return String(value)
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
    }

    function versionedMapUrl(url: string) {
      if (!config.dataVersion || /^(https?:)?\/\//.test(url)) return url;
      const separator = url.includes("?") ? "&" : "?";
      return `${url}${separator}v=${encodeURIComponent(config.dataVersion)}`;
    }

    async function fetchMapJson(url: string) {
      const response = await fetch(versionedMapUrl(url));
      if (!response.ok) throw new Error(`Unable to load ${url}`);
      return await response.json();
    }

    function mapCollection(payload: any, preferredKey: string) {
      if (Array.isArray(payload)) return payload;
      if (payload && Array.isArray(payload[preferredKey])) return payload[preferredKey];
      return [];
    }

    function knownMapLabel(value: string) {
      const text = String(value ?? "");
      const direct = config.knownHistoryLabels?.[text];
      if (direct) return direct;
      const normalizedDirect = config.knownHistoryLabels?.[text.replaceAll("_", "-")];
      if (normalizedDirect) return normalizedDirect;
      if (config.lang === "de") {
        return text
          .replace(/^Modern period(,|$)/, "Moderne$1")
          .replace(/^Bulgarian Revival(,|$)/, "Bulgarische Wiedergeburtszeit$1")
          .replace(/^Roman period(,|$)/, "Römische Zeit$1")
          .replace(/^Ottoman period(,|$)/, "Osmanische Zeit$1")
          .replace(/^Thracian era(,|$)/, "Thrakische Zeit$1");
      }
      if (config.lang === "fr") {
        return text
          .replace(/^Modern period(,|$)/, "Époque moderne$1")
          .replace(/^Bulgarian Revival(,|$)/, "Renaissance nationale bulgare$1")
          .replace(/^Roman period(,|$)/, "Époque romaine$1")
          .replace(/^Ottoman period(,|$)/, "Époque ottomane$1")
          .replace(/^Thracian era(,|$)/, "Époque thrace$1");
      }
      if (config.lang === "it") {
        return text
          .replace(/^Modern period(,|$)/, "Epoca moderna$1")
          .replace(/^Bulgarian Revival(,|$)/, "Rinascita nazionale bulgara$1")
          .replace(/^Roman period(,|$)/, "Epoca romana$1")
          .replace(/^Ottoman period(,|$)/, "Epoca ottomana$1")
          .replace(/^Thracian era(,|$)/, "Epoca tracia$1");
      }
      if (config.lang === "tr") {
        return text
          .replace(/^Modern period(,|$)/, "Modern dönem$1")
          .replace(/^Bulgarian Revival(,|$)/, "Bulgar Ulusal Uyanışı$1")
          .replace(/^Roman period(,|$)/, "Roma dönemi$1")
          .replace(/^Ottoman period(,|$)/, "Osmanlı dönemi$1")
          .replace(/^Thracian era(,|$)/, "Trak dönemi$1");
      }
      if (config.lang === "es") {
        return text
          .replace(/^Modern period(,|$)/, "Época moderna$1")
          .replace(/^Bulgarian Revival(,|$)/, "Renacimiento Nacional búlgaro$1")
          .replace(/^Roman period(,|$)/, "Época romana$1")
          .replace(/^Ottoman period(,|$)/, "Época otomana$1")
          .replace(/^Thracian era(,|$)/, "Época tracia$1");
      }
      if (config.lang === "el") {
        return text
          .replace(/^Modern period(,|$)/, "Σύγχρονη περίοδος$1")
          .replace(/^Bulgarian Revival(,|$)/, "Βουλγαρική Εθνική Αναγέννηση$1")
          .replace(/^Roman period(,|$)/, "Ρωμαϊκή περίοδος$1")
          .replace(/^Ottoman period(,|$)/, "Οθωμανική περίοδος$1")
          .replace(/^Thracian era(,|$)/, "Θρακική εποχή$1");
      }
      if (config.lang === "ja") {
        return text
          .replace(/^Modern period(,|$)/, "近現代$1")
          .replace(/^Bulgarian Revival(,|$)/, "ブルガリア民族復興期$1")
          .replace(/^Roman period(,|$)/, "ローマ時代$1")
          .replace(/^Ottoman period(,|$)/, "オスマン時代$1")
          .replace(/^Thracian era(,|$)/, "トラキア時代$1");
      }
      return text;
    }

    function localizedMap(record: Record<string, any> | undefined, base: string) {
      if (!record) return "";
      return knownMapLabel(String(record[`${base}_${config.lang}`] ?? record[`${base}_en`] ?? record[`${base}_bg`] ?? ""));
    }

    function mapPlaceFacts(place: any) {
      const hasNamedCreator = Boolean(localizedMap(place, "architect") || localizedMap(place, "builder"));
      return [
        localizedMap(place.date_context, "display")
          ? { label: config.labels.built, value: localizedMap(place.date_context, "display") }
          : null,
        localizedMap(place, "architect") ? { label: config.labels.architect, value: localizedMap(place, "architect") } : null,
        localizedMap(place, "builder") ? { label: config.labels.builder, value: localizedMap(place, "builder") } : null,
        !hasNamedCreator && localizedMap(place.creator_context, "display")
          ? { label: config.labels.creator, value: localizedMap(place.creator_context, "display") }
          : null
      ].filter(Boolean);
    }

    async function loadHistoryMapData() {
      const api = config.api ?? {};
      const [placePayload, archivePayload, sourcePayload] = await Promise.all([
        fetchMapJson(api.places),
        fetchMapJson(api.archiveItems),
        fetchMapJson(api.sources)
      ]);
      const rawPlaces = mapCollection(placePayload, "places");
      const sourcesById = new Map(mapCollection(sourcePayload, "sources").map((source: any) => [source.id, source]));
      const rawPlaceById = new Map(rawPlaces.map((place: any) => [place.id, place]));
      const places = rawPlaces
        .filter((place: any) => place.coordinates)
        .map((place: any) => {
          const source = sourcesById.get(place.source_ids?.[0]) as any;
          return {
            id: place.id,
            category: place.category,
            eraKey: place.era,
            name: localizedMap(place, "name"),
            era: localizedMap(place, "era"),
            summary: localizedMap(place, "summary"),
            status: localizedMap(place, "current_status"),
            facts: mapPlaceFacts(place),
            coordinates: place.coordinates,
            media: place.media?.[0] ?? null,
            source: source
              ? {
                  url: source.url,
                  title: localizedMap(source, "title")
                }
              : null
          };
        });
      const archiveItems = mapCollection(archivePayload, "archive_items")
        .filter((item: any) => item.coordinates)
        .map((item: any) => {
          const place = rawPlaceById.get(item.place_id) as any;
          return {
            id: item.id,
            kind: item.kind,
            title: localizedMap(item, "title"),
            description: localizedMap(item, "description"),
            dateDisplay: localizedMap(item, "date_display"),
            place: place ? localizedMap(place, "name") : item.place_id,
            coordinates: item.coordinates,
            georeference: {
              method: item.georeference.method,
              confidence: item.georeference.confidence,
              notes: localizedMap(item.georeference, "notes")
            },
            overlayBounds: item.overlay_bounds
              ? {
                  south: item.overlay_bounds.south,
                  west: item.overlay_bounds.west,
                  north: item.overlay_bounds.north,
                  east: item.overlay_bounds.east,
                  method: item.overlay_bounds.method,
                  notes: localizedMap(item.overlay_bounds, "notes")
                }
              : null,
            media: item.media,
            source: {
              url: item.source.url,
              title: localizedMap(item.source, "title"),
              license: localizedMap(item.source.license, "label")
            }
          };
        });
      return { places, archiveItems };
    }

    function renderPlace(place: any) {
      const image = place.media;
      const factRows = Array.isArray(place.facts)
        ? place.facts
            .map(
              (fact: any) =>
                `<dt>${escapeHtml(fact.label)}</dt><dd>${escapeHtml(fact.value)}</dd>`
            )
            .join("")
        : "";
      detail.innerHTML = `
        ${
          image
            ? `<figure class="landmark-media detail-media"><img src="${escapeHtml(image.url)}" alt="${escapeHtml(place.name)}" loading="lazy" decoding="async"><figcaption>${escapeHtml(image.credit)} · ${escapeHtml(image.license)}</figcaption></figure>`
            : ""
        }
        <p class="eyebrow">${escapeHtml(place.era)}</p>
        <h2>${escapeHtml(place.name)}</h2>
        ${factRows ? `<dl class="place-facts">${factRows}</dl>` : ""}
        <p>${escapeHtml(place.summary)}</p>
        <p class="meta">${escapeHtml(place.status)}</p>
        ${
          place.source
            ? `<a class="src-link" href="${escapeHtml(place.source.url)}" target="_blank" rel="noreferrer">${escapeHtml(config.labels.source)}: ${escapeHtml(place.source.title)} ↗</a>`
            : ""
        }
      `;
    }

    function renderRoute(route: any, routePlaces: any[]) {
      const stops = routePlaces
        .map((place, index) => `<li><strong>${index + 1}.</strong> ${escapeHtml(place.name)}</li>`)
        .join("");
      detail.innerHTML = `
        <p class="eyebrow">${escapeHtml(config.labels.routeStops)} · ${routePlaces.length}</p>
        <h2>${escapeHtml(route.title)}</h2>
        <p>${escapeHtml(route.summary)}</p>
        <ol class="route-stop-list">${stops}</ol>
      `;
    }

    function archiveKindInitial(kind: string) {
      if (kind === "map") return "M";
      if (kind === "document") return "D";
      return "P";
    }

    function renderArchiveItem(item: any) {
      detail.innerHTML = `
        <figure class="landmark-media detail-media"><img src="${escapeHtml(item.media.url)}" alt="${escapeHtml(item.title)}" loading="lazy" decoding="async"><figcaption>${escapeHtml(item.media.credit)} · ${escapeHtml(item.media.license)}</figcaption></figure>
        <p class="eyebrow">${escapeHtml(item.dateDisplay)} · ${escapeHtml(item.kind)}</p>
        <h2>${escapeHtml(item.title)}</h2>
        <p>${escapeHtml(item.description)}</p>
        <dl class="place-facts">
          <dt>${escapeHtml(config.labels.archivePlace)}</dt>
          <dd>${escapeHtml(item.place)}</dd>
          <dt>${escapeHtml(config.labels.license)}</dt>
          <dd>${escapeHtml(item.source.license)}</dd>
          ${
            item.overlayBounds
              ? `<dt>${escapeHtml(config.labels.mapArchiveLayer)}</dt><dd>${escapeHtml(item.overlayBounds.notes)}</dd>`
              : ""
          }
        </dl>
        <p class="meta"><strong>${escapeHtml(config.labels.georeference)}:</strong> ${escapeHtml(item.georeference.notes)}</p>
        <p class="meta">${escapeHtml(config.labels.archiveOverlayNote)}</p>
        <a class="src-link" href="${escapeHtml(item.source.url)}" target="_blank" rel="noreferrer">${escapeHtml(config.labels.source)}: ${escapeHtml(item.source.title)} ↗</a>
      `;
    }

    async function initHistoryMap() {
      const leaflet = await import("leaflet");
      const L = leaflet.default;
      const { places, archiveItems } = await loadHistoryMapData();

      if (places.length) {
      const map = L.map("history-map-canvas", { scrollWheelZoom: false }).setView([42.148, 24.75], 14);
      L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
        maxZoom: 19,
        attribution: "&copy; OpenStreetMap contributors"
      }).addTo(map);
      const bounds = L.latLngBounds([]);
      const markerByPlaceId = new Map<string, any>();
      const placeById = new Map<string, any>(places.map((place: any) => [place.id, place]));
      const archiveMarkerById = new Map<string, any>();
      const archiveOverlayById = new Map<string, any>();
      let activeRouteId = "all";
      let routeLine: any = null;
      for (const place of places) {
        const coords = place.coordinates;
        bounds.extend([coords.lat, coords.lng]);
        const marker = L.marker([coords.lat, coords.lng], {
          title: place.name,
          icon: L.divIcon({
            className: "",
            html: `<span class="marker-pin history-pin marker-era-${escapeHtml(place.eraKey)}"><span>${escapeHtml(place.name.slice(0, 1))}</span></span>`,
            iconSize: [28, 28],
            iconAnchor: [14, 28]
          })
        }).on("click", () => renderPlace(place));
        markerByPlaceId.set(place.id, marker);
      }
      for (const item of archiveItems) {
        const coords = item.coordinates;
        const marker = L.marker([coords.lat, coords.lng], {
          title: item.title,
          zIndexOffset: 500,
          icon: L.divIcon({
            className: "",
            html: `<span class="marker-pin archive-pin archive-kind-${escapeHtml(item.kind)}"><span>${escapeHtml(archiveKindInitial(item.kind))}</span></span>`,
            iconSize: [28, 28],
            iconAnchor: [14, 14]
          })
        }).on("click", () => renderArchiveItem(item));
        archiveMarkerById.set(item.id, marker);
        if (item.kind === "map" && item.overlayBounds?.south < item.overlayBounds?.north && item.overlayBounds?.west < item.overlayBounds?.east) {
          const overlay = L.imageOverlay(
            item.media.url,
            [
              [item.overlayBounds.south, item.overlayBounds.west],
              [item.overlayBounds.north, item.overlayBounds.east]
            ],
            {
              alt: item.title,
              className: "historical-map-overlay",
              interactive: true,
              opacity: 0.38,
              zIndex: 180
            }
          ).on("click", () => renderArchiveItem(item));
          archiveOverlayById.set(item.id, overlay);
        }
      }

      function selectedRoute() {
        return routes.find((route: any) => route.id === activeRouteId) ?? null;
      }

      function visiblePlaces() {
        const route = selectedRoute();
        const routeIds = route ? new Set(route.stop_ids) : null;
        const selectedEra = mapEra?.value ?? "all";
        return places.filter((place: any) => {
          const matchesRoute = !routeIds || routeIds.has(place.id);
          const matchesEra = selectedEra === "all" || place.eraKey === selectedEra;
          return matchesRoute && matchesEra;
        });
      }

      function visibleArchiveItems() {
        const selectedArchive = archiveSelect?.value ?? "map";
        if (selectedArchive === "off") return [];
        if (selectedArchive === "all") return archiveItems;
        if (selectedArchive === "photo") return archiveItems.filter((item: any) => item.kind === "photo");
        return archiveItems.filter((item: any) => item.kind === selectedArchive);
      }

      function syncMapLayers() {
        const visible = visiblePlaces();
        const visibleIds = new Set(visible.map((place: any) => place.id));
        const visibleArchive = visibleArchiveItems();
        const visibleArchiveIds = new Set(visibleArchive.map((item: any) => item.id));
        for (const [placeId, marker] of markerByPlaceId.entries()) {
          const shouldShow = visibleIds.has(placeId);
          const isShown = map.hasLayer(marker);
          if (shouldShow && !isShown) marker.addTo(map);
          if (!shouldShow && isShown) marker.removeFrom(map);
        }
        for (const [itemId, marker] of archiveMarkerById.entries()) {
          const shouldShow = visibleArchiveIds.has(itemId);
          const isShown = map.hasLayer(marker);
          if (shouldShow && !isShown) marker.addTo(map);
          if (!shouldShow && isShown) marker.removeFrom(map);
        }
        for (const [itemId, overlay] of archiveOverlayById.entries()) {
          const shouldShow = visibleArchiveIds.has(itemId);
          const isShown = map.hasLayer(overlay);
          if (shouldShow && !isShown) overlay.addTo(map);
          if (!shouldShow && isShown) overlay.removeFrom(map);
        }

        if (routeLine) {
          routeLine.removeFrom(map);
          routeLine = null;
        }
        const route = selectedRoute();
        if (route) {
          const routePlaces = route.stop_ids.map((id: string) => placeById.get(id)).filter(Boolean);
          const visibleRoutePlaces = routePlaces.filter((place: any) => visibleIds.has(place.id));
          if (visibleRoutePlaces.length >= 2) {
            routeLine = L.polyline(
              visibleRoutePlaces.map((place: any) => [place.coordinates.lat, place.coordinates.lng]),
              { color: route.color, weight: 4, opacity: 0.82, dashArray: "7 8" }
            ).addTo(map);
          }
          renderRoute(route, visibleRoutePlaces.length ? visibleRoutePlaces : routePlaces);
        } else if (visible[0]) {
          renderPlace(visible[0]);
        }

        if (mapCount) {
          mapCount.textContent = `${visible.length} ${config.labels.visiblePlaces}`;
        }
        if (archiveCount) {
          archiveCount.textContent = `${visibleArchive.length} ${config.labels.visibleArchiveItems}`;
        }

        const visibleMapOverlays = visibleArchive.filter((item: any) => archiveOverlayById.has(item.id));
        if (visibleMapOverlays.length && (archiveSelect?.value ?? "map") === "map") {
          const nextBounds = L.latLngBounds([]);
          for (const item of visibleMapOverlays) {
            nextBounds.extend([item.overlayBounds.south, item.overlayBounds.west]);
            nextBounds.extend([item.overlayBounds.north, item.overlayBounds.east]);
          }
          map.fitBounds(nextBounds.pad(0.08));
        } else if (visible.length) {
          const nextBounds = L.latLngBounds(
            visible.map((place: any) => [place.coordinates.lat, place.coordinates.lng])
          );
          map.fitBounds(nextBounds.pad(visible.length === 1 ? 3 : 0.22));
        }
      }

      mapEra?.addEventListener("change", syncMapLayers);
      archiveSelect?.addEventListener("change", syncMapLayers);
      routeButtons.forEach((button) => {
        button.addEventListener("click", () => {
          activeRouteId = button.dataset.historyRoute ?? "all";
          routeButtons.forEach((item) => {
            const active = item === button;
            item.classList.toggle("is-active", active);
            item.setAttribute("aria-pressed", active ? "true" : "false");
          });
          syncMapLayers();
        });
      });
      if (places.length > 1) map.fitBounds(bounds.pad(0.22));
      syncMapLayers();
      }
    }

    function scheduleHistoryMapInit() {
      const mapSection = document.getElementById("landmarks");
      let started = false;
      let removeIntentFallback = () => {};
      const start = () => {
        if (started) return;
        started = true;
        removeIntentFallback();
        initHistoryMap().catch(() => {
          detail.innerHTML = `<h2>${escapeHtml(config.labels.selectPlace)}</h2><p class="meta">${escapeHtml(config.labels.archiveOverlayNote)}</p>`;
        });
      };

      if (mapSection && "IntersectionObserver" in window) {
        const observer = new IntersectionObserver(
          (entries) => {
            if (entries.some((entry) => entry.isIntersecting)) {
              observer.disconnect();
              start();
            }
          },
          { rootMargin: "600px 0px" }
        );
        observer.observe(mapSection);
      } else if ("requestIdleCallback" in window) {
        window.requestIdleCallback(start, { timeout: 2500 });
      } else {
        window.setTimeout(start, 500);
      }

      const intentEvents = ["wheel", "touchstart", "pointerdown", "keydown"] as const;
      removeIntentFallback = () => {
        intentEvents.forEach((eventName) => window.removeEventListener(eventName, start));
      };
      intentEvents.forEach((eventName) => {
        window.addEventListener(eventName, start, {
          once: true,
          passive: eventName !== "keydown"
        });
      });
    }

    scheduleHistoryMapInit();
  </script>

  <script type="application/json" id="nb-map-config" set:html={JSON.stringify(nbMapConfig)}></script>
  <script>
    const nbCfg = JSON.parse(document.getElementById("nb-map-config")?.textContent ?? "{}");
    const nbEl = document.getElementById("nb-map");
    const nbMarkers = (nbCfg.markers ?? []) as Array<{
      lat: number;
      lng: number;
      name: string;
      period: string;
      summary: string;
      era: string;
      color: string;
    }>;
    const nbEsc = (v: string) =>
      String(v).replaceAll("&", "&amp;").replaceAll("<", "&lt;").replaceAll(">", "&gt;");

    async function initNeighbourhoodMap() {
      if (!nbEl || !nbMarkers.length) return;
      const leaflet = await import("leaflet");
      const L = leaflet.default;
      const map = L.map(nbEl, { scrollWheelZoom: false }).setView([42.14, 24.75], 12);
      L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
        maxZoom: 19,
        attribution: "&copy; OpenStreetMap contributors"
      }).addTo(map);
      const pts: [number, number][] = [];
      for (const m of nbMarkers) {
        L.circleMarker([m.lat, m.lng], {
          radius: 9,
          color: m.color,
          weight: 2,
          fillColor: m.color,
          fillOpacity: 0.5
        })
          .addTo(map)
          .bindPopup(
            `<strong>${nbEsc(m.name)}</strong><br><span class="meta">${nbEsc(m.era)} · ${nbEsc(m.period)}</span><br>${nbEsc(m.summary)}<br><span class="meta">${nbEsc(nbCfg.approxNote)}</span>`
          );
        pts.push([m.lat, m.lng]);
      }
      if (pts.length > 1) map.fitBounds(pts, { padding: [40, 40] });
    }

    function scheduleNeighbourhoodMap() {
      if (!nbEl || !nbMarkers.length) return;
      let started = false;
      let removeIntentFallback = () => {};
      const start = () => {
        if (started) return;
        started = true;
        removeIntentFallback();
        void initNeighbourhoodMap();
      };
      if ("IntersectionObserver" in window) {
        const observer = new IntersectionObserver(
          (entries) => {
            if (entries.some((entry) => entry.isIntersecting)) {
              observer.disconnect();
              start();
            }
          },
          { rootMargin: "220px 0px" }
        );
        observer.observe(nbEl);
      } else {
        window.setTimeout(start, 1000);
      }
      const intentEvents = ["wheel", "touchstart", "pointerdown", "keydown"] as const;
      removeIntentFallback = () => {
        intentEvents.forEach((eventName) => window.removeEventListener(eventName, start));
      };
      intentEvents.forEach((eventName) => {
        window.addEventListener(eventName, start, {
          once: true,
          passive: eventName !== "keydown"
        });
      });
    }

    scheduleNeighbourhoodMap();
  </script>

</Layout>

