  .on-this-day-list li {
    display: grid;
    gap: 4px;
    padding: 12px;
    border: 1px solid var(--line);
    border-radius: var(--r-xs);
    background: var(--surface-2);
  }

  .on-this-day-list p {
    color: var(--ink-2);
  }

  .on-this-day-list a {
    justify-self: start;
    font-size: 0.9rem;
    font-weight: 650;
  }

  #history-on-this-day-empty {
