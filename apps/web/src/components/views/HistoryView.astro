  <section class="section" id="city-growth">
    <div class="container">
      <div class="section-head">
        <div><h2>{growth.title}</h2></div>
      </div>

      <div class="card chart-card">
        <h3>{growth.popTitle}</h3>
        <p class="meta" style="max-width:76ch;margin:6px 0 18px">{growth.popLead}</p>
        <svg class="pop-chart" viewBox={`0 0 ${PW} ${PH}`} role="img" aria-label={growth.popTitle}>
          {popYTicks.map((v) => (
            <g>
              <line class="pop-grid" x1={popL} y1={popY(v)} x2={PW - popR} y2={popY(v)} />
              <text class="pop-axis-label" x={popL - 8} y={popY(v) + 5} text-anchor="end">
                {v === 0 ? "0" : `${v / 1000}k`}
              </text>
            </g>
          ))}
          {popXTicks.map((y) => (
            <text class="pop-axis-label" x={popX(y)} y={PH - popB + 24} text-anchor="middle">{y}</text>
          ))}
          <path class="pop-area" d={popArea} />
          <path class="pop-line" d={popLine} />
          {pop.map((p) => (
            <circle
              class={p.year === peakPoint.year ? "pop-dot pop-dot-peak" : "pop-dot"}
              cx={popX(p.year)}
              cy={popY(p.population)}
              r={p.year === peakPoint.year ? 6 : 3.5}
            >
              <title>{`${p.year}: ${numberFmt.format(p.population)}`}</title>
            </circle>
          ))}
          <text class="pop-peak-label" x={popX(peakPoint.year)} y={popY(peakPoint.population) - 14} text-anchor="middle">
            {`${numberFmt.format(peakPoint.population)} · ${peakPoint.year}`}
          </text>
        </svg>
        <p class="meta" style="margin-top:8px">
          {growth.source}:{" "}
          <a href="https://en.wikipedia.org/wiki/Plovdiv" target="_blank" rel="noreferrer">Wikipedia — Plovdiv</a>
        </p>
      </div>

      <div class="section-head" style="margin-top:34px">
        <div>
          <h2 style="font-size:clamp(1.3rem,2.4vw,1.7rem)">{growth.nbTitle}</h2>
          <p class="meta" style="margin-top:8px;max-width:76ch">{growth.nbLead}</p>
        </div>
      </div>
      <div class="nb-eras">
        {nbByEra.map((group) => (
          <div class={`nb-era nb-${group.era}`}>
            <div class="nb-era-head">
              <span class="nb-era-dot" aria-hidden="true"></span>
              <h3>{nbEraLabels[group.era]}</h3>
            </div>
            <div class="nb-list">
              {group.items.map((n) => (
