type Props = { lang: Lang };
const { lang } = Astro.props;
const t = ui[lang];

const eraOrder: HistoryEra[] = [
  "prehistory",
  "thracian",
  "roman",
  "medieval",
  "ottoman",
  "revival",
  "liberation",
  "modern"
];

const entries = [...historyKnowledgeEvents].sort(
  (a, b) =>
    a.date.year - b.date.year ||
    (a.date.year_end ?? a.date.year) - (b.date.year_end ?? b.date.year) ||
    a.id.localeCompare(b.id)
);
const erasPresent = eraOrder.filter((era) => entries.some((e) => e.era === era));
const mayorEvents = entries.filter((event) => event.category === "mayor_term");
const signedOffCount = historyEditorialReview.summary.signed_off_records;
const totalEditorialRecords = historyEditorialReview.summary.total_tracked_records;

const stats = [
  { value: t.home.statYearsValue, label: t.history.statYears },
  { value: String(historyKnowledgeEvents.length), label: lang === "bg" ? "събития" : "events" },
  { value: String(historyKnowledgePeople.length), label: lang === "bg" ? "хора" : "people" },
  { value: String(historyKnowledgeSources.length), label: lang === "bg" ? "източника" : "sources" }
];

