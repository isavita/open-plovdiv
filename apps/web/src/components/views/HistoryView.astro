---
import Layout from "@layouts/Layout.astro";
import HeroBackdrop from "@components/HeroBackdrop.astro";
import { ui, type Lang } from "@i18n/ui";
import { localizePath } from "@i18n/utils";
import {
  historyEditorialReview,
  historyKnowledgeEvents,
  historyKnowledgeIndex,
  historyKnowledgeOrganizations,
  historyKnowledgePeople,
  historyKnowledgePlaces,
  historyKnowledgeSources,
  historicalArchiveItems,
  thenNowPairs,
  plovdivPopulation,
  plovdivNeighbourhoods,
  type HistoryEra,
  type KnowledgeEvent,
  type NeighbourhoodEra
