---
import Layout from "@layouts/Layout.astro";
import { ui, type Lang } from "@i18n/utils";
import { sourceTitle } from "@lib/format";
import {
  educationResources,
  historicalArchiveItems,
  historyKnowledgeEvents,
  historyKnowledgePlaces,
  historyKnowledgeSources,
  thenNowPairs,
  type EducationResource
} from "@lib/data";

type Props = {
  lang: Lang;
};

const { lang } = Astro.props;
const t = ui[lang];

const labels = {
  bg: {
    title: "Образователен хъб",
    eyebrow: "Уроци, работни листове и маршрути за разходка",
    lead:
      "Пет двуезични урока за историята на Пловдив, свързани със събитията, местата, архивните изображения и публичните източници в Open Plovdiv.",
    lessons: "урока",
    quiz: "въпроса в тестове",
    audio: "маршрута за разходка",
    sources: "източника",
    minutes: "мин",
    lessonPlan: "План на урока",
    objectives: "Цели",
    preparation: "Подготовка",
    evidence: "Свързани записи",
    events: "Събития",
    places: "Места",
    archive: "Архив",
    thenNow: "Тогава/сега",
    quizTitle: "Кратък тест",
    answer: "Отговор",
    handout: "Работен лист",
    audioRoutesTitle: "Маршрути за разходка",
    audioRoutesLead:
      "Всеки маршрут следва проверения сценарий от урока и може да се ползва като текстов водач за самостоятелна разходка или за работа с група.",
    stops: "спирки",
    openLesson: "Отвори урока",
    sourcesTitle: "Източници",
    editorialNote:
      "Материалите са подредени за работа в клас, разходки и самостоятелно четене, с ясни връзки към събития, места и източници."
  },
  en: {
    title: "Education Hub",
    eyebrow: "Lessons, worksheets and walking routes",
    lead:
      "Five bilingual lessons on Plovdiv's history, linked to the events, places, archive images and public sources in Open Plovdiv.",
    lessons: "lessons",
    quiz: "quiz questions",
    audio: "walking routes",
    sources: "sources",
    minutes: "min",
    lessonPlan: "Lesson Plan",
    objectives: "Objectives",
    preparation: "Preparation",
    evidence: "Linked Records",
    events: "Events",
    places: "Places",
    archive: "Archive",
    thenNow: "Then/Now",
    quizTitle: "Short Quiz",
    answer: "Answer",
    handout: "Worksheet",
    audioRoutesTitle: "Walking Routes",
    audioRoutesLead:
      "Each route follows the reviewed lesson script and works as a text guide for a self-guided walk or a group.",
    stops: "stops",
    openLesson: "Open lesson",
    sourcesTitle: "Sources",
    editorialNote:
      "The materials are structured for classroom work, walking routes and self-guided reading, with clear links to events, places and sources."
  }
}[lang];

function localized(record: Record<string, unknown>, field: string): string {
  return String(record[`${field}_${lang}`] ?? record[`${field}_bg`] ?? "");
}

function localizedList(record: Record<string, unknown>, field: string): string[] {
  const value = record[`${field}_${lang}`] ?? record[`${field}_bg`] ?? [];
  return Array.isArray(value) ? value.map(String) : [];
}

function sourceLabel(source: { title_bg: string; title_en: string }): string {
  return sourceTitle(lang === "bg" ? source.title_bg : source.title_en, lang);
}

const eventById = new Map(historyKnowledgeEvents.map((event) => [event.id, event]));
const placeById = new Map(historyKnowledgePlaces.map((place) => [place.id, place]));
const sourceById = new Map(historyKnowledgeSources.map((source) => [source.id, source]));
const archiveById = new Map(historicalArchiveItems.map((item) => [item.id, item]));
const pairById = new Map(thenNowPairs.map((pair) => [pair.id, pair]));

const quizCount = educationResources.reduce((sum, resource) => sum + resource.quiz.length, 0);
const audioCount = educationResources.filter((resource) => resource.audio_tour.production_status === "script_ready").length;
const sourceCount = new Set(educationResources.flatMap((resource) => resource.source_ids)).size;
const audioRouteSummaries = educationResources.map((resource) => ({
  id: resource.id,
  title: localized(resource.audio_tour, "title"),
  lessonTitle: localized(resource, "title"),
  duration: resource.duration_minutes,
  stops: resource.audio_tour.stops.length,
  firstStop: localized(resource.audio_tour.stops[0] ?? {}, "title")
}));

function evidenceNames(resource: EducationResource, type: "events" | "places" | "archive" | "thenNow") {
  const lookup = {
    events: {
      ids: resource.linked_event_ids,
      map: eventById
    },
    places: {
      ids: resource.linked_place_ids,
      map: placeById
    },
    archive: {
      ids: resource.linked_archive_item_ids,
      map: archiveById
    },
    thenNow: {
      ids: resource.linked_then_now_pair_ids,
      map: pairById
    }
  }[type];
  return lookup.ids.map((id) => localized((lookup.map.get(id) ?? { id }) as Record<string, unknown>, type === "places" ? "name" : "title"));
}
---

<Layout lang={lang} path="/education" title={labels.title} description={labels.lead}>
  <div class="education-page">
    <section class="section hero hero-compact education-hero">
      <div class="container hero-grid">
        <div>
          <p class="eyebrow">{labels.eyebrow}</p>
          <h1>{labels.title}</h1>
          <p class="lead">{labels.lead}</p>
        </div>
        <dl class="stats-grid education-stats" aria-label={labels.title}>
          <div class="stat-card">
            <dt>{labels.lessons}</dt>
            <dd>{educationResources.length}</dd>
          </div>
          <div class="stat-card">
            <dt>{labels.quiz}</dt>
            <dd>{quizCount}</dd>
          </div>
          <div class="stat-card">
            <dt>{labels.audio}</dt>
            <dd>{audioCount}</dd>
          </div>
          <div class="stat-card">
            <dt>{labels.sources}</dt>
            <dd>{sourceCount}</dd>
          </div>
        </dl>
      </div>
    </section>

    <section class="section" id="lessons">
      <div class="container">
        <div class="education-toolbar">
          <p class="meta">{labels.editorialNote}</p>
        </div>

        <section class="audio-route-overview" aria-labelledby="audio-routes-title">
          <div>
            <h2 id="audio-routes-title">{labels.audioRoutesTitle}</h2>
            <p>{labels.audioRoutesLead}</p>
          </div>
          <div class="audio-route-grid">
            {audioRouteSummaries.map((route) => (
              <article class="audio-route-card">
                <p class="eyebrow">{`${route.stops} ${labels.stops} · ${route.duration} ${labels.minutes}`}</p>
                <h3>{route.title}</h3>
                <p>{route.lessonTitle}</p>
                <p class="meta">{route.firstStop}</p>
                <a class="src-link" href={`#${route.id}`}>{labels.openLesson}</a>
              </article>
            ))}
          </div>
        </section>

        <div class="education-grid">
          {educationResources.map((resource) => {
            const sourceRecords = resource.source_ids
              .map((sourceId) => sourceById.get(sourceId))
              .filter(Boolean);
            return (
              <article class="education-card" id={resource.id} data-education-resource>
                <header>
                  <p class="eyebrow">{`${localized(resource, "audience")} · ${resource.duration_minutes} ${labels.minutes}`}</p>
                  <h2>{localized(resource, "title")}</h2>
                  <p>{localized(resource, "summary")}</p>
                  <p class="education-question">{localized(resource, "driving_question")}</p>
                  <div class="tag-row">
                    {resource.era_tags.map((tag) => <span>{t.history.eraLabels[tag]}</span>)}
                    {resource.subject_tags.slice(0, 3).map((tag) => <span>{tag.replaceAll("_", " ")}</span>)}
                  </div>
                </header>

                <div class="education-columns">
                  <section>
                    <h3>{labels.objectives}</h3>
                    <ul>
                      {localizedList(resource, "objectives").map((item) => <li>{item}</li>)}
                    </ul>
                  </section>
                  <section>
                    <h3>{labels.preparation}</h3>
                    <p>{localized(resource, "preparation")}</p>
                  </section>
                </div>

                <section class="lesson-plan">
                  <h3>{labels.lessonPlan}</h3>
                  <ol>
                    {resource.lesson_steps.map((step) => (
                      <li>
                        <strong>{`${localized(step, "phase")} · ${step.minutes} ${labels.minutes}`}</strong>
                        <span>{localized(step, "activity")}</span>
                      </li>
                    ))}
                  </ol>
                </section>

                <section>
                  <h3>{labels.evidence}</h3>
                  <dl class="evidence-list">
                    <dt>{labels.events}</dt>
                    <dd>{evidenceNames(resource, "events").join(" · ")}</dd>
                    <dt>{labels.places}</dt>
                    <dd>{evidenceNames(resource, "places").join(" · ")}</dd>
                    <dt>{labels.archive}</dt>
                    <dd>{evidenceNames(resource, "archive").join(" · ")}</dd>
                    <dt>{labels.thenNow}</dt>
                    <dd>{evidenceNames(resource, "thenNow").join(" · ")}</dd>
                  </dl>
                </section>

                <section class="education-quiz">
                  <h3>{labels.quizTitle}</h3>
                  {resource.quiz.map((item) => (
                    <details>
                      <summary>{localized(item, "question")}</summary>
                      <ol>
                        {localizedList(item, "answers").map((answer, index) => (
                          <li class={index === item.correct_answer_index ? "is-correct" : undefined}>{answer}</li>
                        ))}
                      </ol>
                      <p class="meta">{`${labels.answer}: ${localized(item, "explanation")}`}</p>
                    </details>
                  ))}
                </section>

                <section class="education-printable">
                  <h3>{localized(resource.printable_handout, "title")}</h3>
                  <ol>
                    {localizedList(resource.printable_handout, "tasks").map((task) => <li>{task}</li>)}
                  </ol>
                </section>

                <section class="audio-tour">
                  <h3>{localized(resource.audio_tour, "title")}</h3>
                  <ol>
                    {resource.audio_tour.stops.map((stop) => (
                      <li>
                        <strong>{localized(stop, "title")}</strong>
                        <span>{localized(stop, "narration")}</span>
                      </li>
                    ))}
                  </ol>
                </section>

                <section>
                  <h3>{labels.sourcesTitle}</h3>
                  <ul class="source-list">
                    {sourceRecords.map((source) => (
                      <li>
                        <a href={source!.url} target="_blank" rel="noreferrer">
                          {sourceLabel(source!)}
                        </a>
                        <span class="meta"> · {`${t.common.accessed} ${source!.accessed_at}`}</span>
                      </li>
                    ))}
                  </ul>
                </section>
              </article>
            );
          })}
        </div>
      </div>
    </section>
  </div>
</Layout>
