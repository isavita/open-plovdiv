---
import HeroBackdrop from "@components/HeroBackdrop.astro";
import StatusBadge from "@components/StatusBadge.astro";
import Layout from "@layouts/Layout.astro";
import { categoryColors, ui, type Lang } from "@i18n/ui";
import { field, localizePath } from "@i18n/utils";
import { budgetItems, projects } from "@lib/data";
import { categoryLabel, formatMoney } from "@lib/format";

type Props = { lang: Lang };
const { lang } = Astro.props;
const t = ui[lang];

const totalBudget = budgetItems.reduce((sum, item) => sum + item.amount_bgn, 0);
const latestProjects = projects.slice(0, 4);

const cards = [
  {
    href: localizePath("/fix-map", lang),
    eyebrow: t.home.cardMapEyebrow,
    title: t.home.cardMapTitle,
    text: t.home.cardMapText
  },
  {
    href: localizePath("/budget", lang),
    eyebrow: t.home.cardBudgetEyebrow,
    title: t.home.cardBudgetTitle,
    text: t.home.cardBudgetText
  },
  {
    href: localizePath("/projects", lang),
    eyebrow: t.home.cardProjectsEyebrow,
    title: t.home.cardProjectsTitle,
    text: t.home.cardProjectsText
  }
];
---

<Layout lang={lang} path="/" description={t.home.lead}>
  <section class="hero">
    <HeroBackdrop />
    <div class="container">
      <p class="eyebrow">{t.home.eyebrow}</p>
      <h1>{t.site.name}</h1>
      <p class="lead">{t.home.lead}</p>
      <div class="actions">
        <a class="button" href={localizePath("/fix-map", lang)}>
          {t.home.ctaMap}<span class="arrow" aria-hidden="true">→</span>
        </a>
        <a class="button secondary" href={localizePath("/budget", lang)}>{t.home.ctaBudget}</a>
      </div>
      <div class="stat-row" aria-label={t.home.statsLabel}>
        <div class="stat"><strong>{projects.length}</strong><span>{t.home.statProjects}</span></div>
        <div class="stat"><strong>{t.home.statReportsValue}</strong><span>{t.home.statReports}</span></div>
        <div class="stat"><strong>{budgetItems.length}</strong><span>{t.home.statBudget}</span></div>
        <div class="stat"><strong>{formatMoney(totalBudget, lang)}</strong><span>{t.home.statTotal}</span></div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2>{t.home.exploreTitle}</h2>
      </div>
      <div class="grid grid-3">
        {cards.map((card) => (
          <a class="card card-link" href={card.href}>
            <p class="eyebrow">{card.eyebrow}</p>
            <h3>{card.title}</h3>
            <p>{card.text}</p>
            <span class="arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-tint">
    <div class="container grid grid-2">
      <div>
        <div class="section-head">
          <h2>{t.home.latestProjects}</h2>
          <a href={localizePath("/projects", lang)}>{t.home.viewAll} →</a>
        </div>
        <div class="list">
          {latestProjects.map((project) => (
            <article class="card project-card">
              <header>
                <div>
                  <h3><a href={localizePath(`/projects/${project.id}`, lang)}>{field(project, "title", lang)}</a></h3>
                  <p class="meta">
                    <span class="cat-dot" style={`--dot:${categoryColors[project.category]}`}></span>
                    {categoryLabel(project.category, lang)} · {project.budget.year}
                  </p>
                </div>
                <StatusBadge status={project.status} type="project" lang={lang} />
              </header>
              <p>{field(project, "summary", lang)}</p>
            </article>
          ))}
        </div>
      </div>
      <div>
        <div class="section-head">
          <h2>{t.home.latestReports}</h2>
          <a href={localizePath("/fix-map", lang)}>{t.home.viewAll} →</a>
        </div>
        <div class="list">
          <article class="card project-card">
            <h3>{t.home.liveReportsTitle}</h3>
            <p>{t.home.liveReportsText}</p>
            <div class="actions" style="margin-top:12px">
              <a class="button secondary" href={localizePath("/fix-map/report", lang)}>{t.fixMap.reportCta}</a>
            </div>
          </article>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="notice">
        <span class="notice-icon" aria-hidden="true">ⓘ</span>
        <span>
          <strong>{t.home.noticeTitle}</strong>
          {t.home.notice}{" "}
          <a href={localizePath("/data-sources", lang)}>{t.home.noticeSources}</a> ·
          <a href={localizePath("/methodology", lang)}> {t.home.noticeMethodology}</a>.
        </span>
      </div>
    </div>
  </section>
</Layout>
