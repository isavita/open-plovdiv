---
import HeroBackdrop from "@components/HeroBackdrop.astro";
import Ornament from "@components/Ornament.astro";
import Layout from "@layouts/Layout.astro";
import { ui, type Lang } from "@i18n/ui";
import { field, localizePath } from "@i18n/utils";
import { plovdivLandmarks, cityArchive, storyLongreads, type HistoryEra } from "@lib/data";

type Props = { lang: Lang };
const { lang } = Astro.props;
const t = ui[lang];

const eraOrder: HistoryEra[] = [
  "prehistory",
  "thracian",
  "roman",
  "medieval",
  "ottoman",
  "revival",
  "liberation",
  "modern"
];

const mayorCount = cityArchive.filter((r) => r.kind === "mayor_term").length;

const stats = [
  { value: t.home.statYearsValue, label: t.home.statYears },
  { value: String(eraOrder.length), label: t.home.statEras },
  { value: String(mayorCount), label: t.home.statMayors },
  { value: String(plovdivLandmarks.length), label: t.home.statLandmarks }
];

// A small, chronological set of mayors with portraits — a visual way into the
// full 1878→today catalogue (not a "most important" claim).
const mayorsWithPortraits = cityArchive
  .filter((r) => r.kind === "mayor_term" && r.image)
  .sort((a, b) => a.year_start - b.year_start);
const featuredMayors = [
  ...new Set([0, 0.25, 0.5, 0.72, 1].map((f) => Math.round(f * (mayorsWithPortraits.length - 1))))
].map((i) => mayorsWithPortraits[i]);

const tr = (
  bg: string,
  en: string,
  de: string,
  fr: string,
  it: string,
  trk: string,
  es: string,
  el: string,
  ja: string
): string => ({ bg, en, de, fr, it, tr: trk, es, el, ja } satisfies Record<Lang, string>)[lang];

