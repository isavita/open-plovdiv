---
import HeroBackdrop from "@components/HeroBackdrop.astro";
import Ornament from "@components/Ornament.astro";
import Layout from "@layouts/Layout.astro";
import { ui, type Lang } from "@i18n/ui";
import { field, localizePath } from "@i18n/utils";
import { plovdivLandmarks, cityArchive, type HistoryEra } from "@lib/data";

type Props = { lang: Lang };
const { lang } = Astro.props;
const t = ui[lang];

const eraOrder: HistoryEra[] = [
  "prehistory",
  "thracian",
  "roman",
  "medieval",
  "ottoman",
  "revival",
  "liberation",
  "modern"
];

const mayorCount = cityArchive.filter((r) => r.kind === "mayor_term").length;

const stats = [
  { value: t.home.statYearsValue, label: t.home.statYears },
  { value: String(eraOrder.length), label: t.home.statEras },
  { value: String(mayorCount), label: t.home.statMayors },
  { value: String(plovdivLandmarks.length), label: t.home.statLandmarks }
];

// A small, chronological set of mayors with portraits — a visual way into the
// full 1878→today catalogue (not a "most important" claim).
const mayorsWithPortraits = cityArchive
  .filter((r) => r.kind === "mayor_term" && r.image)
  .sort((a, b) => a.year_start - b.year_start);
const featuredMayors = [
  ...new Set([0, 0.25, 0.5, 0.72, 1].map((f) => Math.round(f * (mayorsWithPortraits.length - 1))))
].map((i) => mayorsWithPortraits[i]);

const tr = (
  bg: string,
  en: string,
  de: string,
  fr: string,
  it: string,
  trk: string,
  es: string,
  el: string,
  ja: string
): string => ({ bg, en, de, fr, it, tr: trk, es, el, ja } satisfies Record<Lang, string>)[lang];

const labels = {
  pathsTitle: tr("Три начина да започнете", "Three ways to start", "Drei Einstiege", "Trois façons de commencer", "Tre modi per iniziare", "Başlamak için üç yol", "Tres formas de empezar", "Τρεις τρόποι να ξεκινήσετε", "3つの入口"),
  pathsLead: tr(
    "Началната страница вече води към три ясни задачи: научете историята, обиколете местата или помогнете на града.",
    "The homepage now points to three clear jobs: learn the history, walk the places, or help the city.",
    "Die Startseite führt zu drei klaren Aufgaben: Geschichte verstehen, Orte ablaufen oder der Stadt helfen.",
    "La page d'accueil mène à trois usages clairs : comprendre l'histoire, parcourir les lieux ou aider la ville.",
    "La homepage porta a tre azioni chiare: conoscere la storia, percorrere i luoghi o aiutare la città.",
    "Ana sayfa üç net işe yönlendirir: tarihi öğren, yerleri gez veya şehre yardım et.",
    "La portada lleva a tres tareas claras: conocer la historia, recorrer los lugares o ayudar a la ciudad.",
    "Η αρχική σελίδα οδηγεί σε τρεις καθαρές χρήσεις: μάθετε την ιστορία, περπατήστε τα μέρη ή βοηθήστε την πόλη.",
    "トップページは、歴史を学ぶ、場所を歩く、街を助けるという3つの目的に整理されています。"
  ),
  historyPath: tr("Разгледай историята", "Explore history", "Geschichte erkunden", "Explorer l'histoire", "Esplora la storia", "Tarihi keşfet", "Explorar la historia", "Εξερεύνηση ιστορίας", "歴史を探る"),
  historyPathText: tr(
    "Хронология, личности, разкази и източници от праисторията до днес.",
    "Timeline, people, stories and sources from prehistory to today.",
    "Zeitleiste, Personen, Geschichten und Quellen von der Vorgeschichte bis heute.",
    "Chronologie, personnes, récits et sources de la préhistoire à aujourd'hui.",
    "Cronologia, persone, racconti e fonti dalla preistoria a oggi.",
    "Tarih öncesinden bugüne zaman çizelgesi, kişiler, anlatılar ve kaynaklar.",
    "Cronología, personas, relatos y fuentes desde la prehistoria hasta hoy.",
    "Χρονολόγιο, πρόσωπα, αφηγήσεις και πηγές από την προϊστορία έως σήμερα.",
    "先史時代から現在までの年表、人物、ストーリー、出典。"
  ),
  visitPath: tr("Посети местата", "Visit places", "Orte besuchen", "Visiter les lieux", "Visita i luoghi", "Yerleri gez", "Visitar lugares", "Επίσκεψη σε μέρη", "場所を訪ねる"),
  visitPathText: tr(
    "Кратки пешеходни маршрути през римския, османския, възрожденския и гражданския пласт на града.",
    "Short walking routes through the Roman, Ottoman, Revival and civic layers of the city.",
    "Kurze Spazierwege durch römische, osmanische, Wiedergeburts- und bürgerliche Stadtschichten.",
    "De courts parcours dans les couches romaine, ottomane, renaissance et civique de la ville.",
    "Brevi percorsi negli strati romano, ottomano, della Rinascita nazionale e civico della città.",
    "Şehrin Roma, Osmanlı, Uyanış ve yurttaş katmanlarında kısa yürüyüş rotaları.",
    "Rutas cortas por las capas romana, otomana, renacentista y cívica de la ciudad.",
    "Σύντομες διαδρομές στα ρωμαϊκά, οθωμανικά, αναγεννησιακά και αστικά στρώματα της πόλης.",
    "ローマ、オスマン、民族復興、市民記憶の層を歩く短い散策ルート。"
  ),
  helpPath: tr("Помогни на града", "Help the city", "Der Stadt helfen", "Aider la ville", "Aiuta la città", "Şehre yardım et", "Ayudar a la ciudad", "Βοηθήστε την πόλη", "街を助ける"),
  helpPathText: tr(
    "Граждански сигнали, доброволчески инициативи и начини да се включите без профили и без шум.",
    "Citizen reports, volunteer initiatives and ways to take part without profiles or noise.",
    "Bürgermeldungen, Freiwilligeninitiativen und Wege mitzumachen, ohne Profile oder Lärm.",
    "Signalements citoyens, initiatives bénévoles et façons de participer sans profils ni bruit.",
    "Segnalazioni civiche, iniziative di volontariato e modi per partecipare senza profili o rumore.",
    "Yurttaş bildirimleri, gönüllü girişimleri ve profilsiz, gürültüsüz katılım yolları.",
    "Avisos ciudadanos, iniciativas voluntarias y formas de participar sin perfiles ni ruido.",
    "Αναφορές πολιτών, εθελοντικές πρωτοβουλίες και τρόποι συμμετοχής χωρίς προφίλ ή θόρυβο.",
    "市民レポート、ボランティア活動、プロフィール不要で参加できる方法。"
  ),
  politicalTitle: tr("Политическата история е ядрото", "Political history is the core", "Politische Geschichte als Kern", "L'histoire politique comme noyau", "La storia politica è il nucleo", "Siyasi tarih çekirdektir", "La historia política es el núcleo", "Η πολιτική ιστορία είναι ο πυρήνας", "政治史が中核です"),
  politicalLead: tr(
    "Кметовете, архивните промени и проектите са събрани като въпрос: кой управляваше и какво се промени.",
    "Mayors, archive changes and projects are framed as one question: who governed, and what changed.",
    "Bürgermeister, Archivänderungen und Projekte stehen unter einer Frage: Wer regierte, und was änderte sich?",
    "Maires, changements d'archives et projets répondent à une question : qui gouvernait, et qu'est-ce qui a changé ?",
    "Sindaci, cambiamenti d'archivio e progetti rispondono a una domanda: chi governava e cosa è cambiato.",
    "Belediye başkanları, arşiv değişiklikleri ve projeler tek soruda birleşir: kim yönetti, ne değişti?",
    "Alcaldes, cambios de archivo y proyectos se leen como una pregunta: quién gobernó y qué cambió.",
    "Δήμαρχοι, αρχειακές αλλαγές και έργα απαντούν σε ένα ερώτημα: ποιος κυβέρνησε και τι άλλαξε.",
    "市長、アーカイブ上の変化、プロジェクトを、誰が統治し何が変わったかという問いで結びます。"
  ),
  openRoutes: tr("Маршрутите", "Walking routes", "Routen", "Parcours", "Percorsi", "Rotalar", "Rutas", "Διαδρομές", "散策ルート"),
  routeCount: tr("4 маршрута", "4 walking routes", "4 Routen", "4 parcours", "4 percorsi", "4 rota", "4 rutas", "4 διαδρομές", "4 散策ルート"),
  openGovernance: tr("Управление", "Governance", "Governance", "Gouvernance", "Governo", "Yönetim", "Gobernanza", "Διακυβέρνηση", "統治"),
  evidenceLabel: tr("с източници", "with sources", "mit Quellen", "avec sources", "con fonti", "kaynaklı", "con fuentes", "με πηγές", "出典付き")
};

const entryPaths = [
  {
    href: localizePath("/history", lang),
    eyebrow: t.nav.history,
    title: labels.historyPath,
    text: labels.historyPathText,
    meta: `${stats[0].value} ${stats[0].label}`
  },
  {
    href: localizePath("/routes", lang),
    eyebrow: labels.openRoutes,
    title: labels.visitPath,
    text: labels.visitPathText,
    meta: labels.routeCount
  },
  {
    href: localizePath("/community", lang),
    eyebrow: t.nav.community,
    title: labels.helpPath,
    text: labels.helpPathText,
    meta: `${t.home.statReportsValue} · ${t.home.statReports}`
  }
];
---

<Layout lang={lang} path="/" description={t.home.lead}>
  <section class="hero">
    <HeroBackdrop />
    <div class="container">
      <p class="eyebrow">{t.home.eyebrow}</p>
      <h1>{t.site.name}</h1>
      <p class="lead">{t.home.lead}</p>
      <div class="actions">
        <a class="button" href={localizePath("/history", lang)}>
          {t.home.ctaHistory}<span class="arrow" aria-hidden="true">→</span>
        </a>
        <a class="button secondary" href={localizePath("/routes", lang)}>{labels.openRoutes}</a>
      </div>
      <div class="stat-row" aria-label={t.history.title}>
        {stats.map((s) => (
          <div class="stat"><strong>{s.value}</strong><span>{s.label}</span></div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <div>
          <h2>{labels.pathsTitle}</h2>
          <p class="meta" style="margin-top:8px;max-width:74ch">{labels.pathsLead}</p>
        </div>
      </div>
      <div class="grid grid-3">
        {entryPaths.map((path) => (
          <a class="card card-link civic-card" href={path.href}>
            <p class="eyebrow">{path.eyebrow}</p>
            <h3>{path.title}</h3>
            <p>{path.text}</p>
            <span class="badge no-dot">{path.meta}</span>
            <span class="arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Ornament />

  <section class="section section-tint">
    <div class="container">
      <div class="section-head">
        <div>
          <h2>{labels.politicalTitle}</h2>
          <p class="meta" style="margin-top:8px;max-width:74ch">{labels.politicalLead}</p>
        </div>
        <a href={localizePath("/governance", lang)}>{labels.openGovernance} →</a>
      </div>
      <div class="grid grid-2" style="align-items:start;margin-bottom:24px">
        <a class="card card-link" href={localizePath("/mayors", lang)}>
          <p class="eyebrow">{t.nav.mayors}</p>
          <h3>{t.home.cardMayorsTitle}</h3>
          <p>{t.home.cardMayorsText}</p>
          <span class="badge no-dot">{mayorCount} {labels.evidenceLabel}</span>
          <span class="arrow" aria-hidden="true">→</span>
        </a>
        <a class="card card-link" href={localizePath("/governance", lang)}>
          <p class="eyebrow">{labels.openGovernance}</p>
          <h3>{labels.openGovernance}</h3>
          <p>{labels.politicalLead}</p>
          <span class="badge no-dot">{t.nav.projects}</span>
          <span class="arrow" aria-hidden="true">→</span>
        </a>
      </div>
      <ul class="mayor-strip" role="list">
        {featuredMayors.map((m) => (
          <li>
            <a href={localizePath("/mayors", lang)}>
              <img
                class="mayor-portrait mayor-portrait-strip"
                src={m.image}
                alt={t.mayors.portraitAlt(field(m, "actor", lang))}
                loading="lazy"
                decoding="async"
                width="104"
                height="128"
              />
              <strong>{field(m, "actor", lang)}</strong>
              <span>{!m.year_end ? `${m.year_start}–` : m.year_end === m.year_start ? `${m.year_start}` : `${m.year_start}–${m.year_end}`}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</Layout>
