// Mayors preview: the first mayor to take office in each of the city's four
// political periods (same bands as the /mayors chronology). A deterministic,
// factual selection — from the Liberation to the incumbent.
const mayorPeriods = [
  { start: 1878, end: 1944, label: labels.eraLiberation },
  { start: 1945, end: 1989, label: labels.eraSocialist },
  { start: 1990, end: 2022, label: labels.eraDemocratic },
  { start: 2023, end: null as number | null, label: labels.eraCurrent }
]
  .map((band) => {
    const terms = mayorTerms.filter(
      (m) => m.year_start >= band.start && (band.end == null || m.year_start <= band.end)
    );
    return { ...band, count: terms.length, mayor: terms[0] };
  })
  .filter((band) => band.mayor);

const termYears = (m: (typeof mayorTerms)[number]): string =>
  m.year_end == null ? `${m.year_start}–` : m.year_end === m.year_start ? `${m.year_start}` : `${m.year_start}–${m.year_end}`;

const initialsOf = (name: string): string =>
  name
    .replace(/^(д-р|Д-р|инж\.)\s+/u, "")
    .trim()
    .split(/\s+/)
    .slice(0, 2)
    .map((w) => w[0] ?? "")
    .join("");

// Commons photo (with credit) for an essentials place card.
const placeMedia = (id: string) => {
  const media = historyKnowledgePlaces.find((p) => p.id === id)?.media?.[0];
  return media
    ? { src: commonsImageUrl(media.url, 640), credit: `${media.credit} · ${media.license}` }
    : null;
};

// The four visitor-first entry paths: history, routes, places, stories.
const entryPaths = [
  {
    href: localizePath("/history", lang),
    eyebrow: t.nav.history,
    title: labels.historyPath,
    text: labels.historyPathText,
    meta: `${stats[0].value} ${stats[0].label}`
  },
  {
    href: localizePath("/routes", lang),
    eyebrow: labels.openRoutes,
    title: labels.routesPath,
    text: labels.routesPathText,
    meta: labels.routeCount
  },
  {
    href: localizePath("/places", lang),
    eyebrow: t.nav.places,
    title: labels.placesPath,
    text: labels.placesPathText,
    meta: `${plovdivLandmarks.length} ${t.home.statLandmarks}`
  },
  {
    href: localizePath("/stories", lang),
    eyebrow: t.nav.stories,
    title: labels.storiesPath,
    text: labels.storiesPathText,
    meta: `${storyLongreads.length} ${labels.storiesCountLabel}`
  }
];

// First-visit "ailyak essentials" — four landmark pages within a short walk
// of one another, each with a practical, unhurried tip.
const essentials = [
  {
    href: localizePath("/places/place-old-town", lang),
    eyebrow: labels.oldTownEyebrow,
    title: labels.oldTownTitle,
    text: labels.oldTownText,
    media: placeMedia("place-old-town")
  },
  {
    href: localizePath("/places/place-ancient-theatre", lang),
    eyebrow: labels.theatreEyebrow,
    title: labels.theatreTitle,
    text: labels.theatreText,
    media: placeMedia("place-ancient-theatre")
  },
  {
    href: localizePath("/places/place-kapana-q12282547", lang),
    eyebrow: labels.kapanaEyebrow,
    title: labels.kapanaTitle,
    text: labels.kapanaText,
    media: placeMedia("place-kapana-q12282547")
  },
  {
    href: localizePath("/places/place-nebet-tepe", lang),
    eyebrow: labels.nebetEyebrow,
    title: labels.nebetTitle,
    text: labels.nebetText,
    media: placeMedia("place-nebet-tepe")
  }
];

// Quiet secondary destinations under the civic section.
const moreLinks = [
  { href: localizePath("/people", lang), label: t.nav.people },
  { href: localizePath("/archive", lang), label: t.nav.archive },
  { href: localizePath("/overview", lang), label: t.nav.overview },
  { href: localizePath("/projects", lang), label: t.nav.projects }
];
---

<Layout lang={lang} path="/" description={t.home.lead}>
  <section class="hero">
    <HeroBackdrop />
    <div class="container">
      <p class="eyebrow">{t.home.eyebrow}</p>
      <h1>{t.site.name}</h1>
      <p class="lead">{t.home.lead}</p>
      <p class="hero-motto">{labels.heroMotto}</p>
      <div class="actions">
        <a class="button" href={localizePath("/history", lang)}>
          {t.home.ctaHistory}<span class="arrow" aria-hidden="true">→</span>
        </a>
        <a class="button secondary" href={localizePath("/routes", lang)}>{labels.routesPath}</a>
      </div>
      <div class="stat-row" aria-label={t.history.title}>
        {stats.map((s) => (
          <a class="stat" href={s.href}><strong>{s.value}</strong><span>{s.label}</span></a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <div>
          <h2>{labels.startTitle}</h2>
          <p class="meta" style="margin-top:8px;max-width:74ch">{labels.startLead}</p>
        </div>
      </div>
      <div class="grid grid-2">
        {entryPaths.map((path) => (
          <a class="card card-link civic-card" href={path.href}>
            <p class="eyebrow">{path.eyebrow}</p>
            <h3>{path.title}</h3>
            <p>{path.text}</p>
            <span class="badge no-dot">{path.meta}</span>
            <span class="arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Ornament />

  <section class="section section-tint">
    <div class="container">
      <div class="section-head">
        <div>
          <h2>{labels.essentialsTitle}</h2>
          <p class="meta" style="margin-top:8px;max-width:74ch">{labels.essentialsLead}</p>
        </div>
        <a href={localizePath("/places", lang)}>{labels.allPlaces} →</a>
      </div>
      <div class="grid grid-2">
        {essentials.map((place) => (
          <a class="card card-link essential-card" href={place.href}>
            {place.media && (
              <figure class="essential-media">
                <img
                  src={place.media.src}
                  alt={place.title}
                  loading="lazy"
                  decoding="async"
                  width="640"
                  height="400"
                />
                <figcaption>{place.media.credit}</figcaption>
              </figure>
            )}
            <div class="essential-body">
              <p class="eyebrow">{place.eyebrow}</p>
              <h3>{place.title}</h3>
              <p>{place.text}</p>
              <span class="arrow" aria-hidden="true">→</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Ornament />

  <section class="section">
    <div class="container">
      <div class="section-head">
        <div>
          <p class="eyebrow">{t.nav.mayors} · 1878–{new Date().getFullYear()}</p>
          <h2>{labels.mayorsTitle}</h2>
          <p class="meta" style="margin-top:8px;max-width:74ch">{labels.mayorsLead}</p>
        </div>
        <a href={localizePath("/mayors", lang)}>{labels.allMayors} →</a>
      </div>
      <div class="grid mayor-era-grid">
        {mayorPeriods.map((band) => (
          <a class="card card-link mayor-era-card" href={localizePath(`/mayors/${band.mayor.id}`, lang)}>
            <p class="eyebrow">{band.label}</p>
            {band.mayor.image ? (
              <img
                class="mayor-portrait mayor-era-portrait"
                src={band.mayor.image}
                alt={t.mayors.portraitAlt(field(band.mayor, "actor", lang))}
                loading="lazy"
                decoding="async"
                width="108"
                height="132"
              />
            ) : (
              <span class="mayor-portrait mayor-portrait-fallback mayor-era-portrait" aria-hidden="true">
                {initialsOf(field(band.mayor, "actor", lang))}
              </span>
            )}
            <h3>{field(band.mayor, "actor", lang)}</h3>
            <p class="mayor-era-years">{termYears(band.mayor)}</p>
            <span class="badge no-dot">
              {band.end == null ? t.archive.currentMayor : `${band.start}–${band.end} · ${t.mayors.count(band.count)}`}
            </span>
            <span class="arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Ornament />

  <section class="section section-tint">
    <div class="container">
      <div class="section-head">
        <div>
          <h2>{labels.civicTitle}</h2>
          <p class="meta" style="margin-top:8px;max-width:74ch">{labels.civicLead}</p>
        </div>
      </div>
      <div class="grid grid-3" style="align-items:start">
        <a class="card card-link" href={localizePath("/governance", lang)}>
          <p class="eyebrow">{labels.openGovernance}</p>
          <h3>{labels.govCardTitle}</h3>
          <p>{labels.govCardText}</p>
          <span class="badge no-dot">{t.nav.projects}</span>
          <span class="arrow" aria-hidden="true">→</span>
        </a>
        <a class="card card-link" href={localizePath("/community", lang)}>
          <p class="eyebrow">{t.nav.community}</p>
          <h3>{labels.helpPath}</h3>
          <p>{labels.helpPathText}</p>
          <span class="badge no-dot">{t.home.statReportsValue} · {t.home.statReports}</span>
          <span class="arrow" aria-hidden="true">→</span>
        </a>
        <a class="card card-link" href={localizePath("/data-sources", lang)}>
          <p class="eyebrow">{t.footer.sources}</p>
          <h3>{labels.sourcesCardTitle}</h3>
          <p>{labels.sourcesCardText}</p>
          <span class="badge no-dot">{sourceRegistry.length} {labels.sourcesCount}</span>
          <span class="arrow" aria-hidden="true">→</span>
        </a>
      </div>
      <div class="pill-row home-more">
        <span class="meta">{labels.moreLabel}</span>
        {moreLinks.map((link) => (
          <a class="meta" href={link.href}>{link.label}</a>
        ))}
      </div>
    </div>
  </section>
</Layout>
