---
import HeroBackdrop from "@components/HeroBackdrop.astro";
import Ornament from "@components/Ornament.astro";
import Layout from "@layouts/Layout.astro";
import { ui, type Lang } from "@i18n/ui";
import { field, localizePath } from "@i18n/utils";
import { commonsImageUrl } from "@lib/commons";
import {
  plovdivLandmarks,
  cityArchive,
  historyKnowledgePlaces,
  sourceRegistry,
  storyLongreads,
  type HistoryEra
} from "@lib/data";

type Props = { lang: Lang };
const { lang } = Astro.props;
const t = ui[lang];

const eraOrder: HistoryEra[] = [
  "prehistory",
  "thracian",
  "roman",
  "medieval",
  "ottoman",
  "revival",
  "liberation",
  "modern"
];

const mayorTerms = cityArchive
  .filter((r) => r.kind === "mayor_term")
  .sort((a, b) => a.year_start - b.year_start);
const mayorCount = mayorTerms.length;

// Each hero stat doubles as a quiet link into the catalogue it counts.
const stats = [
  { value: t.home.statYearsValue, label: t.home.statYears, href: localizePath("/history", lang) },
  { value: String(eraOrder.length), label: t.home.statEras, href: localizePath("/history", lang) + "#timeline" },
  { value: String(mayorCount), label: t.home.statMayors, href: localizePath("/mayors", lang) },
  { value: String(plovdivLandmarks.length), label: t.home.statLandmarks, href: localizePath("/places", lang) }
];

