---
import Layout from "@layouts/Layout.astro";
import { categoryColors, ui, type Lang } from "@i18n/ui";
import { localizePath } from "@i18n/utils";
import { projects } from "@lib/data";
import { categoryLabel, projectStatusLabel } from "@lib/format";

type Props = { lang: Lang };
const { lang } = Astro.props;
const t = ui[lang];

// ---- Projects: status, category, year -------------------------------------
const statusColors: Record<string, string> = {
  in_progress: "#1b5f7c",
  funded: "#1f6b48",
  contracted: "#1b5f7c",
  planned: "#6a7278",
  completed: "#1f6b48",
  delayed: "#93412f",
  postponed: "#b07d1a",
  unknown: "#6a7278"
};

function countBy<T>(items: T[], key: (item: T) => string): Map<string, number> {
  const map = new Map<string, number>();
  for (const item of items) {
    const k = key(item);
    map.set(k, (map.get(k) ?? 0) + 1);
  }
  return map;
}

const statusCounts = [...countBy(projects, (p) => p.status).entries()].sort((a, b) => b[1] - a[1]);
const categoryCounts = [...countBy(projects, (p) => p.category).entries()].sort((a, b) => b[1] - a[1]);

const postponedCount = projects.filter((p) => p.status === "postponed").length;

// ---- Donut helper ----------------------------------------------------------
const R = 68;
const CIRC = 2 * Math.PI * R;

type Seg = { label: string; value: number; color: string; len: number; gap: number; offset: number };

function donut(items: { label: string; value: number; color: string }[]): Seg[] {
  const total = items.reduce((s, i) => s + i.value, 0) || 1;
  let acc = 0;
  return items.map((it) => {
    const len = (it.value / total) * CIRC;
    const seg: Seg = { ...it, len, gap: CIRC - len, offset: -acc };
    acc += len;
    return seg;
  });
}

const statusSegs = donut(
  statusCounts.map(([status, count]) => ({
    label: projectStatusLabel(status, lang),
    value: count,
    color: statusColors[status] ?? "#6a7278"
  }))
);

const maxCategory = Math.max(...categoryCounts.map(([, c]) => c), 1);
---

<Layout lang={lang} path="/overview" title={t.overview.title} description={t.overview.lead}>
  <section class="page-head">
    <div class="container">
      <p class="eyebrow">{t.overview.eyebrow}</p>
      <h1>{t.overview.title}</h1>
      <p class="lead">{t.overview.lead}</p>
      <p class="meta" style="margin-top:10px">{t.overview.asOf}</p>
    </div>
  </section>

  <section class="section" style="padding-top:0">
    <div class="container">
      <div class="stat-row">
        <div class="stat"><strong>{projects.length}</strong><span>{t.overview.statProjects}</span></div>
        <div class="stat"><strong>{postponedCount}</strong><span>{t.overview.statPostponed}</span></div>
      </div>

      <div class="chart-grid" style="margin-top:24px">
        <!-- Projects by status (donut) -->
        <div class="chart-card">
          <h3>{t.overview.byStatusTitle}</h3>
          <div class="donut-wrap">
            <div class="donut-figure">
              <svg class="donut" viewBox="0 0 168 168" role="img" aria-label={t.overview.byStatusTitle}>
                <circle cx="84" cy="84" r={R} fill="none" stroke="var(--surface-3)" stroke-width="22" />
                {statusSegs.map((s) => (
                  <circle
                    class="donut-seg"
                    cx="84"
                    cy="84"
                    r={R}
                    stroke={s.color}
                    stroke-dasharray={`${s.len} ${s.gap}`}
                    stroke-dashoffset={s.offset}
                  />
                ))}
              </svg>
              <div class="donut-center"><strong>{projects.length}</strong><span>{t.nav.projects.toLowerCase()}</span></div>
            </div>
            <ul class="chart-legend">
              {statusSegs.map((s) => (
                <li>
                  <span class="swatch" style={`background:${s.color}`}></span>
                  {s.label}
                  <span class="legend-value">{s.value}</span>
                </li>
              ))}
            </ul>
          </div>
          <p class="chart-source">
            {t.overview.unitProjects} · <a href={localizePath("/projects", lang)}>{t.overview.viewProjects} →</a>
          </p>
        </div>

        <!-- Projects by category (bars) -->
        <div class="chart-card">
          <h3>{t.overview.byCategoryTitle}</h3>
          <div class="chart">
            {categoryCounts.map(([category, count]) => (
              <div class="bar-row">
                <span class="bar-label">
                  <span class="cat-dot" style={`--dot:${categoryColors[category] ?? "var(--muted)"}`}></span>
                  {categoryLabel(category, lang)}
                </span>
                <div class="bar-track" aria-hidden="true">
                  <div class="bar-fill" data-flat style={`width:${Math.max(6, (count / maxCategory) * 100)}%;--fill:${categoryColors[category] ?? "var(--brand)"}`}></div>
                </div>
                <span class="money">{count}</span>
              </div>
            ))}
          </div>
          <p class="chart-source">
            {t.overview.unitProjects} · <a href={localizePath("/projects", lang)}>{t.overview.viewProjects} →</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="notice">
        <span class="notice-icon" aria-hidden="true">ⓘ</span>
        <span>{t.overview.historyNote}</span>
      </div>
      <div class="actions">
        <a class="button secondary" href={localizePath("/projects", lang)}>{t.overview.viewProjects}</a>
      </div>
    </div>
  </section>
</Layout>
