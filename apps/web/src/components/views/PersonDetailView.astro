        back: "Всички хора",
        profile: "Профил",
        facts: "Данни",
        roles: "Роли",
        life: "Години",
        born: "Роден/а",
        wikidata: "Wikidata",
        linkedEvents: "Свързани събития",
        relationships: "Връзки с други личности",
        noRelationships: "В базата още няма отделни person-to-person връзки за този запис.",
        evidence: "Източници и произход",
        source: "Източник",
        accessed: "Достъп",
        license: "Лиценз",
        editorial: "Редакторски статус",
        statusPending: "Очаква независим редакторски преглед",
        statusSignedOff: "Редакционно потвърден",
        provenance: "Произход на твърденията",
        relationshipSource: "Източник за връзката",
        linkedEvent: "Свързано събитие",
        imageCredit: "Кредит за изображение",
        pending: "Записът е валидиран и източниково проследим, но очаква независим редакторски преглед."
      }
    : {
        back: "All people",
        profile: "Profile",
        facts: "Facts",
        roles: "Roles",
        life: "Life dates",
        born: "Born",
        wikidata: "Wikidata",
        linkedEvents: "Linked events",
        relationships: "Connections to other people",
        noRelationships: "No separate person-to-person links are in the base for this record yet.",
        evidence: "Sources and provenance",
        source: "Source",
        accessed: "Accessed",
        license: "License",
        editorial: "Editorial status",
        statusPending: "Awaiting independent editorial review",
        statusSignedOff: "Editorially signed off",
        provenance: "Claim provenance",
        relationshipSource: "Relationship source",
        linkedEvent: "Linked event",
        imageCredit: "Image credit",
        pending: "The record is validated and source-traceable, but still awaits independent editorial review."
      };

