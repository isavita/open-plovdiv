---
import Layout from "@layouts/Layout.astro";
import { localizePath, type Lang } from "@i18n/utils";
import {
  historyKnowledgeEvents,
  historyKnowledgePeople,
  historyKnowledgeSources,
  type KnowledgeEvent,
  type KnowledgePerson,
  type KnowledgeSource
} from "@lib/data";

type Props = {
  lang: Lang;
  person: KnowledgePerson;
};

type RoleGroup = "governance" | "culture" | "science" | "faith" | "sport" | "civic";

const { lang, person } = Astro.props;

const labels =
  lang === "bg"
