type RouteSpec = {
  id: string;
  title: string;
  shortTitle: string;
  durationMinutes: number;
  pace: string;
  accent: string;
  storyId: string;
  educationId?: string;
  stopIds: string[];
};

type RouteStop = {
  place: KnowledgePlace;
  narration: string;
  pairs: ThenNowPair[];
  archiveItems: HistoricalArchiveItem[];
};

type RouteView = RouteSpec & {
  story: StoryLongread;
  education: EducationResource | null;
  context: string;
  stops: RouteStop[];
  events: KnowledgeEvent[];
  archiveItems: HistoricalArchiveItem[];
  thenNow: ThenNowPair[];
  sources: KnowledgeSource[];
  media: KnowledgePlace["media"][number] | null;
  evidenceCount: number;
};

