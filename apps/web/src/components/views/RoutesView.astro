            <span class="route-action-icon route-action-icon-path" aria-hidden="true"></span>
            <span>
              <strong>{labels.startRoute}</strong>
              <small>{firstRoute.title}</small>
            </span>
          </a>
          <a class="route-action route-action-map" href={`${localizePath("/history", lang)}#landmarks`}>
            <span class="route-action-icon route-action-icon-map" aria-hidden="true"></span>
            <span>
              <strong>{labels.mapView}</strong>
              <small>{labels.mapHint}</small>
            </span>
          </a>
        </div>
      </div>
      <dl class="stats-grid routes-stats" aria-label={labels.title}>
        <div class="stat-card">
          <dt>{labels.routes}</dt>
          <dd>{routeViews.length}</dd>
        </div>
        <div class="stat-card">
          <dt>{labels.stops}</dt>
          <dd>{totalStops}</dd>
        </div>
        <div class="stat-card">
          <dt>{labels.sources}</dt>
          <dd>{totalSources}</dd>
        </div>
        <div class="stat-card">
          <dt>{labels.thenNow}</dt>
          <dd>{totalThenNow}</dd>
        </div>
      </dl>
    </div>
  </section>

  <section class="section routes-picker" id="routes">
    <div class="container">
      <div class="section-head routes-section-head">
        <div>
          <h2>{labels.chooseTitle}</h2>
          <p class="meta">{labels.chooseLead}</p>
        </div>
        <a href={localizePath("/places", lang)}>{labels.allPlaces} →</a>
      </div>

      <div class="route-card-grid">
        {routeViews.map((route) => (
          <article class="route-card" style={`--route-accent:${route.accent}`}>
            {route.media && (
              <a class="route-card-media" href={`#route-${route.id}`} aria-label={route.title}>
                <img
                  src={commonsImageUrl(route.media.url, 640)}
                  alt={route.title}
                  loading="lazy"
                  decoding="async"
                  referrerpolicy="no-referrer"
                />
              </a>
            )}
            <div class="route-card-body">
              <p class="eyebrow">{route.pace}</p>
              <h3><a href={`#route-${route.id}`}>{route.title}</a></h3>
              <p>{route.context}</p>
              <dl class="route-quick-facts">
                <div>
                  <dt>{labels.suggestedDuration}</dt>
                  <dd>{route.durationMinutes} {labels.minutes}</dd>
                </div>
                <div>
                  <dt>{labels.stops}</dt>
                  <dd>{route.stops.length}</dd>
                </div>
                <div>
                  <dt>{labels.evidence}</dt>
                  <dd>{route.evidenceCount}</dd>
                </div>
              </dl>
              <div class="route-card-actions">
                <a class="text-link" href={`#route-${route.id}`}>{labels.stops}</a>
                <a class="text-link" href={localizePath(`/stories/${route.story.id}`, lang)}>{labels.openStory}</a>
              </div>
            </div>
          </article>
        ))}
      </div>

      <p class="notice route-boundary">
        <span class="notice-icon" aria-hidden="true">i</span>
        <span>{labels.dataBoundary}</span>
      </p>
    </div>
  </section>

  {routeViews.map((route, routeIndex) => {
    const startName = localizedAny(route.stops[0].place, "name");
    const finishName = localizedAny(route.stops[route.stops.length - 1].place, "name");
    return (
      <section class={`section route-detail-section ${routeIndex % 2 === 1 ? "section-tint" : ""}`} id={`route-${route.id}`}>
        <div class="container route-detail" style={`--route-accent:${route.accent}`}>
          <header class="route-detail-head">
            <div>
              <p class="eyebrow">{route.shortTitle} · {route.durationMinutes} {labels.minutes}</p>
              <h2>{route.title}</h2>
              <p class="lead compact-lead">{route.context}</p>
            </div>
            <div class="route-start-finish" aria-label={route.title}>
              <dl>
                <div>
                  <dt>{labels.start}</dt>
                  <dd>{startName}</dd>
                </div>
                <div>
                  <dt>{labels.finish}</dt>
                  <dd>{finishName}</dd>
                </div>
              </dl>
            </div>
          </header>

        <div class="route-detail-grid">
          <div class="route-stops">
            <ol class="route-stop-cards">
              {route.stops.map((stop, index) => {
                const place = stop.place;
                const name = localizedAny(place, "name");
                const firstSource = place.source_ids.map((id) => sourcesById.get(id)).find(Boolean);
                return (
                  <li class="route-stop-card">
                    <article>
                      <div class="route-stop-index" aria-hidden="true">{index + 1}</div>
                      {place.media[0] && (
                        <a class="route-stop-media" href={localizePath(`/places/${place.id}`, lang)} aria-label={name}>
                          <img
                            src={commonsImageUrl(place.media[0].url, 360)}
                            alt={name}
                            loading="lazy"
                            decoding="async"
                            referrerpolicy="no-referrer"
                          />
                        </a>
                      )}
                      <div class="route-stop-body">
                        <p class="eyebrow">{localizedAny(place, "era")} · {t.history.eraLabels[place.era]}</p>
                        <h3><a href={localizePath(`/places/${place.id}`, lang)}>{name}</a></h3>
                        <p>{stop.narration}</p>
                        <div class="tag-row route-stop-tags">
                          {stop.pairs.length > 0 && <span>{stop.pairs.length} {labels.thenNow}</span>}
                          {stop.archiveItems.length > 0 && <span>{stop.archiveItems.length} {labels.archive}</span>}
                        </div>
                        <div class="route-stop-actions">
                          <a class="text-link" href={localizePath(`/places/${place.id}`, lang)}>{labels.openPlace}</a>
                          {firstSource && (
                            <a class="src-link compact-source" href={firstSource.url} target="_blank" rel="noreferrer">
                              {labels.source}: {sourceTitle(localizedAny(firstSource, "title"), lang)} ↗
                            </a>
                          )}
                        </div>
                      </div>
                    </article>
                  </li>
                );
              })}
            </ol>
          </div>

          <aside class="route-evidence-panel">
            <section>
              <h3>{labels.routeStory}</h3>
              <p>{localizedAny(route.story, "title")}</p>
              <a class="button secondary" href={localizePath(`/stories/${route.story.id}`, lang)}>{labels.openStory}</a>
            </section>

            <section>
              <h3>{labels.routeEvidence}</h3>
              <dl class="route-evidence-counts">
                <div><dt>{labels.stops}</dt><dd>{route.stops.length}</dd></div>
                <div><dt>{labels.events}</dt><dd>{route.events.length}</dd></div>
                <div><dt>{labels.archive}</dt><dd>{route.archiveItems.length}</dd></div>
                <div><dt>{labels.thenNow}</dt><dd>{route.thenNow.length}</dd></div>
                <div><dt>{labels.sources}</dt><dd>{route.sources.length}</dd></div>
              </dl>
            </section>

            {route.events.length > 0 && (
              <section>
                <h3>{labels.linkedEvents}</h3>
                <ol class="route-evidence-list">
                  {route.events.map((event) => (
                    <li>
                      <span>{localizedAny(event.date, "display")}</span>
                      <strong>{localizedAny(event, "title")}</strong>
                    </li>
                  ))}
                </ol>
              </section>
            )}

            {(route.archiveItems.length > 0 || route.thenNow.length > 0) && (
              <section>
                <h3>{labels.linkedMedia}</h3>
                <ul class="source-list compact route-media-list">
                  {route.thenNow.map((pair) => (
                    <li>
                      <a href={localizePath(`/places/${pair.place_id}`, lang)}>
                        {localizedAny(pair, "title")}
                      </a>
                    </li>
                  ))}
                  {route.archiveItems.map((item) => (
                    <li>
                      <a href={localizePath(`/places/${item.place_id}`, lang)}>
                        {localizedAny(item, "title")}
                      </a>
                    </li>
                  ))}
                </ul>
                <a class="text-link" href={`${localizePath("/history", lang)}#archive-layer`}>{labels.compareArchive}</a>
              </section>
            )}

            <section>
              <h3>{labels.sources}</h3>
              <ul class="source-list compact">
                {route.sources.slice(0, 6).map((source) => (
                  <li>
                    <a href={source.url} target="_blank" rel="noreferrer">
                      {sourceTitle(localizedAny(source, "title"), lang)}
                    </a>
                  </li>
                ))}
              </ul>
            </section>

            <div class="route-panel-actions">
              <a class="button" href={localizePath(`/places/${route.stops[0].place.id}`, lang)}>{labels.firstStop}</a>
              <a class="button secondary" href={`${localizePath("/history", lang)}#landmarks`}>{labels.historyMap}</a>
            </div>
          </aside>
        </div>
      </div>
      </section>
    );
  })}

  <style>
    .route-hero-actions,
    .route-card-actions,
    .route-stop-actions,
    .route-panel-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      align-items: center;
    }

    .route-hero-actions {
      margin-top: 24px;
      gap: 12px;
    }

    .route-action {
      align-items: center;
      border: 1px solid var(--line-strong);
      border-radius: 8px;
      box-sizing: border-box;
      box-shadow: var(--shadow-sm);
      display: inline-flex;
      gap: 12px;
      min-height: 58px;
      min-width: min(100%, 220px);
      padding: 10px 16px;
      text-decoration: none;
      transition: border-color 0.14s ease, box-shadow 0.14s ease, transform 0.14s ease;
    }

    .route-action:hover,
    .route-action:focus-visible {
      box-shadow: var(--shadow);
      outline: none;
      transform: translateY(-2px);
    }

    .route-action-primary {
      background: var(--brand);
      border-color: var(--brand);
      color: var(--brand-ink);
    }

    .route-action-primary:hover,
    .route-action-primary:focus-visible {
      background: var(--brand-strong);
      border-color: var(--brand-strong);
      color: var(--brand-ink);
    }

    .route-action-map {
      background: color-mix(in srgb, var(--surface) 88%, var(--brand));
      color: var(--brand);
    }

    .route-action-map:hover,
    .route-action-map:focus-visible {
      border-color: var(--brand);
      color: var(--brand);
    }

    .route-action strong,
    .route-action small {
      display: block;
      line-height: 1.15;
    }

    .route-action strong {
      font-size: 0.96rem;
      font-weight: 800;
    }

    .route-action small {
      font-size: 0.78rem;
      margin-top: 4px;
      max-width: 24ch;
      opacity: 0.78;
    }

    .route-action-icon {
      align-items: center;
      border-radius: 8px;
      display: inline-flex;
      flex: 0 0 auto;
      height: 34px;
      justify-content: center;
      position: relative;
      width: 34px;
    }

    .route-action-primary .route-action-icon {
      background: rgb(255 255 255 / 0.16);
      border: 1px solid rgb(255 255 255 / 0.24);
    }

    .route-action-map .route-action-icon {
      background: var(--surface);
      border: 1px solid var(--line);
    }

    .route-action-icon-path::before {
      background:
        radial-gradient(circle at 2px 50%, currentColor 0 2px, transparent 2.5px),
        radial-gradient(circle at 26px 50%, currentColor 0 2px, transparent 2.5px),
        linear-gradient(90deg, transparent 0 2px, currentColor 2px 26px, transparent 26px);
      content: "";
      height: 10px;
      width: 28px;
    }

    .route-action-icon-map::before {
      border: 2px solid currentColor;
      border-radius: 50% 50% 50% 0;
      content: "";
      height: 14px;
      transform: rotate(-45deg);
      width: 14px;
    }

    .route-action-icon-map::after {
      background: currentColor;
      border-radius: 50%;
      content: "";
      height: 4px;
      position: absolute;
      width: 4px;
    }

    .stats-grid.routes-stats {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      max-width: 880px;
      width: 100%;
    }

    .routes-stats .stat-card {
      box-sizing: border-box;
      min-width: 0;
    }

    .routes-section-head .meta {
      max-width: 74ch;
      margin-top: 8px;
    }

    .route-card-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 18px;
    }

    .route-card,
    .route-stop-card article,
    .route-evidence-panel {
      border: 1px solid var(--line);
      border-radius: 8px;
      background: var(--surface);
      box-shadow: var(--shadow-sm);
      overflow: hidden;
    }

    .route-card {
      border-top: 4px solid var(--route-accent);
    }

    .route-card-media,
    .route-stop-media {
      display: block;
      background: var(--surface-2);
    }

    .route-card-media img,
    .route-stop-media img {
      display: block;
      width: 100%;
      height: 190px;
      object-fit: cover;
    }

    .route-card-body,
    .route-stop-body {
      padding: 18px;
    }

    .route-card h3,
    .route-stop-card h3,
    .route-evidence-panel h3 {
      margin: 0;
      line-height: 1.2;
    }

    .route-card h3 a,
    .route-stop-card h3 a {
      color: inherit;
      text-decoration: none;
    }

    .route-card h3 a:hover,
    .route-card h3 a:focus-visible,
    .route-stop-card h3 a:hover,
    .route-stop-card h3 a:focus-visible {
      color: var(--brand);
    }

    .route-card p,
    .route-stop-card p,
    .route-evidence-panel p {
      color: var(--muted);
    }

    .route-quick-facts,
    .route-start-finish dl,
    .route-evidence-counts {
      display: grid;
      gap: 10px;
      margin: 18px 0 0;
    }

    .route-quick-facts {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .route-quick-facts div,
    .route-start-finish div,
    .route-evidence-counts div {
      min-width: 0;
    }

    .route-quick-facts dt,
    .route-start-finish dt,
    .route-evidence-counts dt {
      color: var(--muted);
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0;
    }

    .route-quick-facts dd,
    .route-start-finish dd,
    .route-evidence-counts dd {
      margin: 4px 0 0;
      font-weight: 800;
      color: var(--ink);
    }

    .route-boundary {
      margin-top: 22px;
    }

    .route-detail {
      border-top: 4px solid var(--route-accent);
      padding-top: 28px;
    }

    .route-detail-head {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(220px, 320px);
      gap: 28px;
      align-items: start;
      margin-bottom: 24px;
    }

    .compact-lead {
      max-width: 78ch;
    }

    .route-start-finish {
      border: 1px solid var(--line);
      border-radius: 8px;
      background: var(--surface);
      padding: 16px;
    }

    .route-detail-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(270px, 340px);
      gap: 24px;
      align-items: start;
    }

    .route-stop-cards {
      display: grid;
      gap: 16px;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .route-stop-card article {
      display: grid;
      grid-template-columns: 44px minmax(0, 220px) minmax(0, 1fr);
      align-items: stretch;
      position: relative;
    }

    .route-stop-index {
      display: grid;
      place-items: center;
      min-height: 100%;
      background: var(--route-accent);
      color: #fff;
      font-weight: 900;
      font-size: 1.1rem;
    }

    .route-stop-media img {
      height: 100%;
      min-height: 220px;
    }

    .route-stop-tags {
      margin-top: 14px;
    }

    .compact-source {
      font-size: 0.9rem;
    }

    .route-evidence-panel {
      display: grid;
      gap: 18px;
      padding: 18px;
      position: sticky;
      top: 96px;
    }

    .route-evidence-panel section + section {
      border-top: 1px solid var(--line);
      padding-top: 18px;
    }

    .route-evidence-counts {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .route-evidence-list {
      display: grid;
      gap: 10px;
      margin: 12px 0 0;
      padding-left: 1.2rem;
    }

    .route-evidence-list span {
      display: block;
      color: var(--muted);
      font-size: 0.9rem;
      margin-bottom: 2px;
    }

    .route-media-list {
      margin-bottom: 12px;
    }

    @media (max-width: 920px) {
      .route-detail-head,
      .route-detail-grid {
        grid-template-columns: 1fr;
      }

      .route-evidence-panel {
        position: static;
      }
    }

    @media (max-width: 680px) {
      .stats-grid.routes-stats {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .route-action {
        width: min(100%, 320px);
      }

      .route-quick-facts {
        grid-template-columns: 1fr;
      }

      .route-stop-card article {
        grid-template-columns: 38px minmax(0, 1fr);
      }

      .route-stop-media {
        grid-column: 2;
      }

      .route-stop-media img {
        height: 180px;
        min-height: 0;
      }

      .route-stop-body {
        grid-column: 1 / -1;
      }
    }
  </style>
</Layout>
