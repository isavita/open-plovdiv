const placesById = new Map(historyKnowledgePlaces.map((place) => [place.id, place]));
const storiesById = new Map(storyLongreads.map((story) => [story.id, story]));
const educationById = new Map(educationResources.map((resource) => [resource.id, resource]));
const eventsById = new Map(historyKnowledgeEvents.map((event) => [event.id, event]));
const archiveById = new Map(historicalArchiveItems.map((item) => [item.id, item]));
const thenNowById = new Map(thenNowPairs.map((pair) => [pair.id, pair]));
const sourcesById = new Map(historyKnowledgeSources.map((source) => [source.id, source]));

function localized(record: Record<string, unknown> | null | undefined, base: string): string {
  return field(record, base, lang);
}

function localizedAny(record: unknown, base: string): string {
  return localized(record as Record<string, unknown>, base);
}

function requireRecord<T>(map: Map<string, T>, id: string, collection: string): T {
  const record = map.get(id);
  if (!record) throw new Error(`Missing ${collection} record for walking route: ${id}`);
  return record;
}

function unique<T>(items: T[]): T[] {
  return [...new Set(items)];
}

function compactText(value: string, maxLength = 300): string {
  if (value.length <= maxLength) return value;
  const cut = value.slice(0, maxLength).lastIndexOf(" ");
  return `${value.slice(0, cut > 80 ? cut : maxLength).trim()}...`;
}

function routeNarration(place: KnowledgePlace, story: StoryLongread, education: EducationResource | null): string {
  const audioStop = education?.audio_tour.stops.find((stop) => stop.place_id === place.id);
  if (audioStop) return localized(audioStop as Record<string, unknown>, "narration");

  const storySection = story.sections.find((section) => section.linked_place_ids.includes(place.id));
  if (storySection) return compactText(localized(storySection as Record<string, unknown>, "body"), 330);

  return compactText(localizedAny(place, "summary"), 280);
}

const routeViews: RouteView[] = routeSpecs.map((spec) => {
  const story = requireRecord(storiesById, spec.storyId, "story");
  const education = spec.educationId ? requireRecord(educationById, spec.educationId, "education resource") : null;
  const places = spec.stopIds.map((id) => requireRecord(placesById, id, "place"));
  const storyArchiveItems = story.linked_archive_item_ids.map((id) => archiveById.get(id)).filter(Boolean) as HistoricalArchiveItem[];
  const storyPairs = story.linked_then_now_pair_ids.map((id) => thenNowById.get(id)).filter(Boolean) as ThenNowPair[];
  const educationArchiveItems =
    education?.linked_archive_item_ids.map((id) => archiveById.get(id)).filter(Boolean) as HistoricalArchiveItem[] | undefined;
  const educationPairs =
    education?.linked_then_now_pair_ids.map((id) => thenNowById.get(id)).filter(Boolean) as ThenNowPair[] | undefined;
  const archiveItems = unique([...(storyArchiveItems ?? []), ...(educationArchiveItems ?? [])]);
  const preferredPairIds = new Set([...story.linked_then_now_pair_ids, ...(education?.linked_then_now_pair_ids ?? [])]);
  const routePairs = publicThenNowPairs(unique([...(storyPairs ?? []), ...(educationPairs ?? [])]), { preferredPairIds });
  const events = unique([
    ...story.linked_event_ids,
    ...(education?.linked_event_ids ?? [])
  ])
    .map((id) => eventsById.get(id))
    .filter(Boolean) as KnowledgeEvent[];
  const stopPlaceIds = new Set(places.map((place) => place.id));
  const stops: RouteStop[] = places.map((place) => ({
    place,
    narration: routeNarration(place, story, education),
    pairs: routePairs.filter((pair) => pair.place_id === place.id),
    archiveItems: archiveItems.filter((item) => item.place_id === place.id)
  }));
  const sourceIds = unique([
    ...story.source_ids,
    ...(education?.source_ids ?? []),
    ...places.flatMap((place) => place.source_ids),
    ...events.flatMap((event) => event.source_ids),
    ...routePairs.flatMap((pair) => pair.source_ids),
    ...archiveItems.map((item) => item.source.source_id).filter(Boolean)
  ]);
  const sources = sourceIds.map((id) => sourcesById.get(id)).filter(Boolean) as KnowledgeSource[];
  const media = places.find((place) => place.media.length > 0)?.media[0] ?? null;

  return {
    ...spec,
    story,
    education,
    context: localizedAny(story, "dek") || (education ? localizedAny(education, "summary") : ""),
    stops,
    events,
    archiveItems: archiveItems.filter((item) => stopPlaceIds.has(item.place_id)),
    thenNow: routePairs.filter((pair) => stopPlaceIds.has(pair.place_id)),
    sources,
    media,
    evidenceCount: places.length + events.length + archiveItems.length + routePairs.length + sources.length
  };
});

const totalStops = routeViews.reduce((sum, route) => sum + route.stops.length, 0);
const totalSources = new Set(routeViews.flatMap((route) => route.sources.map((source) => source.id))).size;
const totalThenNow = new Set(routeViews.flatMap((route) => route.thenNow.map((pair) => pair.id))).size;
const firstRoute = routeViews[0];
