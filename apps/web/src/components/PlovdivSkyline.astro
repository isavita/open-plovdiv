---
// Decorative silhouette of Plovdiv's layered skyline — the "city of the seven
// hills" told as one engraved horizon. Left to right: Nebet Tepe (the Thracian
// citadel mound with ruins), a cluster of National Revival houses with
// overhanging upper floors and bay windows, the Antique Theatre colonnade,
// the Sahat Tepe clock tower, the Dzhumaya mosque dome with its minaret, and a
// Roman triumphal arch. Purely presentational; fill follows `currentColor` so
// callers control tone via CSS. Two depth layers (back/front) give the horizon
// a faint parallax richness without an extra asset.
type Props = { class?: string };
const { class: className = "" } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 1200 340"
  preserveAspectRatio="xMidYMax slice"
  aria-hidden="true"
  focusable="false"
  xmlns="http://www.w3.org/2000/svg"
>
  <!-- back layer: distant hill + faint Old-Town rooflines for depth -->
  <g fill="currentColor" opacity="0.55">
    <!-- Nebet Tepe — the ancient citadel hill -->
    <path d="M0 322 Q120 232 260 250 Q330 258 380 238 Q430 222 470 250 L470 322 Z" />
    <!-- distant roofline -->
    <polygon points="430,268 452,250 474,268 474,322 430,322" />
    <polygon points="470,272 496,254 522,272 522,322 470,322" />
  </g>

  <!-- front layer: the named landmarks -->
  <g fill="currentColor">
    <!-- ground line -->
    <rect x="0" y="320" width="1200" height="3" />

    <!-- 1 — Nebet Tepe ruins: broken citadel walls atop the hill -->
    <rect x="120" y="262" width="26" height="34" />
    <rect x="150" y="276" width="40" height="20" />
    <rect x="196" y="256" width="20" height="40" />
    <rect x="150" y="252" width="4" height="10" />
    <rect x="206" y="248" width="4" height="10" />

    <!-- 2 — National Revival house A (overhanging upper floor, wide eaves, bay window) -->
    <rect x="262" y="232" width="96" height="88" />
    <rect x="248" y="196" width="124" height="40" />
    <polygon points="240,198 270,158 350,158 380,198" />
    <!-- bay window -->
    <rect x="372" y="210" width="20" height="60" />
    <polygon points="368,212 382,196 396,212" />
    <!-- eaves line -->
    <rect x="244" y="194" width="132" height="5" />
    <!-- windows on upper floor -->
    <rect x="258" y="206" width="10" height="20" opacity="0.0" />
    <rect x="280" y="206" width="12" height="22" fill="none" stroke="currentColor" stroke-width="2" opacity="0.35" />
    <rect x="306" y="206" width="12" height="22" fill="none" stroke="currentColor" stroke-width="2" opacity="0.35" />
    <rect x="332" y="206" width="12" height="22" fill="none" stroke="currentColor" stroke-width="2" opacity="0.35" />
    <!-- chimney -->
    <rect x="338" y="150" width="10" height="14" />

    <!-- 3 — National Revival house B (smaller, mirrored, with cellar door) -->
    <rect x="392" y="252" width="74" height="68" />
    <rect x="382" y="222" width="98" height="34" />
    <polygon points="376,224 400,192 466,192 490,224" />
    <rect x="378" y="220" width="106" height="4" />
    <rect x="402" y="230" width="10" height="18" fill="none" stroke="currentColor" stroke-width="2" opacity="0.35" />
    <rect x="424" y="230" width="10" height="18" fill="none" stroke="currentColor" stroke-width="2" opacity="0.35" />
    <rect x="446" y="230" width="10" height="18" fill="none" stroke="currentColor" stroke-width="2" opacity="0.35" />
    <rect x="456" y="180" width="8" height="14" />

    <!-- 4 — Antique Theatre colonnade (steps, columns, entablature, pediment) -->
    <rect x="500" y="308" width="232" height="14" />
    <rect x="510" y="294" width="212" height="14" />
    <rect x="514" y="196" width="16" height="98" />
    <rect x="556" y="196" width="16" height="98" />
    <rect x="598" y="196" width="16" height="98" />
    <rect x="640" y="196" width="16" height="98" />
    <rect x="682" y="196" width="16" height="98" />
    <rect x="502" y="178" width="228" height="18" />
    <polygon points="500,178 616,138 732,178" />
    <!-- tiered seating hint behind the colonnade -->
    <path d="M506 308 L506 286 L728 286 L728 308" opacity="0.0" />
    <path d="M520 296 L520 274 L714 274 L714 296" fill="none" stroke="currentColor" stroke-width="2" opacity="0.3" />

    <!-- 5 — Sahat Tepe clock tower -->
    <rect x="770" y="150" width="44" height="170" />
    <rect x="763" y="142" width="58" height="10" />
    <polygon points="763,142 792,112 821,142" />
    <!-- clock face -->
    <circle cx="792" cy="178" r="11" fill="none" stroke="currentColor" stroke-width="2.5" opacity="0.4" />
    <rect x="790" y="170" width="4" height="9" opacity="0.4" />
    <rect x="788" y="177" width="8" height="3" opacity="0.4" />
    <rect x="789" y="94" width="6" height="20" />
    <circle cx="792" cy="92" r="5" />

    <!-- 6 — Dzhumaya mosque: dome + minaret -->
    <rect x="846" y="142" width="16" height="178" />
    <rect x="840" y="174" width="28" height="6" />
    <polygon points="844,142 854,118 864,142" />
    <circle cx="854" cy="114" r="4" />
    <rect x="892" y="212" width="172" height="108" />
    <path d="M900 214 Q978 130 1056 214 Z" />
    <!-- dome finial -->
    <rect x="974" y="114" width="6" height="18" />
    <circle cx="977" cy="112" r="5" />
    <!-- arcade under the mosque body -->
    <rect x="902" y="298" width="152" height="22" fill="none" stroke="currentColor" stroke-width="2" opacity="0.3" />
    <path d="M908 320 v-14 a8 8 0 0 1 16 0 v14 M936 320 v-14 a8 8 0 0 1 16 0 v14 M964 320 v-14 a8 8 0 0 1 16 0 v14 M992 320 v-14 a8 8 0 0 1 16 0 v14 M1020 320 v-14 a8 8 0 0 1 16 0 v14" fill="none" stroke="currentColor" stroke-width="2" opacity="0.4" />

    <!-- 7 — Roman triumphal arch (Hill of Youth / stadium gateway) -->
    <rect x="1086" y="170" width="22" height="150" />
    <rect x="1156" y="170" width="22" height="150" />
    <rect x="1080" y="164" width="104" height="10" />
    <rect x="1076" y="150" width="112" height="14" />
    <polygon points="1074,150 1132,124 1190,150" />
    <!-- arch opening (drawn as a solid pier cap so the top stays, opening is transparent) -->
    <path d="M1108 320 v-78 a20 20 0 0 1 40 0 v78 h-6 v-78 a14 14 0 0 0 -28 0 v78 Z" />
    <!-- attic inscription panel -->
    <rect x="1108" y="172" width="40" height="16" fill="none" stroke="currentColor" stroke-width="2" opacity="0.4" />
  </g>
</svg>
