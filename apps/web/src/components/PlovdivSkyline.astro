---
// Decorative silhouette of four landmarks evoking Plovdiv's layered history:
// a National Revival house, the Roman theatre colonnade, the Sahat Tepe clock
// tower, and the Dzhumaya mosque dome with a minaret. Purely presentational;
// fill follows `currentColor` so callers control tone via CSS.
type Props = { class?: string };
const { class: className = "" } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 1200 320"
  preserveAspectRatio="xMidYMax slice"
  aria-hidden="true"
  focusable="false"
  xmlns="http://www.w3.org/2000/svg"
>
  <g fill="currentColor">
    <!-- ground line -->
    <rect x="0" y="299" width="1200" height="3" />

    <!-- 1 — National Revival house (overhanging upper floor, wide eaves) -->
    <rect x="120" y="200" width="120" height="100" />
    <rect x="102" y="150" width="156" height="54" />
    <polygon points="86,152 122,110 238,110 274,152" />
    <rect x="222" y="92" width="14" height="22" />

    <!-- 2 — Roman theatre colonnade (steps, columns, entablature, pediment) -->
    <rect x="360" y="288" width="240" height="12" />
    <rect x="372" y="276" width="216" height="12" />
    <rect x="372" y="178" width="18" height="98" />
    <rect x="420" y="178" width="18" height="98" />
    <rect x="468" y="178" width="18" height="98" />
    <rect x="516" y="178" width="18" height="98" />
    <rect x="564" y="178" width="18" height="98" />
    <rect x="362" y="160" width="236" height="18" />
    <polygon points="360,160 480,118 600,160" />

    <!-- 3 — Sahat Tepe clock tower -->
    <rect x="684" y="132" width="42" height="168" />
    <rect x="678" y="124" width="54" height="10" />
    <polygon points="678,124 705,98 732,124" />
    <rect x="702" y="82" width="6" height="18" />
    <circle cx="705" cy="80" r="5" />

    <!-- 4 — Dzhumaya mosque dome with minaret -->
    <rect x="812" y="124" width="18" height="176" />
    <rect x="806" y="156" width="30" height="6" />
    <polygon points="810,124 821,100 832,124" />
    <circle cx="821" cy="96" r="4" />
    <rect x="860" y="196" width="180" height="104" />
    <path d="M868 198 Q950 116 1032 198 Z" />
    <rect x="947" y="98" width="6" height="20" />
    <circle cx="950" cy="96" r="5" />
  </g>
</svg>
