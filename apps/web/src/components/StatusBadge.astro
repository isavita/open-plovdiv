---
import type { Lang } from "@i18n/ui";
import { fixStatusLabel, projectStatusLabel } from "@lib/format";

type Props = {
  status: string;
  type: "project" | "fix";
  lang: Lang;
};

const { status, type, lang } = Astro.props;
const label =
  type === "project" ? projectStatusLabel(status, lang) : fixStatusLabel(status, lang);
---

<span class={`badge status-${status}`}>{label}</span>
