---
import { fixStatusLabel, projectStatusLabel } from "@lib/format";

type Props = {
  status: string;
  type: "project" | "fix";
};

const { status, type } = Astro.props;
const label = type === "project" ? projectStatusLabel(status) : fixStatusLabel(status);
---

<span class={`badge status-${status}`}>{label}</span>
