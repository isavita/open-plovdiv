---
import "@fontsource-variable/playfair-display/index.css";
import "../styles/global.css";
import PlovdivSkyline from "@components/PlovdivSkyline.astro";
import Ornament from "@components/Ornament.astro";
import { languages, localeCodes, localeForLang, localizePath, ui, type Lang } from "@i18n/utils";
import {
  absoluteUrl,
  buildPageStructuredData,
  inferOpenGraphType,
  serializeJsonLd,
  type JsonLdObject
} from "@lib/seo";

type Props = {
  lang: Lang;
  /** Logical (default-locale) path of this page, e.g. "/budget" or "/". */
  path: string;
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  robots?: string;
  structuredData?: JsonLdObject | JsonLdObject[];
  /**
   * Opt-in for pages that are a single static file shared by every locale
   * (only the global 404.html today — Astro has no per-locale fallback
   * route, confirmed by testing). When true, the header/footer chrome below
   * is additionally re-localized client-side to match the locale detected
   * from the visited URL, instead of staying fixed at `lang`. Every other
   * page already renders the correct chrome server-side and leaves this off.
   */
  localeDetect?: boolean;
};

const { lang, path, title, description, image, imageAlt, robots, structuredData, localeDetect } = Astro.props;
const t = ui[lang];

const pageTitle = title ? `${title} · ${t.site.name}` : t.site.name;
const pageDescription = description ?? t.site.tagline;
const structuredTitle = title ?? t.site.name;

const ogLocales: Record<Lang, string> = { bg: "bg_BG", en: "en_GB", de: "de_DE", fr: "fr_FR", it: "it_IT", tr: "tr_TR", es: "es_ES", el: "el_GR", ja: "ja_JP" };
const ogLocale = ogLocales[lang];
const routesLabel = ({ bg: "Маршрути", en: "Routes", de: "Routen", fr: "Parcours", it: "Percorsi", tr: "Rotalar", es: "Rutas", el: "Διαδρομές", ja: "ルート" } satisfies Record<Lang, string>)[lang];
const governanceLabel = ({ bg: "Управление", en: "Governance", de: "Governance", fr: "Gouvernance", it: "Governo", tr: "Yönetim", es: "Gobernanza", el: "Διακυβέρνηση", ja: "統治" } satisfies Record<Lang, string>)[lang];

// Primary nav now separates deep history, visitor routes and political context;
// civic + reference links live in the footer and homepage action paths.
const navItems = [
  { href: localizePath("/history", lang), base: "/history", label: t.nav.history },
  { href: localizePath("/routes", lang), base: "/routes", label: routesLabel },
  { href: localizePath("/mayors", lang), base: "/mayors", label: t.nav.mayors },
  { href: localizePath("/governance", lang), base: "/governance", label: governanceLabel },
  { href: localizePath("/places", lang), base: "/places", label: t.nav.places }
];

function isActive(base: string): boolean {
  if (base === "/") return path === "/";
  return path === base || path.startsWith(`${base}/`);
}

const site = Astro.site ?? new URL("https://openplovdiv.example");
const canonical = new URL(localizePath(path, lang), site).href;
const seoImage = absoluteUrl(image, site);
const seoImageAlt = imageAlt ?? structuredTitle;
const ogType = inferOpenGraphType(path);
// hreflang alternates for every supported locale (+ x-default → Bulgarian root).
const altLinks = localeCodes.map((code) => ({
  code,
  href: new URL(localizePath(path, code), site).href
}));
const xDefaultHref = new URL(localizePath(path, "bg"), site).href;
const structuredDataJson = serializeJsonLd(
  buildPageStructuredData({
    site,
    lang,
    locale: localeForLang(lang),
    siteName: t.site.name,
    logicalPath: path,
    canonical,
    title: structuredTitle,
    description: pageDescription,
    image: seoImage,
    additional: structuredData,
    breadcrumbLabels: {
      home: t.nav.home,
      history: t.nav.history,
      routes: routesLabel,
      mayors: t.nav.mayors,
      governance: governanceLabel,
      people: t.nav.people,
      places: t.nav.places,
      stories: t.nav.stories,
      archive: t.nav.archive,
      overview: t.nav.overview,
      budget: t.nav.budget,
      projects: t.nav.projects,
      community: t.nav.community,
      "fix-map": t.nav.fixMap,
      "data-sources": t.footer.sources,
      privacy: t.footer.privacy,
      moderation: t.footer.moderation
    }
  })
);

const footerHistory = [
  { href: localizePath("/history", lang), label: t.nav.history, key: "history" },
  { href: localizePath("/routes", lang), label: routesLabel, key: "routes" },
  { href: localizePath("/mayors", lang), label: t.nav.mayors, key: "mayors" },
  { href: localizePath("/governance", lang), label: governanceLabel, key: "governance" },
  { href: localizePath("/people", lang), label: t.nav.people, key: "people" },
  { href: localizePath("/places", lang), label: t.nav.places, key: "places" },
  { href: localizePath("/stories", lang), label: t.nav.stories, key: "stories" },
  { href: localizePath("/archive", lang), label: t.nav.archive, key: "archive" }
];
const footerCivic = [
  { href: localizePath("/overview", lang), label: t.nav.overview, key: "overview" },
  { href: localizePath("/budget", lang), label: t.nav.budget, key: "budget" },
  { href: localizePath("/projects", lang), label: t.nav.projects, key: "projects" },
  { href: localizePath("/fix-map", lang), label: t.nav.fixMap, key: "fix-map" },
  { href: localizePath("/community", lang), label: t.footer.community, key: "community" }
];
const footerAbout = [
  { href: localizePath("/data-sources", lang), label: t.footer.sources, key: "data-sources" },
  { href: localizePath("/privacy", lang), label: t.footer.privacy, key: "privacy" },
  { href: localizePath("/moderation", lang), label: t.footer.moderation, key: "moderation" }
];

// Secondary destinations shown only inside the mobile menu, grouped so the
// phone nav reaches every page without duplicating the 5 primary links.
const menuExplore = [
  { href: localizePath("/people", lang), base: "/people", label: t.nav.people },
  { href: localizePath("/stories", lang), base: "/stories", label: t.nav.stories },
  { href: localizePath("/archive", lang), base: "/archive", label: t.nav.archive }
];
const menuCivic = [
  { href: localizePath("/overview", lang), base: "/overview", label: t.nav.overview },
  { href: localizePath("/budget", lang), base: "/budget", label: t.nav.budget },
  { href: localizePath("/projects", lang), base: "/projects", label: t.nav.projects },
  { href: localizePath("/fix-map", lang), base: "/fix-map", label: t.nav.fixMap },
  { href: localizePath("/community", lang), base: "/community", label: t.footer.community }
];
const menuAbout = [
  { href: localizePath("/data-sources", lang), base: "/data-sources", label: t.footer.sources },
  { href: localizePath("/privacy", lang), base: "/privacy", label: t.footer.privacy },
  { href: localizePath("/moderation", lang), base: "/moderation", label: t.footer.moderation }
];
const menuGroups = [
  { key: "explore", label: t.footer.explore, items: menuExplore },
  { key: "civic", label: t.footer.civic, items: menuCivic },
  { key: "about", label: t.footer.about, items: menuAbout }
];

// All-locale chrome strings for pages that opt into `localeDetect` (see the
// prop doc above) — built once, only when needed, and consumed client-side
// by the bottom script to re-localize the header/footer after detecting the
// visited locale from the URL, using the same stable keys as the
// data-nav-key/data-menu-key/data-footer-key hooks rendered below.
const routesLabels = { bg: "Маршрути", en: "Routes", de: "Routen", fr: "Parcours", it: "Percorsi", tr: "Rotalar", es: "Rutas", el: "Διαδρομές", ja: "ルート" } satisfies Record<Lang, string>;
const governanceLabels = { bg: "Управление", en: "Governance", de: "Governance", fr: "Gouvernance", it: "Governo", tr: "Yönetim", es: "Gobernanza", el: "Διακυβέρνηση", ja: "統治" } satisfies Record<Lang, string>;
const chromeI18n = localeDetect
  ? Object.fromEntries(
      localeCodes.map((code) => {
        const l = ui[code];
        return [
          code,
          {
            siteName: l.site.name,
            skip: l.site.skip,
            menuAria: l.site.menu,
            langSwitchAria: l.site.langSwitch,
            themeAria: l.site.theme,
            homeAria: l.nav.home,
            nav: {
              history: l.nav.history,
              routes: routesLabels[code],
              mayors: l.nav.mayors,
              governance: governanceLabels[code],
              places: l.nav.places,
              people: l.nav.people,
              stories: l.nav.stories,
              archive: l.nav.archive,
              overview: l.nav.overview,
              budget: l.nav.budget,
              projects: l.nav.projects,
              "fix-map": l.nav.fixMap,
              community: l.footer.community,
              "data-sources": l.footer.sources,
              privacy: l.footer.privacy,
              moderation: l.footer.moderation
            },
            groups: { explore: l.footer.explore, civic: l.footer.civic, about: l.footer.about },
            footer: { blurb: l.footer.blurb, note: l.footer.note, dataNote: l.footer.dataNote }
          }
        ];
      })
    )
  : null;
const chromeI18nJson = chromeI18n ? JSON.stringify(chromeI18n) : "";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    {robots && <meta name="robots" content={robots} />}
    <link rel="canonical" href={canonical} />
    {altLinks.map((alt) => (
      <link rel="alternate" hreflang={alt.code} href={alt.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={xDefaultHref} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" content="#f2ead8" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#16120c" media="(prefers-color-scheme: dark)" />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={t.site.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={ogLocale} />
    {altLinks.filter((alt) => alt.code !== lang).map((alt) => (
      <meta property="og:locale:alternate" content={ogLocales[alt.code]} />
    ))}
    {seoImage && (
      <>
        <meta property="og:image" content={seoImage} />
        <meta property="og:image:alt" content={seoImageAlt} />
      </>
    )}
    <meta name="twitter:card" content={seoImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:url" content={canonical} />
    {seoImage && <meta name="twitter:image" content={seoImage} />}
    {seoImage && <meta name="twitter:image:alt" content={seoImageAlt} />}

    <script type="application/ld+json" set:html={structuredDataJson}></script>

    <script is:inline>
      (function () {
        // Mark JS as available so the scroll-reveal hidden state only applies
        // when we can actually reveal it (content stays visible without JS).
        document.documentElement.classList.add("js");
        try {
          var t = localStorage.getItem("op-theme");
          if (t === "dark" || t === "light") {
            document.documentElement.setAttribute("data-theme", t);
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <div class="site-shell">
      <a class="skip-link" href="#main" data-skip-link>{t.site.skip}</a>

      <header class="site-header" id="site-header">
        <nav class="nav" aria-label={t.nav.home} data-nav-aria>
          <a class="brand" href={localizePath("/", lang)} aria-label={`${t.site.name} — ${t.nav.home}`} data-brand data-brand-aria>
            <span data-brand-name>{t.site.name}</span>
          </a>

          <div class="nav-links" id="nav-links">
            {navItems.map((item) => (
              <a href={item.href} data-nav-key={item.base.slice(1)} aria-current={isActive(item.base) ? "page" : undefined}>
                {item.label}
              </a>
            ))}

            <div class="nav-groups" aria-label={t.footer.explore} data-nav-groups-aria>
              {menuGroups.map((group) => (
                <div class="nav-group">
                  <span class="nav-group-label" data-menu-group={group.key}>{group.label}</span>
                  {group.items.map((item) => (
                    <a href={item.href} data-menu-key={item.base.slice(1)} aria-current={isActive(item.base) ? "page" : undefined}>
                      {item.label}
                    </a>
                  ))}
                </div>
              ))}
            </div>
          </div>

          <div class="nav-right">
            <details class="lang-menu" id="lang-menu">
              <summary class="icon-btn lang-switch" aria-label={t.site.langSwitch} title={t.site.langSwitch} data-lang-switch-aria>
                <span class="flag" aria-hidden="true" data-flag>{lang.toUpperCase()}</span>
                <span class="lang-caret" aria-hidden="true">▾</span>
              </summary>
              <ul class="lang-options">
                {localeCodes.map((code) => (
                  <li>
                    <a
                      href={localizePath(path, code)}
                      hreflang={code}
                      lang={code}
                      data-lang-option={code}
                      aria-current={code === lang ? "true" : undefined}
                    >
                      <span class="lang-code" aria-hidden="true">{code.toUpperCase()}</span>
                      <span>{languages[code]}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </details>
            <button
              type="button"
              class="icon-btn theme-toggle"
              id="theme-toggle"
              aria-label={t.site.theme}
              title={t.site.theme}
              data-theme-aria
            >
              <span class="sun" aria-hidden="true">☀</span>
              <span class="moon" aria-hidden="true">☾</span>
            </button>
            <button
              type="button"
              class="icon-btn nav-toggle"
              id="nav-toggle"
              aria-controls="nav-links"
              aria-expanded="false"
              aria-label={t.site.menu}
              data-menu-aria
            >
              <span aria-hidden="true">☰</span>
            </button>
          </div>
        </nav>
      </header>

      <main class="main" id="main">
        <slot />
      </main>

      <footer class="site-footer">
        <PlovdivSkyline class="footer-skyline" />
        <div class="container">
          <div class="footer-top">
            <div class="footer-brand">
              <a class="brand" href={localizePath("/", lang)} data-brand>
                <span data-brand-name>{t.site.name}</span>
              </a>
              <p data-footer-blurb>{t.footer.blurb}</p>
            </div>
            <div class="footer-col">
              <h4 data-footer-group="explore">{t.footer.explore}</h4>
              <ul>
                {footerHistory.map((item) => (
                  <li><a href={item.href} data-footer-key={item.key}>{item.label}</a></li>
                ))}
              </ul>
            </div>
            <div class="footer-col">
              <h4 data-footer-group="civic">{t.footer.civic}</h4>
              <ul>
                {footerCivic.map((item) => (
                  <li><a href={item.href} data-footer-key={item.key}>{item.label}</a></li>
                ))}
              </ul>
            </div>
            <div class="footer-col">
              <h4 data-footer-group="about">{t.footer.about}</h4>
              <ul>
                {footerAbout.map((item) => (
                  <li><a href={item.href} data-footer-key={item.key}>{item.label}</a></li>
                ))}
              </ul>
            </div>
          </div>
          <Ornament />
          <div class="footer-bottom">
            <span data-footer-note>{t.footer.note}</span>
            <span class="meta" data-footer-data-note>{t.footer.dataNote}</span>
          </div>
        </div>
      </footer>
    </div>

    <script is:inline>
      (function () {
        var header = document.getElementById("site-header");
        var navToggle = document.getElementById("nav-toggle");
        var themeToggle = document.getElementById("theme-toggle");
        var langMenu = document.getElementById("lang-menu");

        // Close the language dropdown when clicking outside it.
        if (langMenu) {
          document.addEventListener("click", function (e) {
            if (langMenu.open && !langMenu.contains(e.target)) {
              langMenu.open = false;
            }
          });
        }

        if (navToggle && header) {
          navToggle.addEventListener("click", function () {
            var open = header.getAttribute("data-open") === "true";
            header.setAttribute("data-open", open ? "false" : "true");
            navToggle.setAttribute("aria-expanded", open ? "false" : "true");
          });
        }

        document.addEventListener("keydown", function (e) {
          if (e.key === "Escape") {
            if (header && header.getAttribute("data-open") === "true") {
              header.setAttribute("data-open", "false");
              if (navToggle) navToggle.setAttribute("aria-expanded", "false");
            }
            if (langMenu && langMenu.open) langMenu.open = false;
          }
        });

        if (themeToggle) {
          themeToggle.addEventListener("click", function () {
            var root = document.documentElement;
            var current = root.getAttribute("data-theme");
            var prefersDark =
              window.matchMedia &&
              window.matchMedia("(prefers-color-scheme: dark)").matches;
            var effective = current || (prefersDark ? "dark" : "light");
            var next = effective === "dark" ? "light" : "dark";
            root.setAttribute("data-theme", next);
            try {
              localStorage.setItem("op-theme", next);
            } catch (e) {}
          });
        }

        // Scroll-reveal: gently fade/rise editorial blocks marked [data-reveal]
        // or [data-reveal-stagger] as they enter the viewport. Anything already
        // in view (or when motion is reduced / IO unsupported) shows immediately.
        var revealEls = document.querySelectorAll("[data-reveal], [data-reveal-stagger]");
        if (revealEls.length) {
          var reduceMotion =
            window.matchMedia &&
            window.matchMedia("(prefers-reduced-motion: reduce)").matches;
          if (reduceMotion || !("IntersectionObserver" in window)) {
            revealEls.forEach(function (el) { el.classList.add("is-visible"); });
          } else {
            var io = new IntersectionObserver(
              function (entries) {
                entries.forEach(function (entry) {
                  if (entry.isIntersecting) {
                    entry.target.classList.add("is-visible");
                    io.unobserve(entry.target);
                  }
                });
              },
              { rootMargin: "0px 0px -8% 0px", threshold: 0.05 }
            );
            var vh = window.innerHeight || document.documentElement.clientHeight;
            revealEls.forEach(function (el) {
              // Already on screen at load → reveal now, no flash.
              if (el.getBoundingClientRect().top < vh * 0.92) {
                el.classList.add("is-visible");
              } else {
                io.observe(el);
              }
            });
          }
        }
      })();
    </script>

    {localeDetect && (
      <>
        <script type="application/json" id="op-chrome-i18n" set:html={chromeI18nJson} />
        <script is:inline>
          (function () {
            // Re-localize the shared header/footer chrome for pages that are a
            // single static file shared by every locale (see the `localeDetect`
            // prop). Detects the locale from the visited URL the same way the
            // page's own content script does, then swaps text + hrefs by the
            // stable data-nav-key/data-menu-key/data-footer-key hooks rendered
            // above. A no-op when the detected locale is already "bg" (the
            // server-rendered default), so this never fights normal pages —
            // those never set `localeDetect` in the first place.
            var codes = ["bg", "en", "de", "fr", "it", "tr", "es", "el", "ja"];
            var segments = (window.location.pathname || "/").split("/").filter(Boolean);
            var loc = segments.length > 0 && codes.indexOf(segments[0]) > -1 ? segments[0] : "bg";
            if (loc === "bg") return;

            var dataEl = document.getElementById("op-chrome-i18n");
            var all = dataEl ? JSON.parse(dataEl.textContent) : null;
            var c = all ? all[loc] : null;
            if (!c) return;

            var lp = function (base) { return "/" + loc + base; };
            var setText = function (el, value) { if (el) el.textContent = value; };

            document.querySelectorAll("[data-skip-link]").forEach(function (el) { setText(el, c.skip); });
            document.querySelectorAll("[data-brand-name]").forEach(function (el) { setText(el, c.siteName); });
            document.querySelectorAll("[data-brand]").forEach(function (el) {
              el.setAttribute("href", lp("/"));
              if (el.hasAttribute("data-brand-aria")) el.setAttribute("aria-label", c.siteName + " — " + c.homeAria);
            });
            document.querySelectorAll("[data-nav-aria]").forEach(function (el) { el.setAttribute("aria-label", c.homeAria); });
            document.querySelectorAll("[data-nav-groups-aria]").forEach(function (el) { el.setAttribute("aria-label", c.groups.explore); });
            document.querySelectorAll("[data-lang-switch-aria]").forEach(function (el) {
              el.setAttribute("aria-label", c.langSwitchAria);
              el.setAttribute("title", c.langSwitchAria);
            });
            document.querySelectorAll("[data-theme-aria]").forEach(function (el) {
              el.setAttribute("aria-label", c.themeAria);
              el.setAttribute("title", c.themeAria);
            });
            document.querySelectorAll("[data-menu-aria]").forEach(function (el) { el.setAttribute("aria-label", c.menuAria); });
            document.querySelectorAll("[data-flag]").forEach(function (el) { setText(el, loc.toUpperCase()); });
            document.querySelectorAll("[data-lang-option]").forEach(function (el) {
              var isCurrent = el.getAttribute("data-lang-option") === loc;
              if (isCurrent) el.setAttribute("aria-current", "true");
              else el.removeAttribute("aria-current");
            });

            document.querySelectorAll("[data-nav-key]").forEach(function (el) {
              var key = el.getAttribute("data-nav-key");
              if (c.nav[key]) {
                setText(el, c.nav[key]);
                el.setAttribute("href", lp("/" + key));
              }
            });
            document.querySelectorAll("[data-menu-group]").forEach(function (el) {
              var key = el.getAttribute("data-menu-group");
              if (c.groups[key]) setText(el, c.groups[key]);
            });
            document.querySelectorAll("[data-menu-key]").forEach(function (el) {
              var key = el.getAttribute("data-menu-key");
              if (c.nav[key]) {
                setText(el, c.nav[key]);
                el.setAttribute("href", lp("/" + key));
              }
            });
            document.querySelectorAll("[data-footer-group]").forEach(function (el) {
              var key = el.getAttribute("data-footer-group");
              if (c.groups[key]) setText(el, c.groups[key]);
            });
            document.querySelectorAll("[data-footer-key]").forEach(function (el) {
              var key = el.getAttribute("data-footer-key");
              if (c.nav[key]) {
                setText(el, c.nav[key]);
                el.setAttribute("href", lp("/" + key));
              }
            });
            document.querySelectorAll("[data-footer-blurb]").forEach(function (el) { setText(el, c.footer.blurb); });
            document.querySelectorAll("[data-footer-note]").forEach(function (el) { setText(el, c.footer.note); });
            document.querySelectorAll("[data-footer-data-note]").forEach(function (el) { setText(el, c.footer.dataNote); });
          })();
        </script>
      </>
    )}
  </body>
</html>
