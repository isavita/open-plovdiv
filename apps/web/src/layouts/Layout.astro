---
import "@fontsource-variable/playfair-display/index.css";
import "../styles/global.css";
import PlovdivSkyline from "@components/PlovdivSkyline.astro";
import Ornament from "@components/Ornament.astro";
import { languages, localeCodes, localeForLang, localizePath, ui, type Lang } from "@i18n/utils";
import {
  absoluteUrl,
  buildPageStructuredData,
  inferOpenGraphType,
  serializeJsonLd,
  type JsonLdObject
} from "@lib/seo";

type Props = {
  lang: Lang;
  /** Logical (default-locale) path of this page, e.g. "/budget" or "/". */
  path: string;
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  robots?: string;
  structuredData?: JsonLdObject | JsonLdObject[];
};

const { lang, path, title, description, image, imageAlt, robots, structuredData } = Astro.props;
const t = ui[lang];

const pageTitle = title ? `${title} · ${t.site.name}` : t.site.name;
const pageDescription = description ?? t.site.tagline;
const structuredTitle = title ?? t.site.name;

const ogLocales: Record<Lang, string> = { bg: "bg_BG", en: "en_GB", de: "de_DE", fr: "fr_FR", it: "it_IT", tr: "tr_TR", es: "es_ES", el: "el_GR", ja: "ja_JP" };
const ogLocale = ogLocales[lang];
const routesLabel = ({ bg: "Маршрути", en: "Routes", de: "Routen", fr: "Parcours", it: "Percorsi", tr: "Rotalar", es: "Rutas", el: "Διαδρομές", ja: "ルート" } satisfies Record<Lang, string>)[lang];
const governanceLabel = ({ bg: "Управление", en: "Governance", de: "Governance", fr: "Gouvernance", it: "Governo", tr: "Yönetim", es: "Gobernanza", el: "Διακυβέρνηση", ja: "統治" } satisfies Record<Lang, string>)[lang];

// Primary nav now separates deep history, visitor routes and political context;
// civic + reference links live in the footer and homepage action paths.
const navItems = [
  { href: localizePath("/history", lang), base: "/history", label: t.nav.history },
  { href: localizePath("/routes", lang), base: "/routes", label: routesLabel },
  { href: localizePath("/mayors", lang), base: "/mayors", label: t.nav.mayors },
  { href: localizePath("/governance", lang), base: "/governance", label: governanceLabel },
  { href: localizePath("/places", lang), base: "/places", label: t.nav.places }
];

function isActive(base: string): boolean {
  if (base === "/") return path === "/";
  return path === base || path.startsWith(`${base}/`);
}

const site = Astro.site ?? new URL("https://openplovdiv.example");
const canonical = new URL(localizePath(path, lang), site).href;
const seoImage = absoluteUrl(image, site);
const seoImageAlt = imageAlt ?? structuredTitle;
const ogType = inferOpenGraphType(path);
// hreflang alternates for every supported locale (+ x-default → Bulgarian root).
const altLinks = localeCodes.map((code) => ({
  code,
  href: new URL(localizePath(path, code), site).href
}));
const xDefaultHref = new URL(localizePath(path, "bg"), site).href;
const structuredDataJson = serializeJsonLd(
  buildPageStructuredData({
    site,
    lang,
    locale: localeForLang(lang),
    siteName: t.site.name,
    logicalPath: path,
    canonical,
    title: structuredTitle,
    description: pageDescription,
    image: seoImage,
    additional: structuredData,
    breadcrumbLabels: {
      home: t.nav.home,
      history: t.nav.history,
      routes: routesLabel,
      mayors: t.nav.mayors,
      governance: governanceLabel,
      people: t.nav.people,
      places: t.nav.places,
      stories: t.nav.stories,
      archive: t.nav.archive,
      overview: t.nav.overview,
      budget: t.nav.budget,
      projects: t.nav.projects,
      community: t.nav.community,
      "fix-map": t.nav.fixMap,
      "data-sources": t.footer.sources,
      privacy: t.footer.privacy,
      moderation: t.footer.moderation
    }
  })
);

const footerHistory = [
  { href: localizePath("/history", lang), label: t.nav.history },
  { href: localizePath("/routes", lang), label: routesLabel },
  { href: localizePath("/mayors", lang), label: t.nav.mayors },
  { href: localizePath("/governance", lang), label: governanceLabel },
  { href: localizePath("/people", lang), label: t.nav.people },
  { href: localizePath("/places", lang), label: t.nav.places },
  { href: localizePath("/stories", lang), label: t.nav.stories },
  { href: localizePath("/archive", lang), label: t.nav.archive }
];
const footerCivic = [
  { href: localizePath("/overview", lang), label: t.nav.overview },
  { href: localizePath("/budget", lang), label: t.nav.budget },
  { href: localizePath("/projects", lang), label: t.nav.projects },
  { href: localizePath("/fix-map", lang), label: t.nav.fixMap },
  { href: localizePath("/community", lang), label: t.footer.community }
];
const footerAbout = [
  { href: localizePath("/data-sources", lang), label: t.footer.sources },
  { href: localizePath("/privacy", lang), label: t.footer.privacy },
  { href: localizePath("/moderation", lang), label: t.footer.moderation }
];

// Secondary destinations shown only inside the mobile menu, grouped so the
// phone nav reaches every page without duplicating the 5 primary links.
const menuExplore = [
  { href: localizePath("/people", lang), base: "/people", label: t.nav.people },
  { href: localizePath("/stories", lang), base: "/stories", label: t.nav.stories },
  { href: localizePath("/archive", lang), base: "/archive", label: t.nav.archive }
];
const menuCivic = [
  { href: localizePath("/overview", lang), base: "/overview", label: t.nav.overview },
  { href: localizePath("/budget", lang), base: "/budget", label: t.nav.budget },
  { href: localizePath("/projects", lang), base: "/projects", label: t.nav.projects },
  { href: localizePath("/fix-map", lang), base: "/fix-map", label: t.nav.fixMap },
  { href: localizePath("/community", lang), base: "/community", label: t.footer.community }
];
const menuAbout = [
  { href: localizePath("/data-sources", lang), base: "/data-sources", label: t.footer.sources },
  { href: localizePath("/privacy", lang), base: "/privacy", label: t.footer.privacy },
  { href: localizePath("/moderation", lang), base: "/moderation", label: t.footer.moderation }
];
const menuGroups = [
  { label: t.footer.explore, items: menuExplore },
  { label: t.footer.civic, items: menuCivic },
  { label: t.footer.about, items: menuAbout }
];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    {robots && <meta name="robots" content={robots} />}
    <link rel="canonical" href={canonical} />
    {altLinks.map((alt) => (
      <link rel="alternate" hreflang={alt.code} href={alt.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={xDefaultHref} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" content="#f2ead8" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#16120c" media="(prefers-color-scheme: dark)" />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={t.site.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={ogLocale} />
    {altLinks.filter((alt) => alt.code !== lang).map((alt) => (
      <meta property="og:locale:alternate" content={ogLocales[alt.code]} />
    ))}
    {seoImage && (
      <>
        <meta property="og:image" content={seoImage} />
        <meta property="og:image:alt" content={seoImageAlt} />
      </>
    )}
    <meta name="twitter:card" content={seoImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:url" content={canonical} />
    {seoImage && <meta name="twitter:image" content={seoImage} />}
    {seoImage && <meta name="twitter:image:alt" content={seoImageAlt} />}

    <script type="application/ld+json" set:html={structuredDataJson}></script>

    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem("op-theme");
          if (t === "dark" || t === "light") {
            document.documentElement.setAttribute("data-theme", t);
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <div class="site-shell">
      <a class="skip-link" href="#main">{t.site.skip}</a>

      <header class="site-header" id="site-header">
        <nav class="nav" aria-label={t.nav.home}>
          <a class="brand" href={localizePath("/", lang)} aria-label={`${t.site.name} — ${t.nav.home}`}>
            <span>{t.site.name}</span>
          </a>

          <div class="nav-links" id="nav-links">
            {navItems.map((item) => (
              <a href={item.href} aria-current={isActive(item.base) ? "page" : undefined}>
                {item.label}
              </a>
            ))}

            <div class="nav-groups" aria-label={t.footer.explore}>
              {menuGroups.map((group) => (
                <div class="nav-group">
                  <span class="nav-group-label">{group.label}</span>
                  {group.items.map((item) => (
                    <a href={item.href} aria-current={isActive(item.base) ? "page" : undefined}>
                      {item.label}
                    </a>
                  ))}
                </div>
              ))}
            </div>
          </div>

          <div class="nav-right">
            <details class="lang-menu" id="lang-menu">
              <summary class="icon-btn lang-switch" aria-label={t.site.langSwitch} title={t.site.langSwitch}>
                <span class="flag" aria-hidden="true">{lang.toUpperCase()}</span>
                <span class="lang-caret" aria-hidden="true">▾</span>
              </summary>
              <ul class="lang-options">
                {localeCodes.map((code) => (
                  <li>
                    <a
                      href={localizePath(path, code)}
                      hreflang={code}
                      lang={code}
                      aria-current={code === lang ? "true" : undefined}
                    >
                      <span class="lang-code" aria-hidden="true">{code.toUpperCase()}</span>
                      <span>{languages[code]}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </details>
            <button
              type="button"
              class="icon-btn theme-toggle"
              id="theme-toggle"
              aria-label={t.site.theme}
              title={t.site.theme}
            >
              <span class="sun" aria-hidden="true">☀</span>
              <span class="moon" aria-hidden="true">☾</span>
            </button>
            <button
              type="button"
              class="icon-btn nav-toggle"
              id="nav-toggle"
              aria-controls="nav-links"
              aria-expanded="false"
              aria-label={t.site.menu}
            >
              <span aria-hidden="true">☰</span>
            </button>
          </div>
        </nav>
      </header>

      <main class="main" id="main">
        <slot />
      </main>

      <footer class="site-footer">
        <PlovdivSkyline class="footer-skyline" />
        <div class="container">
          <div class="footer-top">
            <div class="footer-brand">
              <a class="brand" href={localizePath("/", lang)}>
                <span>{t.site.name}</span>
              </a>
              <p>{t.footer.blurb}</p>
            </div>
            <div class="footer-col">
              <h4>{t.footer.explore}</h4>
              <ul>
                {footerHistory.map((item) => (
                  <li><a href={item.href}>{item.label}</a></li>
                ))}
              </ul>
            </div>
            <div class="footer-col">
              <h4>{t.footer.civic}</h4>
              <ul>
                {footerCivic.map((item) => (
                  <li><a href={item.href}>{item.label}</a></li>
                ))}
              </ul>
            </div>
            <div class="footer-col">
              <h4>{t.footer.about}</h4>
              <ul>
                {footerAbout.map((item) => (
                  <li><a href={item.href}>{item.label}</a></li>
                ))}
              </ul>
            </div>
          </div>
          <Ornament />
          <div class="footer-bottom">
            <span>{t.footer.note}</span>
            <span class="meta">{t.footer.dataNote}</span>
          </div>
        </div>
      </footer>
    </div>

    <script is:inline>
      (function () {
        var header = document.getElementById("site-header");
        var navToggle = document.getElementById("nav-toggle");
        var themeToggle = document.getElementById("theme-toggle");
        var langMenu = document.getElementById("lang-menu");

        // Close the language dropdown when clicking outside it.
        if (langMenu) {
          document.addEventListener("click", function (e) {
            if (langMenu.open && !langMenu.contains(e.target)) {
              langMenu.open = false;
            }
          });
        }

        if (navToggle && header) {
          navToggle.addEventListener("click", function () {
            var open = header.getAttribute("data-open") === "true";
            header.setAttribute("data-open", open ? "false" : "true");
            navToggle.setAttribute("aria-expanded", open ? "false" : "true");
          });
        }

        document.addEventListener("keydown", function (e) {
          if (e.key === "Escape") {
            if (header && header.getAttribute("data-open") === "true") {
              header.setAttribute("data-open", "false");
              if (navToggle) navToggle.setAttribute("aria-expanded", "false");
            }
            if (langMenu && langMenu.open) langMenu.open = false;
          }
        });

        if (themeToggle) {
          themeToggle.addEventListener("click", function () {
            var root = document.documentElement;
            var current = root.getAttribute("data-theme");
            var prefersDark =
              window.matchMedia &&
              window.matchMedia("(prefers-color-scheme: dark)").matches;
            var effective = current || (prefersDark ? "dark" : "light");
            var next = effective === "dark" ? "light" : "dark";
            root.setAttribute("data-theme", next);
            try {
              localStorage.setItem("op-theme", next);
            } catch (e) {}
          });
        }
      })();
    </script>
  </body>
</html>
