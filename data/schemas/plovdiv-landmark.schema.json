{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openplovdiv.example/schemas/plovdiv-landmark.schema.json",
  "title": "Open Plovdiv landmark entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "category",
    "era_bg",
    "era_en",
    "name_bg",
    "name_en",
    "summary_bg",
    "summary_en",
    "source",
    "data_quality"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^landmark-[0-9a-z-]+$"
    },
    "category": {
      "type": "string",
      "enum": ["thracian", "roman", "medieval", "ottoman", "revival", "religious", "hill", "civic", "monument"]
    },
    "era_bg": { "type": "string", "minLength": 2 },
    "era_en": { "type": "string", "minLength": 2 },
    "name_bg": { "type": "string", "minLength": 2 },
    "name_en": { "type": "string", "minLength": 2 },
    "summary_bg": { "type": "string", "minLength": 20 },
    "summary_en": { "type": "string", "minLength": 20 },
    "wikidata_id": {
      "type": "string",
      "pattern": "^Q[0-9]+$"
    },
    "built_year": { "type": ["integer", "null"], "minimum": -8000, "maximum": 2100 },
    "built_date": { "type": "string", "minLength": 4 },
    "architect_bg": { "type": "string", "minLength": 2 },
    "architect_en": { "type": "string", "minLength": 2 },
    "builder_bg": { "type": "string", "minLength": 2 },
    "builder_en": { "type": "string", "minLength": 2 },
    "coordinates": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lat", "lng", "accuracy"],
      "properties": {
        "lat": { "type": "number", "minimum": -90, "maximum": 90 },
        "lng": { "type": "number", "minimum": -180, "maximum": 180 },
        "accuracy": { "type": "string", "minLength": 3 }
      }
    },
    "coordinate_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "url", "accessed_at"],
      "properties": {
        "title": { "type": "string", "minLength": 3 },
        "url": { "type": "string", "format": "uri" },
        "accessed_at": { "type": "string", "format": "date" }
      }
    },
    "current_status_bg": { "type": "string", "minLength": 5 },
    "current_status_en": { "type": "string", "minLength": 5 },
    "media": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "title",
          "url",
          "page_url",
          "credit",
          "license",
          "license_url",
          "accessed_at"
        ],
        "properties": {
          "type": { "type": "string", "enum": ["image"] },
          "title": { "type": "string", "minLength": 3 },
          "url": { "type": "string", "format": "uri" },
          "page_url": { "type": "string", "format": "uri" },
          "credit": { "type": "string", "minLength": 2 },
          "license": { "type": "string", "minLength": 2 },
          "license_url": { "type": "string", "format": "uri" },
          "accessed_at": { "type": "string", "format": "date" }
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "url", "accessed_at"],
      "properties": {
        "title": { "type": "string", "minLength": 3 },
        "url": { "type": "string", "format": "uri" },
        "accessed_at": { "type": "string", "format": "date" }
      }
    },
    "data_quality": {
      "type": "string",
      "enum": ["public_source", "manual_reviewed", "provisional"]
    }
  }
}
