{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openplovdiv.example/schemas/plovdiv-population.schema.json",
  "title": "Open Plovdiv population data point",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "year", "population", "source"],
  "properties": {
    "id": { "type": "string", "pattern": "^population-[0-9]+$" },
    "year": { "type": "integer", "minimum": 1800, "maximum": 2100 },
    "population": { "type": "integer", "minimum": 0 },
    "note_bg": { "type": "string", "minLength": 3 },
    "note_en": { "type": "string", "minLength": 3 },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "url", "accessed_at"],
      "properties": {
        "title": { "type": "string", "minLength": 3 },
        "url": { "type": "string", "format": "uri" },
        "accessed_at": { "type": "string", "format": "date" }
      }
    }
  }
}
