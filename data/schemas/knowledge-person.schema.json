{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openplovdiv.example/schemas/knowledge-person.schema.json",
  "title": "Open Plovdiv knowledge person",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "wikidata_id",
    "name_bg",
    "name_en",
    "summary_bg",
    "summary_en",
    "roles",
    "birth_year",
    "death_year",
    "image",
    "image_credit",
    "term_events",
    "event_ids",
    "place_ids",
    "organization_ids",
    "source_ids",
    "relationships",
    "provenance",
    "editorial"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^person-[0-9a-z-]+$" },
    "type": { "const": "person" },
    "wikidata_id": { "type": ["string", "null"], "pattern": "^Q[0-9]+$" },
    "name_bg": { "type": "string", "minLength": 2 },
    "name_en": { "type": "string", "minLength": 2 },
    "summary_bg": { "type": "string", "minLength": 10 },
    "summary_en": { "type": "string", "minLength": 10 },
    "roles": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "birth_year": { "type": ["integer", "null"], "minimum": 0, "maximum": 2100 },
    "death_year": { "type": ["integer", "null"], "minimum": 0, "maximum": 2100 },
    "image": { "type": ["string", "null"] },
    "image_credit": { "type": ["string", "null"] },
    "term_events": { "type": "array", "items": { "type": "string", "pattern": "^event-[0-9a-z-]+$" } },
    "event_ids": {
      "type": "array",
      "items": { "type": "string", "pattern": "^event-[0-9a-z-]+$" }
    },
    "place_ids": {
      "type": "array",
      "items": { "type": "string", "pattern": "^place-[0-9a-z-]+$" }
    },
    "organization_ids": {
      "type": "array",
      "items": { "type": "string", "pattern": "^org-[0-9a-z-]+$" }
    },
    "source_ids": { "type": "array", "items": { "type": "string", "pattern": "^source-[0-9a-z-]+$" }, "minItems": 1 },
    "relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "person_id", "event_id", "source_id"],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "succeeds",
              "succeeded_by",
              "spouse",
              "father",
              "mother",
              "parent",
              "child",
              "sibling",
              "mentor",
              "student",
              "partner",
              "influenced_by"
            ]
          },
          "person_id": { "type": "string", "pattern": "^person-[0-9a-z-]+$" },
          "event_id": { "type": ["string", "null"], "pattern": "^event-[0-9a-z-]+$" },
          "source_id": { "type": "string", "pattern": "^source-[0-9a-z-]+$" },
          "evidence_property": { "type": "string", "pattern": "^P[0-9]+$" }
        }
      }
    },
    "provenance": { "$ref": "knowledge-event.schema.json#/definitions/provenance" },
    "editorial": { "$ref": "knowledge-event.schema.json#/definitions/editorial" }
  }
}
