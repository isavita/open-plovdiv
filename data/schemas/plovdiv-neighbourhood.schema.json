{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openplovdiv.example/schemas/plovdiv-neighbourhood.schema.json",
  "title": "Open Plovdiv neighbourhood entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name_bg",
    "name_en",
    "era_key",
    "year",
    "period_bg",
    "period_en",
    "summary_bg",
    "summary_en",
    "source"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^neighbourhood-[0-9a-z-]+$" },
    "name_bg": { "type": "string", "minLength": 2 },
    "name_en": { "type": "string", "minLength": 2 },
    "era_key": { "type": "string", "enum": ["ottoman", "revival", "modern", "socialist"] },
    "year": { "type": "integer", "minimum": 1000, "maximum": 2100 },
    "period_bg": { "type": "string", "minLength": 3 },
    "period_en": { "type": "string", "minLength": 3 },
    "summary_bg": { "type": "string", "minLength": 20 },
    "summary_en": { "type": "string", "minLength": 20 },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "url", "accessed_at"],
      "properties": {
        "title": { "type": "string", "minLength": 3 },
        "url": { "type": "string", "format": "uri" },
        "accessed_at": { "type": "string", "format": "date" }
      }
    }
  }
}
