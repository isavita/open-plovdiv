{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openplovdiv.example/schemas/knowledge-then-now-pair.schema.json",
  "title": "Open Plovdiv generated then-now pair",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "place_id",
    "historical_archive_item_id",
    "title_bg",
    "title_en",
    "caption_bg",
    "caption_en",
    "then_media",
    "now_media",
    "source_ids",
    "provenance",
    "match_quality",
    "data_quality",
    "editorial"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^then-now-[0-9a-z-]+$" },
    "place_id": { "type": "string", "pattern": "^place-[0-9a-z-]+$" },
    "historical_archive_item_id": { "type": "string", "pattern": "^archive-[0-9a-z-]+$" },
    "title_bg": { "type": "string", "minLength": 3 },
    "title_en": { "type": "string", "minLength": 3 },
    "caption_bg": { "type": "string", "minLength": 20 },
    "caption_en": { "type": "string", "minLength": 20 },
    "then_media": { "$ref": "#/definitions/generated_media" },
    "now_media": { "$ref": "#/definitions/generated_media" },
    "source_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^source-[0-9a-z-]+$" }
    },
    "provenance": {
      "type": "array",
      "minItems": 2,
      "items": { "$ref": "#/definitions/provenance" }
    },
    "match_quality": {
      "type": "string",
      "enum": ["same_place_approximate_viewpoint", "same_place_close_viewpoint", "city_context"]
    },
    "data_quality": { "type": "string", "enum": ["public_source", "manual_reviewed", "provisional"] },
    "editorial": {
      "$ref": "https://openplovdiv.example/schemas/historical-archive-item.schema.json#/definitions/editorial"
    }
  },
  "definitions": {
    "generated_media": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "title",
        "url",
        "page_url",
        "credit",
        "license",
        "license_url",
        "accessed_at",
        "source_id"
      ],
      "properties": {
        "type": { "type": "string", "enum": ["image"] },
        "title": { "type": "string", "minLength": 3 },
        "url": { "type": "string", "format": "uri" },
        "page_url": { "type": "string", "format": "uri" },
        "credit": { "type": "string", "minLength": 2 },
        "license": { "type": "string", "minLength": 2 },
        "license_url": { "type": "string", "format": "uri" },
        "accessed_at": { "type": "string", "format": "date" },
        "source_id": { "type": "string", "pattern": "^source-[0-9a-z-]+$" }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "evidence_type", "claim_bg", "claim_en", "url", "accessed_at", "license_status"],
      "properties": {
        "source_id": { "type": "string", "pattern": "^source-[0-9a-z-]+$" },
        "evidence_type": {
          "type": "string",
          "enum": ["then_now_historical_media", "then_now_current_media"]
        },
        "claim_bg": { "type": "string", "minLength": 10 },
        "claim_en": { "type": "string", "minLength": 10 },
        "url": { "type": "string", "format": "uri" },
        "accessed_at": { "type": "string", "format": "date" },
        "license_status": { "type": "string", "minLength": 3 }
      }
    }
  }
}
