{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openplovdiv.example/schemas/project.schema.json",
  "title": "Open Plovdiv public project",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title_bg",
    "title_en",
    "summary_bg",
    "category",
    "status",
    "municipality",
    "district",
    "location",
    "budget",
    "sources",
    "data_quality",
    "updated_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^plovdiv-[a-z0-9-]+$"
    },
    "title_bg": {
      "type": "string",
      "minLength": 3
    },
    "title_en": {
      "type": "string",
      "minLength": 3
    },
    "summary_bg": {
      "type": "string",
      "minLength": 10
    },
    "summary_en": {
      "type": "string",
      "minLength": 10
    },
    "category": {
      "type": "string",
      "enum": [
        "roads",
        "pavement",
        "street_lighting",
        "parks",
        "waste",
        "public_transport",
        "accessibility",
        "drainage",
        "culture",
        "education",
        "sport",
        "other"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "planned",
        "funded",
        "contracted",
        "in_progress",
        "completed",
        "delayed",
        "postponed",
        "unknown"
      ]
    },
    "note_bg": {
      "type": "string"
    },
    "note_en": {
      "type": "string"
    },
    "municipality": {
      "const": "plovdiv"
    },
    "district": {
      "type": [
        "string",
        "null"
      ]
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lat",
        "lng",
        "address_bg"
      ],
      "properties": {
        "lat": {
          "type": "number",
          "minimum": 42,
          "maximum": 42.25
        },
        "lng": {
          "type": "number",
          "minimum": 24.6,
          "maximum": 24.9
        },
        "address_bg": {
          "type": "string",
          "minLength": 3
        },
        "address_en": {
          "type": "string",
          "minLength": 3
        },
        "approximate": {
          "type": "boolean"
        }
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "year",
        "funding_source"
      ],
      "properties": {
        "amount_bgn": {
          "type": "number",
          "minimum": 0
        },
        "amount_eur": {
          "type": "number",
          "minimum": 0
        },
        "currency": {
          "type": "string",
          "enum": ["BGN", "EUR"]
        },
        "year": {
          "type": "integer",
          "minimum": 2000,
          "maximum": 2100
        },
        "funding_source": {
          "type": "string",
          "minLength": 3
        }
      }
    },
    "related_budget_item_id": {
      "type": "string"
    },
    "timeline": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "date",
          "label_bg",
          "source_url"
        ],
        "properties": {
          "date": {
            "type": "string",
            "format": "date"
          },
          "label_bg": {
            "type": "string",
            "minLength": 3
          },
          "label_en": {
            "type": "string",
            "minLength": 3
          },
          "source_url": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/source"
      }
    },
    "data_quality": {
      "type": "string",
      "enum": [
        "public_source",
        "manual_reviewed",
        "provisional"
      ]
    },
    "updated_at": {
      "type": "string",
      "format": "date"
    }
  },
  "definitions": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "url",
        "accessed_at"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 3
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "accessed_at": {
          "type": "string",
          "format": "date"
        }
      }
    }
  }
}
