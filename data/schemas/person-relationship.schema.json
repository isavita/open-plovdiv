{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openplovdiv.example/schemas/person-relationship.schema.json",
  "title": "Open Plovdiv curated person relationship",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "from_wikidata_id",
    "to_wikidata_id",
    "type",
    "evidence_property",
    "source",
    "data_quality"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^person-rel-[0-9a-z-]+$" },
    "from_wikidata_id": { "type": "string", "pattern": "^Q[0-9]+$" },
    "to_wikidata_id": { "type": "string", "pattern": "^Q[0-9]+$" },
    "type": {
      "type": "string",
      "enum": [
        "spouse",
        "father",
        "mother",
        "parent",
        "child",
        "sibling",
        "mentor",
        "student",
        "partner",
        "influenced_by"
      ]
    },
    "evidence_property": { "type": "string", "pattern": "^P[0-9]+$" },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "url", "accessed_at"],
      "properties": {
        "title": { "type": "string", "minLength": 3 },
        "url": { "type": "string", "format": "uri" },
        "accessed_at": { "type": "string", "format": "date" }
      }
    },
    "data_quality": {
      "type": "string",
      "enum": ["public_source", "manual_reviewed", "provisional"]
    }
  }
}
