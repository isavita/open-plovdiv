{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openplovdiv.example/schemas/city-archive.schema.json",
  "title": "Open Plovdiv city archive record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "municipality",
    "kind",
    "year_start",
    "period_bg",
    "title_bg",
    "summary_bg",
    "source_document",
    "data_quality"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^archive-plovdiv-[0-9a-z-]+$"
    },
    "municipality": {
      "const": "plovdiv"
    },
    "kind": {
      "type": "string",
      "enum": [
        "mayor_term",
        "historical_event",
        "cultural_programme",
        "historical_finance",
        "municipal_programme",
        "governance_change",
        "archive_source"
      ]
    },
    "year_start": {
      "type": "integer",
      "minimum": 1800,
      "maximum": 2100
    },
    "year_end": {
      "type": "integer",
      "minimum": 1800,
      "maximum": 2100
    },
    "period_bg": {
      "type": "string",
      "minLength": 3
    },
    "period_en": {
      "type": "string",
      "minLength": 3
    },
    "title_bg": {
      "type": "string",
      "minLength": 3
    },
    "title_en": {
      "type": "string",
      "minLength": 3
    },
    "actor_bg": {
      "type": "string",
      "minLength": 2
    },
    "actor_en": {
      "type": "string",
      "minLength": 2
    },
    "amount_bgn": {
      "type": "number",
      "minimum": 0
    },
    "amount_eur": {
      "type": "number",
      "minimum": 0
    },
    "summary_bg": {
      "type": "string",
      "minLength": 10
    },
    "summary_en": {
      "type": "string",
      "minLength": 10
    },
    "bio_bg": {
      "type": "string",
      "minLength": 20
    },
    "bio_en": {
      "type": "string",
      "minLength": 20
    },
    "more_url": {
      "type": "string",
      "format": "uri"
    },
    "official_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "url",
        "accessed_at"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 3
        },
        "title_en": {
          "type": "string",
          "minLength": 3
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "url_en": {
          "type": "string",
          "format": "uri"
        },
        "accessed_at": {
          "type": "string",
          "format": "date"
        }
      }
    },
    "reference_links": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "title",
          "url",
          "accessed_at"
        ],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 3
          },
          "title_en": {
            "type": "string",
            "minLength": 3
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "url_en": {
            "type": "string",
            "format": "uri"
          },
          "accessed_at": {
            "type": "string",
            "format": "date"
          }
        }
      }
    },
    "image": {
      "type": "string",
      "pattern": "^/mayors/[a-z0-9-]+\\.(jpg|jpeg|png)$"
    },
    "image_credit": {
      "type": "string",
      "minLength": 2
    },
    "fate": {
      "type": "string",
      "enum": ["killed", "executed", "assassinated", "died_in_office"]
    },
    "fate_note_bg": { "type": "string", "minLength": 5 },
    "fate_note_en": { "type": "string", "minLength": 5 },
    "birthplace_bg": { "type": "string", "minLength": 2 },
    "birthplace_en": { "type": "string", "minLength": 2 },
    "birth_lat": { "type": "number", "minimum": -90, "maximum": 90 },
    "birth_lng": { "type": "number", "minimum": -180, "maximum": 180 },
    "birth_country_bg": { "type": "string", "minLength": 2 },
    "birth_country_en": { "type": "string", "minLength": 2 },
    "birth_wikidata": { "type": "string", "pattern": "^Q[0-9]+$" },
    "source_document": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "url",
        "accessed_at"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 3
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "accessed_at": {
          "type": "string",
          "format": "date"
        }
      }
    },
    "data_quality": {
      "type": "string",
      "enum": [
        "public_source",
        "manual_reviewed",
        "provisional"
      ]
    }
  }
}
