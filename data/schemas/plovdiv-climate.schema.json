{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openplovdiv.example/schemas/plovdiv-climate.schema.json",
  "title": "Open Plovdiv monthly climate normal",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "month", "high", "low", "precip", "source"],
  "properties": {
    "id": { "type": "string", "pattern": "^climate-[0-9]{2}$" },
    "month": { "type": "integer", "minimum": 1, "maximum": 12 },
    "high": { "type": "number", "minimum": -60, "maximum": 60 },
    "low": { "type": "number", "minimum": -60, "maximum": 60 },
    "precip": { "type": "number", "minimum": 0, "maximum": 1000 },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "url", "accessed_at"],
      "properties": {
        "title": { "type": "string", "minLength": 3 },
        "url": { "type": "string", "format": "uri" },
        "accessed_at": { "type": "string", "format": "date" }
      }
    }
  }
}
