{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openplovdiv.example/schemas/historical-archive-item.schema.json",
  "title": "Open Plovdiv historical archive item",
  "type": "object",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": { "kind": { "const": "map" } },
        "required": ["kind"]
      },
      "then": {
        "required": ["overlay_bounds"]
      },
      "else": {
        "not": { "required": ["overlay_bounds"] }
      }
    }
  ],
  "required": [
    "id",
    "kind",
    "place_id",
    "title_bg",
    "title_en",
    "description_bg",
    "description_en",
    "date_year",
    "date_display_bg",
    "date_display_en",
    "coordinates",
    "georeference",
    "media",
    "source",
    "commons_categories",
    "data_quality",
    "editorial"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^archive-[0-9a-z-]+$" },
    "kind": { "type": "string", "enum": ["photo", "map", "document"] },
    "place_id": { "type": "string", "pattern": "^place-[0-9a-z-]+$" },
    "title_bg": { "type": "string", "minLength": 3 },
    "title_en": { "type": "string", "minLength": 3 },
    "description_bg": { "type": "string", "minLength": 20 },
    "description_en": { "type": "string", "minLength": 20 },
    "date_year": { "type": "integer", "minimum": 1, "maximum": 2100 },
    "date_display_bg": { "type": "string", "minLength": 4 },
    "date_display_en": { "type": "string", "minLength": 4 },
    "coordinates": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lat", "lng", "accuracy", "source_place_id"],
      "properties": {
        "lat": { "type": "number", "minimum": -90, "maximum": 90 },
        "lng": { "type": "number", "minimum": -180, "maximum": 180 },
        "accuracy": { "type": "string", "minLength": 3 },
        "source_place_id": { "type": "string", "pattern": "^place-[0-9a-z-]+$" }
      }
    },
    "georeference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "confidence", "notes_bg", "notes_en"],
      "properties": {
        "method": {
          "type": "string",
          "enum": ["matched_to_existing_place_record", "map_extent_approximated_to_city", "manual_control_points"]
        },
        "confidence": { "type": "string", "enum": ["place_level", "city_context", "control_point_verified"] },
        "notes_bg": { "type": "string", "minLength": 10 },
        "notes_en": { "type": "string", "minLength": 10 }
      }
    },
    "overlay_bounds": { "$ref": "#/definitions/overlay_bounds" },
    "media": { "$ref": "#/definitions/media" },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "url", "accessed_at", "license"],
      "properties": {
        "title": { "type": "string", "minLength": 3 },
        "url": { "type": "string", "format": "uri" },
        "accessed_at": { "type": "string", "format": "date" },
        "license": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "label", "url"],
          "properties": {
            "status": { "type": "string", "enum": ["open_license"] },
            "label": { "type": "string", "minLength": 2 },
            "url": { "type": "string", "format": "uri" }
          }
        }
      }
    },
    "commons_categories": { "type": "array", "items": { "type": "string", "minLength": 2 } },
    "data_quality": { "type": "string", "enum": ["public_source", "manual_reviewed", "provisional"] },
    "editorial": { "$ref": "#/definitions/editorial" }
  },
  "definitions": {
    "overlay_bounds": {
      "type": "object",
      "additionalProperties": false,
      "required": ["south", "west", "north", "east", "method", "notes_bg", "notes_en"],
      "properties": {
        "south": { "type": "number", "minimum": -90, "maximum": 90 },
        "west": { "type": "number", "minimum": -180, "maximum": 180 },
        "north": { "type": "number", "minimum": -90, "maximum": 90 },
        "east": { "type": "number", "minimum": -180, "maximum": 180 },
        "method": { "type": "string", "enum": ["approximate_extent", "manual_control_points"] },
        "notes_bg": { "type": "string", "minLength": 20 },
        "notes_en": { "type": "string", "minLength": 20 }
      }
    },
    "media": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "title",
        "url",
        "page_url",
        "credit",
        "license",
        "license_url",
        "accessed_at"
      ],
      "properties": {
        "type": { "type": "string", "enum": ["image"] },
        "title": { "type": "string", "minLength": 3 },
        "url": { "type": "string", "format": "uri" },
        "page_url": { "type": "string", "format": "uri" },
        "credit": { "type": "string", "minLength": 2 },
        "license": { "type": "string", "minLength": 2 },
        "license_url": { "type": "string", "format": "uri" },
        "accessed_at": { "type": "string", "format": "date" }
      }
    },
    "editorial": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reviewed_by", "reviewed_at", "notes_bg", "notes_en"],
      "allOf": [
        {
          "if": {
            "properties": { "status": { "const": "signed_off" } },
            "required": ["status"]
          },
          "then": {
            "properties": {
              "reviewed_by": { "type": "string", "minLength": 2 },
              "reviewed_at": { "type": "string", "format": "date" }
            }
          }
        }
      ],
      "properties": {
        "status": { "type": "string", "enum": ["needs_editorial_signoff", "signed_off"] },
        "reviewed_by": { "type": ["string", "null"] },
        "reviewed_at": { "type": ["string", "null"], "format": "date" },
        "notes_bg": { "type": "string", "minLength": 10 },
        "notes_en": { "type": "string", "minLength": 10 }
      }
    }
  }
}
