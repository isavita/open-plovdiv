{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openplovdiv.example/schemas/primary-document.schema.json",
  "title": "Open Plovdiv primary document transcription",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "kind",
    "date",
    "date_year",
    "title_bg",
    "title_en",
    "summary_bg",
    "summary_en",
    "transcription",
    "linked_event_ids",
    "linked_budget_item_ids",
    "linked_place_ids",
    "linked_organization_ids",
    "source",
    "data_quality",
    "editorial"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^primary-doc-[0-9a-z-]+$" },
    "type": { "type": "string", "enum": ["primary_document"] },
    "kind": {
      "type": "string",
      "enum": ["municipal_decision", "state_gazette_decree", "municipal_rule", "council_minutes", "period_press", "other"]
    },
    "date": { "type": "string", "format": "date" },
    "date_year": { "type": "integer", "minimum": 1, "maximum": 2100 },
    "title_bg": { "type": "string", "minLength": 3 },
    "title_en": { "type": "string", "minLength": 3 },
    "summary_bg": { "type": "string", "minLength": 20 },
    "summary_en": { "type": "string", "minLength": 20 },
    "transcription": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "original_language", "excerpt_bg", "excerpt_en", "notes_bg", "notes_en"],
      "properties": {
        "type": { "type": "string", "enum": ["excerpt", "full", "diplomatic_excerpt"] },
        "original_language": { "type": "string", "enum": ["bg", "en", "el", "la", "tr", "fr", "de", "other"] },
        "excerpt_bg": { "type": "string", "minLength": 5 },
        "excerpt_en": { "type": "string", "minLength": 5 },
        "notes_bg": { "type": "string", "minLength": 10 },
        "notes_en": { "type": "string", "minLength": 10 }
      }
    },
    "linked_event_ids": {
      "type": "array",
      "items": { "type": "string", "pattern": "^event-[0-9a-z-]+$" }
    },
    "linked_budget_item_ids": {
      "type": "array",
      "items": { "type": "string", "pattern": "^budget-[0-9a-z-]+$" }
    },
    "linked_place_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^place-[0-9a-z-]+$" }
    },
    "linked_organization_ids": {
      "type": "array",
      "items": { "type": "string", "pattern": "^org-[0-9a-z-]+$" }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "url", "accessed_at", "license"],
      "properties": {
        "title": { "type": "string", "minLength": 3 },
        "url": { "type": "string", "format": "uri" },
        "accessed_at": { "type": "string", "format": "date" },
        "license": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "label", "url"],
          "properties": {
            "status": { "type": "string", "enum": ["open_license", "public_reference_terms_unverified"] },
            "label": { "type": "string", "minLength": 2 },
            "url": { "type": "string", "format": "uri" }
          }
        }
      }
    },
    "source_ids": {
      "type": "array",
      "items": { "type": "string", "pattern": "^source-[0-9a-z-]+$" }
    },
    "provenance": {
      "type": "array",
      "items": { "$ref": "#/definitions/provenance" }
    },
    "data_quality": { "type": "string", "enum": ["public_source", "manual_reviewed", "provisional"] },
    "editorial": { "$ref": "#/definitions/editorial" }
  },
  "definitions": {
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "evidence_type", "claim_bg", "claim_en", "url", "accessed_at", "license_status"],
      "properties": {
        "source_id": { "type": "string", "pattern": "^source-[0-9a-z-]+$" },
        "evidence_type": { "type": "string", "minLength": 3 },
        "claim_bg": { "type": "string", "minLength": 10 },
        "claim_en": { "type": "string", "minLength": 10 },
        "url": { "type": "string", "format": "uri" },
        "accessed_at": { "type": "string", "format": "date" },
        "license_status": { "type": "string", "minLength": 3 }
      }
    },
    "editorial": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reviewed_by", "reviewed_at", "notes_bg", "notes_en"],
      "properties": {
        "status": { "type": "string", "enum": ["needs_editorial_signoff", "signed_off"] },
        "reviewed_by": { "type": ["string", "null"] },
        "reviewed_at": { "type": ["string", "null"], "format": "date" },
        "notes_bg": { "type": "string", "minLength": 10 },
        "notes_en": { "type": "string", "minLength": 10 }
      }
    }
  }
}
