{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openplovdiv.example/schemas/knowledge-place.schema.json",
  "title": "Open Plovdiv knowledge place",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "category",
    "era",
    "era_bg",
    "era_en",
    "name_bg",
    "name_en",
    "summary_bg",
    "summary_en",
    "coordinates",
    "date_context",
    "creator_context",
    "current_status_bg",
    "current_status_en",
    "media",
    "event_ids",
    "person_ids",
    "organization_ids",
    "archive_item_ids",
    "then_now_pair_ids",
    "source_ids",
    "provenance",
    "editorial"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^place-[0-9a-z-]+$" },
    "type": { "const": "place" },
    "category": { "type": "string", "minLength": 3 },
    "era": {
      "type": "string",
      "enum": ["prehistory", "thracian", "roman", "medieval", "ottoman", "revival", "liberation", "modern"]
    },
    "era_bg": { "type": "string", "minLength": 2 },
    "era_en": { "type": "string", "minLength": 2 },
    "name_bg": { "type": "string", "minLength": 2 },
    "name_en": { "type": "string", "minLength": 2 },
    "summary_bg": { "type": "string", "minLength": 10 },
    "summary_en": { "type": "string", "minLength": 10 },
    "wikidata_id": {
      "type": ["string", "null"],
      "pattern": "^Q[0-9]+$"
    },
    "built_year": { "type": ["integer", "null"], "minimum": -8000, "maximum": 2100 },
    "built_date": { "type": ["string", "null"], "minLength": 4 },
    "date_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["precision", "display_bg", "display_en", "source_id"],
      "properties": {
        "precision": { "type": "string", "enum": ["date", "year", "era"] },
        "display_bg": { "type": "string", "minLength": 2 },
        "display_en": { "type": "string", "minLength": 2 },
        "source_id": { "type": "string", "pattern": "^source-[0-9a-z-]+$" }
      }
    },
    "architect_bg": { "type": ["string", "null"], "minLength": 2 },
    "architect_en": { "type": ["string", "null"], "minLength": 2 },
    "builder_bg": { "type": ["string", "null"], "minLength": 2 },
    "builder_en": { "type": ["string", "null"], "minLength": 2 },
    "creator_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "display_bg", "display_en", "source_id"],
      "properties": {
        "status": { "type": "string", "enum": ["named", "not_identified", "not_applicable"] },
        "display_bg": { "type": "string", "minLength": 2 },
        "display_en": { "type": "string", "minLength": 2 },
        "source_id": { "type": "string", "pattern": "^source-[0-9a-z-]+$" }
      }
    },
    "coordinates": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["lat", "lng", "accuracy", "source_id"],
      "properties": {
        "lat": { "type": "number", "minimum": -90, "maximum": 90 },
        "lng": { "type": "number", "minimum": -180, "maximum": 180 },
        "accuracy": { "type": "string", "minLength": 3 },
        "source_id": { "type": "string", "pattern": "^source-[0-9a-z-]+$" }
      }
    },
    "current_status_bg": { "type": "string", "minLength": 5 },
    "current_status_en": { "type": "string", "minLength": 5 },
    "media": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "title",
          "url",
          "page_url",
          "credit",
          "license",
          "license_url",
          "accessed_at",
          "source_id"
        ],
        "properties": {
          "type": { "type": "string", "enum": ["image"] },
          "title": { "type": "string", "minLength": 3 },
          "url": { "type": "string", "format": "uri" },
          "page_url": { "type": "string", "format": "uri" },
          "credit": { "type": "string", "minLength": 2 },
          "license": { "type": "string", "minLength": 2 },
          "license_url": { "type": "string", "format": "uri" },
          "accessed_at": { "type": "string", "format": "date" },
          "source_id": { "type": "string", "pattern": "^source-[0-9a-z-]+$" }
        }
      }
    },
    "event_ids": {
      "type": "array",
      "items": { "type": "string", "pattern": "^event-[0-9a-z-]+$" }
    },
    "person_ids": {
      "type": "array",
      "items": { "type": "string", "pattern": "^person-[0-9a-z-]+$" }
    },
    "organization_ids": {
      "type": "array",
      "items": { "type": "string", "pattern": "^org-[0-9a-z-]+$" }
    },
    "archive_item_ids": {
      "type": "array",
      "items": { "type": "string", "pattern": "^archive-[0-9a-z-]+$" }
    },
    "then_now_pair_ids": {
      "type": "array",
      "items": { "type": "string", "pattern": "^then-now-[0-9a-z-]+$" }
    },
    "source_ids": { "type": "array", "items": { "type": "string", "pattern": "^source-[0-9a-z-]+$" }, "minItems": 1 },
    "provenance": { "$ref": "knowledge-event.schema.json#/definitions/provenance" },
    "editorial": { "$ref": "knowledge-event.schema.json#/definitions/editorial" }
  }
}
