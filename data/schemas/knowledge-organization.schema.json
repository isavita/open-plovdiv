{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openplovdiv.example/schemas/knowledge-organization.schema.json",
  "title": "Open Plovdiv knowledge organization",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "category",
    "name_bg",
    "name_en",
    "summary_bg",
    "summary_en",
    "event_ids",
    "person_ids",
    "place_ids",
    "source_ids",
    "provenance",
    "editorial"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^org-[0-9a-z-]+$" },
    "type": { "const": "organization" },
    "category": { "type": "string", "minLength": 3 },
    "name_bg": { "type": "string", "minLength": 2 },
    "name_en": { "type": "string", "minLength": 2 },
    "summary_bg": { "type": "string", "minLength": 10 },
    "summary_en": { "type": "string", "minLength": 10 },
    "event_ids": {
      "type": "array",
      "items": { "type": "string", "pattern": "^event-[0-9a-z-]+$" }
    },
    "person_ids": {
      "type": "array",
      "items": { "type": "string", "pattern": "^person-[0-9a-z-]+$" }
    },
    "place_ids": {
      "type": "array",
      "items": { "type": "string", "pattern": "^place-[0-9a-z-]+$" }
    },
    "source_ids": { "type": "array", "items": { "type": "string", "pattern": "^source-[0-9a-z-]+$" }, "minItems": 1 },
    "provenance": { "$ref": "knowledge-event.schema.json#/definitions/provenance" },
    "editorial": { "$ref": "knowledge-event.schema.json#/definitions/editorial" }
  }
}
