# Open Plovdiv — citizen report layer configuration.
# Copy to .env and fill in for production. With none of these set, the site
# runs fully locally: reports are stored in apps/web/.data/ and the admin
# dashboard accepts the insecure dev token below.

# --- Moderation dashboard ---------------------------------------------------
# Shared bearer token for /admin/reports and the /api/admin/* endpoints.
# REQUIRED in production. Locally defaults to "dev-admin-token".
ADMIN_TOKEN=

# --- Storage (Upstash Redis REST) -------------------------------------------
# When both are set, reports are stored in Redis instead of the local file.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Privacy ----------------------------------------------------------------
# Salt for hashing IPs used only for rate limiting. Raw IPs are never stored.
IP_HASH_SALT=

# --- Local file store (optional) --------------------------------------------
# Override where the file-backed store lives when Redis is not configured.
# REPORTS_DATA_DIR=/absolute/path/to/.data

# --- Photo processing (optional) -------------------------------------------
# Pending processed images are kept private here until a moderator approves the
# report. Approved images are copied to the public directory/base URL.
# REPORT_IMAGE_PRIVATE_DIR=/absolute/path/to/private-report-images
# REPORT_IMAGE_PUBLIC_DIR=/absolute/path/to/apps/web/public/uploads/reports
# REPORT_IMAGE_PUBLIC_BASE_URL=/uploads/reports

# Optional S3-compatible public image storage, for example Cloudflare R2.
# When all are set, approved processed images are uploaded here instead of the
# local public directory. REPORT_IMAGE_PUBLIC_BASE_URL should point at the
# bucket's public/custom domain.
# REPORT_IMAGE_S3_BUCKET=
# REPORT_IMAGE_S3_ENDPOINT=
# REPORT_IMAGE_S3_REGION=auto
# REPORT_IMAGE_S3_ACCESS_KEY_ID=
# REPORT_IMAGE_S3_SECRET_ACCESS_KEY=
